---
import BaseLayout from '@/layouts/BaseLayout.astro';

// (FormSubmit redirect URL już nie używany — form submit'uje przez /api/contact)
// Działa zarówno na localhost, dev.dbamyopupile.pl jak i dbamyopupile.pl bez hardcoded URL.
---

<BaseLayout
  title="Kontakt"
  description="Skontaktuj się z nami, telefon 577 723 506, email sklep@dbamyopupile.pl. Dostawa, zwroty, FAQ."
>
  <div class="kp-page">

    {/* ====== HERO ====== */}
    <section class="kp-hero">
      <div class="kp-wrap">
        <span class="kp-pill">
          <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle;">forum</span>
          Kontakt
        </span>
        <h1 class="kp-h1">Pomożemy ci wybrać dobrze</h1>
        <p class="kp-lede">
          Odbieramy telefon w godzinach <strong>9–17 (pon–pt)</strong>. Maile czytamy na bieżąco i zwykle odpowiadamy w kilka godzin, bez chatbotów, bez ticketów, po ludzku.
        </p>

        <div class="kp-contact-cards">
          <a href="tel:577723506" class="kp-contact-card">
            <div class="kp-contact-icon">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">call</span>
            </div>
            <div class="kp-contact-body">
              <div class="kp-contact-label">Zadzwoń</div>
              <div class="kp-contact-value">577 723 506</div>
              <div class="kp-contact-meta">Pon–pt · 9:00–17:00</div>
            </div>
            <span class="material-symbols-outlined kp-contact-chev">arrow_outward</span>
          </a>

          <a href="mailto:sklep@dbamyopupile.pl" class="kp-contact-card">
            <div class="kp-contact-icon">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">mail</span>
            </div>
            <div class="kp-contact-body">
              <div class="kp-contact-label">Napisz mail</div>
              <div class="kp-contact-value">sklep@dbamyopupile.pl</div>
              <div class="kp-contact-meta">Odpowiedź zwykle w kilka godzin</div>
            </div>
            <span class="material-symbols-outlined kp-contact-chev">arrow_outward</span>
          </a>
        </div>

      </div>
    </section>

    {/* ====== CONTACT FORM ====== */}
    <section class="kp-form-sec">
      <div class="kp-wrap kp-wrap--narrow">
        <div class="kp-form-head">
          <span class="kp-eyebrow">Formularz kontaktowy</span>
          <h2 class="kp-h2">Napisz do nas wiadomość</h2>
          <p class="kp-form-sub">Odpowiedź wyślemy na podany adres email, zazwyczaj w kilka godzin. Bez chatbotów, bez ticketów, po ludzku.</p>
        </div>

        {/* Form submit przez własny /api/contact endpoint (server-side proxy do
            FormSubmit). Brak CORS issues, clean error handling. Po pierwszym
            submission FormSubmit wyśle email aktywacyjny na sklep@dbamyopupile.pl —
            wymaga jednorazowego potwierdzenia linku w mailu. */}
        <form class="kp-form" id="kp-form" novalidate>
          {/* Honeypot — bot wypełni, real user nie. */}
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="kp-form-row">
            <label class="kp-form-field">
              <span>Imię i nazwisko *</span>
              <input type="text" name="name" required maxlength="100" placeholder="Jan Kowalski" />
            </label>
            <label class="kp-form-field">
              <span>Email *</span>
              <input type="email" name="email" required maxlength="100" placeholder="jan@przyklad.pl" />
            </label>
          </div>

          <label class="kp-form-field">
            <span>Temat</span>
            <input type="text" name="topic" maxlength="120" placeholder="Pytanie o produkt, zwrot, faktura…" />
          </label>

          <label class="kp-form-field">
            <span>Adres (opcjonalny)</span>
            <input type="text" name="address" maxlength="200" placeholder="Ulica, kod pocztowy, miasto — jeśli sprawa dotyczy zamówienia" />
          </label>

          <label class="kp-form-field">
            <span>Wiadomość *</span>
            <textarea name="message" required maxlength="2000" rows="6" placeholder="Napisz w czym możemy pomóc…"></textarea>
          </label>

          <p class="kp-form-meta">
            <span class="material-symbols-outlined" style="font-size: 14px; vertical-align: middle; color: var(--brand-primary);">lock</span>
            Twoje dane nie są publikowane ani sprzedawane. Wykorzystujemy je tylko aby się z tobą skontaktować.
          </p>

          <p class="kp-form-error" id="kp-form-error" hidden>
            <span class="material-symbols-outlined">error</span>
            <span data-error-msg>Nie udało się wysłać wiadomości. Spróbuj ponownie albo napisz bezpośrednio na sklep@dbamyopupile.pl</span>
          </p>

          <button type="submit" class="kp-form-submit" id="kp-form-submit">
            <span data-submit-label>Wyślij wiadomość</span>
            <span class="material-symbols-outlined">send</span>
          </button>
        </form>

        <div class="kp-form-success" id="kp-form-success" hidden>
          <span class="material-symbols-outlined">task_alt</span>
          <h3>Wiadomość wysłana!</h3>
          <p>Dziękujemy, odpowiemy w ciągu kilku godzin (godziny pracy: pon–pt 9–17).</p>
        </div>
      </div>
    </section>

    {/* ====== QUICK INFO CARDS ====== */}
    <section class="kp-info">
      <div class="kp-wrap">
        <h2 class="kp-h2">Najważniejsze informacje</h2>

        <div class="kp-info-grid">
          <article class="kp-info-card">
            <div class="kp-info-icon">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">local_shipping</span>
            </div>
            <h3>Dostawa</h3>
            <ul>
              <li>Paczkomat InPost — <strong>9,99 zł</strong></li>
              <li>Kurier InPost — <strong>11,99 zł</strong></li>
              <li><strong>Darmowa dostawa od 99 zł</strong></li>
              <li>Wysyłka w 24h od zamówienia</li>
            </ul>
          </article>

          <article class="kp-info-card">
            <div class="kp-info-icon">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">published_with_changes</span>
            </div>
            <h3>Zwroty</h3>
            <ul>
              <li><strong>14 dni na zwrot</strong> bez pytań</li>
              <li>Zwrot pieniędzy w 5 dni roboczych</li>
              <li>Etykieta zwrotna gratis</li>
              <li>Produkt nie pasuje? Oddaj.</li>
            </ul>
          </article>

          <article class="kp-info-card">
            <div class="kp-info-icon">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">payments</span>
            </div>
            <h3>Płatności</h3>
            <ul>
              <li>BLIK, najszybciej</li>
              <li>Karta, Visa / Mastercard</li>
              <li>Przelew online (PayU)</li>
              <li>PayPo, kup teraz, zapłać później</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    {/* ====== FAQ ====== */}
    <section class="kp-faq-sec">
      <div class="kp-wrap kp-wrap--narrow">
        <h2 class="kp-h2">Najczęstsze pytania</h2>

        <div class="kp-faq">
          <details class="kp-faq-item">
            <summary>
              <span>Jaki jest czas dostawy?</span>
              <span class="material-symbols-outlined kp-faq-chev">expand_more</span>
            </summary>
            <div class="kp-faq-body">
              Zamówienia złożone do <strong>13:00</strong> wysyłamy tego samego dnia. Paczkomat InPost dociera następnego dnia (95% przypadków), kurier InPost 1–2 dni robocze. Wysyłka z magazynu w Tarnowie.
            </div>
          </details>

          <details class="kp-faq-item">
            <summary>
              <span>Ile kosztuje dostawa?</span>
              <span class="material-symbols-outlined kp-faq-chev">expand_more</span>
            </summary>
            <div class="kp-faq-body">
              Paczkomat InPost — <strong>9,99 zł</strong>. Kurier InPost — <strong>11,99 zł</strong>. <strong>Darmowa dostawa</strong> przy zamówieniach od 99 zł, niezależnie od metody.
            </div>
          </details>

          <details class="kp-faq-item">
            <summary>
              <span>Jak zwrócić produkt?</span>
              <span class="material-symbols-outlined kp-faq-chev">expand_more</span>
            </summary>
            <div class="kp-faq-body">
              Masz <strong>14 dni na odstąpienie od umowy</strong>. Wystarczy mail na <a href="mailto:sklep@dbamyopupile.pl">sklep@dbamyopupile.pl</a> z numerem zamówienia. Wysyłamy etykietę zwrotną InPost, zostawiasz paczkę w paczkomacie. Pieniądze wracają na konto w 5 dni roboczych.
            </div>
          </details>

          <details class="kp-faq-item">
            <summary>
              <span>Jak się z wami skontaktować?</span>
              <span class="material-symbols-outlined kp-faq-chev">expand_more</span>
            </summary>
            <div class="kp-faq-body">
              Najszybciej: telefon <a href="tel:577723506">577 723 506</a> (pon–pt, 9–17) albo mail na <a href="mailto:sklep@dbamyopupile.pl">sklep@dbamyopupile.pl</a>. Możesz też skorzystać z <a href="#kp-form-success" onclick="document.querySelector('.kp-form input[name=name]').focus(); return false;">formularza powyżej</a>. Odpowiadamy zazwyczaj w kilka godzin.
            </div>
          </details>
        </div>
      </div>
    </section>

    {/* ====== FINAL CTA + DANE FIRMY ====== */}
    <section class="kp-final">
      <div class="kp-wrap">
        <div class="kp-final-cta">
          <div class="kp-final-cta-body">
            <h2>Nie znalazłeś odpowiedzi?</h2>
            <p>Zadzwoń albo napisz, odpowiadamy szybko, po ludzku.</p>
          </div>
          <div class="kp-final-cta-actions">
            <a href="tel:577723506" class="kp-btn-primary">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 18px;">call</span>
              577 723 506
            </a>
            <a href="mailto:sklep@dbamyopupile.pl" class="kp-btn-secondary">
              sklep@dbamyopupile.pl
            </a>
          </div>
        </div>

        <div class="kp-company">
          <div class="kp-company-head">
            <span class="material-symbols-outlined" style="font-size: 18px;">business</span>
            <h3>Dane firmy</h3>
          </div>
          <div class="kp-company-grid">
            <div class="kp-company-cell">
              <span class="kp-company-label">Nazwa</span>
              <span class="kp-company-value">PATRYK JACHYM LABS</span>
            </div>
            <div class="kp-company-cell">
              <span class="kp-company-label">Adres</span>
              <span class="kp-company-value">ul. Tarnowskich 71p/1<br/>33-100 Tarnów</span>
            </div>
            <div class="kp-company-cell">
              <span class="kp-company-label">NIP</span>
              <span class="kp-company-value">9930710781</span>
            </div>
            <div class="kp-company-cell">
              <span class="kp-company-label">REGON</span>
              <span class="kp-company-value">542607372</span>
            </div>
          </div>
          <p class="kp-company-meta">Działalność wpisana do CEIDG. Adres do zwrotów towaru: ul. Tarnowskich 71p/1, 33-100 Tarnów.</p>
        </div>
      </div>
    </section>
  </div>

  <style is:inline slot="head">
    .kp-page {
      font-family: 'Outfit', system-ui, sans-serif;
      color: var(--brand-text);
      background: var(--brand-bg);
    }
    .kp-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .kp-wrap--narrow { max-width: 860px; }
    @media (min-width: 640px) { .kp-wrap { padding: 0 24px; } }
    @media (min-width: 1024px) { .kp-wrap { padding: 0 32px; } }

    /* ============ HERO ============ */
    .kp-hero {
      background:
        radial-gradient(60% 80% at 90% 0%, rgba(116, 151, 191, 0.10) 0%, transparent 60%),
        radial-gradient(45% 60% at 0% 100%, rgba(230, 57, 70, 0.06) 0%, transparent 60%),
        linear-gradient(180deg, var(--brand-primary-soft) 0%, var(--brand-bg) 100%);
      padding: 56px 0 64px;
    }
    @media (min-width: 900px) { .kp-hero { padding: 88px 0 96px; } }

    .kp-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: var(--brand-surface);
      color: var(--brand-primary-hover);
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: 999px;
      margin-bottom: 20px;
      border: 1px solid var(--brand-primary);
    }

    .kp-h1 {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(34px, 5.5vw, 56px);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.025em;
      color: var(--brand-heading);
      margin: 0 0 18px;
      max-width: 720px;
    }
    .kp-lede {
      font-size: clamp(15px, 1.8vw, 17px);
      line-height: 1.65;
      color: var(--brand-text);
      max-width: 580px;
      margin: 0 0 36px;
    }
    .kp-lede strong { color: var(--brand-heading); font-weight: 700; }

    .kp-contact-cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
      max-width: 800px;
    }
    @media (min-width: 640px) {
      .kp-contact-cards { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    }
    .kp-contact-card {
      position: relative;
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 18px 22px;
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 18px;
      text-decoration: none;
      color: var(--brand-text);
      transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
      overflow: hidden;
    }
    .kp-contact-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(116,151,191,0.06) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 240ms ease;
      pointer-events: none;
    }
    .kp-contact-card:hover {
      transform: translateY(-2px);
      border-color: var(--brand-primary);
      box-shadow: 0 14px 32px rgba(116, 151, 191, 0.15);
    }
    .kp-contact-card:hover::before { opacity: 1; }
    .kp-contact-icon {
      flex-shrink: 0;
      width: 52px;
      height: 52px;
      background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary-hover) 100%);
      color: #FFFFFF;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 14px rgba(116, 151, 191, 0.30);
    }
    .kp-contact-icon .material-symbols-outlined { font-size: 24px; }
    .kp-contact-body { flex: 1; min-width: 0; }
    .kp-contact-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--brand-muted);
    }
    .kp-contact-value {
      font-family: 'Outfit', sans-serif;
      font-size: 19px;
      font-weight: 700;
      color: var(--brand-heading);
      margin-top: 2px;
      letter-spacing: -0.01em;
      word-break: break-word;
    }
    .kp-contact-meta {
      font-size: 12.5px;
      color: var(--brand-muted);
      margin-top: 3px;
    }
    .kp-contact-chev {
      color: var(--brand-muted);
      font-size: 18px;
      transition: transform 200ms ease, color 200ms ease;
      flex-shrink: 0;
    }
    .kp-contact-card:hover .kp-contact-chev {
      transform: translate(2px, -2px);
      color: var(--brand-primary);
    }

    .kp-social {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      margin-top: 32px;
      font-size: 13.5px;
    }
    .kp-social-label {
      color: var(--brand-muted);
      font-weight: 500;
      margin-right: 4px;
    }
    .kp-social-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 12px;
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 999px;
      text-decoration: none;
      color: var(--brand-heading);
      font-weight: 600;
      transition: all 200ms;
    }
    .kp-social-link:hover {
      border-color: var(--brand-primary);
      background: var(--brand-primary-soft);
      color: var(--brand-primary-hover);
      transform: translateY(-1px);
    }
    .kp-social-link .material-symbols-outlined {
      font-size: 16px;
      color: var(--brand-primary);
    }

    /* ============ SECTIONS HEADING ============ */
    .kp-h2 {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(24px, 3.5vw, 36px);
      font-weight: 800;
      color: var(--brand-heading);
      letter-spacing: -0.02em;
      margin: 0 0 32px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .kp-h2::before {
      content: '';
      display: inline-block;
      width: 8px;
      height: 28px;
      background: var(--brand-primary);
      border-radius: 999px;
    }

    /* ============ INFO CARDS ============ */
    .kp-info {
      padding: 64px 0;
    }
    @media (min-width: 900px) { .kp-info { padding: 88px 0; } }

    .kp-info-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }
    @media (min-width: 768px) { .kp-info-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; } }

    .kp-info-card {
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 20px;
      padding: 26px 26px 28px;
      transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
    }
    .kp-info-card:hover {
      transform: translateY(-2px);
      border-color: var(--brand-primary);
      box-shadow: 0 10px 30px rgba(116, 151, 191, 0.12);
    }
    .kp-info-icon {
      width: 48px;
      height: 48px;
      background: var(--brand-primary-soft);
      color: var(--brand-primary-hover);
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .kp-info-icon .material-symbols-outlined { font-size: 24px; }
    .kp-info-card h3 {
      font-family: 'Outfit', sans-serif;
      font-size: 19px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0 0 14px;
      letter-spacing: -0.01em;
    }
    .kp-info-card ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 8px;
    }
    .kp-info-card li {
      font-size: 14px;
      line-height: 1.55;
      color: var(--brand-text);
      padding-left: 20px;
      position: relative;
    }
    .kp-info-card li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 9px;
      width: 10px;
      height: 2px;
      background: var(--brand-primary);
      border-radius: 999px;
    }
    .kp-info-card li strong { color: var(--brand-heading); font-weight: 700; }

    /* ============ FAQ ============ */
    .kp-faq-sec {
      padding: 64px 0;
      background: var(--brand-primary-soft);
      border-top: 1px solid var(--brand-border);
      border-bottom: 1px solid var(--brand-border);
    }
    @media (min-width: 900px) { .kp-faq-sec { padding: 88px 0; } }

    .kp-faq {
      display: grid;
      gap: 10px;
    }
    .kp-faq-item {
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 14px;
      overflow: hidden;
      transition: border-color 200ms ease, box-shadow 200ms ease;
    }
    .kp-faq-item[open] {
      border-color: var(--brand-primary);
      box-shadow: 0 6px 18px rgba(116, 151, 191, 0.10);
    }
    .kp-faq-item summary {
      list-style: none;
      cursor: pointer;
      padding: 18px 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      font-weight: 600;
      font-size: 15px;
      color: var(--brand-heading);
      transition: background 180ms ease;
    }
    .kp-faq-item summary:hover { background: var(--brand-primary-soft); }
    .kp-faq-item summary::-webkit-details-marker { display: none; }
    .kp-faq-chev {
      color: var(--brand-primary);
      font-size: 22px;
      transition: transform 250ms ease;
      flex-shrink: 0;
    }
    .kp-faq-item[open] .kp-faq-chev { transform: rotate(180deg); }
    .kp-faq-body {
      padding: 4px 22px 22px;
      font-size: 14.5px;
      line-height: 1.65;
      color: var(--brand-text);
    }
    .kp-faq-body a {
      color: var(--brand-primary-hover);
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .kp-faq-body strong { color: var(--brand-heading); font-weight: 700; }

    /* ============ FINAL CTA + COMPANY ============ */
    .kp-final {
      padding: 64px 0 88px;
    }
    @media (min-width: 900px) { .kp-final { padding: 88px 0 120px; } }

    .kp-final-cta {
      background: linear-gradient(135deg, var(--brand-heading) 0%, #3D4136 100%);
      color: #FFFCF7;
      padding: 36px 28px;
      border-radius: 22px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      margin-bottom: 56px;
      position: relative;
      overflow: hidden;
    }
    .kp-final-cta::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -10%;
      width: 320px;
      height: 320px;
      background: radial-gradient(circle, rgba(116, 151, 191, 0.30) 0%, transparent 70%);
      pointer-events: none;
    }
    @media (min-width: 768px) {
      .kp-final-cta {
        flex-direction: row;
        align-items: center;
