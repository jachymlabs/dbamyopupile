  </style>

  <script is:inline>
    // Form submit DIRECT do Web3Forms (client-side fetch). Web3Forms BLOKUJE
    // server-side requests na free tier ("This method is not allowed... Pro plan
    // required"). Therefore client → api.web3forms.com bezpośrednio.
    // Access key (6c6c0765-...) jest publiczny per Web3Forms docs — to form ID,
    // nie auth secret. Spam protection via captcha + honeypot.
    (function() {
      const WEB3FORMS_KEY = '6c6c0765-ba6e-4bb8-8eb1-f53956cc3a45';
      const form = document.getElementById('kp-form');
      const submitBtn = document.getElementById('kp-form-submit');
      const successEl = document.getElementById('kp-form-success');
      const errorEl = document.getElementById('kp-form-error');
      const submitLabel = submitBtn ? submitBtn.querySelector('[data-submit-label]') : null;
      const errorMsg = errorEl ? errorEl.querySelector('[data-error-msg]') : null;
      if (!form || !submitBtn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const fd = new FormData(form);
        const name = String(fd.get('name') || '').trim();
        const email = String(fd.get('email') || '').trim();
        const topic = String(fd.get('topic') || '').trim();
        const address = String(fd.get('address') || '').trim();
        const message = String(fd.get('message') || '').trim();
        const honey = String(fd.get('_honey') || '').trim();

        if (honey) return; // bot

        if (!name || !email || !message) {
          if (errorEl && errorMsg) {
            errorMsg.textContent = 'Uzupełnij imię, email i wiadomość.';
            errorEl.hidden = false;
          }
          return;
        }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          if (errorEl && errorMsg) {
            errorMsg.textContent = 'Nieprawidłowy format adresu email.';
            errorEl.hidden = false;
          }
          return;
        }

        submitBtn.disabled = true;
        if (submitLabel) submitLabel.textContent = 'Wysyłanie…';
        if (errorEl) errorEl.hidden = true;

        try {
          const res = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
            },
            body: JSON.stringify({
              access_key: WEB3FORMS_KEY,
              subject: `Nowa wiadomość z dbamyopupile.pl — ${topic || 'kontakt'}`,
              from_name: name,
              replyto: email,
              name,
              email,
              topic: topic || '(brak tematu)',
              address: address || '(nie podano)',
              message,
            }),
          });
          const data = await res.json().catch(() => ({}));

          if (res.ok && data.success === true) {
            form.hidden = true;
            if (successEl) {
              successEl.hidden = false;
              successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
          } else {
            if (errorEl && errorMsg) {
              errorMsg.textContent = data.message || 'Nie udało się wysłać. Napisz na sklep@dbamyopupile.pl';
              errorEl.hidden = false;
            }
            submitBtn.disabled = false;
            if (submitLabel) submitLabel.textContent = 'Wyślij wiadomość';
          }
        } catch {
          if (errorEl && errorMsg) {
            errorMsg.textContent = 'Błąd sieci. Napisz na sklep@dbamyopupile.pl';
            errorEl.hidden = false;
          }
          submitBtn.disabled = false;
          if (submitLabel) submitLabel.textContent = 'Wyślij wiadomość';
        }
      });
    })();
  </script>
</BaseLayout>
