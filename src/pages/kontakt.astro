---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt"
  description="Skontaktuj się z nami — telefon 577 723 506, email sklep@dbamyopupile.pl. Dostawa, zwroty, gwarancja, FAQ."
>
  <div class="help-page">
    <!-- HERO -->
    <section class="help-hero">
      <div class="help-wrap">
        <span class="help-pill">KONTAKT</span>
        <h1 class="help-h1">Napisz albo zadzwoń.</h1>
        <p class="help-lede">
          Odbieramy telefon w godzinach 9–17 (pon–pt). Na maile odpowiadamy zwykle w ciągu kilku godzin — bez chatbotów, bez ticketów.
        </p>

        <div class="help-contact-cards">
          <a href="tel:577723506" class="help-contact-card">
            <div class="help-contact-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <div class="help-contact-label">Zadzwoń</div>
              <div class="help-contact-value">577 723 506</div>
              <div class="help-contact-meta">Pon–pt 9:00–17:00</div>
            </div>
          </a>

          <a href="mailto:sklep@dbamyopupile.pl" class="help-contact-card">
            <div class="help-contact-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <div class="help-contact-label">Napisz mail</div>
              <div class="help-contact-value">sklep@dbamyopupile.pl</div>
              <div class="help-contact-meta">Odpowiedź w kilka godzin</div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- QUICK INFO -->
    <section class="help-section">
      <div class="help-wrap">
        <h2 class="help-h2">Najważniejsze informacje</h2>

        <div class="help-info-grid">
          <article class="help-info-card">
            <div class="help-info-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"/>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            </div>
            <h3>Dostawa</h3>
            <ul>
              <li>Paczkomat InPost — 12,99 zł</li>
              <li>Kurier InPost / DPD — 14,99 zł</li>
              <li><strong>Darmowa dostawa od 150 zł</strong></li>
              <li>Wysyłka do 24h od zamówienia</li>
            </ul>
          </article>

          <article class="help-info-card">
            <div class="help-info-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="1 4 1 10 7 10"/>
                <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
              </svg>
            </div>
            <h3>Zwroty i gwarancja</h3>
            <ul>
              <li><strong>30 dni gwarancji satysfakcji</strong></li>
              <li>14 dni na odstąpienie od umowy</li>
              <li>Zwrot pieniędzy w 5 dni roboczych</li>
              <li>Pies nie podchodzi? Zwracamy bez pytań</li>
            </ul>
          </article>

          <article class="help-info-card">
            <div class="help-info-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="5" width="20" height="14" rx="2"/>
                <line x1="2" y1="10" x2="22" y2="10"/>
              </svg>
            </div>
            <h3>Płatności</h3>
            <ul>
              <li>BLIK — najszybciej</li>
              <li>Karta — Visa / Mastercard</li>
              <li>Przelew online (PayU)</li>
              <li>PayPo — kup teraz, zapłać za 30 dni</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="help-section help-section-soft">
      <div class="help-wrap">
        <h2 class="help-h2">Najczęstsze pytania</h2>

        <div class="help-faq">
          <details name="help-faq" class="help-faq-item">
            <summary>
              <span>Jak długo trwa dostawa?</span>
              <span class="help-faq-icon"></span>
            </summary>
            <div class="help-faq-body">
              Zamówienia złożone do 13:00 wysyłamy tego samego dnia. Paczkomat InPost dociera następnego dnia (w 95% przypadków), kurier zwykle w 1-2 dni robocze. Wysyłamy z magazynu w Polsce.
            </div>
          </details>

          <details name="help-faq" class="help-faq-item">
            <summary>
              <span>Jak zwrócić produkt?</span>
              <span class="help-faq-icon"></span>
            </summary>
            <div class="help-faq-body">
              Masz 30 dni gwarancji satysfakcji + 14 dni odstąpienia od umowy. Wystarczy mail na <a href="mailto:sklep@dbamyopupile.pl">sklep@dbamyopupile.pl</a> z numerem zamówienia. Wysyłamy etykietę zwrotną InPost — zostawiasz paczkę w paczkomacie. Pieniądze wracają na konto w 5 dni roboczych.
            </div>
          </details>

          <details name="help-faq" class="help-faq-item">
            <summary>
              <span>Czy mogę zmienić zamówienie?</span>
              <span class="help-faq-icon"></span>
            </summary>
            <div class="help-faq-body">
              Tak — jeśli paczka jeszcze nie poszła. Zadzwoń pod <a href="tel:577723506">577 723 506</a> albo napisz mail. Im szybciej, tym lepiej — wysyłamy zwykle do kilku godzin od zamówienia.
            </div>
          </details>

          <details name="help-faq" class="help-faq-item">
            <summary>
              <span>Kiedy dostanę ebook?</span>
              <span class="help-faq-icon"></span>
            </summary>
            <div class="help-faq-body">
              Link do ebooka z 30 przepisami wysyłamy automatycznie na email z zamówienia — zwykle w ciągu kilku minut. Sprawdź folder spam, jeśli nie widzisz po godzinie. PDF działa na każdym telefonie i komputerze, bez logowania.
            </div>
          </details>

          <details name="help-faq" class="help-faq-item">
            <summary>
              <span>Czy WolnaMiska nadaje się do mojej rasy?</span>
              <span class="help-faq-icon"></span>
            </summary>
            <div class="help-faq-body">
              Tak — od chihuahua po owczarka. Średnica miski (cm) i głębokość są dopasowane tak, żeby rasy z płaskim pyskiem (mops, buldog francuski, boston) też dosięgały bez problemu. Jeśli nie jesteś pewna, napisz lub zadzwoń — pomożemy dobrać.
            </div>
          </details>

          <details name="help-faq" class="help-faq-item">
            <summary>
              <span>Jak wystawić fakturę?</span>
              <span class="help-faq-icon"></span>
            </summary>
            <div class="help-faq-body">
              W formularzu zamówienia jest pole "Faktura" — zaznacz i podaj dane firmy (NIP, nazwa). Fakturę wysyłamy mailem razem z potwierdzeniem zamówienia.
            </div>
          </details>

          <details name="help-faq" class="help-faq-item">
            <summary>
              <span>Co dawać do WolnaMiski?</span>
              <span class="help-faq-icon"></span>
            </summary>
            <div class="help-faq-body">
              <strong>Tylko mokrą karmę</strong> — sucha wypadnie spod kulki. Najlepsze: mokra karma z dodatkami, jogurt naturalny, bulion bez soli, pasta z dyni lub banana, schłodzone smakołyki na lato. W ebooku z 30 przepisami (gratis do zamówienia) masz plan na cały miesiąc.
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- STILL NEED HELP -->
    <section class="help-cta-final">
      <div class="help-wrap">
        <h2>Nie znalazłaś odpowiedzi?</h2>
        <p>Zadzwoń albo napisz — odpowiadamy szybko, po ludzku, bez chatbotów.</p>
        <div class="help-cta-row">
          <a href="tel:577723506" class="help-btn-primary">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            577 723 506
          </a>
          <a href="mailto:sklep@dbamyopupile.pl" class="help-btn-secondary">
            sklep@dbamyopupile.pl
          </a>
        </div>
      </div>
    </section>
  </div>

  <style is:inline slot="head">
    .help-page {
      --hp-navy: #1E3A5F;
      --hp-blue: #B8D8E8;
      --hp-canvas: #FAF7F2;
      --hp-text: #1A1A1A;
      --hp-muted: #6B7280;
      --hp-rule: #E5E7EB;
      font-family: 'Inter', system-ui, sans-serif;
      color: var(--hp-text);
    }
    .help-wrap { max-width: 1180px; margin: 0 auto; padding: 0 16px; }
    @media (min-width: 640px) { .help-wrap { padding: 0 24px; } }

    /* HERO */
    .help-hero {
      background: linear-gradient(180deg, var(--hp-canvas) 0%, #fff 100%);
      padding: 56px 0 64px;
    }
    @media (min-width: 900px) { .help-hero { padding: 80px 0 88px; } }
    .help-pill {
      display: inline-block;
      padding: 6px 12px;
      background: var(--hp-blue);
      color: var(--hp-navy);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: 999px;
      margin-bottom: 18px;
    }
    .help-h1 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: clamp(32px, 5vw, 48px);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--hp-navy);
      margin: 0 0 14px;
    }
    .help-lede {
      font-size: clamp(15px, 2vw, 17px);
      line-height: 1.6;
      color: var(--hp-muted);
      max-width: 540px;
      margin: 0 0 36px;
    }
    .help-contact-cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }
    @media (min-width: 640px) {
      .help-contact-cards { grid-template-columns: repeat(2, 1fr); gap: 16px; max-width: 720px; }
    }
    .help-contact-card {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px 22px;
      background: #fff;
      border: 1px solid var(--hp-rule);
      border-radius: 16px;
      text-decoration: none;
      color: var(--hp-text);
      transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
    }
    .help-contact-card:hover {
      transform: translateY(-2px);
      border-color: var(--hp-blue);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    }
    .help-contact-icon {
      flex-shrink: 0;
      width: 48px;
      height: 48px;
      background: var(--hp-blue);
      color: var(--hp-navy);
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .help-contact-label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--hp-muted);
    }
    .help-contact-value {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 19px;
      font-weight: 700;
      color: var(--hp-navy);
      margin-top: 2px;
      letter-spacing: -0.01em;
    }
    .help-contact-meta {
      font-size: 13px;
      color: var(--hp-muted);
      margin-top: 2px;
    }

    /* SECTIONS */
    .help-section { padding: 56px 0; }
    @media (min-width: 900px) { .help-section { padding: 80px 0; } }
    .help-section-soft { background: var(--hp-canvas); }
    .help-h2 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: clamp(26px, 4vw, 36px);
      font-weight: 700;
      color: var(--hp-navy);
      letter-spacing: -0.02em;
      margin: 0 0 32px;
    }

    /* INFO GRID */
    .help-info-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }
    @media (min-width: 768px) { .help-info-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; } }
    .help-info-card {
      background: #fff;
      border: 1px solid var(--hp-rule);
      border-radius: 16px;
      padding: 24px;
    }
    .help-info-icon {
      width: 44px;
      height: 44px;
      background: var(--hp-canvas);
      color: var(--hp-navy);
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 14px;
    }
    .help-info-card h3 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 19px;
      font-weight: 600;
      color: var(--hp-navy);
      margin: 0 0 12px;
      letter-spacing: -0.01em;
    }
    .help-info-card ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 8px;
    }
    .help-info-card li {
      font-size: 14px;
      line-height: 1.5;
      color: var(--hp-text);
      padding-left: 16px;
      position: relative;
    }
    .help-info-card li::before {
      content: "—";
      position: absolute;
      left: 0;
      color: var(--hp-blue);
      font-weight: 700;
    }

    /* FAQ */
    .help-faq {
      display: grid;
      gap: 10px;
      max-width: 820px;
    }
    .help-faq-item {
      background: #fff;
      border: 1px solid var(--hp-rule);
      border-radius: 12px;
      overflow: hidden;
      transition: border-color 200ms ease;
    }
    .help-faq-item[open] { border-color: var(--hp-blue); }
    .help-faq-item summary {
      list-style: none;
      cursor: pointer;
      padding: 18px 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      font-weight: 600;
      font-size: 15px;
      color: var(--hp-navy);
    }
    .help-faq-item summary::-webkit-details-marker { display: none; }
    .help-faq-icon {
      position: relative;
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }
    .help-faq-icon::before,
    .help-faq-icon::after {
      content: "";
      position: absolute;
      background: var(--hp-navy);
      border-radius: 1px;
      transition: transform 250ms ease;
    }
    .help-faq-icon::before {
      top: 8px; left: 0; right: 0; height: 2px;
    }
    .help-faq-icon::after {
      left: 8px; top: 0; bottom: 0; width: 2px;
    }
    .help-faq-item[open] .help-faq-icon::after { transform: scaleY(0); }
    .help-faq-body {
      padding: 0 22px 20px;
      font-size: 14.5px;
      line-height: 1.6;
      color: var(--hp-text);
    }
    .help-faq-body a {
      color: var(--hp-navy);
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* FINAL CTA */
    .help-cta-final {
      background: var(--hp-navy);
      color: #fff;
      padding: 56px 0;
      text-align: center;
    }
    @media (min-width: 900px) { .help-cta-final { padding: 80px 0; } }
    .help-cta-final h2 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: clamp(26px, 4vw, 36px);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0 0 12px;
    }
    .help-cta-final p {
      color: rgba(255, 255, 255, 0.78);
      margin: 0 auto 28px;
      max-width: 520px;
    }
    .help-cta-row {
      display: flex;
      flex-direction: column;
      gap: 12px;
      align-items: center;
      justify-content: center;
    }
    @media (min-width: 640px) {
      .help-cta-row { flex-direction: row; }
    }
    .help-btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 24px;
      background: #fff;
      color: var(--hp-navy);
      font-weight: 700;
      font-size: 15px;
      border-radius: 12px;
      text-decoration: none;
      transition: background 200ms ease, transform 200ms ease;
    }
    .help-btn-primary:hover {
      background: var(--hp-canvas);
      transform: translateY(-1px);
    }
    .help-btn-secondary {
      display: inline-flex;
      align-items: center;
      padding: 14px 24px;
      background: transparent;
      color: #fff;
      font-weight: 600;
      font-size: 15px;
      border: 1px solid rgba(255, 255, 255, 0.32);
      border-radius: 12px;
      text-decoration: none;
      transition: background 200ms ease;
    }
    .help-btn-secondary:hover {
      background: rgba(255, 255, 255, 0.08);
    }
  </style>
</BaseLayout>
