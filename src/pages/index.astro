---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { buildAssetUrl } from '@/lib/utils';

// All products for shop showcase
let allProducts: any[] = [];
let totalProducts = 0;
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { take: 12, groupByProduct: true },
  }, Astro.request);
  allProducts = data.search?.items ?? [];
  totalProducts = data.search?.totalItems ?? 0;
} catch (e: any) {
  if (import.meta.env.DEV) console.error('Home products search failed:', e?.message);
}

const fmt = (grosze: number) =>
  new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(grosze / 100);

const productPrice = (item: any) => {
  if (item.priceWithTax?.__typename === 'PriceRange') {
    return fmt(item.priceWithTax.min);
  }
  return fmt(item.priceWithTax?.value ?? 0);
};

// 4 bestsellery na hero grid
const featured = allProducts.slice(0, 4);
const heroProduct = allProducts[0];
const heroImage = heroProduct?.productAsset ? buildAssetUrl(heroProduct.productAsset.preview, 'large') : null;

// Persony use-cases — sytuacje, NIE konkretne produkty. Wszystkie linkują
// do /sklep (właściciel dobiera sam).
// SVG paths dla persona icons (Lucide-style stroke, 24x24)
const PERSONA_ICONS: Record<string, string> = {
  sun: '<circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="5" y1="5" x2="7" y2="7"/><line x1="17" y1="17" x2="19" y2="19"/><line x1="5" y1="19" x2="7" y2="17"/><line x1="17" y1="7" x2="19" y2="5"/>',
  paw: '<circle cx="5.5" cy="12.5" r="1.7"/><circle cx="9.5" cy="8" r="1.7"/><circle cx="14.5" cy="8" r="1.7"/><circle cx="18.5" cy="12.5" r="1.7"/><path d="M8 16.5c0-2.2 1.8-3.5 4-3.5s4 1.3 4 3.5c0 1.6-1.4 2.5-3 2.5h-2c-1.6 0-3-.9-3-2.5z"/>',
  car: '<path d="M5 17h14v-5l-2-5H7l-2 5v5z"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/>',
  drop: '<path d="M12 2.5S6 9 6 14a6 6 0 0 0 12 0c0-5-6-11.5-6-11.5z"/>',
  home: '<path d="M3 11l9-7 9 7"/><path d="M5 10v10h14V10"/><path d="M9 20v-6h6v6"/>',
  gift: '<polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>',
};

const personas = [
  { icon: 'sun', title: 'Upalne lato', desc: 'Termometr powyżej 25°C. Pies dyszy już po kilku minutach i szuka cienia zamiast iść dalej.' },
  { icon: 'paw', title: 'Senior lub krótki pysk', desc: 'Buldogi, mopsy, starsze psy. Znoszą gorąco najgorzej i przegrzewają się szybciej niż reszta.' },
  { icon: 'car', title: 'Auto i podróże', desc: 'Nagrzane wnętrze, transporter, trasa na wakacje. W drodze pies nie ma jak się schłodzić.' },
  { icon: 'drop', title: 'Długie spacery i trening', desc: 'Pies chce iść i biegać, ale w cieple szybko się grzeje i pada po kilkunastu minutach.' },
  { icon: 'home', title: 'Balkon, taras, działka', desc: 'Leży na słońcu całe popołudnie i dyszy. W domu też potrafi być duszno i gorąco.' },
  { icon: 'gift', title: 'Prezent dla psiary', desc: 'Komuś, kto traktuje psa jak członka rodziny. Coś, co realnie pomaga, nie gadżet do szuflady.' },
];
---

<BaseLayout
  title="dbamyopupile — Bryza, szal chłodzący dla psa na upały"
  description="Bryza to szal chłodzący dla psa: namaczasz w wodzie i chłodzi przez kilka godzin. Spacer bez przegrzewania, bez lodu i prądu. Polska marka, wysyłka 24h InPost."
>
  <div class="dd-home-stitch bg-background min-h-screen">

    <!-- 1. HERO — narracyjny hook + bestseller image -->
    <section class="dd-stitch-hero">
      <div class="container-stitch flex flex-col md:flex-row items-center gap-md md:gap-lg py-md md:py-xl">
        <!-- LEFT: text + CTAs -->
        <div class="flex-1 flex flex-col gap-sm">
          <span class="dd-hero-eyebrow">Szal chłodzący dla psa</span>
          <h1 class="text-h1">
            W upał pies pada<br/>
            <span style="color: var(--brand-primary);">po kilku minutach</span>
          </h1>
          <p class="text-body-lg" style="max-width: 520px;">
            Pies nie poci się jak my — w gorąco ratuje się dyszeniem, a to nie nadąża. Bryza to szal, który namaczasz w zimnej wodzie i chłodzi psią szyję przez kilka godzin. Pełny spacer bez przegrzewania, bez lodu i bez prądu.
          </p>
          <div class="flex gap-sm flex-wrap mt-xs">
            <a href="/sklep" class="btn-pill btn-pill--primary">
              Zobacz cały sklep
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="#bestsellery" class="btn-pill btn-pill--ghost">
              Zobacz bestsellery
            </a>
          </div>
          <div class="flex gap-md mt-sm flex-wrap text-body-sm" style="color: var(--brand-muted);">
            <span class="flex items-center gap-xs">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
              Setki zadowolonych psiarzy
            </span>
            <span class="flex items-center gap-xs">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--brand-primary);" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              Wysyłka 24h, InPost
            </span>
            <span class="flex items-center gap-xs">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--brand-primary);" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Polska marka
            </span>
          </div>
        </div>

        <!-- RIGHT: hero product image -->
        <div class="flex-1 w-full">
          <div class="aspect-square rounded-2xl overflow-hidden border border-outline-variant shadow-md relative" style="background: var(--brand-surface);">
            {heroImage ? (
              <img src={heroImage} alt={heroProduct.productName} loading="eager" fetchpriority="high" class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center" style="color: var(--brand-muted); font-size: 24px;">dbamyopupile</div>
            )}
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="dd-scroll-indicator" aria-hidden="true">
        <span class="dd-scroll-indicator-label">Więcej niżej</span>
        <svg class="dd-scroll-indicator-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </section>


    <!-- 2. PROBLEM AGITATION — znasz to z własnego psa -->
    <section class="section-stitch dd-section-problem">
      <div class="container-stitch">
        <div class="dd-problem-head">
          <span class="dd-eyebrow">Znasz to z upalnego dnia</span>
          <h2 class="text-h2">Skwar daje psu w kość.<br/><span style="color: var(--brand-primary);">A on nie umie się schłodzić.</span></h2>
        </div>
        <div class="dd-problem-grid">
          <div class="dd-problem-card">
            <span class="dd-problem-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6"/><path d="M6.5 8a6 6 0 1 0 11 0"/><path d="M12 14v4"/><path d="M10 20h4"/></svg></span>
            <h3 class="dd-problem-card-title">Dyszy po kilku minutach</h3>
            <p class="dd-problem-card-desc">Pies nie poci się jak człowiek. W upał chłodzi się głównie dyszeniem, a to nie nadąża.</p>
          </div>
          <div class="dd-problem-card">
            <span class="dd-problem-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17h18"/><path d="M5 17l1-5h12l1 5"/><circle cx="8" cy="9" r="1"/><circle cx="16" cy="9" r="1"/></svg></span>
            <h3 class="dd-problem-card-title">Kładzie się w cień</h3>
            <p class="dd-problem-card-desc">Po kilku minutach pada na trawę, nie chce iść dalej. Spacer kończy się szybciej niż się zaczął.</p>
          </div>
          <div class="dd-problem-card">
            <span class="dd-problem-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17h14v-5l-2-5H7l-2 5v5z"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg></span>
            <h3 class="dd-problem-card-title">Nagrzane auto i balkon</h3>
            <p class="dd-problem-card-desc">W transporterze, w aucie, na słonecznym tarasie pies nie ma jak odprowadzić ciepła.</p>
          </div>
          <div class="dd-problem-card">
            <span class="dd-problem-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/></svg></span>
            <h3 class="dd-problem-card-title">Seniory i krótkie pyski</h3>
            <p class="dd-problem-card-desc">Buldogi, mopsy, starsze psy znoszą gorąco najgorzej. Dla nich upał bywa naprawdę groźny.</p>
          </div>
        </div>
        <p class="dd-problem-closing">
          To nie kaprys i nie lenistwo.<br/>
          <strong>Tak działa pies, który nie nadąża z chłodzeniem. Bryza mu w tym pomaga.</strong>
        </p>
      </div>
    </section>


    <!-- 4. BESTSELLERY — 4 product cards -->
    {featured.length > 0 && (
      <section id="bestsellery" class="section-stitch">
        <div class="container-stitch">
          <div class="dd-problem-head">
            <span class="dd-eyebrow">To kupują najczęściej</span>
            <h2 class="text-h2">Akcesoria, po które<br/><span style="color: var(--brand-primary);">psiarze wracają</span></h2>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-sm md:gap-md">
            {featured.map((p: any) => (
              <a href={`/produkty/${p.slug}`} class="dd-stitch-card group">
                <div class="dd-stitch-card-img">
                  {p.productAsset && (
                    <img src={buildAssetUrl(p.productAsset.preview, 'medium')} alt={p.productName} loading="lazy" />
                  )}
                </div>
                <h3 class="dd-stitch-card-name">{p.productName}</h3>
                <div class="dd-stitch-card-price">{productPrice(p)}</div>
              </a>
            ))}
          </div>
          <div class="text-center mt-md">
            <a href="/sklep" class="btn-pill btn-pill--ghost">
              Wszystkie produkty
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </section>
    )}


    <!-- 5. PERSONY — dla jakiego psa -->
    <section class="section-stitch section-stitch--surface" style="border-top: 1px solid var(--brand-border); border-bottom: 1px solid var(--brand-border);">
      <div class="container-stitch">
        <div class="dd-problem-head">
          <span class="dd-eyebrow">Dla jakiego psa</span>
          <h2 class="text-h2">Znajdź akcesorium<br/><span style="color: var(--brand-primary);">do swojej sytuacji</span></h2>
        </div>
        <div class="dd-persona-grid">
          {personas.map((persona) => (
            <a href="/sklep" class="dd-persona-card">
              <span class="dd-persona-icon" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${PERSONA_ICONS[persona.icon] || ''}</svg>`}></span>
              <div class="dd-persona-text">
                <h3 class="dd-persona-title">{persona.title}</h3>
                <p class="dd-persona-desc">{persona.desc}</p>
              </div>
              <svg class="dd-persona-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- 6. TESTIMONIALS — prawdziwe opinie psiarzy -->
    <section class="section-stitch">
      <div class="container-stitch">
        <div class="dd-problem-head">
          <span class="dd-eyebrow">Psiarze o swoich psach</span>
          <h2 class="text-h2">Prawdziwe psy,<br/><span style="color: var(--brand-primary);">prawdziwe imiona</span></h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-md">
          <article class="dd-stitch-testimonial">
            <div class="flex gap-xs">
              {[...Array(5)].map(() => <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>)}
            </div>
            <p class="text-body-sm">„W lipcu labrador padał po pięciu minutach i kładł się na trawie. Z Bryzą przeszliśmy całą rundę nad rzeką i wrócił normalnie. Powinnam ją kupić rok temu."</p>
            <div class="dd-stitch-testimonial-author">
              <div class="dd-stitch-avatar">A</div>
              <div>
                <p class="text-button" style="font-size: 13px;">Ania</p>
                <p class="text-body-sm" style="font-size: 11px; color: var(--brand-muted);">labrador, 4 lata</p>
              </div>
            </div>
          </article>
          <article class="dd-stitch-testimonial">
            <div class="flex gap-xs">
              {[...Array(5)].map(() => <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>)}
            </div>
            <p class="text-body-sm">„Mam buldoga, a wiadomo jak krótkie pyski znoszą upał. Bryza nie czyni cudów, ale Frania jest spokojniejsza i mniej sapie. Zakładam już przy 25 stopniach."</p>
            <div class="dd-stitch-testimonial-author">
              <div class="dd-stitch-avatar">T</div>
              <div>
                <p class="text-button" style="font-size: 13px;">Tomek</p>
                <p class="text-body-sm" style="font-size: 11px; color: var(--brand-muted);">buldog francuski</p>
              </div>
            </div>
          </article>
          <article class="dd-stitch-testimonial">
            <div class="flex gap-xs">
              {[...Array(5)].map(() => <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>)}
            </div>
            <p class="text-body-sm">„Spodziewałam się, że wyschnie po pół godziny jak mokry ręcznik. Trzymała chłód prawie trzy godziny na działce. Naprawdę robi różnicę."</p>
            <div class="dd-stitch-testimonial-author">
              <div class="dd-stitch-avatar" style="background: var(--brand-accent-soft); color: var(--brand-accent);">M</div>
              <div>
                <p class="text-button" style="font-size: 13px;">Magda</p>
                <p class="text-body-sm" style="font-size: 11px; color: var(--brand-muted);">golden retriever</p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>


    <!-- 7. CO DOSTAJESZ — 4 benefity -->
    <section class="section-stitch section-stitch--surface" style="border-top: 1px solid var(--brand-border); border-bottom: 1px solid var(--brand-border);">
      <div class="container-stitch">
        <div class="dd-problem-head">
          <span class="dd-eyebrow">Co dostajesz</span>
          <h2 class="text-h2">Co dostajesz<br/><span style="color: var(--brand-primary);">z każdą paczką od nas</span></h2>
        </div>
        <div class="dd-benefit-grid">
          <div class="dd-benefit-card">
            <span class="dd-benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="1" y="3" width="15" height="13"/>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            </span>
            <h3 class="dd-benefit-title">Dostawa 24h</h3>
            <p class="dd-benefit-desc">Zamawiasz dzisiaj, jutro masz w paczkomacie InPost. Wysyłka z magazynu w Polsce, bez tygodni czekania na paczkę z Chin.</p>
          </div>
          <div class="dd-benefit-card">
            <span class="dd-benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2L4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4z"/>
                <polyline points="9 12 12 15 16 10"/>
              </svg>
            </span>
            <h3 class="dd-benefit-title">Bezpieczne dla psa</h3>
            <p class="dd-benefit-desc">Łagodny chłód przez parowanie, bez zimnego szoku. Miękka, przewiewna tkanina. Zanim coś trafi do sklepu, przechodzi przez nasze psy.</p>
          </div>
          <div class="dd-benefit-card">
            <span class="dd-benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 3h12l4 6-10 13L2 9z"/>
                <path d="M11 3L8 9l4 13 4-13-3-6"/>
                <path d="M2 9h20"/>
              </svg>
            </span>
            <h3 class="dd-benefit-title">Trwałe materiały</h3>
            <p class="dd-benefit-desc">Setki namoczeń, pranie, cały sezon w użyciu — to powinno wytrzymać. Nie kupujemy od producentów, których rzeczy rozpadają się po miesiącu.</p>
          </div>
          <div class="dd-benefit-card">
            <span class="dd-benefit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 22V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v16"/>
                <path d="M3 6h18"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </span>
            <h3 class="dd-benefit-title">Polska marka</h3>
            <p class="dd-benefit-desc">Pakujemy w Polsce, piszemy po polsku. 14 dni na zwrot bez podawania powodu. Odpisuje człowiek, nie bot.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- 8. FOUNDER STORY — krótki paragraph -->
    <section class="section-stitch">
      <div class="container-stitch">
        <div class="dd-founder">
          <div class="dd-founder-body">
            <span class="dd-eyebrow">Kto za tym stoi</span>
            <h2 class="text-h2">Sami patrzyliśmy,<br/><span style="color: var(--brand-primary);">jak nasz pies się męczy</span></h2>
            <p class="dd-founder-p">
              dbamyopupile nie powstało w sali konferencyjnej. Pierwszy naprawdę gorący lipiec i nasz pies po pięciu minutach spaceru kładł się w cień i nie chciał iść dalej. Próbowaliśmy mokrych ręczników, które wysychały w kwadrans, kostek lodu, których nie da się wziąć na spacer, postojów pod każdym drzewem. Półśrodki.
            </p>
            <p class="dd-founder-p">
              W końcu zaczęliśmy szukać czegoś, co naprawdę trzyma chłód i działa też w ruchu. Przetestowaliśmy kilka splotów na własnych psach, aż znaleźliśmy taki, który chłodzi godzinami. Tak powstała Bryza.
            </p>
            <div class="dd-founder-sign">
              <div class="dd-founder-sign-line"></div>
              <span>Patryk i zespół dbamyopupile</span>
            </div>
