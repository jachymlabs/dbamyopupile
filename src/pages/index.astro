---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { shopApi } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { buildAssetUrl } from '@/lib/utils';
import '@/styles/home.css';

const PRODUCT_SLUG = 'wolnamiska';

let product: any = null;
try {
  const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug: PRODUCT_SLUG }, Astro.request);
  product = data.product;
} catch (e: any) {
  if (import.meta.env.DEV) console.error('Home product fetch failed:', e?.message);
}

const firstVariant = product?.variants?.[0];
const priceWithTax = firstVariant?.priceWithTax ?? 7999;
const priceFormatted = new Intl.NumberFormat('pl-PL', {
  style: 'currency',
  currency: 'PLN',
}).format(priceWithTax / 100);

const mainImage = product?.featuredAsset || product?.assets?.[0];
const heroImageUrl = mainImage ? buildAssetUrl(mainImage.preview, 'large') : '/produkty/wolnamiska/hero-shiba.webp';
---

<BaseLayout
  title="WolnaMiska — koniec z łapczywym jedzeniem psa"
  description="Hybrydowa miska z ruchomą kulką. Zmienia każdy posiłek z 30 sekund pochłaniania w 15 minut spokojnego jedzenia."
>
  <div class="home">

    <!-- HERO -->
    <section class="home-hero">
      <div class="wrap">
        <div class="home-hero-grid">
          <div>
            <span class="home-hero-pill">Pre-launch w Polsce</span>

            <h1 class="home-h1">
              Twój pies pochłania miskę w <em>30 sekund?</em>
            </h1>

            <p class="home-hero-lede">
              WolnaMiska to hybrydowa miska z ruchomą kulką w środku. Zmienia każdy posiłek
              w <strong>15 minut spokojnego jedzenia</strong> — koniec z wzdęciami, krztuszeniem i wymiotami z głodu.
            </p>

            <div class="home-hero-cta">
              <a href="/produkty/wolnamiska" class="btn btn-primary">
                Zobacz WolnaMiskę
                <span class="arrow">→</span>
              </a>
            </div>

            <div class="home-hero-trust">
              <div class="home-hero-trust-item">
                <div class="home-hero-trust-num">30 dni</div>
                <div class="home-hero-trust-label">Gwarancja satysfakcji</div>
              </div>
              <div class="home-hero-trust-item">
                <div class="home-hero-trust-num">24h</div>
                <div class="home-hero-trust-label">Wysyłka z Polski</div>
              </div>
            </div>
          </div>

          <div class="home-hero-visual">
            <div class="home-hero-img">
              <img
                src={heroImageUrl}
                alt="WolnaMiska — hybrydowa miska spowalniająca dla psów"
                fetchpriority="high"
                loading="eager"
                decoding="sync"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- USP STRIP — editorial asymmetric -->
    <section class="home-usp-strip">
      <div class="wrap">
        <div class="home-usp-grid">
          <div class="home-usp-head">
            <div class="home-usp-eyebrow">Co dostajesz</div>
            <h2 class="home-usp-title">Nie kolejna miska — narzędzie zaprojektowane pod konkretny problem.</h2>
          </div>

          <ul class="home-usp-list">
            <li class="home-usp-item">
              <div class="home-usp-num">01</div>
              <div class="home-usp-body">
                <div class="home-usp-label">15 minut zamiast 30 sekund</div>
                <div class="home-usp-desc">Pies pracuje językiem nad kulką — żołądek dostaje sygnał sytości</div>
              </div>
            </li>
            <li class="home-usp-item">
              <div class="home-usp-num">02</div>
              <div class="home-usp-body">
                <div class="home-usp-label">Mentalna stymulacja</div>
                <div class="home-usp-desc">Łamigłówka przy każdym posiłku — koniec z nudą i destrukcją</div>
              </div>
            </li>
            <li class="home-usp-item">
              <div class="home-usp-num">03</div>
              <div class="home-usp-body">
                <div class="home-usp-label">Bezpieczne tworzywo</div>
                <div class="home-usp-desc">Bez BPA, bez PVC, zmywarka 70°C — bezpieczne na lata</div>
              </div>
            </li>
            <li class="home-usp-item">
              <div class="home-usp-num">04</div>
              <div class="home-usp-body">
                <div class="home-usp-label">Polska wysyłka 24h</div>
                <div class="home-usp-desc">BLIK, Paczkomat, kurier — wszystko z magazynu w PL</div>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- PRODUCT FEATURE — wzór PDP final-buy -->
    <section class="home-product-section">
      <div class="wrap">
        <span class="eyebrow">Bestseller pre-launch</span>
        <h2 class="h2">
          Jedna miska. <em>Tysiąc</em> spokojniejszych posiłków.
        </h2>
        <p class="lede">
          Hybryda miski i maty do lizania. Pojemność pełnego posiłku, ruchoma kulka, miękkie wnętrze imitujące naturalne żucie. Zaprojektowana w Polsce.
        </p>

        <article class="home-product-card">
          <div class="home-pc-media">
            <span class="home-pc-badge">WolnaMiska</span>
            <img
              src="/produkty/wolnamiska/na-stole.webp"
              alt="WolnaMiska — produkt"
              loading="lazy"
            />
          </div>

          <div class="home-pc-body">
            <h3 class="home-pc-title">Hybrydowa miska z ruchomą kulką</h3>
            <p class="home-pc-desc">
              Pies pracuje językiem zamiast pochłaniać karmę. Każdy posiłek to 15 minut zamiast 30 sekund — żołądek wysyła sygnał sytości, koniec z wzdęciami i wymiotami z głodu.
            </p>

            <ul class="home-pc-feats">
              <li><strong>Spowalnia jedzenie</strong> — pies pracuje językiem nad kulką, dosięgając każdej kropli mokrej karmy</li>
              <li><strong>Antypoślizgowy spód</strong> — miska nie jeździ po podłodze nawet na kafelkach</li>
              <li><strong>Bezpieczna w zmywarce 70°C</strong> — bez BPA, bez PVC, łatwe czyszczenie</li>
            </ul>

            <div class="home-pc-priceblock">
              <div class="home-pc-price-row">
                <span class="home-pc-price">{priceFormatted}</span>
              </div>
              <p class="home-pc-omnibus">Najniższa cena z 30 dni przed obniżką: 79,99 zł</p>
            </div>

            <a href="/produkty/wolnamiska" class="btn btn-primary">
              Wybierz zestaw i zamów
              <span class="arrow">→</span>
            </a>
          </div>
        </article>
      </div>
    </section>

    <!-- WHY NEED — wzór PDP how-grid (italic numbers) -->
    <section class="section section-soft">
      <div class="wrap">
        <span class="eyebrow">Dlaczego twój pies tego potrzebuje</span>
        <h2 class="h2">
          4 momenty, w których WolnaMiska <em>realnie</em> pomaga.
        </h2>
        <p class="lede">
          Niezależnie od rasy i wieku — jeśli pies je za szybko, to nie "jego charakter". To problem do rozwiązania.
        </p>

        <div class="home-why-grid">
          <article class="home-why-card">
            <div class="home-why-num">01</div>
            <h3>Wzdęcia i wymioty</h3>
            <p>Szybkie jedzenie = powietrze w żołądku. Pies wymiotuje karmą po 5 minutach. Wystarczy 15 minut spokojnego posiłku, żeby to zniknęło.</p>
          </article>

          <article class="home-why-card">
            <div class="home-why-num">02</div>
            <h3>Nuda i destrukcja</h3>
            <p>Owczarki, husky, terriery — rasy pracujące potrzebują mentalnej stymulacji. Łamigłówka w misce to 15 minut "pracy" przy każdym posiłku.</p>
          </article>

          <article class="home-why-card">
            <div class="home-why-num">03</div>
            <h3>Stres i lęk</h3>
            <p>Lizanie uwalnia endorfiny — naturalny mechanizm uspokajający. Idealne dla psów lękowych, po przeprowadzce, podczas burzy.</p>
          </article>

          <article class="home-why-card">
            <div class="home-why-num">04</div>
            <h3>Senior pies</h3>
            <p>Po 7 latach metabolizm zwalnia. Wolniejsze jedzenie = lepsze trawienie, mniej kilogramów, mniej wizyt u weterynarza.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- UGC STRIP -->
    <section class="section">
      <div class="wrap">
        <span class="eyebrow">Z polskich domów</span>
        <h2 class="h2">WolnaMiska w akcji</h2>
        <p class="lede">
          Pierwsi klienci pokazują, jak ich psy radzą sobie z miską. Wszystkie zdjęcia od opiekunów.
        </p>

        <div class="home-ugc-grid">
          <div class="home-ugc-tile">
            <img src="/produkty/wolnamiska/hero-shiba.webp" alt="Buldog francuski liże miskę" loading="lazy" />
            <div class="home-ugc-overlay">
              <span class="home-ugc-tag">Mokra karma</span>
            </div>
          </div>
          <div class="home-ugc-tile">
            <img src="/produkty/wolnamiska/na-stole.webp" alt="WolnaMiska na lnianym tle" loading="lazy" />
            <div class="home-ugc-overlay">
              <span class="home-ugc-tag">Pasta z banana</span>
            </div>
          </div>
          <div class="home-ugc-tile">
            <img src="/produkty/wolnamiska/wlewanie-bulionu.webp" alt="Wlewanie bulionu do miski" loading="lazy" />
            <div class="home-ugc-overlay">
              <span class="home-ugc-tag">Bulion bez soli</span>
            </div>
          </div>
          <div class="home-ugc-tile">
            <img src="/produkty/wolnamiska/flatlay-marble.webp" alt="WolnaMiska gotowa do mycia" loading="lazy" />
            <div class="home-ugc-overlay">
              <span class="home-ugc-tag">Po posiłku</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ MINI — wzór PDP faq-list -->
    <section class="section section-soft">
      <div class="wrap">
        <span class="eyebrow">FAQ — najważniejsze</span>
        <h2 class="h2">3 pytania, które najczęściej dostajemy.</h2>

        <div class="home-faq-list">
          <details name="home-faq" class="home-faq-item">
            <summary>
              <span class="home-faq-num">01</span>
              <span class="home-faq-text">Co dawać do WolnaMiski?</span>
              <span class="home-faq-icon"></span>
            </summary>
            <div class="home-faq-body">
              <strong>Tylko mokrą karmę</strong> — sucha wypadnie spod kulki. Najlepsze: mokra karma z dodatkami, jogurt naturalny, bulion bez soli, pasta z dyni lub banana, schłodzone smakołyki na lato.
            </div>
          </details>

          <details name="home-faq" class="home-faq-item">
            <summary>
              <span class="home-faq-num">02</span>
              <span class="home-faq-text">Czy nadaje się dla mojej rasy?</span>
              <span class="home-faq-icon"></span>
            </summary>
            <div class="home-faq-body">
              Tak — od chihuahua po owczarka. Średnica i głębokość dopasowane tak, żeby mopsy, buldogi francuskie i bostony też dosięgały bez problemu. Senior pies, młody, pracujący — działa na każdy typ.
            </div>
          </details>

          <details name="home-faq" class="home-faq-item">
            <summary>
              <span class="home-faq-num">03</span>
              <span class="home-faq-text">Jak długo trwa dostawa?</span>
              <span class="home-faq-icon"></span>
            </summary>
            <div class="home-faq-body">
              Zamówienia złożone do 13:00 wysyłamy tego samego dnia z magazynu w Polsce. Paczkomat InPost zwykle następnego dnia, kurier 1-2 dni robocze. <strong>Darmowa dostawa od 150 zł.</strong>
            </div>
          </details>
        </div>

        <a href="/kontakt" class="home-faq-more">
          Wszystkie pytania na stronie Kontakt
          <span class="arrow" style="font-family:'Fraunces',Georgia,serif; font-weight:300; font-size:18px">→</span>
        </a>
      </div>
    </section>

    <!-- FINAL CTA — wzór PDP .final -->
    <section class="home-final">
      <div class="wrap">
        <div class="home-final-grid">
          <div>
            <span class="eyebrow">Jedna miska, spokojniejsze posiłki</span>
            <h2>Spokojny pies przy <em>każdym</em> posiłku.</h2>
            <p class="home-final-lede">
              Od pierwszego dnia. Bez tresury, bez aplikacji, bez 5 produktów. Jedna miska, która zmienia każdy posiłek.
            </p>
            <div class="home-final-meta">
              <div class="home-final-meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                30 dni gwarancji satysfakcji
              </div>
              <div class="home-final-meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                Pies nie podchodzi? Zwracamy pieniądze
              </div>
              <div class="home-final-meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                Polska wysyłka, BLIK, Paczkomat
              </div>
            </div>
          </div>

          <div class="home-final-buy">
            <div class="home-final-buy-row">
              <div class="home-final-buy-img">
                <img src="/produkty/wolnamiska/na-stole.webp" alt="WolnaMiska" loading="lazy" />
              </div>
              <div>
                <div class="home-final-buy-title">WolnaMiska</div>
                <div class="home-final-buy-desc">Hybrydowa miska z ruchomą kulką</div>
              </div>
            </div>
            <span class="home-final-buy-price">{priceFormatted}</span>
            <a href="/produkty/wolnamiska" class="home-final-cta">
              Zamawiam
              <span class="arrow">→</span>
            </a>
            <div class="home-final-buy-trust">
              <span>30 dni gwarancji</span>
              <span>Wysyłka 24h</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "DbamyOPupile.pl",
    "url": Astro.url.origin,
  })} slot="head" />
</BaseLayout>
