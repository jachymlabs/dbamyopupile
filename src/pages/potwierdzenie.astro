---
import BaseLayout from '@/layouts/BaseLayout.astro';
import OrderSummary from '@/components/OrderSummary.astro';
import { shopApi } from '@/lib/vendure';
import { GET_ORDER_BY_CODE } from '@/lib/queries';
import { sendCAPIEvent, buildUserData } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';
// Security note: orderByCode in Vendure Shop API requires active session —
// it only returns orders belonging to the current customer/session, preventing IDOR.
// Combined with 16-char alphanumeric codes, brute force is impractical.

const storeConfig = await getStoreConfig(Astro.request);

const code = Astro.url.searchParams.get('code');

// Marker z BLIK waiting screen (manual cancel button). PayU IPN webhook ma
// 30s-2min latency, więc bez tego query param pokazalibyśmy PENDING UI
// niezgodnie z user intent ("kliknąłem anuluj w aplikacji bankowej").
// Po IPN payment.state przejdzie do Cancelled — system eventual consistent.
const manualCancel = Astro.url.searchParams.get('manualCancel') === '1';

if (!code) {
  return Astro.redirect('/');
}

let order: any = null;
try {
  const data = await shopApi<any>(GET_ORDER_BY_CODE, { code }, Astro.request);
  order = data.orderByCode;
} catch {
  // Silently fail — redirect below
}

if (!order) {
  return Astro.redirect('/');
}

const customer = order.customer;
const address = order.shippingAddress;
const shippingMethod = order.shippingLines?.[0]?.shippingMethod?.name;

// ──────────────────────────────────────────────────────────────────────
// PAYMENT STATE LOGIC — audit Patryka 2026-05-26
// ──────────────────────────────────────────────────────────────────────
// Problem: PayU return URL ZAWSZE redirectuje na /potwierdzenie?code=XXX,
// niezależnie od tego czy user kliknął "Zapłać" czy "Anuluj". Stary kod
// pokazywał "Dziękujemy za zakup" w obu przypadkach.
//
// Fix: rozróżniamy 3 stany na podstawie order.payments[].state:
//   - Settled (lub COD) → thank-you
//   - Authorized / Created → pending (polling /api/payment/status co 3s)
//   - Cancelled / Error / Declined → failed (CTA "spróbuj ponownie")
//
// Edge case: brak payments[] (rzadkie, np. order zatrzymany w
// ArrangingPayment przed addPaymentToOrder) → showUnknown (treat as pending).
const payments: Array<{ id: string; state: string; method: string }> = order.payments ?? [];
const payuPayment = payments.find((p) => p.method === 'payu');
const codPayment = payments.find((p) => p.method === 'cod');

// COD: order Settled od razu po addPaymentToOrder (brak online flow).
// Jeśli COD payment istnieje — niezależnie od state — traktujemy jako sukces.
const isCod = !payuPayment && !!codPayment;

// PayU states (Vendure standard PaymentState union: Created, Authorized, Settled, Declined, Cancelled, Error, Refunded)
const isSettled = payuPayment?.state === 'Settled';
const isPending = payuPayment?.state === 'Authorized' || payuPayment?.state === 'Created';
const isFailed =
  payuPayment?.state === 'Cancelled' ||
  payuPayment?.state === 'Error' ||
  payuPayment?.state === 'Declined' ||
  // manual cancel z BLIK waiting screen — pokazujemy failed UI od razu,
  // bez czekania na IPN. `&& !isSettled` żeby nie zoverridować rzadkiego
  // edge case'u "user kliknął anuluj ale platnosc i tak przeszla".
  (manualCancel && payuPayment?.state !== 'Settled');

const showThankYou = isCod || isSettled;
// PRIORYTET: failed > pending. Manual cancel z BLIK ustawia isFailed=true
// PRZED IPN webhook od PayU, ale payment.state w Vendure dalej jest 'Authorized'
// → isPending=true. Bez priorytetu pokazaliby_smy OBIE sekcje (failed UI nad
// pending UI), co Patryk reportowal w teście 2026-05-26.
const showFailed = isFailed;
const showPending = isPending && !showFailed;
// Fallback dla edge case'u "brak payments[]" — pokazujemy pending z polling.
// Po Settled webhook reload pokaże thank-you, po timeout (5min) user może odświeżyć.
const showUnknown = !showThankYou && !showPending && !showFailed;
const showPendingOrUnknown = showPending || showUnknown;

// ──────────────────────────────────────────────────────────────────────
// CAPI Purchase event SSR — TYLKO gdy showThankYou
// ──────────────────────────────────────────────────────────────────────
// Deterministic event_id `purchase-{code}` zapobiega double-count z:
//   - checkout.astro CAPI (COD only) — ten sam event_id
//   - browser fbq Purchase poniżej (skrypt na końcu pliku) — ten sam eventID
// Meta deduplikuje po event_id w 7-dniowym oknie (CAPI/browser pair = 1 event).
if (showThankYou) {
  const purchaseUserData = await buildUserData(Astro.request, {
    email: customer?.emailAddress,
    phone: customer?.phoneNumber,
    firstName: customer?.firstName,
    lastName: customer?.lastName,
    city: address?.city,
    postalCode: address?.postalCode,
  });

  await sendCAPIEvent(
    {
      event_name: 'Purchase',
      event_time: Math.floor(Date.now() / 1000),
      event_id: `purchase-${order.code}`,
      event_source_url: Astro.url.href,
      action_source: 'website',
      user_data: purchaseUserData,
      custom_data: {
        value: (order.totalWithTax ?? 0) / 100,
        currency: order.currencyCode ?? 'PLN',
        order_id: order.code,
        num_items: order.totalQuantity ?? 0,
        content_type: 'product',
        content_ids:
          order.lines?.map((l: any) => l.productVariant?.sku).filter(Boolean) ?? [],
        contents:
          order.lines?.map((l: any) => ({
            id: l.productVariant?.sku,
            quantity: l.quantity,
            item_price: (l.unitPriceWithTax ?? 0) / 100,
          })) ?? [],
      },
    },
    storeConfig.metaDatasetId,
  );
}

// Browser fbq dataset — przekazywane do <script define:vars>
const browserPixelData = showThankYou
  ? {
      orderCode: order.code,
      value: (order.totalWithTax ?? 0) / 100,
      // SP pixel (lejek): produkty z VAT BEZ dostawy — spójne z ATC/IC. M-5.
      // (Meta fbq/CAPI dalej używają value=totalWithTax = realny przychód.)
      spValue: (order.subTotalWithTax ?? order.totalWithTax ?? 0) / 100,
      currency: order.currencyCode ?? 'PLN',
      contentIds:
        order.lines?.map((l: any) => l.productVariant?.sku).filter(Boolean) ?? [],
      contents:
        order.lines?.map((l: any) => ({
          id: l.productVariant?.sku,
          quantity: l.quantity,
          item_price: (l.unitPriceWithTax ?? 0) / 100,
        })) ?? [],
      numItems: order.totalQuantity ?? 0,
      // Behawioralny pixel — lista pozycji (product_id = Vendure productId,
      // TEN SAM klucz co view_content na PDP → JOIN „obejrzenia↔zakupy" w cockpicie).
      items:
        order.lines?.map((l: any) => ({
          product_id: l.productVariant?.productId,
          name: l.productVariant?.product?.name,
          qty: l.quantity,
          price: (l.unitPriceWithTax ?? 0) / 100,
        })) ?? [],
    }
  : null;

// Title/noindex per state — żeby crawler nie indeksował "Dziękujemy" gdy faktycznie payment failed
const pageTitle = showThankYou
  ? 'Dziękujemy za zamówienie'
  : showFailed
    ? 'Płatność nieudana'
    : 'Sprawdzamy płatność…';
---

<BaseLayout title={pageTitle} noindex>
  <div class="thx">

    {/* ============================================================
       STATE: FAILED — PayU Cancelled / Error / Declined
       ============================================================ */}
    {showFailed && (
      <>
        <section class="thx-hero">
          <div class="thx-wrap">
            <span class="thx-eyebrow thx-eyebrow-fail">Płatność nieudana</span>
            <h1 class="thx-h1">
              Płatność <em>nie została zakończona</em>
            </h1>
            <p class="thx-lede">
              Zamówienie <strong class="thx-code">{order.code}</strong> nie zostało opłacone.
              Wróć do sklepu i złóż zamówienie ponownie.
            </p>
          </div>
        </section>

        <section class="thx-section">
          <div class="thx-wrap">
            <div class="thx-fail-card">
              <h2 class="thx-fail-title">Co dalej?</h2>
              <p class="thx-fail-desc">
                Najczęstsze powody: anulowana płatność BLIK, błąd banku, brak środków, zamknięte
                okno PayU. Aby spróbować ponownie, wróć do sklepu i dodaj produkty do koszyka jeszcze raz.
              </p>

              <div class="thx-fail-actions">
                <a href="/sklep" class="thx-cta-btn">
                  Wróć do sklepu
                  <span class="thx-arrow">→</span>
                </a>
              </div>

              <p class="thx-fail-help">
                Coś nie działa? Napisz na <a href="mailto:sklep@dbamyopupile.pl">sklep@dbamyopupile.pl</a>
                lub zadzwoń <a href="tel:+48577723506">577 723 506</a>.
              </p>
            </div>
          </div>
        </section>
      </>
    )}

    {/* ============================================================
       STATE: PENDING — PayU Authorized/Created (polling do Settled)
       Lub UNKNOWN — fallback dla edge case'u brak payments[]
       ============================================================ */}
    {showPendingOrUnknown && (
      <>
        <section class="thx-hero">
          <div class="thx-wrap">
            <span class="thx-eyebrow thx-eyebrow-pending">Status płatności</span>
            <h1 class="thx-h1">
              Sprawdzamy <em>status płatności…</em>
            </h1>
            <p class="thx-lede">
              Twoje zamówienie <strong class="thx-code">{order.code}</strong> jest
              weryfikowane przez bank. Nie zamykaj tej strony — automatycznie odświeży się
              po potwierdzeniu.
            </p>
          </div>
        </section>

        <section class="thx-section">
          <div class="thx-wrap">
            <div class="thx-pending-card">
              <div class="thx-spinner" aria-hidden="true"></div>
              <p class="thx-pending-status">Czekamy na potwierdzenie z PayU…</p>
              <p class="thx-pending-help">
                Zazwyczaj trwa to kilka sekund. Jeśli nic się nie dzieje przez 5 minut,
                <a href="/kontakt">skontaktuj się z nami</a>.
              </p>
            </div>
          </div>
        </section>
      </>
    )}

    {/* ============================================================
       STATE: THANK YOU — COD lub PayU Settled
       ============================================================ */}
    {showThankYou && (
      <>
        {/* HERO */}
        <section class="thx-hero">
          <div class="thx-wrap">
            <span class="thx-eyebrow">Płatność potwierdzona</span>

            <h1 class="thx-h1">
              Dziękujemy. Twoje zamówienie jest <em>w drodze</em>
            </h1>

            <p class="thx-lede">
              Numer zamówienia <strong class="thx-code">{order.code}</strong>.
              {customer?.emailAddress && (
                <>Potwierdzenie wysłaliśmy na <strong>{customer.emailAddress}</strong>.</>
              )}
            </p>
          </div>
        </section>

        {/* DETAILS — promote high so user verifies data before scrolling further */}
        <section class="thx-section thx-section-soft">
          <div class="thx-wrap">
            <span class="thx-eyebrow">Szczegóły zamówienia</span>
            <h2 class="thx-h2">
              Sprawdź, czy <em>wszystko się zgadza</em>
            </h2>
            <p class="thx-h2-sub">Coś nie tak? Napisz na <a href="mailto:sklep@dbamyopupile.pl">sklep@dbamyopupile.pl</a>, poprawimy zanim spakujemy.</p>

            <div class="thx-details-card">
              <div class="thx-details-grid">
                {customer && (
                  <div class="thx-details-block">
                    <div class="thx-details-label">Dane klienta</div>
                    <p class="thx-details-name">{customer.firstName} {customer.lastName}</p>
                    <p>{customer.emailAddress}</p>
                    {customer.phoneNumber && <p>{customer.phoneNumber}</p>}
                  </div>
                )}

                {address && (
                  <div class="thx-details-block">
                    <div class="thx-details-label">Adres dostawy</div>
                    {address.fullName && <p class="thx-details-name">{address.fullName}</p>}
                    <p>{address.streetLine1}</p>
                    <p>{address.postalCode} {address.city}</p>
                    {address.phoneNumber && <p class="thx-details-meta">tel. {address.phoneNumber}</p>}
                    {shippingMethod && (
                      <p class="thx-details-shipping">
                        <span>Dostawa:</span> {shippingMethod}
                      </p>
                    )}
                  </div>
                )}
              </div>

              <div class="thx-details-summary">
                <div class="thx-details-summary-label">Twoje produkty</div>
                <OrderSummary order={order} readonly />
              </div>
            </div>
          </div>
        </section>

        {/* TRACKING */}
        <section class="thx-section">
          <div class="thx-wrap">
            <div class="thx-track-card">
              <div class="thx-track">
                <div class="thx-track-step thx-track-active">
                  <div class="thx-track-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span class="thx-track-label">Potwierdzone</span>
                </div>
                <div class="thx-track-line"></div>
                <div class="thx-track-step">
                  <div class="thx-track-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                  </div>
                  <span class="thx-track-label">Pakowanie</span>
                </div>
                <div class="thx-track-line"></div>
                <div class="thx-track-step">
                  <div class="thx-track-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  </div>
                  <span class="thx-track-label">Wysyłka</span>
                </div>
                <div class="thx-track-line"></div>
                <div class="thx-track-step">
                  <div class="thx-track-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  </div>
                  <span class="thx-track-label">Dostarczone</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        {/* CO TERAZ */}
        <section class="thx-section thx-section-soft">
          <div class="thx-wrap">
            <span class="thx-eyebrow">Co dalej</span>
            <h2 class="thx-h2">
              Trzy <em>kroki</em> i paczka będzie u Ciebie
            </h2>

            <div class="thx-next-grid">
              <article class="thx-next-card">
                <div class="thx-next-num">01</div>
                <h3>Pakujemy zamówienie</h3>
                <p>Dziś przygotowujemy paczkę. Wysyłka tego samego dnia, jeśli zamówiłaś do 14:00.</p>
              </article>

              <article class="thx-next-card">
                <div class="thx-next-num">02</div>
                <h3>Numer śledzenia mailem</h3>
                <p>Dostaniesz link InPost, zobaczysz dokładnie, gdzie jest paczka.</p>
              </article>

              <article class="thx-next-card">
                <div class="thx-next-num">03</div>
                <h3>Paczka u Ciebie w 24–48h</h3>
                <p>Paczkomat InPost, 24h. Kurier, do 48h. Przy zestawie 3 ścierek dostawa za 0 zł.</p>
              </article>
            </div>
          </div>
        </section>

        {/* CTA */}
        <section class="thx-final">
          <div class="thx-wrap">
            <div class="thx-final-inner">
              <h2 class="thx-final-title">
                Do <em>zobaczenia</em> wkrótce
              </h2>
              <p class="thx-final-lede">
                Jeśli masz pytanie do zamówienia, jesteśmy pod ręką.
              </p>

              <div class="thx-cta-wrap">
                <a href="/" class="thx-cta-btn">
                  Wróć do sklepu
                  <span class="thx-arrow">→</span>
                </a>
              </div>

              <p class="thx-cta-meta">
                Napisz na <a href="mailto:sklep@dbamyopupile.pl">sklep@dbamyopupile.pl</a> lub zadzwoń <a href="tel:+48577723506">577 723 506</a>.
              </p>
            </div>
          </div>
        </section>
      </>
    )}

  </div>
</BaseLayout>

{/* ============================================================
   Browser fbq Purchase — TYLKO showThankYou + sessionStorage dedup
   ============================================================ */}
{showThankYou && browserPixelData && (
  <script
    is:inline
    define:vars={{
      orderCode: browserPixelData.orderCode,
      value: browserPixelData.value,
      currency: browserPixelData.currency,
      contentIds: browserPixelData.contentIds,
      contents: browserPixelData.contents,
      numItems: browserPixelData.numItems,
    }}
  >
    (function () {
      if (typeof window.fbq !== 'function') return;
      // sessionStorage dedup chroni przed double-fire po F5 refresh.
      // Meta i tak deduplikuje po eventID (purchase-{orderCode}) w 7-dniowym oknie,
      // ale lokalny check zmniejsza niepotrzebne network calls.
      var key = 'purchase:fired:' + orderCode;
      try {
        if (sessionStorage.getItem(key)) return;
        sessionStorage.setItem(key, '1');
      } catch (e) {
        // sessionStorage może być disabled (private mode, quota) — Meta dedup zadba o resztę
      }
      window.fbq(
        'track',
        'Purchase',
        {
          value: value,
          currency: currency,
          content_type: 'product',
          content_ids: contentIds,
          contents: contents,
          num_items: numItems,
        },
        { eventID: 'purchase-' + orderCode },
      );
    })();
  </script>
)}

{/* ============================================================
   Behawioralny pixel — purchase (Warstwa 1, ZERO Meta).
   TYLKO showThankYou (COD lub Settled — NIGDY pending/failed).
   sessionStorage dedup per order.code chroni przed double-fire po F5.
   ============================================================ */}
{showThankYou && browserPixelData && (
  <script
    is:inline
    define:vars={{
      orderCode: browserPixelData.orderCode,
      value: browserPixelData.spValue,
      currency: browserPixelData.currency,
      items: browserPixelData.items,
    }}
  >
    (function () {
      var key = 'sp:purchase:fired:' + orderCode;
      try {
        if (sessionStorage.getItem(key)) return;
        sessionStorage.setItem(key, '1');
      } catch {
        // sessionStorage disabled (private mode/quota) — strzelamy mimo to.
      }
      if (window.sp && window.sp.track) {
        window.sp.track('purchase', {
          order_id: orderCode,
          value: value,
          currency: currency,
          items: items,
        });
      }
    })();
  </script>
)}

{/* ============================================================
   Polling /api/payment/status co 3s gdy Pending
   Settled → reload pokaże thank-you; Failed → reload pokaże failed state.
   Max 5 min, potem reload (user zobaczy aktualny stan, w razie czego refresh ręczny).
   ============================================================ */}
{showPendingOrUnknown && (
  <script is:inline define:vars={{ orderCode: code }}>
    (function () {
      var POLL_MS = 3000;
      var MAX_MS = 5 * 60 * 1000;
      var url = '/api/payment/status?code=' + encodeURIComponent(orderCode);

      var pollInterval = setInterval(async function () {
        try {
          var res = await fetch(url, { credentials: 'include' });
          if (!res.ok) return; // 404/429 — silent, czekamy na kolejny tick
          var json = await res.json();
          if (json.status === 'COMPLETED' || json.status === 'FAILED') {
            clearInterval(pollInterval);
            window.location.reload();
          }
        } catch (e) {
          // network glitch — silent, kolejny tick spróbuje
        }
      }, POLL_MS);

      setTimeout(function () {
        clearInterval(pollInterval);
        window.location.reload();
      }, MAX_MS);
    })();
  </script>
)}

<style is:global>
  /* ============================================ */
  /* THANK-YOU PAGE — dbamyopupile.pl                    */
  /* Brand-aligned z home.css                      */
  /* ============================================ */
  .thx {
    --tx-canvas: #F5F1EA;
    --tx-ivory-2: #E8F0F6;
    --tx-navy: #1C2331;
    --tx-navy-2: #0F1620;
    --tx-blue: #92c2ea;
    --tx-blue-soft: #A8D2EE;
    --tx-ink: #1C2331;
    --tx-ink-2: #4A5568;
    --tx-ink-3: #6B7280;
    --tx-rule: #D5E3EE;
    --tx-rule-soft: #E8F0F6;
    --tx-white: #ffffff;
    --tx-warn: #C84A4A;
    --tx-warn-soft: #FBEAEA;
    --tx-pending: #B68A3E;
    --tx-pending-soft: #FBF3E2;
    --tx-shadow-soft: 0 4px 16px rgba(28, 35, 49, 0.08);
    --tx-shadow-lift: 0 12px 40px rgba(28, 35, 49, 0.12);
    --tx-f-display: "Outfit", -apple-system, system-ui, sans-serif;
    --tx-f-body: "Outfit", -apple-system, system-ui, sans-serif;
    --tx-wrap: 1100px;
    --tx-gutter: clamp(20px, 4vw, 56px);
    --tx-ease: cubic-bezier(0.16, 1, 0.3, 1);
    font-family: var(--tx-f-body);
    color: var(--tx-ink);
    background: var(--tx-canvas);
    line-height: 1.6;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }
  .thx *, .thx *::before, .thx *::after { box-sizing: border-box; }
  .thx p { margin: 0; }
  .thx h1, .thx h2, .thx h3 {
    margin: 0;
    font-family: var(--tx-f-display);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--tx-ink);
  }

  .thx-wrap {
    max-width: var(--tx-wrap);
    margin: 0 auto;
    padding-left: max(var(--tx-gutter), env(safe-area-inset-left));
    padding-right: max(var(--tx-gutter), env(safe-area-inset-right));
    width: 100%;
  }

  /* Eyebrow pill — identyczny jak home .eyebrow */
  .thx-eyebrow {
    display: inline-block;
    font-family: var(--tx-f-body);
    font-weight: 700;
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tx-navy);
    background: var(--tx-blue);
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 18px;
