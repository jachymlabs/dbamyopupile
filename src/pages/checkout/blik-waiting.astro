---
import BaseLayout from '@/layouts/BaseLayout.astro';

const code = Astro.url.searchParams.get('code') || '';
if (!code) {
  return Astro.redirect('/');
}
---

<BaseLayout title="Potwierdzanie płatności BLIK" noindex={true}>
  <div class="mx-auto max-w-[28rem] px-4 py-16 text-center">
      <!-- Spinner -->
      <div id="blik-spinner" class="mx-auto mb-6 h-16 w-16 animate-spin rounded-full border-4 border-gray-200 border-t-gray-900"></div>

      <h1 id="blik-title" class="text-xl font-bold text-gray-900 mb-2">
        Potwierdź płatność w aplikacji bankowej
      </h1>
      <p id="blik-subtitle" class="text-sm text-gray-500 mb-6">
        Otwórz aplikację banku i zatwierdź płatność BLIK. Czekamy na potwierdzenie...
      </p>

      <div id="blik-timer" class="text-xs text-gray-400 mb-4">
        Pozostało: <span id="blik-countdown">120</span>s
      </div>

      <!--
        Manual cancel — UX dla "user kliknął anuluj w aplikacji bankowej".
        Klik → POST /api/payment/cancel (ACK marker) → redirect na
        /potwierdzenie?code=XXX&manualCancel=1 (failed UI bez czekania na IPN).
        Po IPN PayU Vendure i tak ustawi payment.state=Cancelled — eventual
        consistency, UI już pokazał failed state.
      -->
      <div id="blik-cancel-section" class="mt-10 pt-6 border-t border-gray-100">
        <p class="text-xs text-gray-400 mb-3">
          Anulowałeś płatność w aplikacji bankowej?
        </p>
        <button
          id="manual-cancel-btn"
          type="button"
          class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-400 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
        >
          Tak, anulowałem
        </button>
      </div>

      <!-- Error state (hidden by default) -->
      <div id="blik-error" class="hidden">
        <p class="text-sm text-red-600 mb-4">Płatność nie została potwierdzona.</p>
        <a href="/checkout" class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-6 py-3 text-sm font-medium text-white hover:bg-gray-800 transition-colors">
          Spróbuj ponownie
        </a>
      </div>

      <!-- Success state (hidden by default) -->
      <div id="blik-success" class="hidden">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <p class="text-sm text-green-700 font-medium">Płatność potwierdzona! Przekierowujemy...</p>
      </div>
  </div>

  <script is:inline define:vars={{ orderCode: code }}>
  (function() {
    var countdown = 120;
    var countdownEl = document.getElementById('blik-countdown');
    var spinnerEl = document.getElementById('blik-spinner');
    var titleEl = document.getElementById('blik-title');
    var subtitleEl = document.getElementById('blik-subtitle');
    var timerEl = document.getElementById('blik-timer');
    var errorEl = document.getElementById('blik-error');
    var successEl = document.getElementById('blik-success');
    var done = false;

    function showSuccess() {
      done = true;
      spinnerEl.classList.add('hidden');
      titleEl.classList.add('hidden');
      subtitleEl.classList.add('hidden');
      timerEl.classList.add('hidden');
      successEl.classList.remove('hidden');
      setTimeout(function() {
        window.location.href = '/potwierdzenie?code=' + orderCode;
      }, 1500);
    }

    function showError() {
      done = true;
      spinnerEl.classList.add('hidden');
      titleEl.textContent = 'Płatność nie powiodła się';
      subtitleEl.classList.add('hidden');
      timerEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
    }

    function checkStatus() {
      if (done) return;
      fetch('/api/payment/status?code=' + orderCode, { credentials: 'include' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.status === 'COMPLETED') {
            showSuccess();
          } else if (data.status === 'FAILED' || data.status === 'NOT_FOUND') {
            showError();
          }
          // PENDING — keep polling
        })
        .catch(function() {
          // Network error — keep trying
        });
    }

    // Poll every 1s — szybkie wykrycie Cancelled po IPN webhook (PayU IPN
    // dochodzi 30s-2min po user akcji, więc każda sekunda oczekiwania = UX win).
    // Rate limit `/api/payment/status` podbity do 120 req/min/IP pod ten use case.
    var pollInterval = setInterval(function() {
      if (done) { clearInterval(pollInterval); return; }
      checkStatus();
    }, 1000);

    // Manual cancel — user kliknął "Anuluj" w aplikacji bankowej i chce od razu
    // failed UI bez czekania na IPN webhook od PayU. POST /api/payment/cancel to
    // tylko ACK (Vendure dalej dostanie Cancelled po IPN, eventual consistency),
    // klient robi hard redirect na /potwierdzenie?code=XXX&manualCancel=1.
    var cancelBtn = document.getElementById('manual-cancel-btn');
    if (cancelBtn) {
      cancelBtn.addEventListener('click', function() {
        if (done) return;
        done = true;
        cancelBtn.setAttribute('disabled', 'true');
        cancelBtn.textContent = 'Przekierowuję...';
        clearInterval(pollInterval);
        clearInterval(timerInterval);
        fetch('/api/payment/cancel?code=' + encodeURIComponent(orderCode), {
          method: 'POST',
          credentials: 'include',
        })
          .catch(function() { /* ACK only, ignorujemy błąd */ })
          .finally(function() {
            window.location.href = '/potwierdzenie?code=' + orderCode + '&manualCancel=1';
          });
      });
    }

    // Countdown timer
    var timerInterval = setInterval(function() {
      countdown--;
      if (countdownEl) countdownEl.textContent = countdown;
      if (countdown <= 0) {
        clearInterval(timerInterval);
        clearInterval(pollInterval);
        if (!done) showError();
      }
    }, 1000);

    // First check immediately
    checkStatus();

    // Cleanup on navigation
    document.addEventListener('astro:before-swap', function() {
      clearInterval(pollInterval);
      clearInterval(timerInterval);
    }, { once: true });
  })();
  </script>
</BaseLayout>
