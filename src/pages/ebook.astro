    .eb-bundle:hover {
      transform: translateY(-6px);
      box-shadow: var(--eb-shadow-lg);
    }

    .eb-bundle.popular {
      border-color: var(--eb-blue);
      background: #fff;
    }

    .eb-bundle-badge {
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      padding: 5px 14px;
      background: var(--eb-blue);
      color: var(--eb-navy);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: 999px;
    }

    .eb-bundle-badge.free {
      background: var(--eb-canvas);
      color: var(--eb-navy);
    }

    .eb-bundle-qty {
      font-family: var(--eb-f-display);
      font-weight: 500;
      font-size: 26px;
      letter-spacing: -0.02em;
      color: var(--eb-navy);
      line-height: 1.1;
    }

    .eb-bundle-price {
      font-family: var(--eb-f-display);
      font-weight: 500;
      font-size: 36px;
      letter-spacing: -0.02em;
      color: var(--eb-navy);
      line-height: 1;
    }

    .eb-bundle-each {
      font-size: 13px;
      color: var(--eb-ink-2);
      margin-top: -8px;
    }

    .eb-bundle-feat {
      list-style: none;
      padding: 0;
      margin: 6px 0 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .eb-bundle-feat li {
      font-size: 14px;
      line-height: 1.45;
      color: var(--eb-ink-2);
      padding-left: 20px;
      position: relative;
    }

    .eb-bundle-feat li::before {
      content: '✓';
      position: absolute;
      left: 0;
      top: 0;
      color: var(--eb-navy);
      font-weight: 700;
    }

    .eb-bundle-cta {
      margin-top: 8px;
      padding: 14px 18px;
      background: var(--eb-navy);
      color: var(--eb-canvas);
      font-weight: 600;
      font-size: 14px;
      border-radius: 10px;
      text-align: center;
      min-height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: background 180ms ease;
    }

    .eb-bundle:hover .eb-bundle-cta {
      background: var(--eb-navy-deep);
    }

    .eb-final-trust {
      margin-top: 40px;
      text-align: center;
      font-size: 13px;
      color: var(--eb-blue);
      letter-spacing: 0.04em;
    }

    /* ============================================
       Reduced motion
       ============================================ */
    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        transition: none !important;
        animation: none !important;
      }
