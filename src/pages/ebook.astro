  {/* Gallery interactivity — thumb click → swap main */}
  <script is:inline>
    (function() {
      const thumbs = document.querySelectorAll('.eb-thumb');
      const mockups = document.querySelectorAll('.eb-page-mockup');
      const main = document.getElementById('eb-gallery-main');
      if (!thumbs.length || !mockups.length) return;

      const total = mockups.length;
      let currentIdx = 0;

      function activate(idx) {
        currentIdx = (idx + total) % total;
        thumbs.forEach((t) => t.classList.toggle('active', t.getAttribute('data-target') === String(currentIdx)));
        mockups.forEach((m) => m.classList.toggle('active', m.getAttribute('data-idx') === String(currentIdx)));
      }

      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          activate(parseInt(thumb.getAttribute('data-target') || '0', 10));
        });
      });

      // Touch swipe on main
      if (main) {
        let touchStartX = 0;
        let touchEndX = 0;

        main.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        main.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          const diff = touchStartX - touchEndX;
          if (Math.abs(diff) < 40) return;
          if (diff > 0) activate(currentIdx + 1);
          else activate(currentIdx - 1);
        }, { passive: true });
      }

      // Keyboard arrows when gallery in view
      document.addEventListener('keydown', (e) => {
        if (!main) return;
        const rect = main.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > window.innerHeight) return;
        if (e.key === 'ArrowLeft') activate(currentIdx - 1);
        else if (e.key === 'ArrowRight') activate(currentIdx + 1);
      });
    })();
  </script>

