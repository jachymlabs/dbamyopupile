</BaseLayout>

{/* InPost Geowidget SDK */}
<script is:inline src="https://geowidget.inpost.pl/inpost-geowidget.js" defer></script>

{/* InitiateCheckout pixel event — eventID matches CAPI for dedupe (H11) */}
<script
  is:inline
  define:vars={{
    icValue: checkoutValue,
    icNumItems: checkoutNumItems,
    icEventId: initiateCheckoutEventId,
  }}
>
  if (typeof fbq !== 'undefined') {
    fbq('track', 'InitiateCheckout', {
      value: icValue,
      currency: 'PLN',
      num_items: icNumItems,
    }, { eventID: icEventId });
  }
</script>

{/* Behawioralny pixel — initiate_checkout (Warstwa 1, ZERO Meta).
    value = subtotal z VAT bez dostawy (checkoutSubtotal) — spójne z ATC/Purchase. M-5. */}
<script is:inline define:vars={{ spValue: checkoutSubtotal, spOrderCode: order?.code ?? null }}>
  window.addEventListener('load', function () {
    if (!window.sp || !window.sp.track || !spOrderCode) return;
    // Dedup per order.code (sessionStorage) — wzor jak Purchase. Checkout strzela
    // na kazdy load; upsell ATC robi reload() → bez tego IC liczony 2-3x/sesje.
    var key = 'sp:ic:fired:' + spOrderCode;
    try {
      if (sessionStorage.getItem(key)) return;
      sessionStorage.setItem(key, '1');
    } catch {}
    window.sp.track('initiate_checkout', { value: spValue, currency: 'PLN' });
  });
</script>

<script>
  import { getCouponDisplayName, isHiddenCoupon } from '@/lib/coupon-labels';

  // ============================================================
  // CHECKOUT — Progressive Disclosure + Interactions
  // ============================================================

  // --- Upsell ATC click handler — fetch /api/cart POST → reload checkout
  // (najprostszy sposób żeby OrderSummary się odświeżył z nowym item'em + recalc shipping)
  (function setupUpsellATC() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-upsell-add]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const card = btn.closest<HTMLElement>('[data-upsell-variant]');
        const variantId = card?.dataset.upsellVariant;
        if (!variantId || btn.dataset.loading === '1') return;
        btn.dataset.loading = '1';
        const label = btn.querySelector<HTMLElement>('[data-btn-label]');
        const originalText = label?.textContent;
        if (label) label.textContent = 'Dodaję…';
        try {
          const res = await fetch('/api/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ variantId, quantity: 1 }),
          });
          if (res.ok) {
            btn.dataset.added = '1';
            if (label) label.textContent = 'Dodano';

            // Behawioralny pixel — add_to_cart z upsellu przy kasie (ZERO Meta,
            // fail-safe). product_id = Vendure productId (spójny klucz z view_content
            // /purchase) + value = cena produktu. send() keepalive → przeżyje reload. H-3 + M-5.
            try {
              const data = await res.json();
              const line = data?.order?.lines?.find(
                (l: { productVariant?: { id?: string | number } }) =>
                  String(l.productVariant?.id) === String(variantId),
              );
              const pid = (line?.productVariant as { product?: { id?: string } } | undefined)?.product?.id;
              const unit = Number(line?.unitPriceWithTax) || 0;
              const sp = (window as { sp?: { track?: (t: string, d: unknown) => void } }).sp;
              sp?.track?.('add_to_cart', {
                product_id: pid ?? variantId,
                value: unit / 100, // upsell dodaje 1 szt
                currency: 'PLN',
              });
            } catch {
              const sp = (window as { sp?: { track?: (t: string, d: unknown) => void } }).sp;
              sp?.track?.('add_to_cart', { product_id: variantId, currency: 'PLN' });
            }

            // Reload żeby OrderSummary się odświeżył (i potencjalnie nowe upselle pojawiły)
            setTimeout(() => { window.location.reload(); }, 500);
          } else {
            if (label) label.textContent = originalText || 'Dodaj';
            btn.dataset.loading = '0';
          }
        } catch {
          if (label) label.textContent = originalText || 'Dodaj';
          btn.dataset.loading = '0';
        }
      });
    });
  })();

  // --- Slim header — hide on scroll down, show on scroll up (smartphone-like).
  // Threshold: only kick in past 80px so micro-scrolls at top don't trigger.
  (function setupHeaderHideOnScroll() {
    const header = document.querySelector<HTMLElement>('.co-header');
    if (!header) return;
    let lastY = window.scrollY;
    let ticking = false;
    const THRESHOLD = 80;
    const DELTA = 6;

    const update = () => {
      const y = window.scrollY;
      const dy = y - lastY;
      if (y < THRESHOLD) {
        header.classList.remove('co-header--hidden');
      } else if (dy > DELTA) {
        header.classList.add('co-header--hidden');
      } else if (dy < -DELTA) {
        header.classList.remove('co-header--hidden');
      }
      lastY = y;
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();

  // --- Geowidget button: stop click propagation żeby nie togglować radio paczkomatu.
  // Button siedzi WEWNĄTRZ `<label>` Paczkomat radio (HTML semantics), więc click bubbluje
  // do `<label>` i przełącza radio przy ponownym kliknięciu. stopPropagation rozwiązuje.
  (function setupGeowidgetClickGuard() {
    const ids = ['open-geowidget', 'change-locker'];
    ids.forEach((id) => {
      const btn = document.getElementById(id) as HTMLButtonElement | null;
      if (!btn) return;
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
      });
    });
  })();

  // --- Back button: czytamy document.referrer i wracamy do strony z ktorej user
  // przyszedl (np. PDP /produkty/bezsmugi-zestaw). Wykluczamy /koszyk i /checkout
  // (user nigdy nie chce wracac do koszyka — to nie jest "wczesniejsza strona"
  // w sensie shoppingowym). Fallback: home `/` (single-product = landing produktu).
  // Bez JS link i tak prowadzi do `/`.
  (function setupBackLink() {
    const backLink = document.getElementById('checkout-back') as HTMLAnchorElement | null;
    if (!backLink) return;
    const fallback = backLink.dataset.fallback || '/';
    let target = fallback;
    const ref = document.referrer;
    if (ref) {
      try {
        const u = new URL(ref);
        if (u.origin === location.origin) {
          const p = u.pathname;
          if (!p.startsWith('/koszyk') && !p.startsWith('/checkout')) {
            target = u.pathname + u.search + u.hash;
          }
        }
      } catch { /* invalid URL — keep fallback */ }
    }
    backLink.setAttribute('href', target);
  })();

  // --- DOM References ---
  const phoneInput = document.getElementById('phone') as HTMLInputElement | null;
  const streetInput = document.getElementById('street') as HTMLInputElement | null;
  const fullNameInput = document.getElementById('fullName') as HTMLInputElement | null;
  const postalInput = document.getElementById('postalCode') as HTMLInputElement | null;
  const blikCodeInput = document.getElementById('blikCode') as HTMLInputElement | null;
  const flowTypeInput = document.getElementById('flowType') as HTMLInputElement | null;
  // Invoice removed — handled via BaseLinker

  // Sections
  const sectionShipping = document.getElementById('section-shipping') as HTMLElement | null;
  const sectionInpost = document.getElementById('section-inpost') as HTMLElement | null;
  const sectionAddress = document.getElementById('section-address') as HTMLElement | null;
  const sectionPersonal = document.getElementById('section-personal') as HTMLElement | null;
  const sectionPayment = document.getElementById('section-payment') as HTMLElement | null;
  const sectionFinalize = document.getElementById('section-finalize') as HTMLElement | null;
  const codNotice = document.getElementById('cod-notice') as HTMLElement | null;
  const payuNotice = document.getElementById('payu-notice') as HTMLElement | null;
  const blikCodeSection = document.getElementById('blik-code-section') as HTMLElement | null;

  // Geowidget
  const openGeowidgetBtn = document.getElementById('open-geowidget') as HTMLElement | null;
  const geowidgetModal = document.getElementById('geowidget-modal') as HTMLElement | null;
  const closeGeowidgetBtn = document.getElementById('close-geowidget') as HTMLElement | null;
  const geowidgetBackdrop = document.getElementById('geowidget-backdrop') as HTMLElement | null;
  const selectedLockerDiv = document.getElementById('selected-locker') as HTMLElement | null;
  const lockerNameEl = document.getElementById('locker-name') as HTMLElement | null;
  const lockerAddressEl = document.getElementById('locker-address') as HTMLElement | null;
  const lockerIdInput = document.getElementById('inpostLockerId') as HTMLInputElement | null;
  const changeLockerBtn = document.getElementById('change-locker') as HTMLElement | null;

  // Form
  const checkoutForm = document.getElementById('checkout-form') as HTMLFormElement | null;
  const submitBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('#submit-btn, #submit-btn-mobile'));
  const submitBtn = submitBtns[0] ?? null;

  // --- State ---
  let currentShippingType: 'paczkomat' | 'kurier' | 'pobranie' = 'kurier';

  // --- Helpers ---
  function show(el: HTMLElement | null) { el?.classList.remove('hidden'); }
  function hide(el: HTMLElement | null) { el?.classList.add('hidden'); }

  const fmtShipping = (g: number) => (g / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });

  // Refresh shipping method labels based on cart total — show "Gratis" gdy >= threshold
  function refreshShippingMethods(order: any) {
    const section = document.getElementById('section-shipping');
    if (!section || !order) return;
    const threshold = parseInt(section.getAttribute('data-free-shipping-threshold') || '0', 10);
    const subTotal = order.subTotalWithTax ?? 0;
    const isFree = threshold > 0 && subTotal >= threshold;

    section.querySelectorAll('[data-shipping-method-row]').forEach((row) => {
      const price = parseInt(row.getAttribute('data-method-price') || '0', 10);
      const cell = row.querySelector('[data-method-price-cell]');
      if (!cell) return;
      if (price === 0) {
        cell.innerHTML = 'Gratis';
      } else if (isFree) {
        cell.innerHTML = `<s class="text-gray-400 text-xs mr-1">${fmtShipping(price)}</s><span class="text-green-600 font-semibold">Gratis</span>`;
      } else {
        cell.textContent = fmtShipping(price);
      }
    });
  }

  // Update OrderSummary "Dostawa" line from the currently checked shipping radio.
  // Vendure does not know about the selection until form submit, so we sync the UI client-side.
  function refreshSummaryShipping() {
    const shipEl = document.getElementById('summary-shipping');
    if (!shipEl) return;
    const selected = document.querySelector<HTMLInputElement>('input[name="shippingMethodId"]:checked');
    if (!selected) {
      shipEl.innerHTML = '<span class="text-gray-400">—</span>';
      return;
    }
    const row = selected.closest('[data-shipping-method-row]') as HTMLElement | null;
    const price = parseInt(row?.getAttribute('data-method-price') || '0', 10);

    const section = document.getElementById('section-shipping');
    const threshold = parseInt(section?.getAttribute('data-free-shipping-threshold') || '0', 10);
    const subEl = document.getElementById('summary-subtotal') as HTMLElement | null;
    // HIGH-1: data-grosze (single source of truth) zamiast parseFloat na locale-formatted
    // tekscie. Polski "129,99 zl" + parseFloat = lamliwy (separator, NBSP, Zł).
    const subTotalGr = parseInt(subEl?.dataset.grosze || '0', 10);
    // MEDIUM-1 follow-up: czytaj `data-has-free-shipping` z <dl> w summary — applyOrderToSummary
    // ustawia ten flag na bazie order.discounts (promotion-based free shipping). Bez tego
    // refreshSummaryShipping widzi tylko threshold-based i flashuje pelna cene 1-2s przy promo.
    const totalsEl = document.querySelector('[data-has-free-shipping]') as HTMLElement | null;
    const hasPromoFreeShipping = totalsEl?.dataset.hasFreeShipping === 'true';
    const isFree = hasPromoFreeShipping || (threshold > 0 && subTotalGr >= threshold);

    if (price === 0) {
      shipEl.innerHTML = '<span class="text-green-600 font-medium">Gratis</span>';
    } else if (isFree) {
      shipEl.innerHTML = `<s class="text-gray-400 text-xs mr-1">${fmtShipping(price)}</s><span class="text-green-600 font-medium">Gratis</span>`;
    } else {
      shipEl.textContent = fmtShipping(price);
    }
  }

  // CRITICAL-4: precyzyjny helper detekcji "darmowej dostawy" — strict regex po
  // poczatku description + sanity check ze amount matchuje shippingLine price.
  // Stara wersja matchujaca substring "darmowa dostaw" mogla false-positive na
  // promocji typu "Bonus przy darmowej dostawie".
  const isFreeShippingDiscount = (d: any, order?: any): boolean => {
    if (!d) return false;
    const desc = (d.description || '').toLowerCase().trim();
    const matchesName = /^darmowa dostawa\b/.test(desc) || /^free shipping\b/.test(desc);
    if (!matchesName) return false;
    if (order?.shippingLines?.length > 0) {
      const methodPrice = order.shippingLines[0]?.priceWithTax ?? 0;
      // Akceptuj jesli shippingWithTax = 0 (Vendure wyzerowal po promo) albo amount
      // discountu rowny pelnej cenie metody (rabat = pelny shipping cost).
      return methodPrice === 0 || Math.abs(d.amountWithTax || 0) === methodPrice;
    }
    return true;
  };

  // Update OrderSummary DOM from a Vendure order — shipping, total, discounts.
  // Reuses #summary-* elementy zrenderowane przez OrderSummary.astro.
  // Note: NIE dispatchujemy 'cart:updated' tutaj — listener w checkout.astro
  // juz reaguje na 'cart:updated' dispatchowane przez updateSummaryFromOrder
  // (qty change), a applyOrderToSummary jest wywolywany Z TEGO listenera po
  // set-shipping. Dispatch tutaj = nieskonczona petla.
  function applyOrderToSummary(order: any) {
    if (!order) return;
    const shipEl = document.getElementById('summary-shipping');
    const totalEl = document.getElementById('summary-total');
    const subEl = document.getElementById('summary-subtotal');

    // CRITICAL-2: aktualizuj line-totals (Vendure rozdystrybuowuje rabaty per
    // linie po set-shipping → linePriceWithTax mogl sie zmienic, summary tego
    // nie odzwierciedlalo).
    const lines = order.lines || [];
    for (const line of lines) {
      const li = document.querySelector(`[data-line="${line.id}"]`);
      if (!li) continue;
      const qtyEl = li.querySelector('[data-qty]');
      const totalElLine = li.querySelector('[data-line-total]');
      if (qtyEl) qtyEl.textContent = String(line.quantity);
      if (totalElLine) totalElLine.textContent = fmtShipping(line.linePriceWithTax ?? 0);
    }

    const rawSub = lines.reduce((s: number, l: any) => s + (l.linePriceWithTax ?? 0), 0);
    if (subEl) {
      subEl.textContent = fmtShipping(rawSub);
      // HIGH-1: data-grosze jako single source of truth do refreshSummaryShipping
      subEl.setAttribute('data-grosze', String(rawSub));
    }

    const hasShipMethod = (order.shippingLines || []).length > 0;
    const hasFreeShippingPromo = (order.discounts || []).some((d: any) => isFreeShippingDiscount(d, order));
    // MEDIUM-1 follow-up: sync data-has-free-shipping na <dl> zeby refreshSummaryShipping
    // (optymistyczny pre-update) widzial promotion-based free shipping, nie tylko threshold.
    const dlEl = document.querySelector('[data-has-free-shipping]') as HTMLElement | null;
    if (dlEl) dlEl.dataset.hasFreeShipping = hasFreeShippingPromo ? 'true' : 'false';
    const shippingPrice = order.shippingWithTax ?? 0;
    // UI tweak: strikethrough uses pelna cena z shippingLines[0].priceWithTax
    // (Vendure zeruje shippingWithTax przy free-shipping promo, ale zachowuje
    // pelna wartosc w shippingLines).
    const fullShippingPrice = order.shippingLines?.[0]?.priceWithTax ?? 0;

    if (shipEl) {
      if (!hasShipMethod) {
        shipEl.innerHTML = '<span class="text-gray-400">—</span>';
      } else if (hasFreeShippingPromo && fullShippingPrice > 0) {
        shipEl.innerHTML = `<s class="text-gray-400 text-xs mr-1">${fmtShipping(fullShippingPrice)}</s><span class="text-green-600 font-medium">Gratis</span>`;
      } else if (shippingPrice > 0) {
        shipEl.textContent = fmtShipping(shippingPrice);
      } else {
        shipEl.innerHTML = '<span class="text-green-600 font-medium">Gratis</span>';
      }
    }
    if (totalEl) totalEl.textContent = fmtShipping(order.totalWithTax);

    // Re-render discounts list — pomijamy promo darmowej dostawy (juz pokazane jako "Gratis" w Dostawie),
    // dyskonty zerowe (MEDIUM-6) i internal coupony oznaczone jako ukryte w coupon-labels.ts.
    const discountsEl = document.getElementById('summary-discounts');
    if (discountsEl) {
      const discounts = (order.discounts || [])
        .filter((d: any) => Math.abs(d.amountWithTax || 0) > 0)
        .filter((d: any) => !isFreeShippingDiscount(d, order))
        .filter((d: any) => !isHiddenCoupon(d.description));
      discountsEl.innerHTML = discounts.map((d: any) => {
        const displayName = getCouponDisplayName(d.description).replace(/[<>]/g, '');
        const amount = fmtShipping(Math.abs(d.amountWithTax || 0));
        return `<div class="flex items-center justify-between gap-3 py-1" data-discount-row>
          <dt class="flex items-center gap-2 text-gray-700 min-w-0">
            <svg class="w-4 h-4 shrink-0 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            <span class="truncate">${displayName}</span>
          </dt>
          <dd class="shrink-0 font-semibold text-emerald-700 tabular-nums">-${amount}</dd>
        </div>`;
      }).join('');
    }
  }

  // Push selected shipping method to Vendure → recalc totals.
  // CRITICAL-1: request-generation counter zamiast shippingInFlight flag.
  // Stary flag blokowal nowe requesty i pozwalal staremu response nadpisac
  // swiezszy stan (user szybko klika Paczkomat → Kurier → response Paczkomat
  // wraca po response Kurier, nadpisuje UI).
  let shippingGen = 0;
  async function syncShippingToVendure(methodId: string) {
    if (!methodId) return;
    const myGen = ++shippingGen;
    try {
      const res = await fetch('/api/cart/set-shipping', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ shippingMethodId: methodId }),
      });
      const data = await res.json();
      // Stale response — nowszy request juz wystartowal, ignoruj nas.
      if (myGen !== shippingGen) return;
      if (data?.order) {
        applyOrderToSummary(data.order);
        refreshShippingMethods(data.order);
      }
    } catch {
      /* offline — UI juz zaktualizowane optymistycznie przez refreshSummaryShipping */
    }
  }

  // Listen for cart updates dispatched by OrderSummary (qty change).
  // HIGH-7: cart:updated jest dispatchowane TYLKO przez updateSummaryFromOrder
  // (OrderSummary.astro) na qty change. applyOrderToSummary (set-shipping path)
  // celowo NIE dispatchuje cart:updated zeby uniknac petli. Jesli sciezka qty
  // zresetowala shippingMethod (Vendure), pushujemy ponownie domyslna metode.
  document.addEventListener('cart:updated', (e: any) => {
    const order = e.detail?.order;
    if (order) refreshShippingMethods(order);
    refreshSummaryShipping();
    // Po zmianie qty Vendure mogl zresetowac shippingMethod → zsyncuj ponownie
    const checked = document.querySelector<HTMLInputElement>('input[name="shippingMethodId"]:checked');
    if (checked && order && (order.shippingLines || []).length === 0) {
      syncShippingToVendure(checked.value);
    }
  });

  function getShippingType(): 'paczkomat' | 'kurier' | 'pobranie' {
    const selected = document.querySelector<HTMLInputElement>('input[name="shippingMethodId"]:checked');
    if (!selected) return 'kurier';
    const code = (selected.dataset.code || '').toLowerCase();
    if (code.includes('pobranie')) return 'pobranie';
    if (code.includes('paczkomat')) return 'paczkomat';
    return 'kurier';
  }

  // Hide everything below contact
  function hideAllBelow() {
    hide(sectionShipping);
    hide(sectionInpost);
    hide(sectionAddress);
    hide(sectionPersonal);
    hide(sectionPayment);
    hide(sectionFinalize);
    hide(codNotice);
  }

  // Apply shipping type — controls which sections are visible
  // Called on: shipping radio change, page load restore
  function applyShippingType(type: 'paczkomat' | 'kurier' | 'pobranie') {
    currentShippingType = type;

    // Toggle `required` on address fields — paczkomat nie wymaga adresu po stronie klienta.
    const addressInputs = ['street', 'city', 'postalCode']
      .map((id) => document.getElementById(id) as HTMLInputElement | null)
      .filter(Boolean) as HTMLInputElement[];
    if (type === 'paczkomat') {
      addressInputs.forEach((i) => i.removeAttribute('required'));
    } else {
      addressInputs.forEach((i) => i.setAttribute('required', ''));
    }

    if (type === 'paczkomat') {
      // sectionInpost visibility — CSS :has() handles it (inline w radio Paczkomat).
      // Wystarczy nie ukrywać JS-em, bo .hidden override'uje CSS.
      sectionInpost?.classList.remove('hidden');
      show(sectionPersonal);
      show(sectionPayment);
      hide(codNotice);
      show(sectionFinalize);
    } else if (type === 'pobranie') {
      sectionInpost?.classList.remove('hidden');
      show(sectionPersonal);
      hide(sectionPayment);  // NO payment for COD
      show(codNotice);
      hide(payuNotice); // COD → no PayU redirect
      show(sectionFinalize);
      if (flowTypeInput) flowTypeInput.value = '';
      document.querySelectorAll<HTMLInputElement>('input[name="paymentFlow"]').forEach((r) => {
        r.checked = false;
      });
      hide(blikCodeSection);
    } else {
      // kurier
      sectionInpost?.classList.remove('hidden');
      show(sectionPersonal);
      show(sectionPayment);
      hide(codNotice);
      // PayU notice — show jeśli current flow to REDIRECT/PAYPO
      const currentFlow = flowTypeInput?.value;
      if (currentFlow === 'REDIRECT' || currentFlow === 'PAYPO') {
        show(payuNotice);
      } else {
        hide(payuNotice);
      }
      show(sectionFinalize);
    }
  }

  // --- Show all sections on load (no progressive disclosure) ---
  applyShippingType(getShippingType());
  refreshSummaryShipping();

  // CRITICAL-3 / HIGH-5 / HIGH-8: initial sync USUNIĘTY — server-side handler
  // (checkout.astro frontmatter) pushuje domyślną metodę do Vendure przed render,
  // więc SSR ma już prawdziwy total. Brak race z form submit, brak amplifikacji
  // requestów per page load.

  // --- Shipping radio change → toggle sections + sync z Vendure (recalc totalu/promo) ---
  document.querySelectorAll<HTMLInputElement>('input[name="shippingMethodId"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      applyShippingType(getShippingType());
      refreshSummaryShipping(); // optymistyczny update Dostawy
      syncShippingToVendure(radio.value); // realne przeliczenie totalu/promo
    });
  });

  // --- Payment flow radio → toggle BLIK ---
  // Visibility blikCodeSection obsługuje CSS (.co-radio-card:not(:has(input:checked)) .co-blik-input).
  // JS tylko: sync hidden flowType + autofocus BLIK input + cleanup .hidden klasy gdy CSS przejmuje.
  document.querySelectorAll<HTMLInputElement>('input[name="paymentFlow"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      if (flowTypeInput) flowTypeInput.value = radio.value;

      // Pozbądź się .hidden żeby CSS:has() mógł kontrolować widoczność.
      blikCodeSection?.classList.remove('hidden');

      if (radio.value === 'BLIK') {
        setTimeout(() => blikCodeInput?.focus(), 50);
      }

      // PayU notice — pokazuj tylko dla REDIRECT/PAYPO (user zostaje przekierowany).
      if (radio.value === 'REDIRECT' || radio.value === 'PAYPO') {
        show(payuNotice);
      } else {
        hide(payuNotice);
      }

      show(sectionFinalize);
    });
  });

  // Initial PayU notice state — gdy formValues miało persisted flowType REDIRECT/PAYPO
  (function initPayuNotice() {
    const initialFlow = flowTypeInput?.value;
    if (initialFlow === 'REDIRECT' || initialFlow === 'PAYPO') {
      show(payuNotice);
    }
  })();

  // --- BLIK input: digits only, max 6 ---
  if (blikCodeInput) {
    blikCodeInput.addEventListener('input', () => {
      blikCodeInput.value = blikCodeInput.value.replace(/\D/g, '').slice(0, 6);
    });
  }

  // --- Postal code auto-format: XX-XXX ---
  if (postalInput) {
    postalInput.addEventListener('input', () => {
      let val = postalInput.value.replace(/[^\d]/g, '');
      if (val.length > 2) {
        val = val.slice(0, 2) + '-' + val.slice(2, 5);
      }
      postalInput.value = val;
    });
  }

  // --- Postal code → city lookup (H4: debounce + per-page-load cache) ---
  // Without these the input event fires every keystroke and re-hits /api/postal-lookup
  // (which proxies to a 3rd-party API + is rate-limited). Cache survives back/forward
  // within the same page-load; debounce coalesces typing bursts.
  const cityContainer = document.getElementById('city')?.parentElement;
  const postalCache = new Map<string, string[]>();
  let lookupDebounce: ReturnType<typeof setTimeout> | undefined;
  let lookupGeneration = 0;

  async function lookupCity(code: string) {
    if (postalCache.has(code)) {
      applyCities(postalCache.get(code)!);
      return;
    }
    const myGen = ++lookupGeneration;
    try {
      const res = await fetch(`/api/postal-lookup?code=${encodeURIComponent(code)}`, {
        credentials: 'include',
      });
      const data = await res.json();
      const cities: string[] = data.cities || [];
      // Cache even empty results — saves a roundtrip if user re-edits to the same code.
      postalCache.set(code, cities);
      // Stale check: another lookup started while this one was in flight; ignore us.
      if (myGen !== lookupGeneration) return;
      applyCities(cities);
    } catch {
      // Silently fail
    }
  }

  function applyCities(cities: string[]) {
    if (!cityContainer) return;
    if (cities.length === 0) {
      restoreCityInput('');
    } else if (cities.length === 1) {
      restoreCityInput(cities[0]);
    } else {
      replaceCityWithSelect(cities);
    }
  }

  function scheduleLookup(code: string) {
    clearTimeout(lookupDebounce);
    // Cache hit fires immediately (no network) — only debounce true network calls.
    if (postalCache.has(code)) {
      applyCities(postalCache.get(code)!);
      return;
    }
    lookupDebounce = setTimeout(() => lookupCity(code), 300);
  }

  function restoreCityInput(value: string) {
    if (!cityContainer) return;
    const existing = cityContainer.querySelector('#city');
    if (existing?.tagName === 'INPUT') {
      (existing as HTMLInputElement).value = value;
      return;
    }
    const input = document.createElement('input');
    input.type = 'text';
    input.id = 'city';
    input.name = 'city';
    input.value = value;
    input.required = true;
    input.autocomplete = 'address-level2';
    input.className = 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm min-h-[44px] focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent';
    existing?.replaceWith(input);
  }

  function replaceCityWithSelect(cities: string[]) {
    if (!cityContainer) return;
    const existing = cityContainer.querySelector('#city');
    const currentValue = existing?.tagName === 'INPUT' ? (existing as HTMLInputElement).value : (existing as HTMLSelectElement)?.value || '';

    const select = document.createElement('select');
    select.id = 'city';
    select.name = 'city';
    select.required = true;
    select.className = 'w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm min-h-[44px] focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent bg-white';

    const placeholder = document.createElement('option');
    placeholder.value = '';
    placeholder.textContent = 'Wybierz miejscowość';
    placeholder.disabled = true;
    select.appendChild(placeholder);

    cities.forEach((city) => {
      const opt = document.createElement('option');
      opt.value = city;
      opt.textContent = city;
      if (city === currentValue) opt.selected = true;
      select.appendChild(opt);
    });

    if (!currentValue || !cities.includes(currentValue)) {
      if (cities.length > 0) {
        (select.options[1] as HTMLOptionElement).selected = true;
      } else {
        placeholder.selected = true;
      }
    }

    existing?.replaceWith(select);
  }

  if (postalInput) {
    postalInput.addEventListener('input', () => {
      const val = postalInput.value.trim();
      if (/^\d{2}-\d{3}$/.test(val)) {
        scheduleLookup(val);
      }
    });
    // Trigger on load if already filled — bypass debounce (initial state, not typing).
    if (/^\d{2}-\d{3}$/.test(postalInput.value.trim())) {
      lookupCity(postalInput.value.trim());
    }
  }

  // --- InPost Geowidget ---
  function openGeoModal() {
    show(geowidgetModal);
    document.body.style.overflow = 'hidden';
  }
  function closeGeoModal() {
    hide(geowidgetModal);
    document.body.style.overflow = '';
  }

  openGeowidgetBtn?.addEventListener('click', openGeoModal);
  changeLockerBtn?.addEventListener('click', openGeoModal);
  closeGeowidgetBtn?.addEventListener('click', closeGeoModal);
  geowidgetBackdrop?.addEventListener('click', closeGeoModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !geowidgetModal?.classList.contains('hidden')) {
      closeGeoModal();
    }
  });

  // Handle locker selection from Geowidget
  document.addEventListener('onpointselect', ((event: CustomEvent) => {
    const point = event.detail;
    if (!point) return;

    if (lockerIdInput) lockerIdInput.value = point.name || '';
    if (lockerNameEl) lockerNameEl.textContent = point.name || '';

    const addr = point.address;
    const details = point.address_details;
    // Tylko ulica + numer — bez postcode/city (te idą do osobnych pól w shippingAddress).
    // address_details.street czasem ma sam ulicę bez numeru, addr.line1 ma "Tarnowskich 69"
    // (pelne street + building number). Preferujemy line1 jako pełen adres ulicy.
    const streetOnly = (addr?.line1 || '').trim()
      || [details?.street, details?.building_number].filter(Boolean).join(' ');

    // Display text dla user — pełen adres "Tarnowskich 69, 33-100 Tarnów"
    if (lockerAddressEl) {
      const displayParts = [streetOnly, details?.post_code && details?.city ? `${details.post_code} ${details.city}` : details?.city].filter(Boolean);
      lockerAddressEl.textContent = displayParts.join(', ');
    }

    // Zapisz structured address do hidden inputs — server używa ich w shippingAddress.
    const streetInput = document.getElementById('inpostLockerStreet') as HTMLInputElement | null;
    const cityInput = document.getElementById('inpostLockerCity') as HTMLInputElement | null;
    const postcodeInput = document.getElementById('inpostLockerPostcode') as HTMLInputElement | null;
    if (streetInput) streetInput.value = streetOnly;
    if (cityInput) cityInput.value = details?.city || '';
    if (postcodeInput) postcodeInput.value = details?.post_code || '';

    show(selectedLockerDiv);
    hide(openGeowidgetBtn);

    closeGeoModal();
    saveFormData();
  }) as EventListener);

  // --- Loading state on submit (H10: triple-submit guard) ---
  // Sequence:
  //  1. Mark submitting flag synchronously in capture phase — wins races against
  //     duplicate submit events (Enter key + click, autofill quirk, double-tap).
  //  2. Disable + spinner BEFORE any async work, so the second invocation finds
  //     buttons already disabled.
  //  3. Cancel any subsequent submit while flag is set.
  let isSubmitting = false;
  if (checkoutForm) {
    checkoutForm.addEventListener(
      'submit',
      (e: Event) => {
        if (isSubmitting) {
          e.preventDefault();
          e.stopImmediatePropagation();
          return;
        }
        isSubmitting = true;
        submitBtns.forEach((b) => {
          b.disabled = true;
          b.setAttribute('aria-busy', 'true');
          b.textContent = 'Przetwarzanie...';
        });
      },
      { capture: true },
    );
  }

  // --- Restore visibility on reload with errors ---
  (function restoreVisibilityOnLoad() {
    const selectedShipping = document.querySelector<HTMLInputElement>('input[name="shippingMethodId"]:checked');
    if (!selectedShipping) return;

    show(sectionShipping);
    applyShippingType(getShippingType());

    // Restore locker display if selected (paczkomat)
    if (lockerIdInput?.value) {
      show(selectedLockerDiv);
      hide(openGeowidgetBtn);
    }

    // Restore BLIK section visibility
    const selectedPayment = document.querySelector<HTMLInputElement>('input[name="paymentFlow"]:checked');
    if (selectedPayment?.value === 'BLIK') {
      show(blikCodeSection);
    }
  })();

  // --- Save/restore form data in localStorage ---
  const STORAGE_KEY = 'checkout-form-data';
  const fieldsToSave = ['email', 'phone', 'street', 'postalCode', 'city', 'fullName'];

  function saveFormData() {
    const data: Record<string, string> = {};
    fieldsToSave.forEach(id => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el?.value) data[id] = el.value;
    });
    // Save selected shipping method
    const selectedShipping = document.querySelector<HTMLInputElement>('input[name="shippingMethodId"]:checked');
    if (selectedShipping) data._shippingMethodId = selectedShipping.value;
    // Save locker — id + display + structured address (street/city/postcode)
    if (lockerIdInput?.value) data._lockerId = lockerIdInput.value;
    if (lockerNameEl?.textContent) data._lockerName = lockerNameEl.textContent;
    if (lockerAddressEl?.textContent) data._lockerAddress = lockerAddressEl.textContent;
    const streetEl = document.getElementById('inpostLockerStreet') as HTMLInputElement | null;
    const cityEl = document.getElementById('inpostLockerCity') as HTMLInputElement | null;
    const postcodeEl = document.getElementById('inpostLockerPostcode') as HTMLInputElement | null;
    if (streetEl?.value) data._lockerStreet = streetEl.value;
    if (cityEl?.value) data._lockerCity = cityEl.value;
    if (postcodeEl?.value) data._lockerPostcode = postcodeEl.value;

    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  }

  function restoreFormData() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const data = JSON.parse(raw) as Record<string, string>;

      // Migration: poprzednie wersje storefronta zapisywały tylko _lockerId
      // bez structured address (street/city/postcode). Po fixu (29-04-2026)
      // wymagamy pełnego adresu — czyścimy stare dane żeby user wybrał paczkomat
      // ponownie i dostał poprawne dane shippingAddress.
      if (data._lockerId && !data._lockerStreet) {
        delete data._lockerId;
        delete data._lockerName;
        delete data._lockerAddress;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      }

      fieldsToSave.forEach(id => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el && !el.value && data[id]) el.value = data[id];
      });

      // Restore shipping selection
      if (data._shippingMethodId) {
        const radio = document.querySelector<HTMLInputElement>(`input[name="shippingMethodId"][value="${data._shippingMethodId}"]`);
        if (radio) { radio.checked = true; applyShippingType(getShippingType()); }
      }

      // Restore locker — id + display + structured address
      if (data._lockerId && lockerIdInput && !lockerIdInput.value) {
        lockerIdInput.value = data._lockerId;
        if (lockerNameEl) lockerNameEl.textContent = data._lockerName || '';
        if (lockerAddressEl) lockerAddressEl.textContent = data._lockerAddress || '';
        const streetEl = document.getElementById('inpostLockerStreet') as HTMLInputElement | null;
        const cityEl = document.getElementById('inpostLockerCity') as HTMLInputElement | null;
        const postcodeEl = document.getElementById('inpostLockerPostcode') as HTMLInputElement | null;
        if (streetEl) streetEl.value = data._lockerStreet || '';
        if (cityEl) cityEl.value = data._lockerCity || '';
        if (postcodeEl) postcodeEl.value = data._lockerPostcode || '';
        show(selectedLockerDiv);
        hide(openGeowidgetBtn);
      }
    } catch {}
  }

  // Restore on page load
  restoreFormData();

  // Save on input change (debounced)
  let saveTimer: ReturnType<typeof setTimeout>;
  document.querySelectorAll<HTMLInputElement | HTMLSelectElement>('#checkout-form input, #checkout-form select').forEach(el => {
    el.addEventListener('change', () => { clearTimeout(saveTimer); saveTimer = setTimeout(saveFormData, 300); });
    el.addEventListener('input', () => { clearTimeout(saveTimer); saveTimer = setTimeout(saveFormData, 500); });
  });

  // MEDIUM-3: NIE kasujemy localStorage na submit. Powod: jesli POST failuje
  // (network error, walidacja serwera), user zostaje na stronie z czystymi
  // polami i traci wpisane dane. Locker fields i tak sa nadpisywane przy
  // nastepnym wyborze paczkomatu, kontaktowe pola przy edycji. Cleanup mial sens
  // tylko po successful redirect — ale wtedy juz na innej stronie.

  // --- Scroll to first error on page load ---
  const firstError = document.querySelector('.text-red-600, .text-red-700');
  if (firstError) {
    firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  // --- Save progress on blur (abandoned cart capture) ---
  // Wysyla setCustomerForOrder do Vendure jak tylko mamy: imie+nazwisko + (email lub telefon).
  // Fire-and-forget z keepalive — wysle nawet gdy user zamknie karte.
  // Idempotentne: kazda zmiana pola = update tych samych danych w Vendure.
  let saveProgressTimer: ReturnType<typeof setTimeout> | null = null;
  let lastSavedPayload = '';

  function readProgressFields(): { fullName: string; email: string; phone: string } {
    const form = document.getElementById('checkout-form') as HTMLFormElement | null;
    if (!form) return { fullName: '', email: '', phone: '' };
    const fd = new FormData(form);
    return {
      fullName: ((fd.get('fullName') as string) || '').trim(),
      email: ((fd.get('email') as string) || '').trim(),
      phone: ((fd.get('phone') as string) || '').trim(),
    };
  }

  async function saveProgress(): Promise<void> {
    const payload = readProgressFields();
    if (!payload.fullName && !payload.email && !payload.phone) return;

    const serialized = JSON.stringify(payload);
    if (serialized === lastSavedPayload) return;
    lastSavedPayload = serialized;

    try {
      await fetch('/api/checkout/save-progress', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: serialized,
        keepalive: true,
        credentials: 'same-origin',
      });
    } catch {
      lastSavedPayload = '';
    }
  }

  function scheduleSaveProgress(): void {
    if (saveProgressTimer) clearTimeout(saveProgressTimer);
    saveProgressTimer = setTimeout(saveProgress, 600);
  }

  ['fullName', 'email', 'phone'].forEach((name) => {
    const el = document.querySelector<HTMLInputElement>(`#checkout-form [name="${name}"]`);
    if (!el) return;
    el.addEventListener('blur', scheduleSaveProgress);
    el.addEventListener('change', scheduleSaveProgress);
  });

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') saveProgress();
  });
</script>
