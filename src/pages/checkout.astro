---
import BaseLayout from '@/layouts/BaseLayout.astro';
import OrderSummary from '@/components/OrderSummary.astro';
import { shopApi, shopApiRaw, saveAuthToken, redirectWithToken } from '@/lib/vendure';
import { formatPrice, buildAssetUrl } from '@/lib/utils';
import { GET_ACTIVE_ORDER, GET_ELIGIBLE_SHIPPING_METHODS } from '@/lib/queries';
import {
  SET_CUSTOMER_FOR_ORDER,
  SET_ORDER_SHIPPING_ADDRESS,
  SET_ORDER_SHIPPING_METHOD,
  SET_ORDER_CUSTOM_FIELDS,
  TRANSITION_ORDER_TO_STATE,
  ADD_PAYMENT_TO_ORDER,
} from '@/lib/mutations';
import { sendCAPIEvent, buildUserData, generateEventId } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';
import { sanitizePaymentsArray, assertSameOrigin } from '@/lib/security';
const storeConfig = await getStoreConfig(Astro.request);

// --- Types ---
interface FormErrors {
  [key: string]: string;
}

let errors: FormErrors = {};
let formValues: Record<string, string> = {};
let globalError = '';

// --- POST: Process checkout ---
// CSRF protection: SameSite=Lax cookie is primary defense.
// Origin check as secondary layer — compare against PUBLIC_SITE_URL (not Astro.url which is localhost behind proxy).
if (Astro.request.method === 'POST') {
  const blocked = assertSameOrigin(Astro.request);
  if (blocked) return blocked;
  try {
    const formData = await Astro.request.formData();

    // Extract form values
    formValues = {
      email: (formData.get('email') as string || '').trim(),
      phone: (formData.get('phone') as string || '').trim(),
      shippingMethodId: (formData.get('shippingMethodId') as string || ''),
      street: (formData.get('street') as string || '').trim(),
      city: (formData.get('city') as string || '').trim(),
      postalCode: (formData.get('postalCode') as string || '').trim(),
      fullName: (formData.get('fullName') as string || '').trim(),
      firstName: '',
      lastName: '',
      paymentMethodCode: (formData.get('paymentMethodCode') as string || ''),
      flowType: (formData.get('flowType') as string || ''),
      blikCode: (formData.get('blikCode') as string || '').trim(),
      nip: (formData.get('nip') as string || '').trim(),
      notes: (formData.get('notes') as string || '').trim(),
      needsInvoice: formData.get('needsInvoice') ? 'on' : '',
      acceptTerms: formData.get('acceptTerms') ? 'on' : '',
      inpostLockerId: (formData.get('inpostLockerId') as string || '').trim(),
      inpostLockerStreet: (formData.get('inpostLockerStreet') as string || '').trim(),
      inpostLockerCity: (formData.get('inpostLockerCity') as string || '').trim(),
      inpostLockerPostcode: (formData.get('inpostLockerPostcode') as string || '').trim(),
    };

    // --- Validation ---
    if (formValues.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(formValues.email)) {
      errors.email = 'Ups! Wygląda na to, że adres email jest nieprawidłowy.';
    }
    if (!formValues.phone) {
      errors.phone = 'Ups! Wygląda na to, że brakuje numeru telefonu.';
    } else if (!/^[\d\s+\-()]{7,15}$/.test(formValues.phone)) {
      errors.phone = 'Ups! Wygląda na to, że numer telefonu jest nieprawidłowy.';
    }
    if (!formValues.shippingMethodId) errors.shippingMethodId = 'Ups! Wygląda na to, że nie wybrano metody dostawy.';

    // Determine shipping type from method name
    let shippingType: 'paczkomat' | 'kurier' | 'pobranie' = 'kurier';
    try {
      const shippingData = await shopApi<any>(GET_ELIGIBLE_SHIPPING_METHODS, {}, Astro.request);
      const methods = shippingData.eligibleShippingMethods ?? [];
      const selectedShipping = methods.find((m: any) => m.id === formValues.shippingMethodId);
      const name = selectedShipping?.name?.toLowerCase() || '';
      const code = selectedShipping?.code?.toLowerCase() || '';
      if (code.includes('pobranie') || name.includes('pobranie')) {
        shippingType = 'pobranie';
      } else if (code.includes('paczkomat') || name.includes('paczkomat')) {
        shippingType = 'paczkomat';
      }
    } catch (err) {
      // CRITICAL-5 follow-up: log silent fallback. Bez tego brak observability gdy
      // GET_ELIGIBLE_SHIPPING_METHODS pada — zamowienia paczkomatowe routuja sie
      // jako kurier przez default i nie wiemy czemu.
      console.error('[checkout:84] eligible shipping methods fetch failed (fallback to kurier):', err);
    }

    // Paczkomat: require locker selection + format validation.
    // H7 (Sprint 1): InPost locker ID = 3-5 liter miasta + 2-4 cyfry + opcjonalna
    // litera sufiksu (np. WAW01A, KRK15N, GDA123M). Regex: ^[A-Z]{3,5}\d{1,4}[A-Z]?$
    // Trim + uppercase żeby tolerować copy-paste z whitespace / lowercase.
    // Chroni przed: injection w `streetLine1: Paczkomat ${id}`, XSS w confirmation,
    // garbage w BaseLinker / InPost ShipX API.
    if (shippingType === 'paczkomat') {
      if (!formValues.inpostLockerId) {
        errors.inpostLockerId = 'Ups! Wygląda na to, że nie wybrano paczkomatu.';
      } else {
        const normalizedLocker = formValues.inpostLockerId.toUpperCase();
        if (!/^[A-Z]{3,5}\d{1,4}[A-Z]?$/.test(normalizedLocker) || normalizedLocker.length > 10) {
          errors.inpostLockerId = 'Ups! Kod paczkomatu ma nieprawidłowy format.';
        } else {
          // Użyj znormalizowanej (uppercase) wartości w dalszym flow.
          formValues.inpostLockerId = normalizedLocker;
        }
      }
    }

    // Address validation only for courier methods (not paczkomat)
    if (shippingType !== 'paczkomat') {
      if (!formValues.street) errors.street = 'Ups! Wygląda na to, że brakuje ulicy i numeru.';
      if (!formValues.city) errors.city = 'Ups! Wygląda na to, że brakuje miasta.';
      if (!formValues.postalCode) {
        errors.postalCode = 'Ups! Wygląda na to, że brakuje kodu pocztowego.';
      } else if (!/^\d{2}-\d{3}$/.test(formValues.postalCode)) {
        errors.postalCode = 'Ups! Kod pocztowy powinien miec format XX-XXX.';
      }
    }

    if (!formValues.fullName) {
      errors.fullName = 'Ups! Wygląda na to, że brakuje imienia i nazwiska.';
    } else {
      const nameParts = formValues.fullName.split(/\s+/);
      formValues.firstName = nameParts[0];
      formValues.lastName = nameParts.slice(1).join(' ') || nameParts[0];
    }

    // Payment validation — skip for COD (pobranie)
    if (shippingType !== 'pobranie') {
      if (!formValues.flowType) errors.paymentMethodCode = 'Ups! Wygląda na to, że nie wybrano metody płatności.';
      // H7 (Sprint 1): BLIK code MUST be exactly 6 ASCII digits.
      // Frontend formatuje to przez slice/replace, ale POST może być raw —
      // walidujemy server-side regex'em żeby nie przepuścić letter/whitespace
      // do PayU API (które i tak odrzuci, ale lepszy UX = wcześniej).
      if (formValues.flowType === 'BLIK' && (!formValues.blikCode || !/^\d{6}$/.test(formValues.blikCode))) {
        errors.blikCode = 'Ups! Wygląda na to, że kod BLIK jest nieprawidłowy (6 cyfr).';
      }
    }
    // Terms accepted implicitly by placing order (no checkbox needed)

    // Invoice/NIP removed — handled via BaseLinker

    // If no validation errors, proceed with Vendure mutations
    if (Object.keys(errors).length === 0) {
      // 0. Ensure order is in AddingItems state
      try {
        const orderCheck = await shopApi<any>(GET_ACTIVE_ORDER, {}, Astro.request);
        const currentState = orderCheck.activeOrder?.state;
        if (currentState && currentState !== 'AddingItems') {
          await shopApiRaw<any>(TRANSITION_ORDER_TO_STATE, { state: 'AddingItems' }, Astro.request);
        }
      } catch (err) {
        // CRITICAL-5 follow-up: log silent state-reset failure. Bez tego order utyka
        // w stanie != AddingItems, kazdy submit zwraca OrderModificationError, brak diagnostyki.
        console.error('[checkout:149] pre-submit order state reset failed:', err);
      }

      // 1. Set customer
      //
      // H3 (Sprint 2): Vendure Shop API has no phone-based customer lookup
      // (only logged-in `activeCustomer`), so we cannot dedupe by phoneNumber via
      // shop-api. Workaround: when only a phone is provided, derive a DETERMINISTIC
      // synthetic email from the digits (no timestamp). Same phone → same email →
      // Vendure's email-unique constraint reuses the existing customer record on
      // the next order automatically.
      //
      // TODO: full phone-based dedupe across phone+email combos requires either
      //  (a) a Vendure custom plugin exposing sanitized `customerByPhone(phone, channelToken)`
      //      in shop-api with strict rate limiting, OR
      //  (b) an /api/admin/customer-lookup-by-phone endpoint guarded by a server-side
      //      admin token + Origin check + rate limit.
      // Either requires backend work — out of Sprint 2 scope. Track in agent vendure backlog.
      const phoneDigits = formValues.phone.replace(/\D/g, '');
      const customerEmail = formValues.email || `tel-${phoneDigits}@phone-checkout.internal`;
      const customerRaw = await shopApiRaw<any>(SET_CUSTOMER_FOR_ORDER, {
        input: {
          firstName: formValues.firstName,
          lastName: formValues.lastName,
          emailAddress: customerEmail,
          phoneNumber: formValues.phone,
        },
      }, Astro.request);
      saveAuthToken(customerRaw.authToken, Astro.response.headers);

      const customerResponse = customerRaw.data.setCustomerForOrder;
      if (customerResponse.__typename !== 'Order' && customerResponse.__typename !== 'AlreadyLoggedInError') {
        globalError = 'Nie udalo sie zapisac danych kontaktowych. Sprawdz dane i sprobuj ponownie.';
      }

      if (!globalError) {
        // 2. Set shipping address
        const addressInput = shippingType === 'paczkomat'
          ? {
              fullName: `${formValues.firstName} ${formValues.lastName}`,
              // streetLine1 = "Paczkomat TAR21M, Tarnowskich 69" (locker id + faktyczna ulica z geowidget)
              streetLine1: [
                `Paczkomat ${formValues.inpostLockerId || ''}`,
                formValues.inpostLockerStreet,
              ]
                .filter(Boolean)
                .join(', '),
              // Fallback do placeholderów jeśli geowidget nie zwrócił adresu
              // (nie powinno się zdarzyć, bo onpointselect zawsze ma address_details).
              city: formValues.inpostLockerCity || 'InPost',
              postalCode: formValues.inpostLockerPostcode || '00-000',
              countryCode: 'PL',
              phoneNumber: formValues.phone,
            }
          : {
              fullName: `${formValues.firstName} ${formValues.lastName}`,
              streetLine1: formValues.street,
              city: formValues.city,
              postalCode: formValues.postalCode,
              countryCode: 'PL',
              phoneNumber: formValues.phone,
            };

        const addressRaw = await shopApiRaw<any>(SET_ORDER_SHIPPING_ADDRESS, {
          input: addressInput,
        }, Astro.request);

        const addressResponse = addressRaw.data.setOrderShippingAddress;
        if (addressResponse.__typename !== 'Order') {
          globalError = 'Nie udało się zapisać adresu dostawy. Sprawdź dane i spróbuj ponownie.';
        }

        // 2b. Save InPost locker ID
        if (!globalError && shippingType === 'paczkomat' && formValues.inpostLockerId) {
          await shopApiRaw<any>(SET_ORDER_CUSTOM_FIELDS, {
            input: {
              customFields: {
                inpostLockerId: formValues.inpostLockerId,
              },
            },
          }, Astro.request);
        }
      }

      if (!globalError) {
        // 3. Set shipping method
        const shippingRaw = await shopApiRaw<any>(SET_ORDER_SHIPPING_METHOD, {
          shippingMethodId: [formValues.shippingMethodId],
        }, Astro.request);

        const shippingResponse = shippingRaw.data.setOrderShippingMethod;
        if (shippingResponse.__typename !== 'Order') {
          globalError = `Nie udało się ustawić metody dostawy: ${shippingResponse?.message || shippingResponse?.__typename || 'unknown'}`;
        }
      }

      if (!globalError) {
        // 4. Transition to ArrangingPayment
        const transitionRaw = await shopApiRaw<any>(TRANSITION_ORDER_TO_STATE, {
          state: 'ArrangingPayment',
        }, Astro.request);

        const transitionResponse = transitionRaw.data.transitionOrderToState;
        if (transitionResponse.__typename === 'OrderStateTransitionError') {
          globalError = 'Nie udało się przejść do płatności. Spróbuj ponownie.';
        }
      }

      // Save UTM data from URL/cookies to order
      if (!globalError) {
        try {
          const url = Astro.url;
          const utmParams: Record<string, string> = {};
          ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'].forEach(key => {
            const val = url.searchParams.get(key);
            if (val) utmParams[key] = val;
          });
          // Also check cookies for stored UTM (set by landing page JS)
          const utmCookie = Astro.request.headers.get('cookie')?.match(/utm_data=([^;]+)/)?.[1];
          if (utmCookie) {
            try { Object.assign(utmParams, JSON.parse(decodeURIComponent(utmCookie))); } catch {}
          }
          if (Object.keys(utmParams).length > 0) {
            await shopApiRaw<any>(SET_ORDER_CUSTOM_FIELDS, {
              input: { customFields: { utmData: JSON.stringify(utmParams) } },
            }, Astro.request);
          }
        } catch {
          // UTM save is best-effort — don't block checkout
        }
      }

      if (!globalError) {
        // HARDBLOCK PayU na dev/preview environments (audit H3 short-term).
        // Vendure channel doodie ma teraz PROD PayU credentials (payuSandbox=false),
        // wiec kazdy online payment z dev.dbamyopupile.pl / *-vercel.app = realny charge.
        // Proper fix: PayU sandbox env-driven payment method (backlog P2 — wymaga
        // sandbox credentials w Vendure channel custom fields). Do tego czasu
        // pozwalamy online payment WYLACZNIE z hostow produkcyjnych.
        const hostname = Astro.url.hostname;
        const isProductionHost = hostname === 'dbamyopupile.pl' || hostname === 'www.dbamyopupile.pl';
        const isOnlinePayment = shippingType !== 'pobranie';

        if (!isProductionHost && isOnlinePayment) {
          globalError = 'Płatności online są wyłączone na środowisku testowym. Wybierz „Pobranie" (COD) aby przetestować checkout, albo zamów na https://dbamyopupile.pl';
        } else {
        // 5. Add payment
        const paymentMethod = shippingType === 'pobranie' ? 'cod' : 'payu';
        const paymentMetadata: Record<string, string> = {};

        if (shippingType !== 'pobranie') {
          paymentMetadata.flowType = formValues.flowType;
          paymentMetadata.email = formValues.email || customerEmail;
          paymentMetadata.phone = formValues.phone;
          paymentMetadata.firstName = formValues.firstName;
          paymentMetadata.lastName = formValues.lastName;
          paymentMetadata.customerIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0] || '';
          // H2 (Sprint 2): BLIK code is a SINGLE-USE secret consumed by PayU during the
          // payment call. Vendure plugin needs it on the input to authorize the transaction,
          // but it MUST NOT be persisted in `order.payments[].metadata` long-term.
          // Storefront-side mitigation:
          //   - Always sanitize `payments[].metadata` on the response read path
          //     (see sanitizePaymentsArray below) so a leaked code never reaches the client.
          //   - Plugin-side: payu plugin must store BLIK code only transiently (in-memory /
          //     ephemeral) and never write it to Vendure DB. Verify via agent vendure when
          //     touching the plugin.
          if (formValues.flowType === 'BLIK' && formValues.blikCode) {
            paymentMetadata.blikCode = formValues.blikCode;
          }
        }

        const paymentRaw = await shopApiRaw<any>(ADD_PAYMENT_TO_ORDER, {
          input: {
            method: paymentMethod,
            metadata: paymentMetadata,
          },
        }, Astro.request);

        const paymentResponse = paymentRaw.data.addPaymentToOrder;
        if (paymentResponse.__typename !== 'Order') {
          globalError = 'Nie udało się przetworzyć płatności. Spróbuj ponownie lub wybierz inną metodę.';
        } else {
          // CAPI: Purchase event — TYLKO dla COD (pobranie), bo:
          //   - COD: order powstaje od razu w stanie Settled (brak online payment flow) → bezpieczne fire
          //   - PayU: order = Authorized/Created, user MOZE anulować w PayU → Purchase fire w
          //     potwierdzenie.astro PO osiągnięciu payment.state === 'Settled'
          // Bez tego rozróżnienia Meta dostawała fake Purchase za każde otwarcie checkout PayU
          // (test Patryka 2026-05-26 PayU "Anuluj" → fake conversion w learning algo).
          //
          // Deterministic event_id = `purchase-{orderCode}` — IDENTYCZNY z tym używanym w
          // potwierdzenie.astro (CAPI + browser fbq). Meta deduplikuje po event_id w 7-dniowym
          // oknie, więc nawet jeśli COD user dotrze do /potwierdzenie i Purchase odpali się tam
          // ponownie — Meta liczy jako 1 event.
          if (paymentMethod === 'cod') {
            // await — Vercel serverless aborts pending fetches po redirect, bez await event ginie
            const purchaseUserData = await buildUserData(Astro.request, {
              email: formValues.email,
              phone: formValues.phone,
              firstName: formValues.firstName,
              lastName: formValues.lastName,
              city: formValues.city,
              postalCode: formValues.postalCode,
            });

            await sendCAPIEvent({
              event_name: 'Purchase',
              event_time: Math.floor(Date.now() / 1000),
              event_id: `purchase-${paymentResponse.code}`,
              event_source_url: Astro.url.href,
              action_source: 'website',
              user_data: purchaseUserData,
              custom_data: {
                value: paymentResponse.totalWithTax / 100,
                currency: 'PLN',
                order_id: paymentResponse.code,
                num_items: paymentResponse.totalQuantity,
                content_type: 'product',
                content_ids: paymentResponse.lines?.map((l: any) => l.productVariant?.sku).filter(Boolean) || [],
                contents: paymentResponse.lines?.map((l: any) => ({
                  id: l.productVariant?.sku,
                  quantity: l.quantity,
                  item_price: l.unitPriceWithTax / 100,
                })) || [],
              },
            }, storeConfig.metaDatasetId);
          }

          // Check for PayU redirect URI (REDIRECT/PAYPO flows)
          if (shippingType !== 'pobranie') {
            // H2 (Sprint 2): sanitize payments[].metadata read path — strips BLIK auth code
            // and any other forbidden secrets before we touch the data.
            const payments = sanitizePaymentsArray(paymentResponse.payments ?? []);
            const lastPayment = payments[payments.length - 1];
            const paymentMeta = lastPayment?.metadata as { public?: { redirectUri?: string } } | undefined;
            const redirectUri = paymentMeta?.public?.redirectUri;
            if (redirectUri && (formValues.flowType === 'REDIRECT' || formValues.flowType === 'PAYPO')) {
              // Validate redirect URL — only allow exact PayU hostnames.
              // C4 (Sprint 1): używamy === (exact match), NIE endsWith(),
              // żeby uniknąć bypass typu `evil-secure.payu.com` lub
              // `secure.payu.com.attacker.tld`.
              const allowedRedirectHosts = new Set([
                'secure.payu.com',
                'merch-prod.snd.payu.com',
                'secure.snd.payu.com',
              ]);
              let redirectBlocked = false;
              try {
                const redirectUrl = new URL(redirectUri);
                // Wymuś HTTPS — PayU nigdy nie używa http: dla redirectu.
                if (redirectUrl.protocol !== 'https:') {
                  console.error('Blocked non-HTTPS payment redirect:', redirectUrl.protocol);
                  globalError = 'Wystąpił błąd płatności. Spróbuj ponownie.';
                  redirectBlocked = true;
                } else if (!allowedRedirectHosts.has(redirectUrl.hostname)) {
                  console.error('Blocked redirect to untrusted hostname:', redirectUrl.hostname);
                  globalError = 'Wystąpił błąd płatności. Spróbuj ponownie.';
                  redirectBlocked = true;
                }
              } catch {
                globalError = 'Nieprawidłowy adres płatności.';
                redirectBlocked = true;
              }
              if (!redirectBlocked) {
                return redirectWithToken(redirectUri, paymentRaw.authToken);
              }
            }
          }

          // BLIK → wait for bank confirmation before proceeding
          if (formValues.flowType === 'BLIK') {
            return redirectWithToken(`/checkout/blik-waiting?code=${paymentResponse.code}`, paymentRaw.authToken ?? customerRaw.authToken);
          }

          // COD or fallback — direct to confirmation
          return redirectWithToken(`/potwierdzenie?code=${paymentResponse.code}`, paymentRaw.authToken ?? customerRaw.authToken);
        }
        } // end else (production host OR COD — HARDBLOCK PayU dev)
      }
    }
  } catch (err: any) {
    globalError = 'Wystąpił nieoczekiwany błąd. Spróbuj ponownie.';
    // MEDIUM-4: redact BLIK code (6 cyfr) z error logow zanim trafia do
    // Vercel Logs / Sentry. Vendure error msg moze zawierac fragment
    // requestu/payloadu, w skrajnym przypadku metadata.blikCode.
    const rawMsg = err instanceof Error ? err.message : String(err ?? 'Unknown error');
    // LOW-1: zawezony regex — redact tylko 6-cyfrowych liczb przy kluczu blikCode
    // (JSON / form encoding). Stary pattern \b\d{6}\b ukrywal tez Vendure order
    // increment IDs, PayU transaction IDs itp. — psuc debug.
    const safeMsg = rawMsg.replace(/(["']?blikCode["']?\s*[:=]\s*["']?)\d{6}(["']?)/gi, '$1[REDACTED-BLIK]$2');
    console.error('Checkout error:', safeMsg);
    // Try to reset order state on failure
    try {
      await shopApi<any>(`mutation { transitionOrderToState(state: "AddingItems") { __typename ... on Order { id state } ... on OrderStateTransitionError { errorCode } } }`, {}, Astro.request);
    } catch (resetErr) {
      // CRITICAL-5: log silent reset failure — bez tego user uknal w stanie
      // ArrangingPayment / non-AddingItems, kolejny submit failuje, nie wiemy czemu.
      console.error('[checkout] Order reset to AddingItems failed:', resetErr instanceof Error ? resetErr.message : resetErr);
    }
  }
}

// --- GET: Fetch data (parallel) ---
let order: any = null;
let shippingMethods: any[] = [];
let inpostToken = '';

try {
  const [orderData, shippingData, channelData] = await Promise.all([
    shopApi<any>(GET_ACTIVE_ORDER, {}, Astro.request),
    shopApi<any>(GET_ELIGIBLE_SHIPPING_METHODS, {}, Astro.request),
    shopApi<any>(`{ activeChannel { customFields { inpostGeowidgetToken } } }`, {}, Astro.request),
  ]);

  order = orderData.activeOrder;
  shippingMethods = shippingData.eligibleShippingMethods ?? [];
  inpostToken = channelData?.activeChannel?.customFields?.inpostGeowidgetToken || '';
} catch (err) {
  // CRITICAL-5 follow-up: log GET handler fetch failure. Bez tego user widzi
  // redirect do /koszyk (przez `if (!order)` ponizej) bez sygnalu od ops.
  console.error('[checkout:430] GET active order / shipping methods / channel failed:', err);
}

if (!inpostToken) {
  inpostToken = import.meta.env.PUBLIC_INPOST_GEOWIDGET_TOKEN || '';
}

// Redirect if cart is empty
if (!order || !order.lines?.length) {
  return Astro.redirect('/koszyk');
}

// Fetch upsell products (brelok-fasola + gniotek-pingwinek) — pokazywane pod
// "Złóż zamówienie" jako last-minute add-on. Filter slugs which już są w koszyku.
const UPSELL_QUERY = `query Upsell($slug: String!) {
  product(slug: $slug) {
    id slug name
    featuredAsset { preview }
    variants { id priceWithTax }
  }
}`;
const cartSlugs = new Set((order.lines || []).map((l: any) => l.productVariant?.product?.slug));
let upsellProducts: any[] = [];
try {
  const slugs = ['brelok-fasola', 'gniotek-pingwinek'].filter((s) => !cartSlugs.has(s));
  if (slugs.length > 0) {
    const results = await Promise.all(
      slugs.map((slug) => shopApi<any>(UPSELL_QUERY, { slug }, Astro.request).catch(() => null)),
    );
    upsellProducts = results.map((r: any) => r?.product).filter(Boolean);
  }
} catch (err) {
  console.error('[checkout] upsells fetch failed:', err);
}

// Default shipping method: Paczkomat (jeśli user nic jeszcze nie wybrał).
// Fallback: pierwsza dostępna metoda.
const isPaczkomat = (m: any) => {
  const c = (m.code || '').toLowerCase();
  const n = (m.name || '').toLowerCase();
  return c.includes('paczkomat') || c.includes('inpost') || n.includes('paczkomat');
};

// MEDIUM-5: walidacja defaultShippingMethodId — formValues.shippingMethodId może być
// stale po zmianie eligible methods (qty change → free-shipping promo nie matchuje już
// pobrania, etc.). Tylko zaakceptuj wartość która jest w aktualnej liście.
const validShippingIds = new Set(shippingMethods.map((m: any) => m.id));
const requestedShippingId = formValues.shippingMethodId && validShippingIds.has(formValues.shippingMethodId)
  ? formValues.shippingMethodId
  : '';
const defaultShippingMethodId =
  requestedShippingId ||
  shippingMethods.find(isPaczkomat)?.id ||
  shippingMethods[0]?.id ||
  '';

// CRITICAL-3: server-side push domyślnej metody dostawy do Vendure jeśli order
// nie ma jeszcze shippingLines. Dzięki temu SSR ma już prawdziwy total + free-shipping
// promo zaaplikowane, eliminuje race między user submit a initial client-side sync,
// i nie pokazuje stale "0,00 zł" w Dostawie podczas pierwszego render.
if (
  Astro.request.method !== 'POST'
  && order
  && order.lines?.length > 0
  && (order.shippingLines?.length ?? 0) === 0
  && defaultShippingMethodId
) {
  try {
    const setShipResult = await shopApi<any>(
      SET_ORDER_SHIPPING_METHOD,
      { shippingMethodId: [defaultShippingMethodId] },
      Astro.request,
    );
    const r = setShipResult?.setOrderShippingMethod;
    if (r?.__typename === 'Order') {
      // Re-fetch GET_ACTIVE_ORDER → uzyskać pełen order shape (discounts, lines z linePriceWithTax)
      // bo setOrderShippingMethod zwraca tylko podzbiór pól.
      const refreshed = await shopApi<any>(GET_ACTIVE_ORDER, {}, Astro.request);
      if (refreshed?.activeOrder) order = refreshed.activeOrder;
    }
  } catch (err) {
    // CRITICAL-3 follow-up: log silent failure. Brak fallbacku po stronie klienta
    // (initial sync usuniety w tym samym commicie), wiec to jedyne miejsce gdzie
    // mozemy zauwazyc ze Vendure padl podczas SET_ORDER_SHIPPING_METHOD na page render.
    console.error('[checkout:488] server-side default shipping setup failed:', err);
  }
}

// H11 (Sprint 2): InitiateCheckout — server CAPI + browser Pixel share the SAME
// event_id so Meta deduplicates the pair. Without this, both events count
// independently and inflate the InitiateCheckout metric ~2x.
// 2026-06-02: event_id deterministyczny per order.code (jak Purchase: `purchase-${code}`).
// Checkout SSR-renderuje sie na kazdy load — upsell ATC nizej robi reload() —
// wiec losowy id per render liczyl IC ~2-3x/sesje. Staly id per koszyk → Meta
// dedup w oknie 48h. CAPI + fbq dalej czytaja te sama zmienna (H11 bez zmian).
const initiateCheckoutEventId = order?.code ? `ic-${order.code}` : generateEventId();
const icUserData = await buildUserData(Astro.request);
sendCAPIEvent({
  event_name: 'InitiateCheckout',
  event_time: Math.floor(Date.now() / 1000),
  event_id: initiateCheckoutEventId,
  event_source_url: Astro.url.href,
  action_source: 'website',
  user_data: icUserData,
  custom_data: {
    value: order ? order.totalWithTax / 100 : 0,
    currency: 'PLN',
    num_items: order ? order.totalQuantity : 0,
    content_type: 'product',
    content_ids: order?.lines?.map((l: any) => l.productVariant?.sku).filter(Boolean) || [],
  },
}, storeConfig.metaDatasetId);

// InitiateCheckout pixel data
const checkoutValue = order ? order.totalWithTax / 100 : 0;
// SP pixel (lejek behawioralny): wartość = produkty z VAT BEZ dostawy — spójna
// definicja ATC/IC/Purchase (wartość koszyka, nie skok z dostawy). M-5.
const checkoutSubtotal = order ? (order.subTotalWithTax ?? order.totalWithTax) / 100 : 0;
const checkoutNumItems = order ? order.totalQuantity : 0;

// CRITICAL-4: precyzyjna detekcja "darmowej dostawy" z amount sanity check.
// Strict regex po poczatku description + sprawdzenie ze amount = pelna cena
// metody (lub Vendure wyzerowal shippingWithTax).
const isFreeShippingDiscountSSR = (d: any, ord: any): boolean => {
  if (!d) return false;
  const desc = (d.description || '').toLowerCase().trim();
  const matchesName = /^darmowa dostawa\b/.test(desc) || /^free shipping\b/.test(desc);
  if (!matchesName) return false;
  if (ord?.shippingLines?.length > 0) {
    const methodPrice = ord.shippingLines[0]?.priceWithTax ?? 0;
    return methodPrice === 0 || Math.abs(d.amountWithTax || 0) === methodPrice;
  }
  return true;
};
const hasFreeShippingFromDiscounts = (order?.discounts ?? []).some((d: any) => isFreeShippingDiscountSSR(d, order));
const channelThreshold = storeConfig?.freeShippingThreshold ?? 0;
const hasFreeShippingPromo = hasFreeShippingFromDiscounts
  || (channelThreshold > 0 && (order?.subTotalWithTax ?? 0) >= channelThreshold);

// Check if form was submitted with errors
const hasErrors = Object.keys(errors).length > 0 || !!globalError;
---

<BaseLayout title="Zamówienie" noindex hideCart hideFooter hideHeader>
  <div class="co-page">
    {/* ==================================================
       SLIM CHECKOUT HEADER — Stitch trust-focused
       ================================================== */}
    <header class="co-header">
      <div class="co-header-inner">
        <a href="/" id="checkout-back" class="co-logo-link" data-fallback="/">
          <img src="/logo/dbamyopupileprostokatbezta.png" alt="dbamyopupile" class="co-logo-img" width="100" height="40" />
        </a>
        <div class="co-trust-icons">
          <span class="material-symbols-outlined co-trust-ico" style="font-variation-settings: 'FILL' 1;">lock</span>
          <span class="co-trust-text">Bezpieczna kasa</span>
          <span class="material-symbols-outlined co-trust-ico">verified_user</span>
        </div>
      </div>
    </header>

    {/* ==================================================
       MAIN — 2-col Stitch grid (7/5 split)
       ================================================== */}
    <main class="co-main">
      {globalError && (
        <div class="co-error-banner">
          <span class="material-symbols-outlined">error</span>
          <p>{globalError}</p>
        </div>
      )}

      <form method="POST" id="checkout-form" novalidate class="co-grid">

        {/* LEFT COLUMN — Forms (col-span-7) */}
        <div class="co-col-left">
          <h1 class="co-h1">Kasa</h1>

          {/* SECTION 1: Kontakt */}
          <section id="section-contact" class="co-card">
            <h2 class="co-card-title">Dane kontaktowe</h2>
            <div class="co-field-grid">
              <div class="co-field">
                <label for="phone">Telefon *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  value={formValues.phone || ''}
                  placeholder="600 100 200"
                  required
                  inputmode="tel"
                  autocomplete="tel"
                  class:list={['co-input', errors.phone && 'co-input--error']}
                />
                {errors.phone && <p class="co-field-error">{errors.phone}</p>}
              </div>

              <div class="co-field">
                <label for="email">Email <span class="co-label-opt">(opcjonalne)</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  value={formValues.email || ''}
                  autocomplete="email"
                  inputmode="email"
                  placeholder="twój@email.pl"
                  class:list={['co-input', errors.email && 'co-input--error']}
                />
                {errors.email && <p class="co-field-error">{errors.email}</p>}
              </div>
            </div>
          </section>

          {/* SECTION 2: Dane osobowe — imię, ulica, kod/miasto 50/50 */}
          <section id="section-personal" class="co-card">
            <h2 class="co-card-title">Dane osobowe</h2>
            <div class="co-field-grid">
              <div class="co-field co-field--full">
                <label for="fullName">Imię i nazwisko *</label>
                <input
                  type="text"
                  id="fullName"
                  name="fullName"
                  value={formValues.fullName || ''}
                  required
                  autocomplete="name"
                  placeholder="Jan Kowalski"
                  class:list={['co-input', errors.fullName && 'co-input--error']}
                />
                {errors.fullName && <p class="co-field-error">{errors.fullName}</p>}
              </div>

              <div class="co-field co-field--full" id="section-address">
                <label for="street">Ulica i numer *</label>
                <input
                  type="text"
                  id="street"
                  name="street"
                  value={formValues.street || ''}
                  autocomplete="street-address"
                  placeholder="ul. Spokojna 15/4"
                  class:list={['co-input', errors.street && 'co-input--error']}
                />
                {errors.street && <p class="co-field-error">{errors.street}</p>}
              </div>

              <div class="co-field">
                <label for="postalCode">Kod pocztowy *</label>
                <input
                  type="text"
                  id="postalCode"
                  name="postalCode"
                  value={formValues.postalCode || ''}
                  placeholder="XX-XXX"
                  inputmode="numeric"
                  autocomplete="postal-code"
                  class:list={['co-input', errors.postalCode && 'co-input--error']}
                />
                {errors.postalCode && <p class="co-field-error">{errors.postalCode}</p>}
              </div>

              <div class="co-field">
                <label for="city">Miasto *</label>
                <input
                  type="text"
                  id="city"
                  name="city"
                  value={formValues.city || ''}
                  autocomplete="address-level2"
                  placeholder="Warszawa"
                  class:list={['co-input', errors.city && 'co-input--error']}
                />
                {errors.city && <p class="co-field-error">{errors.city}</p>}
              </div>
            </div>
          </section>

          {/* SECTION 3: Dostawa — radios; Paczkomat ma inline button do wyboru */}
          <section id="section-shipping" class="co-card" data-free-shipping-threshold={channelThreshold}>
            <h2 class="co-card-title">Metoda dostawy</h2>
            {errors.shippingMethodId && <p class="co-field-error">{errors.shippingMethodId}</p>}

            {shippingMethods.length > 0 ? (
              <div class="co-radios">
                {shippingMethods.map((method: any) => {
                  const isPobranie = method.code?.toLowerCase().includes('pobranie') || method.name?.toLowerCase().includes('pobranie');
                  const showFreeShipping = hasFreeShippingPromo && method.priceWithTax > 0;
                  const isPaczkomat = method.code?.toLowerCase().includes('paczkomat') || method.name?.toLowerCase().includes('paczkomat');
                  const iconName = isPobranie ? 'payments' : isPaczkomat ? 'package_2' : 'local_shipping';
                  return (
                    <label class="co-radio-card" data-shipping-method-row data-method-price={method.priceWithTax}>
                      <div class="co-radio-card-head">
                        <input
                          type="radio"
                          name="shippingMethodId"
                          value={method.id}
                          data-code={method.code}
                          checked={defaultShippingMethodId === method.id}
                        />
                        <span class="material-symbols-outlined co-radio-ico">{iconName}</span>
                        <div class="co-radio-body">
                          <span class="co-radio-label">{method.name}</span>
                          {method.description && (
                            <p class="co-radio-desc">{method.description}</p>
                          )}
                        </div>
                        <span class="co-radio-price" data-method-price-cell>
                          {showFreeShipping
                            ? <><s class="co-price-strike">{formatPrice(method.priceWithTax)}</s><span class="co-price-free">Gratis</span></>
                            : method.priceWithTax === 0
                              ? <span class="co-price-free">Gratis</span>
                              : formatPrice(method.priceWithTax)}
                        </span>
                      </div>

                      {/* Paczkomat inline expand — pokazywane tylko gdy ten radio checked (CSS :has) */}
                      {isPaczkomat && (
                        <div id="section-inpost" class="co-paczkomat-expand">
                          {errors.inpostLockerId && <p class="co-field-error">{errors.inpostLockerId}</p>}

                          <button type="button" id="open-geowidget" class="co-geowidget-btn">
                            <span class="material-symbols-outlined">location_on</span>
                            Wybierz paczkomat na mapie
                          </button>

                          <div id="selected-locker" class="hidden co-locker-selected">
                            <div class="co-locker-info">
                              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                              <div>
                                <p id="locker-name"></p>
                                <p id="locker-address"></p>
                              </div>
                            </div>
                            <button type="button" id="change-locker" class="co-locker-change">Zmień</button>
                          </div>

                          <input type="hidden" name="inpostLockerId" id="inpostLockerId" value={formValues.inpostLockerId || ''} />
                          <input type="hidden" name="inpostLockerStreet" id="inpostLockerStreet" value={formValues.inpostLockerStreet || ''} />
                          <input type="hidden" name="inpostLockerCity" id="inpostLockerCity" value={formValues.inpostLockerCity || ''} />
                          <input type="hidden" name="inpostLockerPostcode" id="inpostLockerPostcode" value={formValues.inpostLockerPostcode || ''} />
                        </div>
                      )}
                    </label>
                  );
                })}
              </div>
            ) : (
              <p class="co-empty">Brak dostępnych metod dostawy.</p>
            )}
          </section>

          {/* SECTION 4: Płatność — domyślnie BLIK */}
          <section id="section-payment" class="co-card">
            <h2 class="co-card-title">Płatność</h2>
            {errors.paymentMethodCode && <p class="co-field-error">{errors.paymentMethodCode}</p>}

            <input type="hidden" name="flowType" id="flowType" value={formValues.flowType || 'BLIK'} />

            <div class="co-radios">
              {/* BLIK — domyślnie */}
              <label class="co-radio-card">
                <div class="co-radio-card-head">
                  <input
                    type="radio"
                    name="paymentFlow"
                    value="BLIK"
                    checked={(formValues.flowType || 'BLIK') === 'BLIK'}
                  />
                  <span class="material-symbols-outlined co-radio-ico">smartphone</span>
                  <div class="co-radio-body">
                    <span class="co-radio-label">BLIK</span>
                    <p class="co-radio-desc">Wpisz kod z aplikacji bankowej</p>
                  </div>
                </div>

                {/* BLIK code input — inline expand */}
                <div id="blik-code-section" class={((formValues.flowType || 'BLIK') === 'BLIK') ? 'co-blik-input' : 'co-blik-input hidden'}>
                  <label for="blikCode">Kod BLIK</label>
                  <input
                    type="text"
                    id="blikCode"
                    name="blikCode"
                    value={formValues.blikCode || ''}
                    placeholder="••••••"
                    inputmode="numeric"
                    maxlength="6"
                    autocomplete="one-time-code"
                    class:list={['co-input', 'co-input--blik', errors.blikCode && 'co-input--error']}
                  />
                  {errors.blikCode && <p class="co-field-error">{errors.blikCode}</p>}
                </div>
              </label>

              {/* Płatność online (redirect) */}
              <label class="co-radio-card">
                <div class="co-radio-card-head">
                  <input
                    type="radio"
                    name="paymentFlow"
                    value="REDIRECT"
                    checked={formValues.flowType === 'REDIRECT'}
                  />
                  <span class="material-symbols-outlined co-radio-ico">credit_card</span>
                  <div class="co-radio-body">
                    <span class="co-radio-label">Karta / przelew online</span>
                    <p class="co-radio-desc">Płatność przez PayU, Visa, Mastercard, przelewy</p>
                  </div>
                </div>
              </label>

              {/* PayPo */}
              <label class="co-radio-card">
                <div class="co-radio-card-head">
                  <input
                    type="radio"
                    name="paymentFlow"
                    value="PAYPO"
                    checked={formValues.flowType === 'PAYPO'}
                  />
                  <span class="material-symbols-outlined co-radio-ico">schedule</span>
                  <div class="co-radio-body">
                    <span class="co-radio-label">PayPo</span>
                    <p class="co-radio-desc">Kup teraz, zapłać za 30 dni</p>
                  </div>
                </div>
              </label>
            </div>
          </section>

          {/* COD Notice (only for pobranie) */}
          <div id="cod-notice" class="hidden co-cod-notice">
            <span class="material-symbols-outlined">payments</span>
            <div>
              <p class="co-cod-title">Płatność przy odbiorze</p>
              <p class="co-cod-desc">Zapłacisz kurierowi przy odbiorze przesyłki.</p>
            </div>
          </div>

          {/* PayU redirect notice — pokazywany gdy flowType = REDIRECT lub PAYPO */}
          <div id="payu-notice" class="hidden co-payu-notice">
            <span class="material-symbols-outlined">open_in_new</span>
            <div>
              <p class="co-payu-title">Przekierowanie do bramki płatności</p>
              <p class="co-payu-desc">Po kliknięciu „Złóż zamówienie" zostaniesz przekierowany do bramki PayU, gdzie dokończysz płatność. Po jej zatwierdzeniu wrócisz na stronę zamówienia.</p>
            </div>
          </div>

          {/* JS placeholder — section-finalize zachowane (no-op show/hide w JS) */}
          <section id="section-finalize" class="hidden"></section>

          {/* Submit + legal — pokazywany na <1024px (poniżej breakpointu grida) */}
          <div class="co-submit-mobile">
            <button type="submit" id="submit-btn-mobile" class="co-place-order">
              Złóż zamówienie
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">arrow_forward</span>
            </button>
            <p class="co-legal">
              Klikając, akceptujesz <a href="/regulamin" target="_blank">regulamin</a> i <a href="/polityka-prywatnosci" target="_blank">politykę prywatności</a>.
            </p>
          </div>
        </div>

        {/* RIGHT COLUMN — Sticky Order summary (col-span-5) */}
        <aside class="co-col-right">
          <div class="co-summary">
            <h2 class="co-summary-title">Podsumowanie</h2>

            <div class="co-summary-lines">
              <OrderSummary order={order} hasFreeShippingPromo={hasFreeShippingPromo} />
            </div>


            {/* Free Shipping Banner — Stitch sage */}
            {hasFreeShippingPromo && (
              <div class="co-free-banner">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                <p>Gratulacje! Masz <strong>darmową dostawę</strong> 🎉</p>
              </div>
            )}

            {/* Submit + legal — pokazywany na >=1024px (desktop, prawa kolumna sticky) */}
            <div class="co-submit-desktop">
              <button type="submit" id="submit-btn" class="co-place-order">
                Złóż zamówienie
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">arrow_forward</span>
              </button>
              <p class="co-legal">
                Klikając, akceptujesz <a href="/regulamin" target="_blank">regulamin</a> i <a href="/polityka-prywatnosci" target="_blank">politykę prywatności</a>.
              </p>
            </div>

            {/* === UPSELLS — compact cards pod CTA (desktop) / pod summary (mobile) === */}
            {upsellProducts.length > 0 && (
              <div class="co-upsells">
                <p class="co-upsells-title">
                  <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">add_shopping_cart</span>
                  Dodaj do zamówienia
                </p>
                <div class="co-upsells-list">
                  {upsellProducts.map((p: any) => {
                    const variant = p.variants?.[0];
                    if (!variant) return null;
                    return (
                      <div class="co-upsell-card" data-upsell-variant={variant.id}>
                        <div class="co-upsell-img">
                          {p.featuredAsset?.preview ? (
                            <img src={buildAssetUrl(p.featuredAsset.preview, 'thumb')} alt={p.name} loading="lazy" />
                          ) : (
                            <span class="material-symbols-outlined">image</span>
                          )}
                        </div>
                        <div class="co-upsell-info">
                          <p class="co-upsell-name">{p.name.split(/\s+[-–]\s+/)[0].trim()}</p>
                          <p class="co-upsell-price">{formatPrice(variant.priceWithTax)}</p>
                        </div>
                        <button type="button" class="co-upsell-btn" data-upsell-add aria-label={`Dodaj ${p.name} do koszyka`}>
                          <span data-btn-label>Dodaj</span>
                          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">add</span>
                        </button>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}

            {/* SSL Trust Row */}
            <div class="co-ssl">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">lock</span>
              <span>SSL · PayU certyfikowany · 30 dni na zwrot</span>
            </div>

            <a href="/sklep" class="co-back-cart">
              <span class="material-symbols-outlined">arrow_back</span>
              Kontynuuj zakupy
            </a>
          </div>
        </aside>
      </form>
    </main>

    {/* ==================================================
       SLIM FOOTER
       ================================================== */}
    <footer class="co-footer">
      <div class="co-footer-inner">
        <span class="co-footer-brand">dbamyopupile</span>
        <div class="co-footer-links">
          <a href="/regulamin">Regulamin</a>
          <a href="/polityka-prywatnosci">Polityka prywatności</a>
          <a href="/kontakt">Kontakt</a>
        </div>
        <span class="co-footer-copy">© 2026 dbamyopupile. Dbamy o Twojego pupila.</span>
      </div>
    </footer>
  </div>

  {/* InPost Geowidget Modal */}
  <div id="geowidget-modal" class="hidden fixed inset-0 z-50">
    <div id="geowidget-backdrop" class="absolute inset-0 bg-black/50"></div>
    <div class="absolute inset-0 sm:inset-4 lg:inset-8 bg-white rounded-lg sm:rounded-xl flex flex-col overflow-hidden z-10">
      <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
        <h3 class="text-base font-semibold text-gray-900">Wybierz paczkomat</h3>
        <button
          type="button"
          id="close-geowidget"
          class="rounded-lg p-2 text-gray-500 hover:bg-gray-100 hover:text-gray-700 min-w-[44px] min-h-[44px] flex items-center justify-center"
          aria-label="Zamknij"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
      <div class="flex-1 overflow-hidden">
        <inpost-geowidget
          id="inpost-geowidget"
          onpoint="onpointselect"
          token={inpostToken}
          language="pl"
          config="parcelCollect"
          style="width:100%;height:100%;display:block;"
        ></inpost-geowidget>
      </div>
    </div>
  </div>

  <style is:global>
    /* ============================================================
       DOODIE CHECKOUT — Stitch port
       2-col grid (7/5 split) · Outfit · sage + strawberry · pill inputs
       ============================================================ */

    .co-page {
      background: var(--brand-bg);
      min-height: 100vh;
      font-family: 'Outfit', system-ui, sans-serif;
      color: var(--brand-heading);
      display: flex;
      flex-direction: column;
    }

    /* ---------- Slim Header (hides on scroll down, shows on scroll up) ---------- */
    .co-header {
      background: var(--brand-bg);
      border-bottom: 1px solid var(--brand-border);
      width: 100%;
      position: sticky;
      top: 0;
      z-index: 40;
      transform: translateY(0);
      transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }
    .co-header--hidden {
      transform: translateY(-100%);
    }
    .co-header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      padding: 14px 20px;
    }
    @media (min-width: 768px) {
      .co-header-inner { padding: 16px 24px; }
    }
    .co-logo-link {
      display: inline-flex;
      align-items: center;
      text-decoration: none;
    }
    .co-logo-img {
      height: 36px;
      width: auto;
      object-fit: contain;
    }
    @media (min-width: 768px) {
      .co-logo-img { height: 44px; }
    }
    .co-trust-icons {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--brand-primary);
    }
    .co-trust-ico {
      font-size: 22px !important;
    }
    .co-trust-text {
      display: none;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.01em;
    }
    @media (min-width: 640px) {
      .co-trust-text { display: inline; }
    }

    /* ---------- Main grid ---------- */
    .co-main {
      flex: 1;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px 80px;
    }
    @media (min-width: 1024px) {
      .co-main { padding: 64px 24px 96px; }
    }

    .co-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
    }
    @media (min-width: 1024px) {
      .co-grid {
        grid-template-columns: 7fr 5fr;
        gap: 48px;
        align-items: start;
      }
    }

    /* min-width: 0 — bez tego grid items rosną do content size i robią horizontal overflow na mobile */
    .co-col-left {
      display: flex;
      flex-direction: column;
      gap: 20px;
      order: 2;
      min-width: 0;
    }
    @media (min-width: 1024px) {
      .co-col-left { order: 1; gap: 24px; }
    }

    .co-col-right {
      order: 1;
      min-width: 0;
    }
    @media (min-width: 1024px) {
      .co-col-right {
        order: 2;
        position: sticky;
        top: 100px;
      }
    }

    /* ---------- H1 ---------- */
    .co-h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 32px;
      font-weight: 800;
      letter-spacing: -0.025em;
      color: var(--brand-heading);
      margin: 0 0 4px;
      line-height: 1.1;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .co-h1::before {
      content: '';
      display: inline-block;
      width: 6px;
      height: 28px;
      background: var(--brand-primary);
      border-radius: 999px;
    }
    @media (min-width: 768px) {
      .co-h1 { font-size: 42px; }
      .co-h1::before { width: 8px; height: 36px; }
    }

    /* ---------- Error banner ---------- */
    .co-error-banner {
      background: var(--brand-accent-soft);
      border: 1px solid var(--brand-accent);
      border-radius: 16px;
      padding: 14px 18px;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--brand-accent);
    }
    .co-error-banner p {
      margin: 0;
      font-size: 14px;
      font-weight: 600;
    }

    /* ---------- Card sections ---------- */
    .co-card {
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 20px;
      padding: 22px 22px 24px;
      box-shadow: 0 1px 2px rgba(42, 45, 39, 0.04), 0 8px 24px rgba(42, 45, 39, 0.05);
      transition: box-shadow 220ms ease, border-color 220ms ease;
    }
    .co-card:focus-within {
      border-color: var(--brand-primary);
      box-shadow: 0 2px 4px rgba(42, 45, 39, 0.05), 0 12px 32px rgba(116, 151, 191, 0.10);
    }
    @media (min-width: 768px) {
      .co-card { padding: 28px 28px 30px; border-radius: 22px; }
    }
    .co-card-title {
      font-family: 'Outfit', sans-serif;
      font-size: 17px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0 0 18px;
      letter-spacing: -0.005em;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .co-card-title::before {
      content: '';
      width: 4px;
      height: 16px;
      background: var(--brand-primary);
      border-radius: 999px;
      flex-shrink: 0;
    }
    @media (min-width: 768px) {
      .co-card-title { font-size: 19px; }
    }
    .co-label-opt {
      font-weight: 400;
      color: var(--brand-muted);
      font-size: 13px;
    }

    /* ---------- Fields ---------- */
    .co-field-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 640px) {
      .co-field-grid { grid-template-columns: 1fr; }
    }
    .co-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .co-field--full { grid-column: 1 / -1; }
    .co-field label {
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: var(--brand-text);
    }
    .co-field-error {
      color: var(--brand-accent);
      font-size: 12px;
      font-weight: 500;
      margin: 4px 0 0;
    }

    .co-input {
      background: var(--brand-surface-2);
      border: 1.5px solid var(--brand-border);
      border-radius: 14px;
      padding: 14px 18px;
      font-family: 'Outfit', sans-serif;
      font-size: 15px;
      color: var(--brand-heading);
      width: 100%;
      box-sizing: border-box;
      transition: border-color 200ms, box-shadow 200ms, background 200ms;
      min-height: 50px;
    }
    .co-input::placeholder {
      color: var(--brand-muted);
    }
    .co-input:hover:not(:focus) {
      border-color: var(--brand-border-strong);
    }
    .co-input:focus {
      outline: none;
      border-color: var(--brand-primary);
      background: var(--brand-surface);
      box-shadow: 0 0 0 4px rgba(116, 151, 191, 0.18);
    }
    .co-input--error {
      border-color: var(--brand-accent);
      background: var(--brand-accent-soft);
    }
    .co-textarea {
      border-radius: 14px;
      resize: vertical;
      min-height: 70px;
      padding: 14px 18px;
    }
    .co-input--blik {
      width: 180px;
      text-align: center;
      letter-spacing: 0.5em;
      font-family: 'Outfit', monospace;
      font-weight: 700;
      font-size: 18px;
    }

    /* ---------- Radio cards (shipping + payment) ---------- */
    .co-radios {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .co-radio-card {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 14px 18px;
      background: var(--brand-surface);
      border: 1.5px solid var(--brand-border);
      border-radius: 16px;
      cursor: pointer;
      transition: border-color 200ms, background 200ms, box-shadow 220ms, transform 120ms;
      position: relative;
    }
    .co-radio-card-head {
      display: flex;
      align-items: center;
      gap: 14px;
      min-height: 36px;
    }
    .co-radio-card:hover {
      background: var(--brand-surface);
      border-color: var(--brand-primary);
      box-shadow: 0 4px 14px rgba(116, 151, 191, 0.12);
      transform: translateY(-1px);
    }
    .co-radio-card:has(input:checked) {
      border-color: var(--brand-primary);
      background: var(--brand-primary-soft);
      box-shadow: 0 0 0 3px rgba(116, 151, 191, 0.18), 0 6px 18px rgba(116, 151, 191, 0.15);
      transform: translateY(0);
    }
    .co-radio-card input[type="radio"] {
      accent-color: var(--brand-primary);
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      cursor: pointer;
    }

    /* ---------- Paczkomat inline expand (inside radio) ---------- */
    .co-paczkomat-expand {
      display: none;
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1px solid var(--brand-border);
      flex-direction: column;
      gap: 10px;
    }
    .co-radio-card:has(input[type="radio"]:checked) .co-paczkomat-expand {
      display: flex;
    }
    /* Allow JS .hidden to still hide it if needed */
    .co-paczkomat-expand.hidden { display: none !important; }

    /* BLIK code inline expand — visible only when BLIK radio checked */
    .co-radio-card:not(:has(input[type="radio"]:checked)) .co-blik-input {
      display: none;
    }
    .co-radio-ico {
      color: var(--brand-primary);
      font-size: 24px !important;
      flex-shrink: 0;
    }
    .co-radio-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .co-radio-label {
      font-size: 15px;
      font-weight: 600;
      color: var(--brand-heading);
    }
    .co-radio-desc {
      font-size: 13px;
      color: var(--brand-text);
      margin: 0;
    }
    .co-radio-price {
      font-size: 15px;
      font-weight: 700;
      color: var(--brand-heading);
      white-space: nowrap;
    }
    .co-price-strike {
      color: var(--brand-muted);
      font-size: 13px;
      margin-right: 6px;
      font-weight: 500;
    }
    .co-price-free {
      color: var(--brand-primary);
      font-weight: 700;
    }
    .co-pay-badge {
      background: var(--brand-heading);
      color: #FFFCF7;
      font-size: 11px;
      font-weight: 800;
      padding: 4px 10px;
      border-radius: 6px;
      letter-spacing: 0.05em;
    }
    .co-pay-badge--blik {
      background: linear-gradient(135deg, #DB1F3B 0%, #FF3B5C 100%);
    }

    /* ---------- BLIK code input (inline w radio) ---------- */
    .co-blik-input {
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1px solid var(--brand-border);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .co-blik-input label {
      font-size: 13px;
      font-weight: 500;
      color: var(--brand-text);
    }

    /* ---------- InPost geowidget button ---------- */
    .co-geowidget-btn {
      width: 100%;
      background: var(--brand-heading);
      color: var(--brand-inverse);
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 14px;
      padding: 16px 20px;
      border: none;
      border-radius: 9999px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: background 200ms;
      letter-spacing: 0.02em;
    }
    .co-geowidget-btn:hover { background: #3A3F35; }
    .co-locker-selected {
      background: var(--brand-primary-soft);
      border: 1px solid var(--brand-primary);
      border-radius: 16px;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .co-locker-info {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .co-locker-info .material-symbols-outlined {
      color: var(--brand-primary);
      font-size: 24px !important;
    }
    .co-locker-info p:first-of-type {
      font-size: 14px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0;
    }
    .co-locker-info p:last-of-type {
      font-size: 12px;
      color: var(--brand-text);
      margin: 2px 0 0;
    }
    .co-locker-change {
      background: transparent;
      border: none;
      color: var(--brand-primary);
      font-weight: 700;
      font-size: 13px;
      text-decoration: underline;
      cursor: pointer;
    }

    /* ---------- COD notice ---------- */
    .co-cod-notice {
      background: #FDF6E4;
      border: 1px solid #E8C97A;
      border-radius: 18px;
      padding: 16px 20px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .co-cod-notice .material-symbols-outlined {
      color: #B8861F;
      font-size: 24px !important;
    }
    .co-cod-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0;
    }
    .co-cod-desc {
      font-size: 13px;
      color: var(--brand-text);
      margin: 4px 0 0;
    }

    /* ---------- PayU redirect notice ---------- */
    .co-payu-notice {
      background: var(--brand-primary-soft);
      border: 1px solid var(--brand-primary);
      border-radius: 18px;
      padding: 16px 20px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .co-payu-notice .material-symbols-outlined {
      color: var(--brand-primary-hover);
      font-size: 24px !important;
      font-variation-settings: 'FILL' 1;
    }
    .co-payu-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0;
    }
    .co-payu-desc {
      font-size: 13px;
      color: var(--brand-text);
      margin: 4px 0 0;
      line-height: 1.5;
    }

    /* ---------- Empty state ---------- */
    .co-empty {
      color: var(--brand-muted);
      font-size: 14px;
      padding: 16px;
      text-align: center;
    }

    /* ---------- Summary right column ---------- */
    .co-summary {
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 24px;
      padding: 24px;
      box-shadow: 0px 4px 20px rgba(42, 45, 39, 0.04);
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    @media (min-width: 768px) {
      .co-summary { padding: 28px; }
    }
    .co-summary-title {
      font-family: 'Outfit', sans-serif;
      font-size: 20px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0;
    }
    .co-summary-lines {
      border-bottom: 1px solid var(--brand-border);
      padding-bottom: 16px;
    }

    /* Kod rabatowy */
    .co-coupon {
      margin-top: 14px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--brand-border);
    }
    .co-coupon-summary {
      cursor: pointer;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: var(--brand-primary-hover);
      list-style: none;
      user-select: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .co-coupon-summary::-webkit-details-marker { display: none; }
    .co-coupon-summary:hover { color: var(--brand-primary); }
    .co-coupon-body { margin-top: 12px; }
    .co-coupon-row { display: flex; gap: 8px; }
    .co-coupon-input {
      flex: 1;
      min-width: 0;
      padding: 11px 14px;
      background: var(--brand-bg);
      border: 1.5px solid var(--brand-border);
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      color: var(--brand-heading);
      text-transform: uppercase;
      transition: border-color 200ms;
    }
    .co-coupon-input:focus { outline: none; border-color: var(--brand-primary); }
    .co-coupon-input::placeholder { text-transform: none; color: var(--brand-muted); }
    .co-coupon-btn {
      flex-shrink: 0;
      padding: 11px 20px;
      background: var(--brand-primary);
      color: #FFFFFF;
      border: none;
      border-radius: 10px;
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      transition: background 200ms;
    }
    .co-coupon-btn:hover { background: var(--brand-primary-hover); }
    .co-coupon-msg {
      margin: 10px 0 0;
      font-size: 13px;
      line-height: 1.4;
    }
    .co-coupon-msg--ok { color: var(--brand-success); }
    .co-coupon-msg--err { color: var(--brand-error); }

    /* OrderSummary inheritance — strip gray colors */
    .co-summary-lines #order-lines {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    /* Border tylko między liniami zamówienia — NIE między atrybutami wewnątrz linii */
    .co-summary-lines #order-lines > li {
      padding: 12px 0 !important;
      border-bottom: 1px solid var(--brand-border) !important;
    }
    .co-summary-lines #order-lines > li:last-child {
      border-bottom: none !important;
    }
    .co-summary-lines #order-lines ul li {
      border: none !important;
      padding: 0 !important;
    }
    .co-summary-lines [data-line] .text-gray-900,
    .co-summary-lines [data-line] .text-gray-500,
    .co-summary-lines [data-line] .text-gray-700,
    .co-summary-lines [data-line] .text-gray-300 {
      color: var(--brand-heading) !important;
    }
    .co-summary-lines [data-line] .text-gray-500,
    .co-summary-lines [data-line] p.text-gray-500 {
      color: var(--brand-text) !important;
    }
    /* Qty selector — pill group (- count +) bez spacji między elementami */
    .co-summary-lines button[data-adjust-qty] {
      border-color: var(--brand-border) !important;
      background: var(--brand-surface-2) !important;
      color: var(--brand-heading) !important;
      width: 26px !important;
      height: 26px !important;
      transition: background 180ms ease, color 180ms ease;
    }
    .co-summary-lines button[data-adjust-qty]:hover {
      background: var(--brand-primary-soft) !important;
      color: var(--brand-primary-hover) !important;
    }
    .co-summary-lines button[data-adjust-qty].rounded-l {
      border-radius: 999px 0 0 999px !important;
      border-right: none !important;
    }
    .co-summary-lines button[data-adjust-qty].rounded-r {
      border-radius: 0 999px 999px 0 !important;
      border-left: none !important;
    }
    .co-summary-lines [data-qty] {
      background: var(--brand-surface-2) !important;
      border-color: var(--brand-border) !important;
      color: var(--brand-heading) !important;
      height: 26px !important;
      font-weight: 600;
    }
    .co-summary-lines .rounded-md {
      border-radius: 12px !important;
      background: var(--brand-surface-2) !important;
    }

    /* ---------- Free shipping banner ---------- */
    .co-free-banner {
      background: var(--brand-primary-soft);
      border: 1px solid var(--brand-primary);
      border-radius: 14px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--brand-primary-hover);
    }
    .co-free-banner .material-symbols-outlined {
      color: var(--brand-primary);
      font-size: 22px !important;
    }
    .co-free-banner p {
      margin: 0;
      font-size: 13px;
      font-weight: 600;
    }
    .co-free-banner strong {
      font-weight: 800;
    }

    /* ---------- Place order button (sage gradient) ---------- */
    .co-place-order,
    .co-submit {
      width: 100%;
      background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary-hover) 100%);
      color: #FFFFFF;
      font-family: 'Outfit', sans-serif;
      font-size: 14.5px;
      font-weight: 800;
      letter-spacing: 0.045em;
      text-transform: uppercase;
      padding: 18px 24px;
      border: none;
      border-radius: 9999px;
      cursor: pointer;
      box-shadow: 0 8px 24px rgba(116, 151, 191, 0.32), 0 2px 6px rgba(116, 151, 191, 0.18);
      transition: background 200ms, transform 100ms, box-shadow 200ms, filter 200ms;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 58px;
    }
    .co-place-order:hover,
    .co-submit:hover {
      filter: brightness(0.96);
      box-shadow: 0 10px 28px rgba(116, 151, 191, 0.40), 0 3px 8px rgba(116, 151, 191, 0.22);
      transform: translateY(-1px);
    }
    .co-place-order:active,
    .co-submit:active {
      transform: scale(0.98);
    }

    /* === UPSELLS (compact cards) — pod CTA na desktop, pod summary na mobile === */
    .co-upsells {
      margin-top: 20px;
      padding: 16px 18px;
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 14px;
    }
    .co-upsells-title {
      display: flex;
      align-items: center;
      gap: 6px;
      margin: 0 0 12px;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--brand-muted);
    }
    .co-upsells-title .material-symbols-outlined {
      font-size: 16px !important;
      color: var(--brand-primary);
    }
    .co-upsells-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .co-upsell-card {
      display: grid;
      grid-template-columns: 48px 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 8px;
      background: var(--brand-bg);
      border: 1px solid var(--brand-border);
      border-radius: 10px;
      transition: border-color 200ms ease, background 200ms ease;
    }
    .co-upsell-card:hover {
      border-color: var(--brand-primary);
      background: var(--brand-surface);
    }
    .co-upsell-img {
      width: 48px;
      height: 48px;
      border-radius: 8px;
      background: var(--brand-surface-2);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .co-upsell-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .co-upsell-img .material-symbols-outlined {
      font-size: 22px !important;
      color: var(--brand-muted);
    }
    .co-upsell-info {
      min-width: 0;
