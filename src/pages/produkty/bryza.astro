---
/**
 * STRONA PRODUKTOWA — Bryza (DbamyOPupile.pl)
 *
 * DUPLIKAT 1:1 wolnamiska.astro — ten sam layout, sekcje, klasy wm- i CSS.
 * Zmienione tylko: PRODUCT_SLUG, cena (dynamicznie z Vendure), warianty (kolor),
 * tytuł oferty (name + shortDescription), ATC drawer (utwardzony intercept).
 *
 * UWAGA — placeholdery do późniejszej podmiany (copy z bryza-landing-copy.md):
 * - galleryImages: ścieżki /produkty/wolnamiska/* (Bryza nie ma assetów w Vendure)
 * - sekcja "Ebook z 30 przepisami" + prelaunch badge + link do ebooka — copy WolnejMiski
 * - wszystkie teksty/recenzje/FAQ — copy WolnejMiski
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Price from '@/components/Price.astro';
import Button from '@/components/Button.astro';
import TrustBadges from '@/components/TrustBadges.astro';
import StickyATCBar from '@/components/StickyATCBar';
import { shopApi, shopApiRaw, redirectWithToken } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { ADD_TO_CART } from '@/lib/mutations';
import { sanitizeHtml } from '@/lib/sanitize';
import '@/styles/wolnamiska-pdp.css';
import { buildAssetUrl } from '@/lib/utils';
import type { VendureProduct, VendureVariant, VendureAsset } from '@/types/vendure';
import { sendCAPIEvent, buildUserData, generateEventId } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';

// SLUG produktu w Vendure (channel dbamyopupile)
const PRODUCT_SLUG = 'bryza';

const storeConfig = await getStoreConfig(Astro.request);

// Handle POST — add to cart (no-JS fallback)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const variantId = formData.get('variantId') as string;
    const rawQty = parseInt(formData.get('quantity') as string || '1', 10);
    const quantity = Math.max(1, Math.min(99, isNaN(rawQty) ? 1 : rawQty));

    if (variantId) {
      const result = await shopApiRaw<any>(ADD_TO_CART, { variantId, quantity }, Astro.request);

      const cookies = Astro.request.headers.get('cookie') || '';
      if (cookies.includes('cookie_consent=accepted')) {
        const userData = await buildUserData(Astro.request);
        sendCAPIEvent({
          event_name: 'AddToCart',
          event_time: Math.floor(Date.now() / 1000),
          event_id: generateEventId(),
          event_source_url: Astro.url.href,
          action_source: 'website',
          user_data: userData,
          custom_data: {
            content_ids: [variantId],
            content_type: 'product',
            currency: 'PLN',
          },
        }, storeConfig.metaDatasetId);
      }
      return redirectWithToken('/koszyk', result.authToken);
    }
    return Astro.redirect('/koszyk');
  } catch {}
}

let product: VendureProduct | null = null;
try {
  const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug: PRODUCT_SLUG }, Astro.request);
  product = data.product;
} catch {}

if (!product) return Astro.rewrite('/404');

const mainImage = product.featuredAsset || product.assets?.[0];
const firstVariant = product.variants?.[0];

// ============================================
// GALLERY — placeholder (WolnaMiska assets; Bryza nie ma zdjęć w Vendure)
// ============================================
type GalleryImage = { src: string; thumb?: string; alt: string };
const galleryImages: GalleryImage[] = [
  { src: '/produkty/wolnamiska/hero-shiba.webp', alt: 'Bryza — chłodząca chusta dla psa na upały' },
  { src: '/produkty/wolnamiska/jak-dziala.webp', alt: 'Jak działa Bryza — zmocz, wykręć, zawiąż na szyi' },
  { src: '/produkty/wolnamiska/shiba-jedzenie.webp', alt: 'Bryza w użyciu — chusta zawiązana na szyi psa' },
  { src: '/produkty/wolnamiska/piec-zalet.webp', alt: 'Najważniejsze zalety chłodzącej chusty Bryza' },
  { src: '/produkty/wolnamiska/przed-po.webp', alt: 'Upalny dzień z Bryzą i bez niej — porównanie' },
  { src: '/produkty/wolnamiska/frenchie-jasny.webp', alt: 'Bryza — pies z chłodzącą chustą w domu' },
  { src: '/produkty/wolnamiska/dla-kogo.webp', alt: 'Dla kogo Bryza — krótki pysk, senior, gęste futro, pies na dworze' },
  { src: '/produkty/wolnamiska/bez-z-porownanie.webp', alt: 'Jak schłodzić psa w upał — porównanie sposobów' },
  { src: '/produkty/wolnamiska/kuchnia-shiba.webp', alt: 'Bryza — chłodząca chusta dla psa' },
  { src: '/produkty/wolnamiska/polisa-na-zycie.webp', alt: 'Pies leżący w cieniu z chłodzącą chustą Bryza' },
  { src: '/produkty/wolnamiska/rece-misa.webp', alt: 'Bryza — chłodząca chusta dla psa w rękach' },
  { src: '/produkty/wolnamiska/misa-kubek.webp', alt: 'Bryza — chłodząca chusta dla psa, skala produktu' },
  { src: '/produkty/wolnamiska/wymiar-16cm.webp', alt: 'Bryza — chłodząca chusta dla psa, materiał poliester' },
];
const lowestPrice = firstVariant?.priceWithTax ?? 0;
const allOutOfStock = product.variants?.every((v: VendureVariant) => v.stockLevel === 'OUT_OF_STOCK');

// ============================================
// WARIANTY KOLORÓW — wykrywane z Vendure (nazwa zawiera kolor), z bezpiecznym fallbackiem na ID
// Zielony = 68, Czarny = 69 (zweryfikowane live). Fallback chroni przed pomyłką gdyby ktoś zmienił ID.
// ============================================
const variantList = (product.variants ?? []) as VendureVariant[];
const greenVariant =
  variantList.find((v) => /ziel/i.test(v.name)) ?? variantList.find((v) => v.id === '68');
const blackVariant =
  variantList.find((v) => /czarn/i.test(v.name)) ?? variantList.find((v) => v.id === '69');
const GREEN_ID = greenVariant?.id ?? '68';
const BLACK_ID = blackVariant?.id ?? '69';

// ============================================
// ZESTAWY — ceny w groszach (brutto). Kupony BRYZA2 / BRYZA3 zweryfikowane na żywo Shop API.
// single: 1 szt 59,99 zł | b2: 2+1 gratis 119 zł (BRYZA2) | b3: 3+2 gratis 179 zł (BRYZA3)
// ============================================
type Bundle = {
  key: string;
  units: number;
  coupon: string | null;
  total: number; // grosze, cena końcowa po kuponie
  title: string;
  priceLabel: string;
  oldPrice?: string;
  save?: string;
  perUnit: string;
  badges: string[];
  recommended?: boolean;
  cornerBadge?: string; // rogowy badge nad kartą (Goli-style)
  freeShipping?: boolean; // osobna linia "Darmowa dostawa" z checkmarkiem
};
// Cena z Vendure — format PLN (dynamiczna). MUSI być przed `bundles` (const = TDZ, nie hoistuje się).
const formatPLN = (cents: number) =>
  new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(cents / 100);
const unitPrice = lowestPrice; // 5999
const bundles: Bundle[] = [
  {
    key: 'single',
    units: 1,
    coupon: null,
    total: unitPrice,
    title: 'Pojedynczy',
    priceLabel: formatPLN(unitPrice),
    perUnit: '1 chusta dla psa',
    badges: [],
  },
  {
    key: 'b2',
    units: 3,
    coupon: 'BRYZA2',
    total: 11900,
    title: '2 + 1 GRATIS',
    priceLabel: formatPLN(11900),
    oldPrice: formatPLN(unitPrice * 3),
    save: `Oszczędzasz ${formatPLN(unitPrice * 3 - 11900)}`,
    perUnit: `${formatPLN(Math.round(11900 / 3))} / szt`,
    badges: [],
    recommended: true,
    cornerBadge: 'NAJPOPULARNIEJSZE',
    freeShipping: true,
  },
  {
    key: 'b3',
    units: 5,
    coupon: 'BRYZA3',
    total: 17900,
    title: '3 + 2 GRATIS',
    priceLabel: formatPLN(17900),
    oldPrice: formatPLN(unitPrice * 5),
    save: `Oszczędzasz ${formatPLN(unitPrice * 5 - 17900)}`,
    perUnit: `${formatPLN(Math.round(17900 / 5))} / szt`,
    badges: [],
    cornerBadge: 'NAJTANIEJ ZA SZTUKĘ',
    freeShipping: true,
  },
];

const priceFormatted = formatPLN(lowestPrice);

const stripHtml = (html: string) => html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
const metaDescription = stripHtml(product.customFields?.shortDescription || product.description || '').slice(0, 160);
const ogImageUrl = mainImage?.preview ? buildAssetUrl(mainImage.preview, 'large') : undefined;

// Tytuł oferty: name + shortDescription (jak w [slug].astro)
const subtitleRaw = stripHtml(product.customFields?.shortDescription || '');
const pageTitle = subtitleRaw ? `${product.name} — ${subtitleRaw}` : product.name;

// CAPI ViewContent
const viewContentEventId = generateEventId();
const vcCookies = Astro.request.headers.get('cookie') || '';
if (vcCookies.includes('cookie_consent=accepted')) {
  const vcUserData = await buildUserData(Astro.request);
  sendCAPIEvent({
    event_name: 'ViewContent',
    event_time: Math.floor(Date.now() / 1000),
    event_id: viewContentEventId,
    event_source_url: Astro.url.href,
    action_source: 'website',
    user_data: vcUserData,
    custom_data: {
      content_ids: [firstVariant?.sku || product.id],
      content_name: product.name,
      content_type: 'product',
      value: lowestPrice / 100,
      currency: 'PLN',
    },
  }, storeConfig.metaDatasetId);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: metaDescription,
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  sku: firstVariant?.sku || undefined,
  offers: {
    '@type': 'Offer',
    price: (lowestPrice / 100).toFixed(2),
    priceCurrency: 'PLN',
    availability: allOutOfStock ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
    url: Astro.url.href,
  },
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogType="product"
>
  <div class="bg-brand-canvas text-brand-text">

    <!-- ============================================ -->
    <!-- HERO + ATC — Conversion-Optimized (research-pdp-hero.md) -->
    <!-- ============================================ -->
    <section class="wm-hero">
      <div class="wm-hero-wrap">
        <div class="wm-hero-grid">
          <!-- LEFT: Sticky Gallery -->
          <div class="wm-gallery-col">
            <div class="wm-gallery">
              <div class="wm-gallery-main" id="wm-gallery-main">
                {galleryImages.map((img, i) => (
                  <img
                    src={img.src}
                    alt={img.alt}
                    width="900"
                    height="900"
                    class:list={['wm-gallery-img', i === 0 && 'active']}
                    data-idx={String(i)}
                    fetchpriority={i === 0 ? 'high' : undefined}
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                ))}

                <button type="button" class="wm-gallery-arrow prev" id="wm-arrow-prev" aria-label="Poprzednie zdjęcie">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <button type="button" class="wm-gallery-arrow next" id="wm-arrow-next" aria-label="Następne zdjęcie">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>

                <span class="wm-gallery-counter">
                  <span id="wm-counter-current">1</span> / <span id="wm-counter-total">{galleryImages.length}</span>
                </span>
              </div>

              <div class="wm-gallery-thumbs" role="tablist" aria-label="Galeria produktu">
                {galleryImages.map((img, i) => (
                  <button
                    class:list={['wm-thumb', i === 0 && 'active']}
                    data-target={String(i)}
                    aria-label={`Zdjęcie ${i + 1}`}
                    type="button"
                  >
                    <img src={img.thumb || img.src} alt="" loading="lazy" />
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- RIGHT: Conversion Engine -->
          <div class="wm-conv-col">
            <div class="wm-prelaunch">
              <span class="wm-prelaunch-dot"></span>
              <span><strong>Bryza</strong> — chłodząca chusta dla psa, żeby nie cierpiał w upale</span>
            </div>

            <h1 class="wm-title">Twój pies nie powie Ci, że jest mu za gorąco</h1>
            <p class="wm-subtitle">Zmoczysz ją wodą, zawiążesz na szyi i przez kilka godzin daje psu ulgę w największy skwar. Bez prądu, bez lodówki, bez czekania.</p>

            <div class="wm-price-block">
              <div class="wm-price-row">
                <span class="wm-price" id="wm-price">{priceFormatted}</span>
                <span class="wm-price-old"></span>
                <span class="wm-price-save"></span>
              </div>
              <div class="wm-omnibus">Najniższa cena z 30 dni przed obniżką: {priceFormatted}</div>
            </div>

            <ul class="wm-usps">
              <li>
                <svg class="wm-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>Chłodzi nawet kilka godzin</strong> — dopóki paruje z niej woda</span>
              </li>
              <li>
                <svg class="wm-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>Bez prądu i bez lodówki</strong> — wystarczy woda z kranu</span>
              </li>
              <li>
                <svg class="wm-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>Regulowana</strong> — pasuje i na małego, i na większego psa</span>
              </li>
            </ul>

            {/*
              MODUŁ ZAKUPU ZESTAWÓW — Bryza.
              3 zestawy: pojedynczy / 2+1 gratis (kupon BRYZA2) / 3+2 gratis (kupon BRYZA3).
              Kolor wybierany przez dwa liczniki auto-balansujące (Zielony 68 / Czarny 69): suma ZAWSZE = liczba sztuk zestawu.
              Single = prosty toggle dwóch przycisków. Stan {green,black} → ATC.
              ATC: stan green/black → POST /api/cart per kolor → POST /api/cart/coupon (jeśli zestaw) → dispatch cart-updated.
              Wszystkie wartości w groszach/brutto zweryfikowane na żywo Shop API: 11900 / 17900 + free shipping.
              Klasy wm-* dla spójności wizualnej z resztą storefrontu.
            */}
            <form class="wm-form" id="wm-atc-form" data-variant-green={GREEN_ID} data-variant-black={BLACK_ID}>
              {/* Wybór zestawu */}
              <div class="wm-bundle-label">Wybierz zestaw</div>
              <div class="wm-bundles" id="wm-bundle-list" role="radiogroup" aria-label="Wybierz zestaw">
                {bundles.map((b, i) => (
                  <label
                    class:list={['wm-bundle-card', i === 1 && 'active', b.recommended && 'wm-bundle-reco', b.cornerBadge && 'has-corner']}
                    data-bundle={b.key}
                    data-units={String(b.units)}
                    data-coupon={b.coupon || ''}
                    data-total={String(b.total)}
                  >
                    {b.cornerBadge && <span class="wm-bundle-corner">{b.cornerBadge}</span>}
                    <input
                      type="radio"
                      name="bundle-choice"
                      value={b.key}
                      checked={i === 1}
                    />
                    <div class="wm-bundle-check">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div class="wm-bundle-main">
                      <div class="wm-bundle-name">{b.title}</div>
                      <div class="wm-bundle-meta">
                        {b.oldPrice && <span class="wm-bundle-old">{b.oldPrice}</span>}
                        <span class="wm-bundle-perunit-inline">{b.perUnit}</span>
                      </div>
                      {b.save && <div class="wm-bundle-save">{b.save}</div>}
                      {b.freeShipping && (
                        <div class="wm-bundle-freeship">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                          <span>Darmowa dostawa</span>
                        </div>
                      )}
                    </div>
                    <div class="wm-bundle-pricing">
                      <div class="wm-bundle-price">{b.priceLabel}</div>
                    </div>
                  </label>
                ))}
              </div>

              {/* Selektory koloru per sztuka — generowane JS-em na podstawie wybranego zestawu */}
              <div class="wm-color-picker" id="wm-color-picker" aria-live="polite"></div>

              {allOutOfStock ? (
                <button type="button" disabled class="wm-atc disabled">Chwilowo niedostępna</button>
              ) : (
                <button type="submit" class="wm-atc" id="primary-atc-btn">
                  <span class="wm-atc-text">Dodaj do koszyka</span>
                  <span class="wm-atc-price" id="wm-atc-price">{bundles[1].priceLabel}</span>
                  <svg class="wm-atc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
              )}

              <div class="wm-delivery-promise">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>Zamów do <strong>14:00</strong>, paczka wyruszy <strong>jeszcze dzisiaj</strong></span>
              </div>
            </form>

            <div class="wm-trust-row">
              <div class="wm-trust">
                <div class="wm-trust-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                </div>
                <div class="wm-trust-text">
                  <strong>BLIK · PayU</strong>
                  <small>Płatność</small>
                </div>
              </div>
              <div class="wm-trust">
                <div class="wm-trust-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="1"/><line x1="9" y1="4" x2="9" y2="20"/><line x1="15" y1="4" x2="15" y2="20"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>
                </div>
                <div class="wm-trust-text">
                  <strong>InPost</strong>
                  <small>Wysyłka 24h</small>
                </div>
              </div>
              <div class="wm-trust">
                <div class="wm-trust-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
                </div>
                <div class="wm-trust-text">
                  <strong>30 dni</strong>
                  <small>Zwrotu</small>
                </div>
              </div>
              <div class="wm-trust">
                <div class="wm-trust-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 4v6c0 4.5-3.5 7-8 8-4.5-1-8-3.5-8-8V7l8-4z"/></svg>
                </div>
                <div class="wm-trust-text">
                  <strong>Polski sklep</strong>
                  <small>Wysyłka z PL</small>
                </div>
              </div>
            </div>

            <!-- Accordions -->
            <div class="wm-accordions">
              <details class="wm-acc" name="wm-acc">
                <summary>
                  <span class="wm-acc-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  </span>
                  <span class="wm-acc-title">Opis produktu</span>
                  <span class="wm-acc-chevron" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </summary>
                <div class="wm-acc-body">
                  <p>Chłodząca chusta dla psa na upalne dni. Zmoczysz ją wodą, wykręcisz nadmiar i zawiążesz psu na szyi. Woda paruje, a parowanie zabiera ciepło z ciała — chusta daje psu ulgę tak długo, jak długo z niej paruje.</p>
                  <ul class="wm-acc-list">
                    <li><strong>Materiał:</strong> poliester, który chłonie wodę i powoli ją oddaje</li>
                    <li><strong>Wiązanie:</strong> regulowane, pasuje na małego i większego psa</li>
                    <li><strong>Kolory:</strong> zielony lub czarny — obie chłodzą tak samo</li>
                    <li><strong>Dla kogo:</strong> psy z krótkim pyskiem, seniory, psy z gęstym futrem i te dużo na dworze</li>
                  </ul>
                </div>
              </details>

              <details class="wm-acc" name="wm-acc">
                <summary>
                  <span class="wm-acc-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 4v6c0 4.5-3.5 7-8 8-4.5-1-8-3.5-8-8V7l8-4z"/></svg>
                  </span>
                  <span class="wm-acc-title">Materiał i bezpieczeństwo</span>
                  <span class="wm-acc-chevron" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </span>
                </summary>
                <div class="wm-acc-body">
                  <p>Chusta daje psu chłód przez wilgoć i parowanie — nic w nią nie dodajemy. Zakładasz ją tak, by leżała wygodnie i nie uciskała szyi.</p>
                  <ul class="wm-acc-list">
