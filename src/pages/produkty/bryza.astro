  {/* Intercept ATC forms — async cart API + open drawer (utwardzony wzorzec [slug].astro).
      UWAGA: #wm-atc-form (moduł zestawów) ma WŁASNĄ obsługę niżej (multi-kolor + kupon),
      więc tutaj go pomijamy. Tutaj zostają tylko proste formularze POST (np. sekcja bundle .bc-form). */}
  <script>
    function initAddToCartForms() {
      const forms = document.querySelectorAll('form[method="POST"]');
      forms.forEach((node) => {
        const form = node as HTMLFormElement;
        if (form.id === 'wm-atc-form') return; // obsługiwany osobno
        if ((form as any).__atcBound) return;
        (form as any).__atcBound = true;
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const formData = new FormData(form);
          const variantId = formData.get('variantId') as string;
          const quantity = parseInt(formData.get('quantity') as string || '1', 10);

          if (!variantId) return;

          let originalText = '';
          if (btn) {
            btn.disabled = true;
            originalText = btn.textContent || '';
            btn.textContent = 'Dodawanie...';
          }

          try {
            const res = await fetch('/api/cart', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ variantId, quantity }),
            });

            if (res.ok) {
              const data = await res.json();
              window.dispatchEvent(new CustomEvent('cart-updated', { detail: data.order }));
            } else {
              alert('Nie udało się dodać do koszyka. Spróbuj ponownie.');
            }
          } catch {
            alert('Nie udało się dodać do koszyka. Sprawdź połączenie i spróbuj ponownie.');
          } finally {
            if (btn) {
              btn.disabled = false;
              btn.textContent = originalText;
            }
          }
        });
      });
    }
    initAddToCartForms();
    document.addEventListener('astro:page-load', initAddToCartForms);
  </script>

  {/* MODUŁ ZESTAWÓW — wybór zestawu, selektory koloru per sztuka, ATC multi-kolor + kupon */}
  <script>
    function initBryzaBundles() {
      const form = document.getElementById('wm-atc-form') as HTMLFormElement | null;
      if (!form || (form as any).__bundleBound) return;
      (form as any).__bundleBound = true;

      const GREEN_ID = form.getAttribute('data-variant-green') || '68';
      const BLACK_ID = form.getAttribute('data-variant-black') || '69';

      const cards = Array.from(document.querySelectorAll('#wm-bundle-list .wm-bundle-card')) as HTMLElement[];
      const picker = document.getElementById('wm-color-picker') as HTMLElement | null;
      const atcPrice = document.getElementById('wm-atc-price');
      const heroPrice = document.getElementById('wm-price');
      const heroPriceOld = document.querySelector('.wm-price-old') as HTMLElement | null;
      const heroPriceSave = document.querySelector('.wm-price-save') as HTMLElement | null;
      const atcBtn = document.getElementById('primary-atc-btn') as HTMLButtonElement | null;

      // ============================================================
      // STAN KOLORÓW — liczniki auto-balansujące.
      // green + black ZAWSZE = liczba sztuk wybranego zestawu (totalUnits).
      // Dla single (totalUnits=1) używamy toggle: green=1/black=0 lub odwrotnie.
      // Wszystkie helpery zadeklarowane PRZED użyciem (zero forward-reference / TDZ).
      // ============================================================
      let green = 1;        // domyślnie wszystkie sztuki zielone
      let black = 0;
      let totalUnits = 1;   // ustawiane przy wyborze zestawu

      function activeCard(): HTMLElement | undefined {
        return cards.find((c) => c.classList.contains('active')) || cards[0];
      }

      // Render liczników (zestaw) lub toggle (single) na podstawie aktualnego stanu green/black.
      function renderColorPicker() {
        if (!picker) return;
        picker.innerHTML = '';

        if (totalUnits <= 1) {
          // POJEDYNCZY — prosty przełącznik dwóch przycisków (bez licznika)
          const head = document.createElement('div');
          head.className = 'wm-color-head';
          head.innerHTML = '<span>Wybierz kolor</span>';
          picker.appendChild(head);

          const toggle = document.createElement('div');
          toggle.className = 'wm-color-toggle';
          const greenSel = green >= 1;
          toggle.innerHTML =
            '<button type="button" class="wm-color-toggle-btn' + (greenSel ? ' active' : '') + '" data-color="green">' +
            '<span class="wm-color-dot wm-color-dot--green"></span><span>Zielony</span></button>' +
            '<button type="button" class="wm-color-toggle-btn' + (!greenSel ? ' active' : '') + '" data-color="black">' +
            '<span class="wm-color-dot wm-color-dot--black"></span><span>Czarny</span></button>';
          picker.appendChild(toggle);

          toggle.querySelectorAll('.wm-color-toggle-btn').forEach((btn) => {
            btn.addEventListener('click', () => {
              const color = btn.getAttribute('data-color') || 'green';
              green = color === 'green' ? 1 : 0;
              black = color === 'black' ? 1 : 0;
              renderColorPicker();
            });
          });
          return;
        }

        // ZESTAW (3 lub 5 szt) — dwa wiersze liczników z auto-balansem
        const head = document.createElement('div');
        head.className = 'wm-color-head';
        head.innerHTML =
          '<span>Wybierz kolory</span>' +
          '<span class="wm-color-count">razem ' + totalUnits + ' szt</span>';
        picker.appendChild(head);

        picker.appendChild(counterRow('green', 'Zielony', green));
        picker.appendChild(counterRow('black', 'Czarny', black));
      }

      // Pojedynczy wiersz licznika: kropka koloru + etykieta + [−] liczba [+]
      function counterRow(color: string, label: string, value: number): HTMLElement {
        const row = document.createElement('div');
        row.className = 'wm-counter-row';
        row.innerHTML =
          '<span class="wm-counter-label"><span class="wm-color-dot wm-color-dot--' + color + '"></span>' + label + '</span>' +
          '<div class="wm-counter-controls">' +
          '<button type="button" class="wm-counter-btn" data-action="dec" data-color="' + color + '" aria-label="Mniej ' + label.toLowerCase() + '">−</button>' +
          '<span class="wm-counter-value" aria-live="polite">' + value + '</span>' +
          '<button type="button" class="wm-counter-btn" data-action="inc" data-color="' + color + '" aria-label="Więcej ' + label.toLowerCase() + '">+</button>' +
          '</div>';

        row.querySelectorAll('.wm-counter-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const action = btn.getAttribute('data-action');
            const c = btn.getAttribute('data-color');
            adjustColor(c === 'black' ? 'black' : 'green', action === 'inc' ? 1 : -1);
          });
        });
        return row;
      }

      // Auto-balans: zmiana jednego koloru o delta, drugi dopełnia tak, by suma = totalUnits.
      // Granice 0..totalUnits. Suma ZAWSZE poprawna — brak stanu błędu.
      function adjustColor(color: 'green' | 'black', delta: number) {
        if (color === 'green') {
          green = Math.max(0, Math.min(totalUnits, green + delta));
          black = totalUnits - green;
        } else {
          black = Math.max(0, Math.min(totalUnits, black + delta));
          green = totalUnits - black;
        }
        renderColorPicker();
      }

      function selectBundle(card: HTMLElement) {
        cards.forEach((c) => c.classList.remove('active'));
        card.classList.add('active');
        const radio = card.querySelector('input[type="radio"]') as HTMLInputElement | null;
        if (radio) radio.checked = true;

        const units = parseInt(card.getAttribute('data-units') || '1', 10);
        const priceLabel = card.querySelector('.wm-bundle-price')?.textContent || '';
        const oldLabel = card.querySelector('.wm-bundle-old')?.textContent || '';
        const saveLabel = card.querySelector('.wm-bundle-save')?.textContent || '';

        if (atcPrice) atcPrice.textContent = priceLabel;
        if (heroPrice) heroPrice.textContent = priceLabel;
        if (heroPriceOld) heroPriceOld.textContent = oldLabel;
        if (heroPriceSave) heroPriceSave.textContent = saveLabel;

        // Zmiana zestawu resetuje liczniki do domyślnych: wszystkie zielone, czarny 0.
        totalUnits = units;
        green = units;
        black = 0;
        renderColorPicker();

        // Powiadom StickyATCBar (zachowanie kompatybilności): qty = liczba sztuk zestawu, cena = etykieta zestawu
        window.dispatchEvent(new CustomEvent('wm-bundle-change', {
          detail: { variantId: GREEN_ID, qty: units, priceText: priceLabel }
        }));
      }

      cards.forEach((card) => {
        card.addEventListener('click', (e) => {
          // Klik na całą kartę = wybór zestawu. Liczniki koloru są poza kartą,
          // więc ich kliknięcia nie przełączają zestawu.
          e.preventDefault();
          selectBundle(card);
        });
      });

      // Init na karcie domyślnie aktywnej (2+1)
      selectBundle(activeCard()!);

      // ATC: użyj stanu green/black → POST /api/cart per kolor → kupon → drawer
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const card = activeCard();
        if (!card) return;
        const coupon = card.getAttribute('data-coupon') || '';

        const adds: Array<{ variantId: string; quantity: number }> = [];
        if (green > 0) adds.push({ variantId: GREEN_ID, quantity: green });
        if (black > 0) adds.push({ variantId: BLACK_ID, quantity: black });
        if (adds.length === 0) return;

        let originalText = '';
        if (atcBtn) {
          atcBtn.disabled = true;
          originalText = atcBtn.innerHTML;
          atcBtn.textContent = 'Dodawanie...';
        }

        try {
          let lastOrder: any = null;
          // Dodaj pozycje sekwencyjnie (token sesji utrzymywany przez cookie, serwer serializuje)
          for (const item of adds) {
            const res = await fetch('/api/cart', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify(item),
            });
            if (!res.ok) throw new Error('add failed');
            const data = await res.json();
            if (data.error) throw new Error(data.error);
            lastOrder = data.order;
          }

          // Zastosuj kupon zestawu (jeśli dotyczy)
          if (coupon) {
            const cres = await fetch('/api/cart/coupon', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ couponCode: coupon }),
            });
            if (cres.ok) {
              const cdata = await cres.json();
              if (cdata.order) lastOrder = cdata.order;
            }
            // Brak kuponu nie blokuje — pozycje już w koszyku, drawer i tak się otworzy
          }

          window.dispatchEvent(new CustomEvent('cart-updated', { detail: lastOrder }));
        } catch {
          alert('Nie udało się dodać do koszyka. Spróbuj ponownie.');
        } finally {
          if (atcBtn) {
            atcBtn.disabled = false;
            atcBtn.innerHTML = originalText;
          }
        }
      });
    }
    initBryzaBundles();
    document.addEventListener('astro:page-load', initBryzaBundles);
  </script>

  {/* Scroll reveal for handoff sections */}
  <script>
    (function() {
      const items = document.querySelectorAll('.wm-pdp .reveal');
      if (!items.length) return;
      if (!('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('in'));
        return;
      }
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
      items.forEach((el) => io.observe(el));
    })();
  </script>

  {/* Hero interactivity: gallery thumbs/dots (wybór koloru/zestawu obsługuje moduł zestawów) */}
  <script>
    (function() {
      // ---- Gallery (thumbs + arrows + swipe + counter) ----
      const thumbs = document.querySelectorAll('.wm-thumb');
      const images = document.querySelectorAll('.wm-gallery-img');
      const counter = document.getElementById('wm-counter-current');
      const arrowPrev = document.getElementById('wm-arrow-prev');
      const arrowNext = document.getElementById('wm-arrow-next');
      const total = images.length;
      let currentIdx = 0;

      const thumbsContainer = document.querySelector('.wm-gallery-thumbs');

      function activate(idx) {
        currentIdx = (idx + total) % total;
        thumbs.forEach((t) => t.classList.toggle('active', t.getAttribute('data-target') === String(currentIdx)));
        images.forEach((img) => img.classList.toggle('active', img.getAttribute('data-idx') === String(currentIdx)));
        if (counter) counter.textContent = String(currentIdx + 1);

        if (thumbsContainer && thumbsContainer.scrollWidth > thumbsContainer.clientWidth) {
          const activeThumb = thumbsContainer.querySelector('.wm-thumb.active');
          if (activeThumb) {
            const target = activeThumb.offsetLeft - (thumbsContainer.clientWidth / 2) + (activeThumb.clientWidth / 2);
            thumbsContainer.scrollTo({ left: target, behavior: 'smooth' });
          }
        }
      }

      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          activate(parseInt(thumb.getAttribute('data-target') || '0', 10));
        });
      });

      if (arrowPrev) arrowPrev.addEventListener('click', () => activate(currentIdx - 1));
      if (arrowNext) arrowNext.addEventListener('click', () => activate(currentIdx + 1));

      // ---- Touch swipe (mobile) ----
      const main = document.getElementById('wm-gallery-main');
      if (main) {
        let touchStartX = 0;
        let touchEndX = 0;

        main.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        main.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          const diff = touchStartX - touchEndX;
          if (Math.abs(diff) < 40) return;
          if (diff > 0) activate(currentIdx + 1);
          else activate(currentIdx - 1);
        }, { passive: true });
      }

      // ---- Keyboard arrows (desktop a11y) ----
      document.addEventListener('keydown', (e) => {
        if (!main) return;
        const rect = main.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > window.innerHeight) return;
        if (e.key === 'ArrowLeft') activate(currentIdx - 1);
        else if (e.key === 'ArrowRight') activate(currentIdx + 1);
      });
    })();
  </script>

  {/* Mobile carousel dots — auto-attach to .wm-carousel-mobile */}
  <script>
    (function() {
      if (window.matchMedia('(min-width: 681px)').matches) return;

      const carousels = document.querySelectorAll('[data-carousel]');
      carousels.forEach((carousel) => {
        const items = carousel.children;
        const total = items.length;
        if (total < 2) return;

        const dots = document.createElement('div');
        dots.className = 'wm-carousel-dots';
        for (let i = 0; i < total; i++) {
          const dot = document.createElement('span');
          if (i === 0) dot.classList.add('active');
          dots.appendChild(dot);
        }
        carousel.parentNode?.insertBefore(dots, carousel.nextSibling);

        carousel.addEventListener('scroll', () => {
          const scrollLeft = carousel.scrollLeft;
          const itemWidth = items[0]?.getBoundingClientRect().width || 1;
          const idx = Math.round(scrollLeft / (itemWidth + 14));
          dots.querySelectorAll('span').forEach((d, i) => {
            d.classList.toggle('active', i === idx);
          });
        }, { passive: true });
      });
    })();
  </script>
</BaseLayout>
