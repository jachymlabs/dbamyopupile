---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Price from '@/components/Price.astro';
import StickyATCBar from '@/components/StickyATCBar';
import FormiDescription from '@/components/pdp/FormiDescription.astro';
import NeuroCubeDescription from '@/components/pdp/NeuroCubeDescription.astro';
import SnapStonesDescription from '@/components/pdp/SnapStonesDescription.astro';
import ClickyDescription from '@/components/pdp/ClickyDescription.astro';
import LoomoDescription from '@/components/pdp/LoomoDescription.astro';
import FlickoDescription from '@/components/pdp/FlickoDescription.astro';
import FasolkaDescription from '@/components/pdp/FasolkaDescription.astro';
import PingwinDescription from '@/components/pdp/PingwinDescription.astro';
import WibbloDescription from '@/components/pdp/WibbloDescription.astro';
import GorlyDescription from '@/components/pdp/GorlyDescription.astro';
import CrockyDescription from '@/components/pdp/CrockyDescription.astro';
import MoodlesKidsDescription from '@/components/pdp/MoodlesKidsDescription.astro';
import BryzaDescription from '@/components/pdp/BryzaDescription.astro';
import PostATCBlock from '@/components/pdp/PostATCBlock.astro';
import AllReviewsSection from '@/components/pdp/AllReviewsSection.astro';
import { shopApi, shopApiRaw, redirectWithToken } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { ADD_TO_CART } from '@/lib/mutations';
import { sanitizeHtml } from '@/lib/sanitize';
import { buildAssetUrl } from '@/lib/utils';
import type { VendureProduct, VendureVariant, VendureAsset, VendureCollection } from '@/types/vendure';
import { sendCAPIEvent, buildUserData, generateEventId } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';
import { assertSameOrigin } from '@/lib/security';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { computeSale, getVariantRegularPrice } from '@/lib/prices';

const storeConfig = await getStoreConfig(Astro.request);
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

// Handle POST — add to cart
if (Astro.request.method === 'POST') {
  const blocked = assertSameOrigin(Astro.request);
  if (blocked) return blocked;
  try {
    const formData = await Astro.request.formData();
    const variantId = formData.get('variantId') as string;
    const rawQty = parseInt(formData.get('quantity') as string || '1', 10);
    const quantity = Math.max(1, Math.min(99, isNaN(rawQty) ? 1 : rawQty));

    if (variantId) {
      const result = await shopApiRaw<any>(ADD_TO_CART, { variantId, quantity }, Astro.request);

      // CAPI: AddToCart event
      const userData = await buildUserData(Astro.request);
      await sendCAPIEvent({
        event_name: 'AddToCart',
        event_time: Math.floor(Date.now() / 1000),
        event_id: generateEventId(),
        event_source_url: Astro.url.href,
        action_source: 'website',
        user_data: userData,
        custom_data: {
          content_ids: [variantId],
          content_type: 'product',
          currency: 'PLN',
        },
      }, storeConfig.metaDatasetId);

      return redirectWithToken('/koszyk', result.authToken);
    }
    return Astro.redirect('/koszyk');
  } catch {
    // Fall through to render page with error state if needed
  }
}

let product: VendureProduct | null = null;
let error: string | null = null;

try {
  const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug }, Astro.request);
  product = data.product;
} catch (e: any) {
  error = 'Nie udalo sie zaladowac produktu. Sprobuj ponownie.';
}

if (!product && !error) {
  return Astro.rewrite('/404');
}

// CAPI: ViewContent (server-side)
// viewContentEventId is shared with browser pixel for deduplication (defined below, used in both)
const viewContentEventId = generateEventId();
if (product) {
  const vcUserData = await buildUserData(Astro.request);
  const vcFirstVariant = product.variants?.[0];
  sendCAPIEvent({
    event_name: 'ViewContent',
    event_time: Math.floor(Date.now() / 1000),
    event_id: viewContentEventId,
    event_source_url: Astro.url.href,
    action_source: 'website',
    user_data: vcUserData,
    custom_data: {
      content_ids: [vcFirstVariant?.sku || product.id],
      content_name: product.name,
      content_type: 'product',
      value: vcFirstVariant ? vcFirstVariant.priceWithTax / 100 : 0,
      currency: 'PLN',
    },
  }, storeConfig.metaDatasetId);
}

// Find parent collection for breadcrumbs
const parentCollection = product?.collections?.find((c: VendureCollection) => c.parent?.id === '1');

// Per-product reviews — z src/data/reviews.json. Null jeśli brak danych dla tego sluga.
const productReviews = slug ? getProductReviews(slug) : null;
const ratingPct = productReviews ? ratingPercentages(productReviews) : null;

// Main image — featuredAsset or first asset
const mainImage = product?.featuredAsset || product?.assets?.[0];

// SEO: Strip HTML tags from description, max 160 chars
function stripHtml(html: string): string {
  return html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
}

const rawDescription = product?.customFields?.shortDescription || product?.description || '';
const metaDescription = stripHtml(rawDescription).slice(0, 160);
const ogImageUrl = mainImage?.preview ? buildAssetUrl(mainImage.preview, 'large') : undefined;

// Stock status
const allOutOfStock = (product?.variants?.length ?? 0) > 0
  && product!.variants.every((v: VendureVariant) => v.stockLevel === 'OUT_OF_STOCK');

// JSON-LD: Product structured data
const lowestPrice = product?.variants?.length
  ? Math.min(...product.variants.map((v: VendureVariant) => v.priceWithTax))
  : 0;

const availability = allOutOfStock
  ? 'https://schema.org/OutOfStock'
  : 'https://schema.org/InStock';

const jsonLd = product ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: metaDescription,
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  sku: product.variants?.[0]?.sku || undefined,
  offers: {
    '@type': 'Offer',
    price: (lowestPrice / 100).toFixed(2),
    // TODO: Use product.variants[0].currencyCode when added to GET_PRODUCT_DETAIL query
    priceCurrency: 'PLN',
    availability,
    url: Astro.url.href,
  },
} : null;

// Stock count logic
const firstVariantStock = product?.variants?.[0]?.stockLevel;
const stockNum = parseInt(firstVariantStock || '', 10);
// Stock guards: wymagaj stockNum > 0 żeby nie pokazywać "ostatnie 0 szt"
// gdy Vendure zwraca stockLevel='0' jako string (kasuje legacy bug).
const showStockCritical = !isNaN(stockNum) && stockNum > 0 && stockNum <= 2;
const showStockLow = !isNaN(stockNum) && stockNum > 2 && stockNum <= 5;

// Omnibus: najnizsza cena z 30 dni
// Coerce do liczb żeby uniknąć "0" gdy customField wraca jako string albo null
const lowestPrice30dNum = Number(product?.variants?.[0]?.customFields?.lowestPrice30d ?? 0);
const firstVariantPriceNum = Number(product?.variants?.[0]?.priceWithTax ?? 0);

// JSX gotcha: `{0 && ...}` renderuje literalnie "0". Wrap'ujemy w Boolean() żeby zwracać czysty true/false.
const showOmnibus: boolean = lowestPrice30dNum > 0 && firstVariantPriceNum > 0 && firstVariantPriceNum < lowestPrice30dNum;
const omnibusFormatted = showOmnibus
  ? new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(lowestPrice30dNum / 100)
  : '';

// Sale info — z src/data/prices.json (per slug). Frontend-only, brak ruszania Vendure.
// Używamy MIN ceny ze wszystkich wariantów (variants[0] może być droższym maxi/zestawem).
const variantPrices = product?.variants?.map((v: VendureVariant) => Number(v.priceWithTax)) ?? [];
const minVariantPrice = variantPrices.length ? Math.min(...variantPrices) : firstVariantPriceNum;
const maxVariantPrice = variantPrices.length ? Math.max(...variantPrices) : firstVariantPriceNum;
const hasVariantRange = minVariantPrice !== maxVariantPrice;
const saleInfo = slug && minVariantPrice > 0 ? computeSale(slug, minVariantPrice) : null;
const showSale = !!saleInfo;
const regularPriceFormatted = saleInfo?.regularFormatted ?? '';
const salePercent = saleInfo?.discountPercent ?? 0;
const saleSavingsFormatted = saleInfo?.savingsFormatted ?? '';

// Per-variant regular prices map (variantId → regularPrice grosze).
// Używana przez client-side JS przy zmianie wariantu — jeśli wariant ma
// override w prices.json, używamy go zamiast skalowania przez data-sale-ratio.
const variantRegulars: Record<string, number> = {};
if (slug && product?.variants) {
  for (const v of product.variants as any[]) {
    const reg = getVariantRegularPrice(slug, v.name);
    if (reg) variantRegulars[v.id] = reg;
  }
}

// "Najniższa cena z 30 dni" (dyrektywa Omnibus) — zawsze pokazywana pod ceną.
// Fallback do current min variant price (stabilne ceny = current price IS lowest 30d).
const lowest30dInitial = minVariantPrice > 0
  ? new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(minVariantPrice / 100)
  : '';

// ViewContent event data for browser pixel (viewContentEventId generated above for dedup)
const firstVariant = product?.variants?.[0];

// Savings calculation — relative do lowestPrice30d (Omnibus, dla compliance)
const savings = showOmnibus ? lowestPrice30dNum - firstVariantPriceNum : 0;
const savingsFormatted = savings > 0
  ? new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(savings / 100)
  : '';
const discountPercent = showOmnibus
  ? Math.round(((lowestPrice30dNum - firstVariantPriceNum) / lowestPrice30dNum) * 100)
  : 0;
const oldPriceFormatted = showOmnibus
  ? new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(lowestPrice30dNum / 100)
  : '';

// Backward-compat aliases (używane w innych miejscach komponentu — JSON-LD, omnibusFormatted reference)
const lowestPrice30d = lowestPrice30dNum > 0 ? lowestPrice30dNum : undefined;
const firstVariantPrice = firstVariantPriceNum > 0 ? firstVariantPriceNum : undefined;

// ============================================================
// Stitch variant selector — option groups → swatches/pills.
// Vendure variant = combination of options across optionGroups.
// We render each optionGroup as its own row (color swatches OR
// size pills), then JS finds matching variant on selection change.
// ============================================================
const optionGroups: any[] = (product as any)?.optionGroups ?? [];
const hasMultipleVariants = (product?.variants?.length ?? 0) > 1;
const useOptionGroups = hasMultipleVariants && optionGroups.length > 0;

// Map option NAME / CODE → hex color for color swatches (heuristic).
function nameToColor(name: string): string | null {
  const n = (name || '').toLowerCase();
  if (n.includes('truskaw') || n.includes('strawberry') || n.includes('różow') || n.includes('pink')) return '#E63946';
  if (n.includes('leśn') || n.includes('forest') || n.includes('zielon') || n.includes('green')) return '#6E8B5A';
  if (n.includes('lawend') || n.includes('lavender') || n.includes('fiolet') || n.includes('purple')) return '#A78BCC';
  if (n.includes('sage') || n.includes('szałwi')) return '#7497BF';
  if (n.includes('niebies') || n.includes('blue')) return '#5BA4DD';
  if (n.includes('żółt') || n.includes('yellow')) return '#F4C95D';
  if (n.includes('pomarań') || n.includes('orange')) return '#F08A45';
  if (n.includes('czarn') || n.includes('black')) return '#2A2D27';
  if (n.includes('biał') || n.includes('white')) return '#FFFCF7';
  if (n.includes('szary') || n.includes('gray') || n.includes('grey')) return '#8A8E84';
  if (n.includes('brąz') || n.includes('brown')) return '#7C5B3A';
  if (n.includes('miętow') || n.includes('mint')) return '#A7D7C5';
  return null;
}

// Heuristic — czy to grupa kolorów? (po nazwie albo po wartościach options)
function isColorGroup(group: any): boolean {
  const groupName = (group.name || group.code || '').toLowerCase();
  if (/(kolor|color|colour|wariant kolor)/i.test(groupName)) return true;
  // Jeśli wszystkie nazwy opcji da się zmapować na kolor → traktuj jak kolor.
  if (group.options?.length && group.options.every((o: any) => nameToColor(o.name) !== null)) return true;
  return false;
}

// Default selected options — per-group heuristic.
//  * Color group → NO default (user wybiera). Bez tego nie da się ATC.
//  * Size group → preferuj opcję zawierającą "mini" (case-insensitive).
//  * Set/zestaw group → preferuj opcję zawierającą "4" (4 sztuki).
//  * Inne grupy → pierwsza opcja.
// Jeśli żadna heurystyka nie pasuje i grupa NIE jest color → fallback pierwsza opcja.
function findDefaultOption(group: any): any | null {
  if (isColorGroup(group)) return null;
  const groupName = (group.name || group.code || '').toLowerCase();
  const opts = group.options ?? [];
  if (!opts.length) return null;

  if (/rozm|size/.test(groupName)) {
    return opts.find((o: any) => /\bmini\b/i.test(o.name || '')) || opts[0];
  }
  if (/zestaw|set|opakowanie|pakiet/.test(groupName)) {
    return opts.find((o: any) => /\b4\b/.test(o.name || '')) || opts[0];
  }
  return opts[0];
}

const defaultSelectedOptionIds: string[] = optionGroups
  .map((g: any) => findDefaultOption(g)?.id)
  .filter(Boolean) as string[];

const firstAvailableVariant =
  product?.variants?.find((v: any) => v.stockLevel !== 'OUT_OF_STOCK') ||
  product?.variants?.[0];

// Lookup table: stringify sorted optionIds → variant info (id, price, stock, image URL).
// Used by client JS to swap main image, ATC color, label, and price on option change.
const variantLookup: Record<string, { id: string; price: number; stock: string; image: string | null; lowestPrice30d: number }> = {};
(product?.variants ?? []).forEach((v: any) => {
  const key = (v.options || []).map((o: any) => o.id).sort().join('|');
  const previewSrc = v.featuredAsset?.preview;
  variantLookup[key] = {
    id: v.id,
    price: v.priceWithTax,
    stock: v.stockLevel,
    image: previewSrc ? buildAssetUrl(previewSrc, 'large') : null,
    lowestPrice30d: Number(v.customFields?.lowestPrice30d ?? 0),
  };
});

// Per-option stock: optionId -> czy ISTNIEJE choc jeden in-stock wariant z ta opcja.
// Opcja bez zadnego in-stock wariantu = wyprzedana (SSR baseline; JS dopina cross-group).
const optionHasStock: Record<string, boolean> = {};
(product?.variants ?? []).forEach((v: any) => {
  const inStock = v.stockLevel !== 'OUT_OF_STOCK';
  (v.options || []).forEach((o: any) => {
    if (inStock) optionHasStock[o.id] = true;
    else if (!(o.id in optionHasStock)) optionHasStock[o.id] = false;
  });
});
const isOptionOos = (id: string): boolean => optionHasStock[id] !== true;
---

<BaseLayout
  title={product?.name || 'Produkt'}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogType="product"
>
  <div class="pdp-page">
    {product ? (
      <>
        {/* Breadcrumbs — Sklep / [short name]. Krótka nazwa = przed pierwszym " - "
            albo " – " (np. "Moodles" z "Moodles - wyciszające kulki..."). */}
        <div class="pdp-breadcrumbs-wrap">
          <Breadcrumbs items={[
            { label: 'Sklep', href: '/sklep' },
            { label: product.name.split(/\s+[-–]\s+/)[0].trim() },
          ]} />
        </div>

        {/* ==================================================
           1. HERO — gallery + info (sticky desktop)
           ================================================== */}
        <section class="pdp-hero">
          {/* LEFT: Gallery */}
          <div class="pdp-gallery">
            <div class="pdp-main-image">
              {mainImage ? (
                <img
                  id="pdp-main-img"
                  src={buildAssetUrl(mainImage.preview, 'large')}
                  alt={product.name}
                  width="800"
                  height="800"
                  fetchpriority="high"
                  loading="eager"
                />
              ) : (
                <div class="pdp-image-placeholder">
                  <span class="material-symbols-outlined">image</span>
                </div>
              )}

              {/* Gallery arrows — prev/next, widoczne tylko gdy >1 zdjęcie */}
              {(product.assets?.length ?? 0) > 1 && (
                <>
                  <button
                    type="button"
                    id="pdp-gallery-prev"
                    class="pdp-gallery-arrow pdp-gallery-arrow--prev"
                    aria-label="Poprzednie zdjęcie"
                  >
                    <svg class="pdp-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
                  </button>
                  <button
                    type="button"
                    id="pdp-gallery-next"
                    class="pdp-gallery-arrow pdp-gallery-arrow--next"
                    aria-label="Następne zdjęcie"
                  >
                    <svg class="pdp-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                  </button>
                </>
              )}
            </div>

            {/* Thumbnails — horizontalna lista z arrows do scrollowania */}
            {(product.assets?.length ?? 0) > 1 && (
              <div class="pdp-thumb-strip">
                <button
                  type="button"
                  id="pdp-thumbs-prev"
                  class="pdp-thumb-arrow pdp-thumb-arrow--prev"
                  aria-label="Przewiń galerię w lewo"
                >
                  <svg class="pdp-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <div class="pdp-thumbnails" id="pdp-thumbnails">
                  {product.assets.slice(0, 20).map((asset: VendureAsset, i: number) => (
                    <button
                      type="button"
                      class:list={['pdp-thumb', i === 0 && 'pdp-thumb--active']}
                      data-thumb-index={i}
                      data-full-src={buildAssetUrl(asset.preview, 'large')}
                    >
                      <img
                        src={buildAssetUrl(asset.preview, 'small')}
                        alt={`${product.name} ${i + 1}`}
                        width="150"
                        height="150"
                        loading="lazy"
                      />
                    </button>
                  ))}
                </div>
                <button
                  type="button"
                  id="pdp-thumbs-next"
                  class="pdp-thumb-arrow pdp-thumb-arrow--next"
                  aria-label="Przewiń galerię w prawo"
                >
                  <svg class="pdp-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                </button>
              </div>
            )}
          </div>

          {/* RIGHT: Product info */}
          <div class="pdp-info">

            {/* FOMO bar PRZED nazwą — pulsujący dot + scarcity */}
            <div class="pdp-fomo-strip">
              <span class="pdp-fomo-dot"></span>
              <span class="pdp-fomo-strip-text">
                {showStockCritical
                  ? <>Ostatnie <strong>{stockNum} szt</strong> w tym wariancie</>
                  : showStockLow
                    ? <>Zostało <strong>{stockNum} szt</strong> · ostatnia dostawa za 7 dni</>
                    : <>Ostatnie sztuki <strong>na magazynie</strong></>
                }
              </span>
            </div>

            {/* Top chips row — bestseller usunięty */}
            {((showOmnibus && discountPercent > 0) || allOutOfStock) && (
              <div class="pdp-chips">
                {showOmnibus && discountPercent > 0 && (
                  <span class="pdp-chip pdp-chip--sale">-{discountPercent}%</span>
                )}
                {allOutOfStock && (
                  <span class="pdp-chip pdp-chip--oos">Niedostępny</span>
                )}
              </div>
            )}

            {/* Product name */}
            <h1 class="pdp-h1">{product.name}</h1>

            {/* Rating — clickable, scroll do reviews. Pokazuje się tylko gdy produkt ma opinie. */}
            {productReviews && (
              <a href="#reviews-section" class="pdp-rating-row">
                <div class="pdp-stars">
                  {[1, 2, 3, 4, 5].map((i) => {
                    const k = starKind(i, productReviews.averageRating);
                    if (k === 'full') return (
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/>
                      </svg>
                    );
                    if (k === 'half') return (
                      <svg viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <defs>
                          <linearGradient id={`half-${i}`}>
                            <stop offset="50%" stop-color="#F5B544"/>
                            <stop offset="50%" stop-color="#D6CEBE"/>
                          </linearGradient>
                        </defs>
                        <path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#half-${i})`}/>
                      </svg>
                    );
                    return (
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/>
                      </svg>
                    );
                  })}
                </div>
                <span class="pdp-rating-num">{formatRating(productReviews.averageRating)}</span>
                <span class="pdp-rating-count">Z {productReviews.totalCount} {opiniiPlural(productReviews.totalCount)}</span>
                <span class="material-symbols-outlined pdp-rating-arrow">arrow_forward</span>
              </a>
            )}

            {/* Price block — flat, bez kafelka. Strikethrough = regularPrice (z prices.json).
                Wariantowe produkty (hasVariantRange) → prefix "od" przy obu cenach.
                data-sale-ratio = regularPrice / currentPrice — używane przez JS do dynamicznego
                przeliczania ceny regularnej po zmianie wariantu (zachowuje % zniżki).
                Dla Moodles ukryte — bundle pokazuje ceny per tier i per zestaw. */}
            <div
              class="pdp-price-block"
              data-sale-ratio={saleInfo ? (saleInfo.regularPrice / saleInfo.currentPrice).toFixed(4) : ''}
              data-variant-regulars={JSON.stringify(variantRegulars)}
              data-has-variant-range={hasVariantRange ? '1' : '0'}
            >
              <div class="pdp-price-row">
                {showSale && regularPriceFormatted && (
                  <span class="pdp-price-regular">
                    {regularPriceFormatted}
                  </span>
                )}
                {product.variants.length === 1 ? (
                  <Price price={product.variants[0].priceWithTax} class={`pdp-price${showSale ? ' pdp-price--sale' : ''}${allOutOfStock ? ' pdp-price--oos' : ''}`} />
                ) : (
                  <Price
                    priceRange={{
                      __typename: 'PriceRange',
                      min: minVariantPrice,
                      max: maxVariantPrice,
                    }}
                    class={`pdp-price${showSale ? ' pdp-price--sale' : ''}${allOutOfStock ? ' pdp-price--oos' : ''}`}
                  />
                )}
                {showSale && saleSavingsFormatted && (
                  <span class="pdp-sale-badge">oszczędzasz {saleSavingsFormatted}</span>
                )}
                {showOmnibus && !showSale && oldPriceFormatted && (
                  <span class="pdp-price-old">{oldPriceFormatted}</span>
                )}
              </div>
              {minVariantPrice > 0 && (
                <p class="pdp-lowest-30d">Najniższa cena z 30 dni: <span data-lowest-30d>{lowest30dInitial}</span></p>
              )}
            </div>

            {/* Short description */}
            {product.customFields?.shortDescription && (
              <div
                class="pdp-short-desc rich-text"
                set:html={sanitizeHtml(product.customFields.shortDescription)}
              />
            )}

            {/* ATC form */}
            <form
              method="POST"
              class="pdp-form"
              data-variant-lookup={JSON.stringify(variantLookup)}
            >
              {/* Variant selector — Stitch swatches + pills, grouped by optionGroup. */}
              {useOptionGroups ? (
                <>
                  {/* variantId puste gdy nie wszystkie grupy mają default (np. brak default koloru).
                      JS wypełnia po pełnym wyborze; ATC dotąd disabled z hint. */}
                  <input
                    type="hidden"
                    name="variantId"
                    id="variantId"
                    value={defaultSelectedOptionIds.length === optionGroups.length
                      ? (firstAvailableVariant?.id || product.variants[0]?.id || '')
                      : ''}
                  />
                  {optionGroups.map((group: any) => {
                    const colorGroup = isColorGroup(group);
                    const groupLabel = group.name || group.code || 'Wariant';
                    return (
                      <div class="pdp-variant-block" data-option-group={group.id}>
                        <span class="pdp-variant-label">{groupLabel}:</span>
                        {colorGroup ? (
                          <div class="pdp-swatches" role="radiogroup" aria-label={groupLabel}>
                            {group.options.map((opt: any) => {
                              const color = nameToColor(opt.name) || '#E5DFD2';
                              const selected = defaultSelectedOptionIds.includes(opt.id);
                              const isLight = color === '#FFFCF7';
                              const oos = isOptionOos(opt.id);
                              return (
                                <button
                                  type="button"
                                  class:list={['pdp-swatch-wrap', selected && 'pdp-swatch-wrap--active', oos && 'pdp-swatch-wrap--oos']}
                                  data-option-id={opt.id}
                                  data-option-group-id={group.id}
                                  data-option-name={opt.name.toLowerCase()}
                                  data-option-color={color}
                                  data-option-oos={oos ? '1' : '0'}
                                  aria-label={oos ? `${opt.name} (wyprzedane)` : opt.name}
                                  aria-pressed={selected ? 'true' : 'false'}
                                  title={oos ? `${opt.name}: chwilowo niedostepny` : undefined}
                                >
                                  <span
                                    class:list={['pdp-swatch', isLight && 'pdp-swatch--light']}
                                    style={`background:${color};`}
                                  ></span>
                                  <span class="pdp-swatch-label">{opt.name}</span>
                                </button>
                              );
                            })}
                          </div>
                        ) : (
                          <div class="pdp-pills" role="radiogroup" aria-label={groupLabel}>
                            {group.options.map((opt: any) => {
                              const selected = defaultSelectedOptionIds.includes(opt.id);
                              const oos = isOptionOos(opt.id);
                              return (
                                <button
                                  type="button"
                                  class:list={['pdp-pill', selected && 'pdp-pill--active', oos && 'pdp-pill--oos']}
                                  data-option-id={opt.id}
                                  data-option-group-id={group.id}
                                  data-option-name={opt.name.toLowerCase()}
                                  data-option-oos={oos ? '1' : '0'}
                                  aria-pressed={selected ? 'true' : 'false'}
                                  title={oos ? `${opt.name}: chwilowo niedostepny` : undefined}
                                >
                                  {opt.name}
                                </button>
                              );
                            })}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </>
              ) : product.variants.length > 1 ? (
                <div class="pdp-variant-block">
                  <span class="pdp-variant-label">Wariant:</span>
                  <div class="pdp-pills" role="radiogroup" aria-label="Wariant">
                    {product.variants.map((v: VendureVariant, i: number) => (
                      <label class:list={['pdp-pill-radio', v.stockLevel === 'OUT_OF_STOCK' && 'pdp-pill-radio--disabled']}>
                        <input
                          type="radio"
                          name="variantId"
                          value={v.id}
                          checked={i === 0}
                          disabled={v.stockLevel === 'OUT_OF_STOCK'}
                          required
                          class="sr-only"
                        />
                        <span class="pdp-pill">
                          {v.name}
                        </span>
                      </label>
                    ))}
                  </div>
                </div>
              ) : (
                <input type="hidden" name="variantId" value={product.variants[0]?.id} />
              )}

              {/* Variant selection hint — NAD qty/ATC żeby był widoczny od razu po
                  swatchach, zanim user dotrze wzrokiem do "Dodaj do koszyka". JS w
                  block 'Variant option groups' toggluje display + tekst. */}
              <p class="pdp-variant-hint" id="pdp-variant-hint" hidden>
                <svg class="pdp-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                <span data-hint-msg>Wybierz wariant aby dodać do koszyka</span>
              </p>

              {/* Bundle selector — tylko Bryza. Ustawia ilość w #quantity; cenę pakietu
                  w koszyku domyka promocja w Vendure (front pokazuje ofertę). */}
              {slug === 'bryza' && (
                <Fragment>
                <div class="pdp-bundle">
                  <span class="pdp-bundle-title">Wybierz zestaw</span>
                  <p class="pdp-bundle-omnibus" id="pdp-bundle-omnibus" aria-live="polite"></p>
                  <div class="pdp-bundle-tiers" role="radiogroup" aria-label="Wybierz zestaw">
                    <div class="pdp-bundle-tile is-selected" data-bundle-qty="1" data-omnibus="59,99 zł" role="radio" aria-checked="true" tabindex="0">
                      <div class="pdp-bundle-head">
                        <span class="pdp-bundle-radio" aria-hidden="true"></span>
                        <span class="pdp-bundle-info">
                          <span class="pdp-bundle-name">1 sztuka</span>
                          <span class="pdp-bundle-sub">Pojedyncza sztuka</span>
                        </span>
                        <span class="pdp-bundle-price">
                          <span class="pdp-bundle-price-now">59,99 zł</span>
                        </span>
                      </div>
                      <div class="pdp-bundle-tile-colors"></div>
                    </div>
                    <div class="pdp-bundle-tile pdp-bundle-tile--popular" data-bundle-qty="3" data-omnibus="99,99 zł" role="radio" aria-checked="false" tabindex="0">
                      <span class="pdp-bundle-flag">Najpopularniejszy</span>
                      <div class="pdp-bundle-head">
                        <span class="pdp-bundle-radio" aria-hidden="true"></span>
                        <span class="pdp-bundle-info">
                          <span class="pdp-bundle-name">2 + 1 gratis <em>(3 szt.)</em></span>
                          <span class="pdp-bundle-sub">
                            <span class="pdp-bundle-ship">
                              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                              Darmowa dostawa
                            </span>
                          </span>
                        </span>
                        <span class="pdp-bundle-price">
                          <span class="pdp-bundle-price-old">179,97 zł</span>
                          <span class="pdp-bundle-price-now">99,99 zł</span>
                        </span>
                      </div>
                      <div class="pdp-bundle-tile-colors"></div>
                    </div>
                    <div class="pdp-bundle-tile" data-bundle-qty="5" data-omnibus="149,99 zł" role="radio" aria-checked="false" tabindex="0">
                      <div class="pdp-bundle-head">
                        <span class="pdp-bundle-radio" aria-hidden="true"></span>
                        <span class="pdp-bundle-info">
                          <span class="pdp-bundle-name">3 + 2 gratis <em>(5 szt.)</em></span>
                          <span class="pdp-bundle-sub">
                            <span class="pdp-bundle-ship">
                              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                              Darmowa dostawa
                            </span>
                          </span>
                        </span>
                        <span class="pdp-bundle-price">
                          <span class="pdp-bundle-price-old">299,95 zł</span>
                          <span class="pdp-bundle-price-now">149,99 zł</span>
                        </span>
                      </div>
                      <div class="pdp-bundle-tile-colors"></div>
                    </div>
                  </div>
                </div>
                <script is:inline>
                  (function () {
                    function initBundle() {
                      const bundle = document.querySelector('.pdp-bundle');
                      if (!bundle) return;
                      const form = document.querySelector('form.pdp-form');
                      const qtyControl = document.querySelector('.pdp-qty-control');
                      const atcBtn = document.getElementById('primary-atc-btn');

                      // Kolory z istniejących swatchy Vendure + variantId z variantLookup.
                      let lookup = {};
                      try { lookup = JSON.parse(form.getAttribute('data-variant-lookup') || '{}'); } catch (e) {}
                      const colors = Array.prototype.slice.call(document.querySelectorAll('.pdp-swatch-wrap')).map(function (el) {
                        const optId = el.getAttribute('data-option-id');
                        const v = lookup[optId] || {};
                        return {
                          name: el.getAttribute('data-option-name') || '',
                          color: el.getAttribute('data-option-color') || '#E5DFD2',
                          oos: el.getAttribute('data-option-oos') === '1',
                          variantId: v.id || ''
                        };
                      }).filter(function (c) { return c.variantId; });

                      // Ukryj oryginalny selektor koloru, stepper, sticky bar, główną cenę + omnibus.
                      document.querySelectorAll('.pdp-variant-block').forEach(function (b) { b.style.display = 'none'; });
                      if (qtyControl) qtyControl.style.display = 'none';
                      const priceBlock = document.querySelector('.pdp-price-block');
                      if (priceBlock) priceBlock.style.display = 'none';
                      const sticky = document.querySelector('.dop-sticky-atc');
                      if (sticky) sticky.style.display = 'none';
                      const hint = document.getElementById('pdp-variant-hint');
                      const omnibusEl = document.getElementById('pdp-bundle-omnibus');
                      const vidInput = document.getElementById('variantId');

                      const firstAvail = (colors.find(function (c) { return !c.oos; }) || colors[0] || {}).variantId || '';

                      // Bundle sam zarządza kolorem — wyłącz gating "wybierz wariant" i trzymaj ATC aktywny.
                      function forceAtcReady() {
                        if (vidInput && firstAvail) vidInput.value = firstAvail;
                        if (hint) { hint.hidden = true; hint.style.display = 'none'; }
                        if (atcBtn) {
                          atcBtn.removeAttribute('aria-disabled');
                          atcBtn.removeAttribute('data-needs-selection');
                          atcBtn.classList.remove('pdp-atc--needs-selection', 'pdp-atc--disabled');
                          atcBtn.removeAttribute('disabled');
                          atcBtn.disabled = false;
                        }
                      }

                      function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }
                      function nameOf(vid) {
                        const c = colors.find(function (x) { return String(x.variantId) === String(vid); });
                        return c ? capitalize(c.name) : '';
                      }

                      let tierQty = 1;
                      let slots = [];

                      function renderRows(container) {
                        if (!container || !colors.length) { if (container) container.innerHTML = ''; return; }
                        let html = '';
                        for (let i = 0; i < tierQty; i++) {
                          if (!slots[i]) slots[i] = firstAvail;
                          html += '<div class="pdp-bundle-color-row"><span class="pdp-bundle-color-label">Kolor ' + (i + 1) + ': <span class="pdp-bundle-color-chosen" data-chosen>' + nameOf(slots[i]) + '</span></span><div class="pdp-bundle-color-opts" role="radiogroup">';
                          colors.forEach(function (c) {
                            const active = String(slots[i]) === String(c.variantId);
                            html += '<button type="button" class="pdp-bundle-color-sw' + (active ? ' is-active' : '') + (c.oos ? ' is-oos' : '') + '" data-slot="' + i + '" data-variant="' + c.variantId + '" data-name="' + c.name + '" title="' + capitalize(c.name) + '" aria-label="' + capitalize(c.name) + '"' + (c.oos ? ' disabled' : '') + ' style="background:' + c.color + '"></button>';
                          });
                          html += '</div></div>';
                        }
                        container.innerHTML = html;
                        container.querySelectorAll('.pdp-bundle-color-sw').forEach(function (sw) {
                          sw.addEventListener('click', function (ev) {
                            ev.stopPropagation();
                            if (sw.classList.contains('is-oos')) return;
                            slots[parseInt(sw.getAttribute('data-slot'), 10)] = sw.getAttribute('data-variant');
                            sw.parentNode.querySelectorAll('.pdp-bundle-color-sw').forEach(function (x) { x.classList.toggle('is-active', x === sw); });
                            const row = sw.closest('.pdp-bundle-color-row');
                            const chosen = row ? row.querySelector('[data-chosen]') : null;
                            if (chosen) chosen.textContent = capitalize(sw.getAttribute('data-name'));
                          });
                        });
                      }

                      const tiles = bundle.querySelectorAll('.pdp-bundle-tile');
                      function selectTier(t) {
                        tiles.forEach(function (x) {
                          const on = x === t;
                          x.classList.toggle('is-selected', on);
                          x.setAttribute('aria-checked', on ? 'true' : 'false');
                          const box = x.querySelector('.pdp-bundle-tile-colors');
                          if (box && !on) box.innerHTML = '';
                        });
                        tierQty = parseInt(t.getAttribute('data-bundle-qty'), 10) || 1;
                        slots = slots.slice(0, tierQty);
                        if (omnibusEl) omnibusEl.textContent = 'Najniższa cena z 30 dni: ' + (t.getAttribute('data-omnibus') || '');
                        renderRows(t.querySelector('.pdp-bundle-tile-colors'));
                        forceAtcReady();
                      }
                      tiles.forEach(function (t) {
                        t.addEventListener('click', function (e) {
                          if (e.target.closest && e.target.closest('.pdp-bundle-color-sw')) return;
                          selectTier(t);
                        });
                        t.addEventListener('keydown', function (e) {
                          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectTier(t); }
                        });
                      });
                      selectTier(bundle.querySelector('.pdp-bundle-tile.is-selected') || tiles[0]);
                      setTimeout(forceAtcReady, 0);
                      setTimeout(forceAtcReady, 300);

                      if (form && atcBtn) {
                        form.addEventListener('submit', async function (e) {
                          e.preventDefault();
                          e.stopImmediatePropagation();
                          if (!slots.length) return;
                          const counts = {};
                          slots.forEach(function (v) { if (v) counts[v] = (counts[v] || 0) + 1; });
                          const textEl = atcBtn.querySelector('.pdp-atc-text');
                          const base = atcBtn.getAttribute('data-base-text') || 'Dodaj do koszyka';
                          atcBtn.disabled = true;
                          if (textEl) textEl.textContent = 'Dodawanie...';
                          let lastOrder = null;
                          try {
                            for (const variantId in counts) {
                              const res = await fetch('/api/cart', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                credentials: 'include',
                                body: JSON.stringify({ variantId: variantId, quantity: counts[variantId] })
                              });
                              if (res.ok) { const d = await res.json(); lastOrder = d.order; }
                            }
                            // Otwórz koszyk OD RAZU po dodaniu sztuk (szybciej w odczuciu);
                            // kupon doliczy się chwilę później drugim eventem.
                            if (lastOrder) window.dispatchEvent(new CustomEvent('cart-updated', { detail: lastOrder }));

                            // Auto-aplikacja kuponu zestawu — tylko niezbędne wywołania.
                            // Kody MUSZĄ zgadzać się z promocjami kuponowymi w Vendure.
                            const BUNDLE_COUPONS = { 3: 'ZESTAW3', 5: 'ZESTAW5' };
                            const wantCode = BUNDLE_COUPONS[tierQty];
                            const applied = (lastOrder && lastOrder.couponCodes) || [];
                            let couponChanged = false;
                            // usuń tylko realnie zastosowany, niechciany kod zestawu
                            for (const q in BUNDLE_COUPONS) {
                              const c = BUNDLE_COUPONS[q];
                              if (c !== wantCode && applied.indexOf(c) !== -1) {
                                try {
                                  const rr = await fetch('/api/cart/coupon', {
                                    method: 'DELETE',
                                    headers: { 'Content-Type': 'application/json' },
                                    credentials: 'include',
                                    body: JSON.stringify({ couponCode: c })
                                  });
                                  if (rr.ok) { const rd = await rr.json(); if (rd && rd.order) { lastOrder = rd.order; couponChanged = true; } }
                                } catch (e) {}
                              }
                            }
                            // aplikuj docelowy kod tylko jeśli jeszcze go nie ma
                            if (wantCode && applied.indexOf(wantCode) === -1) {
                              try {
                                const cr = await fetch('/api/cart/coupon', {
                                  method: 'POST',
                                  headers: { 'Content-Type': 'application/json' },
                                  credentials: 'include',
                                  body: JSON.stringify({ couponCode: wantCode })
                                });
                                if (cr.ok) { const cd = await cr.json(); if (cd && cd.order) { lastOrder = cd.order; couponChanged = true; } }
                              } catch (e) {}
                            }
                            if (couponChanged && lastOrder) window.dispatchEvent(new CustomEvent('cart-updated', { detail: lastOrder }));
                          } catch (err) {}
                          atcBtn.disabled = false;
                          if (textEl) textEl.textContent = base;
                        });
                      }
                    }
                    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initBundle);
                    else initBundle();
                  })();
                </script>
                </Fragment>
              )}

              {/* Quantity + ATC row */}
              <div class="pdp-qty-row">
                <div class="pdp-qty-control">
                  <button type="button" class="pdp-qty-btn" data-qty-delta="-1" aria-label="Mniej">
                    <svg class="pdp-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                  </button>
                  <input
                    type="number"
                    name="quantity"
                    id="quantity"
                    value="1"
                    min="1"
                    max="99"
                    required
                    class="pdp-qty-input"
                  />
                  <button type="button" class="pdp-qty-btn" data-qty-delta="1" aria-label="Więcej">
                    <svg class="pdp-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                  </button>
                </div>

                {allOutOfStock ? (
                  <button type="button" disabled class="pdp-atc pdp-atc--disabled">
                    Niedostępny
                  </button>
                ) : (
                  <button
                    type="submit"
                    class="pdp-atc"
                    id="primary-atc-btn"
                    data-base-text="Dodaj do koszyka"
                  >
                    <span class="pdp-atc-text">Dodaj do koszyka</span>
                    <svg class="pdp-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
                  </button>
                )}
              </div>

            </form>

            {/* Bryza: 3 najczęstsze pytania pod ATC — karty z ikoną (inny styl niż akordeon niżej) */}
            {slug === 'bryza' && (
              <div class="pdp-bryza-faq">
                <h3 class="pdp-bryza-faq-title">Najczęstsze pytania</h3>
                <div class="pdp-pf-list">
                  <details class="pdp-pf-item" open>
                    <summary class="pdp-pf-head">
                      <span class="pdp-pf-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                      </span>
                      <span class="pdp-pf-q">Czy szal jest bezpieczny dla psa?</span>
                      <svg class="pdp-pf-chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <p class="pdp-pf-a">Tak. Bryza chłodzi łagodnie, przez parowanie wody, więc nie ma zimnego szoku jak przy kostkach lodu. Tkanina jest miękka i przewiewna, zawiązujesz ją luźno na szyi, bez uciskania. Przy pierwszym założeniu popatrz na psa przez chwilę i nie zostawiaj go z szalem bez nadzoru na cały dzień.</p>
                  </details>
                  <details class="pdp-pf-item">
                    <summary class="pdp-pf-head">
                      <span class="pdp-pf-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="5.5" cy="12.5" r="1.7"/><circle cx="9.5" cy="8" r="1.7"/><circle cx="14.5" cy="8" r="1.7"/><circle cx="18.5" cy="12.5" r="1.7"/><path d="M8 16.5c0-2.2 1.8-3.5 4-3.5s4 1.3 4 3.5c0 1.6-1.4 2.5-3 2.5h-2c-1.6 0-3-.9-3-2.5z"/></svg>
                      </span>
                      <span class="pdp-pf-q">Czy pasuje na każdą rasę psa?</span>
                      <svg class="pdp-pf-chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <p class="pdp-pf-a">Bryza jest w rozmiarach S, M i L, od małego psa po dużego. Zawiązujesz ją na szyi, więc masz zapas regulacji. Zmierz obwód szyi w miejscu, gdzie pies nosi obrożę, i porównaj z tabelą przy wariancie. Jeśli pies wypada między rozmiarami, wybierz większy.</p>
                  </details>
                  <details class="pdp-pf-item">
                    <summary class="pdp-pf-head">
                      <span class="pdp-pf-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.5S6 9 6 14a6 6 0 0 0 12 0c0-5-6-11.5-6-11.5z"/></svg>
                      </span>
                      <span class="pdp-pf-q">Jak używać szala?</span>
                      <svg class="pdp-pf-chev" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <p class="pdp-pf-a">Namocz szal w zimnej wodzie przez chwilę, lekko wykręć nadmiar, żeby był wilgotny, a nie ociekający, i zawiąż na szyi psa. Chłodzi przez kilka godzin. Gdy wyschnie, po prostu namocz go znowu, tyle razy ile trzeba, także w trakcie spaceru.</p>
                  </details>
                </div>
              </div>
            )}

