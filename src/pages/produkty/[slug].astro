  {/* Intercept ATC form — use async cart API + open drawer instead of redirect */}
  <script>
    function initAddToCartForm() {
      const form = document.querySelector('form[method="POST"]') as HTMLFormElement | null;
      if (!form) return;
      // Bryza: bundle z wyborem koloru per sztuka ma własny handler ATC (multi-wariant).
      if (form.querySelector('.pdp-bundle')) return;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (!btn) return;
      // BUG FIX: btn.textContent wipes child spans (icon!) → target only .pdp-atc-text span.
      // Bez tego po dodaniu do koszyka znika <span class="material-symbols-outlined"> i
      // tekst "shopping_cart" renderuje się literalnie zamiast jako ikona.
      const textEl = btn.querySelector('.pdp-atc-text') as HTMLSpanElement | null;
      const baseText = btn.getAttribute('data-base-text')
        || (textEl ? (textEl.textContent || 'Dodaj do koszyka') : 'Dodaj do koszyka');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const variantId = formData.get('variantId') as string;
        const quantity = parseInt(formData.get('quantity') as string || '1', 10);

        if (!variantId) return;

        btn.disabled = true;
        if (textEl) textEl.textContent = 'Dodawanie...';

        // Shared event ID dla deduplikacji browser fbq + server CAPI
        const atcEventId = crypto.randomUUID();

        try {
          const res = await fetch('/api/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ variantId, quantity, eventId: atcEventId }),
          });

          if (res.ok) {
            const data = await res.json();
            window.dispatchEvent(new CustomEvent('cart-updated', { detail: data.order }));

            // Browser Pixel AddToCart — leci po Vendure success
            try {
              const order = data?.order;
              const line = order?.lines?.find(
                (l: { productVariant?: { id?: string | number } }) =>
                  String(l.productVariant?.id) === String(variantId),
              );
              const variant = line?.productVariant;
              const unitPriceWithTax = Number(line?.unitPriceWithTax) || 0;
              if (typeof (window as any).fbq !== 'undefined') {
                (window as any).fbq('track', 'AddToCart', {
                  content_ids: [variant?.sku || String(variantId)],
                  content_type: 'product',
                  value: (unitPriceWithTax * quantity) / 100,
                  currency: 'PLN',
                }, { eventID: atcEventId });
              }

              // Behawioralny pixel — add_to_cart (Warstwa 1, ZERO Meta).
              // product_id = Vendure productId (TEN SAM klucz co view_content
              // i purchase → JOIN „obejrzenia↔koszyk↔zakupy"); value = produkt × qty. H-3.
              const sp = (window as { sp?: { track?: (t: string, d: unknown) => void } }).sp;
              sp?.track?.('add_to_cart', {
                product_id:
                  (variant as { product?: { id?: string } } | undefined)?.product?.id
                  ?? variantId,
                value: (unitPriceWithTax * quantity) / 100,
                currency: 'PLN',
              });
            } catch {
              // never break UX
            }
          } else {
            // Fallback: submit form normally
            form.submit();
            return;
          }
        } catch {
          // Fallback: submit form normally
          form.submit();
          return;
        }

        btn.disabled = false;
        if (textEl) textEl.textContent = baseText;
      });
    }
    initAddToCartForm();
  </script>

  {/* Gallery: thumbnail clicks + prev/next arrows swap main image + auto-scroll thumb strip */}
  <script is:inline>
  (function() {
    var mainImg = document.getElementById('pdp-main-img');
    var thumbs = Array.from(document.querySelectorAll('.pdp-thumb'));
    var thumbStrip = document.getElementById('pdp-thumbnails');
    if (!mainImg || !thumbs.length) return;

    var currentIndex = 0;

    // Sprawdza czy thumbnail jest w pełni widoczny w viewport scroll container'a.
    // Jeśli nie — przewija strip tak żeby był na środku.
    function ensureThumbVisible(thumb) {
      if (!thumbStrip) return;
      var stripRect = thumbStrip.getBoundingClientRect();
      var thumbRect = thumb.getBoundingClientRect();
      // Tolerancja 4px na padding/border
      var isFullyVisible =
        thumbRect.left >= stripRect.left - 4
        && thumbRect.right <= stripRect.right + 4;
      if (!isFullyVisible) {
        // scroll thumbnail to center w stripie
        var stripScrollLeft = thumbStrip.scrollLeft;
        var thumbOffsetFromStripStart = thumbRect.left - stripRect.left + stripScrollLeft;
        var targetScroll = thumbOffsetFromStripStart - (stripRect.width / 2) + (thumbRect.width / 2);
        thumbStrip.scrollTo({ left: targetScroll, behavior: 'smooth' });
      }
    }

    function updateStripArrowsState() {
      if (!thumbStrip) return;
      var prevA = document.getElementById('pdp-thumbs-prev');
      var nextA = document.getElementById('pdp-thumbs-next');
      var atStart = thumbStrip.scrollLeft <= 2;
      var atEnd = thumbStrip.scrollLeft + thumbStrip.clientWidth >= thumbStrip.scrollWidth - 2;
      if (prevA) prevA.disabled = atStart;
      if (nextA) nextA.disabled = atEnd;
    }

    function showAt(idx) {
      if (idx < 0) idx = thumbs.length - 1;
      if (idx >= thumbs.length) idx = 0;
      var thumb = thumbs[idx];
      var fullSrc = thumb.getAttribute('data-full-src');
      if (!fullSrc) return;
      mainImg.src = fullSrc;
      thumbs.forEach(function(t) { t.classList.remove('pdp-thumb--active'); });
      thumb.classList.add('pdp-thumb--active');
      currentIndex = idx;
      // Auto-scroll strip do aktywnego thumbnaila jeśli nie jest widoczny
      ensureThumbVisible(thumb);
    }

    // Thumb click
    thumbs.forEach(function(thumb, idx) {
      thumb.addEventListener('click', function() {
        showAt(idx);
      });
    });

    // Main image arrows
    var prevBtn = document.getElementById('pdp-gallery-prev');
    var nextBtn = document.getElementById('pdp-gallery-next');
    if (prevBtn) prevBtn.addEventListener('click', function() { showAt(currentIndex - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { showAt(currentIndex + 1); });

    // Thumb strip arrows — scroll strip o ~1 thumbnail width
    var thumbsPrev = document.getElementById('pdp-thumbs-prev');
    var thumbsNext = document.getElementById('pdp-thumbs-next');
    function scrollStrip(dir) {
      if (!thumbStrip) return;
      var oneThumb = thumbStrip.querySelector('.pdp-thumb');
      var step = oneThumb ? oneThumb.offsetWidth + 8 : 100;
      thumbStrip.scrollBy({ left: step * dir, behavior: 'smooth' });
    }
    if (thumbsPrev) thumbsPrev.addEventListener('click', function() { scrollStrip(-3); });
    if (thumbsNext) thumbsNext.addEventListener('click', function() { scrollStrip(3); });

    // Disabled state na końcach
    if (thumbStrip) {
      thumbStrip.addEventListener('scroll', updateStripArrowsState);
      window.addEventListener('resize', updateStripArrowsState);
      // Initial check (po renderze)
      setTimeout(updateStripArrowsState, 100);
    }

    // Keyboard arrows
    document.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft') showAt(currentIndex - 1);
      else if (e.key === 'ArrowRight') showAt(currentIndex + 1);
    });

    // Touch swipe — mobile gallery navigation. Próg 50px horizontal + dx > dy
    // żeby nie myliło ze scrollowaniem strony pionowo.
    var mainImageEl = document.querySelector('.pdp-main-image');
    if (mainImageEl && thumbs.length > 1) {
      var touchStartX = 0;
      var touchStartY = 0;
      var touchActive = false;
      mainImageEl.addEventListener('touchstart', function(e) {
        if (e.touches.length !== 1) return;
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchActive = true;
      }, { passive: true });
      mainImageEl.addEventListener('touchend', function(e) {
        if (!touchActive) return;
        touchActive = false;
        var t = e.changedTouches[0];
        var dx = t.clientX - touchStartX;
        var dy = t.clientY - touchStartY;
        // Swipe musi być wyraźnie horyzontalny: |dx|>50 AND |dx| > 1.5*|dy|
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
          if (dx > 0) showAt(currentIndex - 1);
          else showAt(currentIndex + 1);
        }
      }, { passive: true });
      mainImageEl.addEventListener('touchcancel', function() { touchActive = false; }, { passive: true });
    }
  })();
  </script>

  {/* Qty +/- buttons */}
  <script is:inline>
  (function() {
    var qtyInput = document.getElementById('quantity');
    if (!qtyInput) return;
    var btns = document.querySelectorAll('[data-qty-delta]');
    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var delta = parseInt(btn.getAttribute('data-qty-delta') || '0', 10);
        var current = parseInt(qtyInput.value || '1', 10);
        var next = Math.max(1, Math.min(99, current + delta));
        qtyInput.value = String(next);
        qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
      });
    });
  })();
  </script>

  {/* Variant option groups — sync selection to hidden variantId, swap main image, update ATC */}
  <script is:inline>
  (function() {
    var form = document.querySelector('form.pdp-form');
    if (!form) return;
    var lookupRaw = form.getAttribute('data-variant-lookup');
    if (!lookupRaw) return;
    var lookup = {};
    try { lookup = JSON.parse(lookupRaw); } catch (e) { return; }

    var hiddenInput = document.getElementById('variantId');
    if (!hiddenInput) return;

    var atc = document.getElementById('primary-atc-btn');
    var atcTextEl = atc ? atc.querySelector('.pdp-atc-text') : null;
    var atcBaseText = (atc && atc.getAttribute('data-base-text')) || 'Dodaj do koszyka';
    var hintEl = document.getElementById('pdp-variant-hint');
    var hintMsgEl = hintEl ? hintEl.querySelector('[data-hint-msg]') : null;

    var mainImg = document.getElementById('pdp-main-img');
    var thumbs = document.querySelectorAll('.pdp-thumb');
    var originalImageSrc = mainImg ? mainImg.src : null;
    var isInitialRender = true; // flaga: nie swapuj main image na page load — pokaż product.featuredAsset

    // Per-group selected option id
    var selectedByGroup = {};
    var groupBlocks = document.querySelectorAll('[data-option-group]');
    if (!groupBlocks.length) return;

    // Init: read which option is currently marked --active in each group
    groupBlocks.forEach(function(block) {
      var groupId = block.getAttribute('data-option-group');
      var active = block.querySelector('[aria-pressed="true"]');
      if (active) selectedByGroup[groupId] = active.getAttribute('data-option-id');
    });

    // Compute readable text color (white or dark) for a hex bg — luminance heuristic.
    function getContrastColor(hex) {
      if (!hex) return '#FFFFFF';
      var clean = hex.replace('#', '');
      if (clean.length !== 6) return '#FFFFFF';
      var r = parseInt(clean.substring(0, 2), 16);
      var g = parseInt(clean.substring(2, 4), 16);
      var b = parseInt(clean.substring(4, 6), 16);
      var lum = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
      return lum > 0.62 ? '#2A2D27' : '#FFFFFF';
    }

    function hexToRgba(hex, alpha) {
      var clean = hex.replace('#', '');
      var r = parseInt(clean.substring(0, 2), 16);
      var g = parseInt(clean.substring(2, 4), 16);
      var b = parseInt(clean.substring(4, 6), 16);
      return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
    }

    // Smooth image swap — fade out, change src, fade in on load.
    function swapMainImage(newSrc) {
      if (!mainImg || !newSrc || mainImg.src === newSrc) return;
      mainImg.style.opacity = '0.4';
      var preload = new Image();
      preload.onload = function() {
        mainImg.src = newSrc;
        mainImg.style.opacity = '1';
      };
      preload.onerror = function() {
        mainImg.style.opacity = '1';
      };
      preload.src = newSrc;
    }

    // Sync thumbnail active state to current main image src.
    function syncThumbActive(src) {
      if (!thumbs.length) return;
      thumbs.forEach(function(t) {
        var thumbSrc = t.getAttribute('data-full-src');
        t.classList.toggle('pdp-thumb--active', thumbSrc === src);
      });
    }

    // Cross-group availability: opcja niedostepna jesli z obecnym wyborem w
    // pozostalych grupach nie ma zadnego in-stock wariantu.
    var variantEntries = Object.keys(lookup).map(function(k) {
      return { opts: k.split('|'), stock: lookup[k].stock };
    });
    function optionAvailable(groupId, optionId) {
      return variantEntries.some(function(ve) {
        if (ve.stock === 'OUT_OF_STOCK') return false;
        if (ve.opts.indexOf(optionId) === -1) return false;
        for (var gid in selectedByGroup) {
          if (gid === groupId) continue;
          if (ve.opts.indexOf(selectedByGroup[gid]) === -1) return false;
        }
        return true;
      });
    }
    function refreshOptionAvailability() {
      document.querySelectorAll('[data-option-id]').forEach(function(btn) {
        var gid = btn.getAttribute('data-option-group-id');
        var oid = btn.getAttribute('data-option-id');
        if (!gid || !oid) return;
        var oos = !optionAvailable(gid, oid);
        btn.setAttribute('data-option-oos', oos ? '1' : '0');
        if (btn.classList.contains('pdp-swatch-wrap')) btn.classList.toggle('pdp-swatch-wrap--oos', oos);
        if (btn.classList.contains('pdp-pill')) btn.classList.toggle('pdp-pill--oos', oos);
        if (oos) btn.setAttribute('title', 'Chwilowo niedostepny');
        else btn.removeAttribute('title');
      });
    }

    function recomputeVariant() {
      // 0. Odswiez dostepnosc opcji (cross-group), od razu widac wyprzedane.
      refreshOptionAvailability();
      // 1. Detect missing groups (no option selected) — driver for ATC validation state.
      var totalGroups = groupBlocks.length;
      var missingLabels = [];
      groupBlocks.forEach(function(block) {
        var gid = block.getAttribute('data-option-group');
        if (!selectedByGroup[gid]) {
          var lbl = block.querySelector('.pdp-variant-label');
          if (lbl) {
            var t = (lbl.textContent || '').replace(':', '').trim().toLowerCase();
            if (t) missingLabels.push(t);
          }
        }
      });
      var needsSelection = missingLabels.length > 0;

      // 2. Build variant key & lookup match (only valid when all groups picked).
      var ids = Object.values(selectedByGroup).sort();
      var key = ids.join('|');
      var match = needsSelection ? null : lookup[key];

      // 3. Collect selected color (for ATC bg) and color name (for label).
      var selectedColor = null;
      var selectedColorName = null;
      var fallbackName = null;
      Object.keys(selectedByGroup).forEach(function(groupId) {
        var optionId = selectedByGroup[groupId];
        var btn = document.querySelector('[data-option-group-id="' + groupId + '"][data-option-id="' + optionId + '"]');
        if (!btn) return;
        var name = btn.getAttribute('data-option-name');
        var color = btn.getAttribute('data-option-color');
        if (color && !selectedColor) {
          selectedColor = color;
          selectedColorName = name;
        } else if (name && !fallbackName) {
          fallbackName = name;
        }
      });

      // 4. Apply variant data (price, image, stock) — only when we have a match.
      if (match && match.id) {
        hiddenInput.value = match.id;

        var priceEl = document.querySelector('.pdp-price');
        if (priceEl && typeof match.price === 'number') {
          var formatted = new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(match.price / 100);
          priceEl.textContent = formatted;
        }

        // Update sale info (strikethrough + badge) na podstawie ratio.
        // Wariantowe produkty mają różne ceny — utrzymujemy ten sam % zniżki, regular price
        // skaluje się proporcjonalnie. Hide "od" prefix bo użytkownik wybrał konkretny wariant.
        var priceBlock = document.querySelector('.pdp-price-block');
        var fmtPLN = function(g) { return new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(g / 100); };
        var saleRatio = priceBlock ? parseFloat(priceBlock.getAttribute('data-sale-ratio') || '0') : 0;
        var variantRegularsRaw = priceBlock ? priceBlock.getAttribute('data-variant-regulars') : '';
        var variantRegularsMap = {};
        try { variantRegularsMap = variantRegularsRaw ? JSON.parse(variantRegularsRaw) : {}; } catch (e) {}

        // Update Omnibus "Najniższa cena z 30 dni" do current variant price
        if (priceBlock && typeof match.price === 'number') {
          var lowest30dEl = priceBlock.querySelector('[data-lowest-30d]');
          if (lowest30dEl) lowest30dEl.textContent = fmtPLN(match.price);
        }

        var newRegular = 0;
        if (match.id && variantRegularsMap[match.id]) {
          newRegular = variantRegularsMap[match.id];
        } else if (saleRatio > 1 && typeof match.price === 'number') {
          newRegular = Math.round(match.price * saleRatio);
        }
        if (priceBlock && newRegular > match.price && typeof match.price === 'number') {
          var newSavings = newRegular - match.price;

          // Update strikethrough regular price (usuń wewnętrzne "od" prefix gdy konkretny wariant)
          var regSpan = priceBlock.querySelector('.pdp-price-regular');
          if (regSpan) regSpan.innerHTML = fmtPLN(newRegular);
          // Update sale badge — "oszczędzasz X zł" zamiast %
          var badgeEl = priceBlock.querySelector('.pdp-sale-badge');
          if (badgeEl) badgeEl.textContent = 'oszczędzasz ' + fmtPLN(newSavings);
          // Ukryj "od" prefix obok ceny — user wybrał wariant
          var odMain = priceBlock.querySelector('.pdp-price-od--main');
          if (odMain) odMain.style.display = 'none';
        }

        // Swap main image to variant.featuredAsset TYLKO po realnym kliknięciu user'a,
        // nie na page load — początkowo pokazujemy product.featuredAsset.
        if (!isInitialRender) {
          if (match.image) {
            swapMainImage(match.image);
            syncThumbActive(match.image);
          } else if (originalImageSrc) {
            swapMainImage(originalImageSrc);
            syncThumbActive(originalImageSrc);
          }
        }
      } else if (needsSelection) {
        // Clear variantId — uniemożliwia submit zanim user wybierze pełen zestaw opcji.
        hiddenInput.value = '';
      }

      // 5. Update ATC button — needs-selection mode OR full-info mode.
      if (atc && atcTextEl) {
        if (needsSelection) {
          // Domyślny tekst = "dodaj do koszyka". Na hover / click pokaże hint przez
          // mouseenter handler poniżej. Po kliknięciu submit zablokowany przez click guard.
          atcTextEl.textContent = atcBaseText;

          var hintLabel = 'Wybierz ' + missingLabels.join(' i ') + ' aby dodać do koszyka';
          atc.setAttribute('data-needs-selection', '1');
          atc.setAttribute('data-hint-text', hintLabel);
          atc.setAttribute('aria-disabled', 'true');
          atc.classList.add('pdp-atc--needs-selection');
          // NIE używamy native `disabled` — chcemy żeby click/hover event nadal działały.
          atc.removeAttribute('disabled');

          // Visible hint — sage soft pill nad ATC żeby user wiedział co kliknąć.
          if (hintEl && hintMsgEl) {
            hintMsgEl.textContent = hintLabel;
            hintEl.hidden = false;
          }

          // Reset color override — wracamy do sage baseline.
          if (atc.getAttribute('data-color-applied') === '1') {
            atc.style.background = '';
            atc.style.color = '';
            atc.style.boxShadow = '';
            atc.removeAttribute('data-color-applied');
          }
        } else {
          // Pełen wybór — pokaż "dodaj do koszyka [kolor]" + tło wybranego koloru.
          atc.removeAttribute('data-needs-selection');
          atc.removeAttribute('data-hint-text');
          atc.removeAttribute('aria-disabled');
          atc.classList.remove('pdp-atc--needs-selection');

          // Hide hint — user wybrał wszystkie opcje.
          if (hintEl) hintEl.hidden = true;

          // Stock state — native disabled OK tutaj (browser blokuje wszystko).
          if (match && match.stock === 'OUT_OF_STOCK') {
            atc.setAttribute('disabled', 'disabled');
            atc.classList.add('pdp-atc--disabled');
          } else {
            atc.removeAttribute('disabled');
            atc.classList.remove('pdp-atc--disabled');
          }

          // Tekst zawsze "dodaj do koszyka" — żadnego suffix'u z nazwą wariantu.
          atcTextEl.textContent = atcBaseText;

          // Zmienia się TYLKO kolor tła + cień przy wybranym kolorze.
          // Tekst ZAWSZE biały (CSS default na .pdp-atc) — getContrastColor
          // dawał czarny tekst dla jasnych kolorów (np. pomarańczowy Wibblo),
          // ale user wymagał spójności: każdy wariant kolorowy ma biały label.
          if (selectedColor) {
            atc.style.background = selectedColor;
            atc.style.color = '#FFFFFF';
            atc.style.boxShadow = '0 6px 20px ' + hexToRgba(selectedColor, 0.30)
              + ', 0 2px 4px ' + hexToRgba(selectedColor, 0.15);
            atc.setAttribute('data-color-applied', '1');
          } else if (atc.getAttribute('data-color-applied') === '1') {
            atc.style.background = '';
            atc.style.color = '';
            atc.style.boxShadow = '';
            atc.removeAttribute('data-color-applied');
          }
        }
      }
    }

    // --- Click guard na needs-selection ATC (tekst zawsze "dodaj do koszyka") ---
    if (atc && atcTextEl) {
      // Click: jeśli brak pełnego wyboru — zablokuj submit, scroll do brakującej grupy, shake.
      // NIE zmienia tekstu guzika (user chce: tekst zawsze "dodaj do koszyka").
      atc.addEventListener('click', function(e) {
        if (atc.getAttribute('data-needs-selection') === '1') {
          e.preventDefault();
          e.stopImmediatePropagation();
          var firstMissing = null;
          groupBlocks.forEach(function(block) {
            var gid = block.getAttribute('data-option-group');
            if (!selectedByGroup[gid] && !firstMissing) firstMissing = block;
          });
          if (firstMissing) {
            firstMissing.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          atc.classList.add('pdp-atc--shake');
          setTimeout(function() { atc.classList.remove('pdp-atc--shake'); }, 500);
        }
      }, true); // capture phase — zatrzymuje przed form submit handlerem
    }

    function selectOption(groupId, optionId, clickedBtn) {
      selectedByGroup[groupId] = optionId;
      var block = document.querySelector('[data-option-group="' + groupId + '"]');
      if (!block) return;
      block.querySelectorAll('[data-option-id]').forEach(function(btn) {
        var isActive = btn === clickedBtn;
        btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        btn.classList.toggle('pdp-swatch-wrap--active', isActive && btn.classList.contains('pdp-swatch-wrap'));
        btn.classList.toggle('pdp-pill--active', isActive && btn.classList.contains('pdp-pill'));
      });
      recomputeVariant();
    }

    document.querySelectorAll('[data-option-id]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var groupId = btn.getAttribute('data-option-group-id');
        var optionId = btn.getAttribute('data-option-id');
        if (!groupId || !optionId) return;
        selectOption(groupId, optionId, btn);
      });
    });

    // Initial compute — bez swapu obrazka (page load shows product.featuredAsset)
    recomputeVariant();
    isInitialRender = false;
  })();
  </script>

  {/* Shipping urgency countdown */}
  <script is:inline>
  (function() {
    var el = document.getElementById('shipping-urgency');
    if (!el) return;

    function update() {
      var now = new Date();
      var waw = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Warsaw' }));
      var day = waw.getDay();
      var hours = waw.getHours();
      var minutes = waw.getMinutes();

      if (day === 0 || day === 6) {
        el.textContent = 'Zamow teraz, wysylka w poniedzialek!';
        return;
      }

      var cutoff = 14;
      if (hours >= cutoff) {
        el.textContent = 'Zamow teraz, wysylka jutro!';
        return;
      }

      var remainH = cutoff - hours - 1;
      var remainM = 60 - minutes;
      if (remainM === 60) { remainM = 0; remainH++; }
      el.textContent = 'Zamow w ciagu ' + remainH + ' godz. ' + remainM + ' min, wysylka dzisiaj!';
    }

    update();
    const urgencyTimer = setInterval(update, 60000);
    document.addEventListener('astro:before-swap', () => clearInterval(urgencyTimer), { once: true });
  })();
  </script>

