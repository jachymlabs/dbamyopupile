      display: flex;
      gap: 8px;
      overflow-x: auto;
      scroll-snap-type: x proximity;
      scroll-padding: 4px;
      scrollbar-width: none;
      scroll-behavior: smooth;
      min-width: 0;
    }
    .pdp-thumbnails::-webkit-scrollbar { display: none; }
    .pdp-thumb {
      flex: 0 0 calc((100% - 32px) / 5);
      aspect-ratio: 1 / 1;
      border: 2px solid var(--brand-border);
      background: var(--brand-surface);
      border-radius: 12px;
      overflow: hidden;
      cursor: pointer;
      padding: 0;
      scroll-snap-align: center;
      transition: border-color 200ms, transform 150ms;
    }
    @media (min-width: 768px) {
      .pdp-thumb {
        flex: 0 0 calc((100% - 40px) / 6);
      }
    }

    /* Thumbnail strip arrows (po bokach galerii) */
    .pdp-thumb-arrow {
      flex-shrink: 0;
      width: 32px;
      height: 32px;
      border-radius: 9999px;
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      color: var(--brand-heading);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background 200ms, color 200ms, transform 200ms;
    }
    .pdp-thumb-arrow:hover {
      background: var(--brand-primary);
      color: white;
      transform: scale(1.08);
    }
    .pdp-thumb-arrow:hover .material-symbols-outlined,
    .pdp-thumb-arrow:hover .pdp-svg-icon { color: white !important; }
    .pdp-thumb-arrow:active { transform: scale(0.94); }
    .pdp-thumb-arrow:disabled {
      opacity: 0.35;
      cursor: not-allowed;
      transform: none;
    }
    .pdp-thumb-arrow:disabled:hover {
      background: var(--brand-surface);
      color: var(--brand-heading);
      transform: none;
    }
    .pdp-thumb-arrow:disabled:hover .material-symbols-outlined,
    .pdp-thumb-arrow:disabled:hover .pdp-svg-icon { color: var(--brand-heading) !important; }
    .pdp-thumb-arrow .material-symbols-outlined,
    .pdp-thumb-arrow .pdp-svg-icon {
      color: var(--brand-heading) !important;
      font-size: 18px !important;
      width: 18px;
      height: 18px;
    }
    @media (min-width: 768px) {
      .pdp-thumb-arrow { width: 36px; height: 36px; }
      .pdp-thumb-arrow .material-symbols-outlined,
      .pdp-thumb-arrow .pdp-svg-icon { font-size: 20px !important; width: 20px; height: 20px; }
    }
    .pdp-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .pdp-thumb--active,
    .pdp-thumb:hover {
      border-color: var(--brand-primary);
    }

    /* Info column */
    .pdp-info {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    /* === FOMO strip przed nazwą (pulsujący dot + scarcity text) === */
    .pdp-fomo-strip {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      align-self: flex-start;
      padding: 6px 14px 6px 12px;
      background: var(--brand-accent-soft);
      border: 1px solid rgba(230, 57, 70, 0.25);
      border-radius: 9999px;
      font-size: 12px;
      color: var(--brand-accent);
      font-weight: 600;
    }
    .pdp-fomo-strip-text {
      letter-spacing: 0.01em;
    }
    .pdp-fomo-strip-text strong {
      font-weight: 800;
    }
    .pdp-fomo-dot {
      width: 8px; height: 8px;
      border-radius: 9999px;
      background: var(--brand-accent);
      flex-shrink: 0;
      animation: pdp-pulse-dot 1.5s ease-in-out infinite;
      box-shadow: 0 0 0 0 var(--brand-accent);
    }
    @keyframes pdp-pulse-dot {
      0%, 100% { box-shadow: 0 0 0 0 rgba(230, 57, 70, 0.4); }
      50% { box-shadow: 0 0 0 6px rgba(230, 57, 70, 0); }
    }

    /* === Chips row === */
    .pdp-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .pdp-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 5px 12px;
      border-radius: 9999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
    }
    .pdp-chip .material-symbols-outlined {
      font-size: 14px !important;
    }
    .pdp-chip--bestseller {
      background: var(--brand-primary-soft);
      color: var(--brand-primary-hover);
      border: 1px solid var(--brand-primary);
    }
    .pdp-chip--bestseller .material-symbols-outlined {
      color: var(--brand-primary) !important;
    }
    .pdp-chip--sale {
      background: var(--brand-accent);
      color: white;
      letter-spacing: 0.02em;
    }
    .pdp-chip--oos {
      background: var(--brand-accent-soft);
      color: var(--brand-accent);
      border: 1px solid var(--brand-accent);
    }

    /* === Rating row (clickable, links to reviews) === */
    .pdp-rating-row {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      padding: 4px 0;
      margin: -4px 0;
      transition: opacity 180ms;
      flex-wrap: wrap;
    }
    .pdp-rating-row:hover { opacity: 0.85; }
    .pdp-rating-row:hover .pdp-rating-arrow {
      transform: translateX(2px);
    }
    .pdp-rating-num {
      font-family: 'Outfit', sans-serif;
      font-size: 16px;
      font-weight: 800;
      color: var(--brand-heading);
      letter-spacing: -0.01em;
    }
    .pdp-rating-count {
      font-size: 13px;
      color: var(--brand-text);
      font-weight: 600;
      text-decoration: underline;
      text-decoration-color: var(--brand-border-strong);
      text-underline-offset: 3px;
    }
    .pdp-rating-arrow {
      color: var(--brand-primary) !important;
      font-size: 14px !important;
      transition: transform 180ms;
    }

    .pdp-rating {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .pdp-stars {
      display: flex;
      color: var(--brand-primary);
    }
    .pdp-stars .material-symbols-outlined {
      font-size: 18px !important;
    }
    .pdp-stars--lg .material-symbols-outlined {
      font-size: 24px !important;
    }
    /* Wymuszone FILL axis — bez tego font-variation-settings inline mógł nie
       złapać się na pierwszym renderze (font loading race). Force !important. */
    .pdp-star-full {
      font-variation-settings: 'FILL' 1 !important;
      color: #F5B544 !important;
    }
    .pdp-star-empty {
      font-variation-settings: 'FILL' 0 !important;
      color: var(--brand-border-strong) !important;
    }
    .pdp-stars--lg .pdp-star-full { color: #F5B544 !important; }
    .pdp-stars--lg .pdp-star-empty { color: var(--brand-border-strong) !important; }
    .pdp-rating-text {
      font-size: 14px;
      color: var(--brand-text);
    }
    .pdp-out-of-stock {
      align-self: flex-start;
      background: var(--brand-accent-soft);
      color: var(--brand-accent);
      font-size: 12px;
      font-weight: 700;
      padding: 4px 12px;
      border-radius: 9999px;
      letter-spacing: 0.05em;
    }
    .pdp-price-block {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 8px 0 4px;
    }
    .pdp-price-row {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 12px;
    }
    .pdp-price {
      font-size: 36px;
      font-weight: 800;
      color: var(--brand-primary);
      font-family: 'Outfit', sans-serif;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    @media (min-width: 768px) {
      .pdp-price { font-size: 44px; }
    }
    .pdp-price-old {
      font-size: 17px;
      font-weight: 600;
      color: var(--brand-muted);
      text-decoration: line-through;
      text-decoration-color: var(--brand-accent);
      text-decoration-thickness: 1.5px;
    }
    .pdp-savings {
      display: inline-flex;
      align-items: center;
      background: var(--brand-accent-soft);
      color: var(--brand-accent);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.04em;
      padding: 4px 10px;
      border-radius: 9999px;
      margin-left: auto;
    }
    .pdp-lowest-30d {
      font-size: 11px;
      color: var(--brand-muted);
      font-style: italic;
      margin: 6px 0 0;
      font-weight: 400;
    }

    /* === Sale price (regularPrice) === */
    /* Cena regularna — strikethrough w kolorze tekstu (muted) */
    .pdp-price-regular {
      font-size: 19px;
      font-weight: 600;
      color: var(--brand-muted);
      text-decoration: line-through;
      text-decoration-color: currentColor;
      text-decoration-thickness: 1.5px;
      margin-right: 4px;
    }
    /* "od" prefix dla wariantowych produktów (range min != max) */
    .pdp-price-od {
      font-size: 0.75em;
      font-weight: 500;
      letter-spacing: 0.01em;
      opacity: 0.85;
      margin-right: 2px;
    }
    .pdp-price-od--main {
      font-size: 18px;
      font-weight: 500;
      color: var(--brand-muted);
      letter-spacing: 0;
      align-self: flex-end;
      margin: 0 -2px 8px 0;
    }
    @media (min-width: 768px) {
      .pdp-price-od--main { font-size: 22px; margin-bottom: 10px; }
    }
    /* Aktualna cena gdy promocja — strawberry */
    .pdp-price--sale { color: var(--brand-accent) !important; }
    /* Caly produkt wyprzedany: cena przekreslona + wyszarzona */
    .pdp-price--oos {
      text-decoration: line-through;
      text-decoration-thickness: 2px;
      color: var(--brand-muted, #9a9d95) !important;
      opacity: 0.75;
    }
    /* Sale badge — "oszczędzasz X zł" obok ceny promocyjnej (vertically centered) */
    .pdp-sale-badge {
      display: inline-flex;
      align-items: center;
      align-self: center;
      background: var(--brand-accent);
      color: #FFFFFF;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.02em;
      padding: 7px 14px;
      border-radius: 9999px;
      box-shadow: 0 4px 14px rgba(230, 57, 70, 0.30);
      white-space: nowrap;
    }
    @media (min-width: 768px) {
      .pdp-price-regular { font-size: 22px; }
    }
    .pdp-fomo {
      background: var(--brand-accent-soft);
      color: var(--brand-accent);
      border-radius: 14px;
      padding: 12px 16px;
      font-size: 14px;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .pdp-fomo .material-symbols-outlined { font-size: 22px !important; }
    .pdp-fomo--soft {
      background: #FDF6E4;
      color: #B8861F;
    }

    .pdp-short-desc {
      font-size: 15px;
      line-height: 1.6;
      color: var(--brand-text);
      /* Mobile word-wrap fix dla krótkiego opisu (hero column) — długie
         polskie słowa typu "obgryzanie", "magnetyczne", "wyciszające" mogły
         się ucinać po prawej krawędzi container'a. */
      word-wrap: break-word;
      overflow-wrap: break-word;
      hyphens: auto;
      -webkit-hyphens: auto;
    }
    .pdp-short-desc p { margin: 0 0 8px; }
    .pdp-short-desc strong { color: var(--brand-heading); }

    /* Form */
    .pdp-form {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-top: 8px;
    }

    /* Variant blocks */
    .pdp-variant-block {
      display: flex;
      flex-direction: column;
      gap: 10px;
      border-radius: 12px;
      padding: 4px;
      transition: background 400ms ease, box-shadow 400ms ease;
    }
    .pdp-variant-block.pdp-variant-flash {
      background: var(--brand-primary-soft);
      box-shadow: 0 0 0 3px var(--brand-primary);
      animation: pdp-variant-pulse 1.4s ease-out;
    }
    @keyframes pdp-variant-pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(116, 151, 191, 0.0); }
      30% { box-shadow: 0 0 0 6px rgba(116, 151, 191, 0.45); }
      70% { box-shadow: 0 0 0 3px rgba(116, 151, 191, 0.35); }
    }
    .pdp-variant-label {
      font-size: 13px;
      color: var(--brand-text);
      font-weight: 500;
      letter-spacing: 0.02em;
    }

    /* --- Bundle selector (Bryza) --- */
    .pdp-bundle {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin: 4px 0 20px;
    }
    .pdp-bundle-title {
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--brand-heading);
    }
    .pdp-bundle-tile {
      position: relative;
      display: flex;
      flex-direction: column;
      width: 100%;
      text-align: left;
      padding: 16px 18px;
      background: var(--brand-surface);
      border: 1.5px solid var(--brand-border);
      border-radius: 16px;
      cursor: pointer;
      transition: border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }
    .pdp-bundle-head { display: flex; align-items: center; gap: 14px; width: 100%; }
    .pdp-bundle-tile:hover { border-color: var(--brand-primary); }
    .pdp-bundle-tile.is-selected {
      border-color: var(--brand-primary);
      background: var(--brand-primary-soft);
      box-shadow: 0 0 0 3px rgba(116, 151, 191, 0.18);
    }
    .pdp-bundle-radio {
      flex-shrink: 0;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 2px solid var(--brand-border-strong);
      position: relative;
      transition: border-color 180ms ease;
    }
    .pdp-bundle-tile.is-selected .pdp-bundle-radio { border-color: var(--brand-primary); }
    .pdp-bundle-tile.is-selected .pdp-bundle-radio::after {
      content: '';
      position: absolute;
      inset: 4px;
      border-radius: 50%;
      background: var(--brand-primary);
    }
    /* Kolory wewnątrz wybranego zestawu */
    .pdp-bundle-tile-colors:empty { display: none; }
    .pdp-bundle-tile-colors {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--brand-border);
    }
    .pdp-bundle-tile.is-selected .pdp-bundle-tile-colors { border-top-color: rgba(116, 151, 191, 0.35); }
    .pdp-bundle-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 3px; }
    .pdp-bundle-name {
      font-family: 'Outfit', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: var(--brand-heading);
      line-height: 1.25;
    }
    .pdp-bundle-name em { font-style: normal; font-weight: 500; color: var(--brand-muted); font-size: 14px; }
    .pdp-bundle-sub { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; font-size: 12.5px; font-weight: 600; color: var(--brand-primary-hover); }
    .pdp-bundle-ship {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: var(--brand-primary-soft);
      color: var(--brand-primary-hover);
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 9px 3px 7px;
      border-radius: 999px;
    }
    .pdp-bundle-ship svg { flex-shrink: 0; }
    .pdp-bundle-price {
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      line-height: 1.05;
    }
    .pdp-bundle-price-old {
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--brand-muted);
      text-decoration: line-through;
    }
    .pdp-bundle-price-now {
      font-family: 'Outfit', sans-serif;
      font-size: 19px;
      font-weight: 800;
      color: var(--brand-heading);
      letter-spacing: -0.01em;
    }
    .pdp-bundle-omnibus {
      font-size: 11.5px;
      color: var(--brand-muted);
      margin: 0 0 2px;
    }
    .pdp-bundle-color-chosen { font-weight: 700; color: var(--brand-heading); }
    .pdp-bryza-faq { margin-top: 18px; }
    .pdp-bryza-faq-title {
      font-family: 'Outfit', sans-serif;
      font-size: 15px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0 0 10px;
    }
    .pdp-pf-list { display: flex; flex-direction: column; gap: 10px; }
    .pdp-pf-item {
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 14px;
      overflow: hidden;
      transition: border-color 180ms ease, box-shadow 180ms ease;
    }
    .pdp-pf-item:hover { border-color: var(--brand-primary); }
    .pdp-pf-item[open] { border-color: var(--brand-primary); box-shadow: 0 2px 10px rgba(116, 151, 191, 0.10); }
    .pdp-pf-head {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      cursor: pointer;
      list-style: none;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
      outline: none;
    }
    .pdp-pf-head::-webkit-details-marker { display: none; }
    .pdp-pf-icon {
      flex-shrink: 0;
      width: 38px;
      height: 38px;
      border-radius: 10px;
      background: var(--brand-primary-soft);
      color: var(--brand-primary);
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .pdp-pf-icon svg { width: 20px; height: 20px; }
    .pdp-pf-q {
      flex: 1;
      min-width: 0;
      font-family: 'Outfit', sans-serif;
      font-size: 14.5px;
      font-weight: 700;
      color: var(--brand-heading);
      line-height: 1.3;
      margin: 0;
    }
    .pdp-pf-chev { flex-shrink: 0; color: var(--brand-muted); transition: transform 220ms ease; }
    .pdp-pf-item[open] .pdp-pf-chev { transform: rotate(180deg); color: var(--brand-primary); }
    .pdp-pf-a {
      margin: 0;
      padding: 0 16px 14px 52px;
      font-size: 13px;
      line-height: 1.55;
      color: var(--brand-text);
    }
    .pdp-bundle-tile--popular { border-color: var(--brand-primary); }
    .pdp-bundle-flag {
      position: absolute;
      top: -10px;
      right: 14px;
      background: var(--brand-primary);
      color: #fff;
      font-family: 'Outfit', sans-serif;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 999px;
    }
    .pdp-bundle-tiers { display: flex; flex-direction: column; gap: 10px; }
    .pdp-bundle-colors { display: flex; flex-direction: column; gap: 12px; margin-top: 14px; }
    .pdp-bundle-color-row { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .pdp-bundle-color-label {
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: var(--brand-text);
      min-width: 64px;
    }
    .pdp-bundle-color-opts { display: flex; gap: 10px; flex-wrap: wrap; }
    .pdp-bundle-color-sw {
      position: relative;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 2px solid var(--brand-border);
      cursor: pointer;
      padding: 0;
      transition: transform 150ms ease, border-color 150ms ease, box-shadow 150ms ease;
    }
    .pdp-bundle-color-sw:hover { transform: scale(1.08); }
    .pdp-bundle-color-sw.is-active {
      border-color: var(--brand-heading);
      box-shadow: 0 0 0 3px var(--brand-primary);
      transform: scale(1.06);
    }
    .pdp-bundle-color-sw.is-active::after {
      content: '';
      position: absolute;
      left: 50%;
      top: 47%;
      width: 12px;
      height: 7px;
      border-left: 2.5px solid #fff;
      border-bottom: 2.5px solid #fff;
      transform: translate(-50%, -50%) rotate(-45deg);
    }
    .pdp-bundle-color-sw.is-oos { opacity: 0.35; cursor: not-allowed; }

    /* --- Stitch SWATCHES (color circles + label) --- */
    .pdp-swatches {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
    }
    .pdp-swatch-wrap {
      background: transparent;
      border: none;
      padding: 0;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      transition: transform 150ms;
    }
    .pdp-swatch-wrap:hover {
      transform: translateY(-1px);
    }
    .pdp-swatch {
      width: 40px;
      height: 40px;
      border-radius: 9999px;
      border: 2px solid transparent;
      box-shadow: 0 2px 8px rgba(42, 45, 39, 0.08);
      transition: border-color 200ms, transform 150ms, box-shadow 200ms;
    }
    .pdp-swatch--light {
      border-color: var(--brand-border-strong);
    }
    .pdp-swatch-wrap:hover .pdp-swatch {
      border-color: var(--brand-border-strong);
      box-shadow: 0 4px 12px rgba(42, 45, 39, 0.12);
    }
    .pdp-swatch-wrap--active .pdp-swatch {
      border-color: var(--brand-primary);
      box-shadow: 0 0 0 3px var(--brand-primary-soft), 0 2px 8px rgba(116, 151, 191, 0.25);
    }
    .pdp-swatch-label {
      font-size: 10px;
      font-weight: 600;
      color: var(--brand-text);
      letter-spacing: 0.05em;
      transition: color 200ms;
    }
    .pdp-swatch-wrap--active .pdp-swatch-label {
      color: var(--brand-primary);
      font-weight: 800;
    }
    /* Swatch wyprzedany: wyszarzony + ukosne przekreslenie probki + strike na nazwie */
    .pdp-swatch-wrap--oos { cursor: not-allowed; }
    .pdp-swatch-wrap--oos .pdp-swatch {
      position: relative;
      opacity: 0.4;
      filter: grayscale(0.55);
      box-shadow: none;
    }
    .pdp-swatch-wrap--oos .pdp-swatch::after {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: inherit;
      background: linear-gradient(to top left, transparent calc(50% - 1px), var(--brand-muted, #9a9d95) calc(50% - 1px), var(--brand-muted, #9a9d95) calc(50% + 1px), transparent calc(50% + 1px));
    }
    .pdp-swatch-wrap--oos:hover { transform: none; }
    .pdp-swatch-wrap--oos:hover .pdp-swatch { border-color: transparent; box-shadow: none; }
    .pdp-swatch-wrap--oos .pdp-swatch-label {
      text-decoration: line-through;
      color: var(--brand-muted, #9a9d95);
    }

    /* === MOBILE — większe kafelki kolorów, grid 3-col, full-width ===
       Desktop: flex circles 40px. Mobile: tile cards z paddingiem i borderem,
       większe kółko 56px, label większy. Layout grid 3 kolumny full-width
       żeby wyglądały "jak sekcja z gifami" (na całą szerokość). */
    @media (max-width: 640px) {
      .pdp-swatches {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        width: 100%;
      }
      .pdp-swatch-wrap {
        background: var(--brand-surface);
        border: 1.5px solid var(--brand-border);
        border-radius: 14px;
        padding: 14px 8px 12px;
        gap: 10px;
        transition: background 200ms ease, border-color 200ms ease, transform 150ms;
      }
      .pdp-swatch-wrap:hover { transform: none; }
      .pdp-swatch-wrap--active {
        background: var(--brand-primary-soft);
        border-color: var(--brand-primary);
      }
      .pdp-swatch {
        width: 56px;
        height: 56px;
      }
      .pdp-swatch-wrap--active .pdp-swatch {
        box-shadow: 0 0 0 3px #fff, 0 0 0 5px var(--brand-primary);
      }
      .pdp-swatch-label {
        font-size: 12px;
        letter-spacing: 0.02em;
      }
    }

    /* --- Stitch PILLS (size / set / fallback) --- */
    .pdp-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .pdp-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 24px;
      background: var(--brand-surface);
      border: 2px solid var(--brand-border);
      border-radius: 9999px;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.03em;
      color: var(--brand-text);
      cursor: pointer;
      transition: all 200ms;
      min-height: 40px;
    }
    .pdp-pill:hover {
      border-color: var(--brand-primary);
      color: var(--brand-heading);
    }
    button.pdp-pill {
      font-family: 'Outfit', sans-serif;
    }
    .pdp-pill--active,
    .pdp-pill-radio:has(input:checked) .pdp-pill {
      border-color: var(--brand-primary);
      background: var(--brand-primary-soft);
      color: var(--brand-primary-hover);
    }
    .pdp-pill-radio--disabled .pdp-pill {
      opacity: 0.4;
      cursor: not-allowed;
      text-decoration: line-through;
    }
    /* Pill rozmiaru wyprzedany (optionGroups path) */
    .pdp-pill--oos {
      opacity: 0.45;
      cursor: not-allowed;
      text-decoration: line-through;
    }
    .pdp-pill--oos:hover { border-color: var(--brand-border); color: var(--brand-text); }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* Quantity + ATC row */
    .pdp-qty-row {
      display: flex;
      gap: 12px;
      align-items: stretch;
    }
    .pdp-qty-control {
      display: flex;
      align-items: center;
      background: var(--brand-surface-2);
      border: 1px solid var(--brand-border);
      border-radius: 9999px;
      padding: 4px;
      gap: 4px;
    }
    .pdp-qty-btn {
      width: 40px;
      height: 40px;
      border-radius: 9999px;
      background: transparent;
      border: none;
      color: var(--brand-heading);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 200ms;
    }
    .pdp-qty-btn:hover { background: var(--brand-surface); }
    .pdp-qty-btn .material-symbols-outlined { font-size: 20px !important; }
    .pdp-qty-btn .pdp-svg-icon { width: 18px; height: 18px; }
    .pdp-qty-input {
      width: 36px;
      background: transparent;
      border: none;
      text-align: center;
      font-family: 'Outfit', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: var(--brand-heading);
      -moz-appearance: textfield;
    }
    .pdp-qty-input::-webkit-outer-spin-button,
    .pdp-qty-input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    .pdp-atc {
      flex: 1;
      background: var(--brand-primary);
      color: #FFFFFF;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.04em;
      padding: 16px 20px;
      border: none;
      border-radius: 9999px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 6px 20px rgba(116, 151, 191, 0.25);
      transition: background 280ms ease, color 200ms ease, box-shadow 280ms ease, transform 100ms;
      min-height: 56px;
      text-align: center;
      line-height: 1.2;
    }
    .pdp-atc-text {
      transition: color 200ms ease;
    }
    .pdp-atc:hover {
      filter: brightness(0.95);
    }
    /* Default hover only when color NOT overridden via JS */
    .pdp-atc:not([data-color-applied="1"]):hover {
      background: var(--brand-primary-hover);
      box-shadow: 0 8px 24px rgba(116, 151, 191, 0.35);
      filter: none;
    }
    .pdp-atc:active { transform: scale(0.98); }
    .pdp-atc .material-symbols-outlined { font-size: 20px !important; }
    .pdp-atc .pdp-svg-icon { width: 20px; height: 20px; color: currentColor; }
    .pdp-atc--disabled {
      background: var(--brand-border-strong);
      color: var(--brand-muted);
      cursor: not-allowed;
      box-shadow: none;
    }
    .pdp-atc--disabled:hover {
      background: var(--brand-border-strong);
      box-shadow: none;
    }

    /* Variant selection hint — NAD qty/ATC, czerwony pulsujący box. Widoczny gdy
       user nie wybrał wszystkich opcji. Mocna stylizacja: prominent border, animation,
       większa typografia żeby był ZAWSZE widoczny na mobile. */
    .pdp-variant-hint {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 4px 0 14px;
      padding: 12px 16px;
      background: var(--brand-accent-soft);
      border: 1.5px solid var(--brand-accent);
      border-radius: 14px;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--brand-accent);
      letter-spacing: 0.01em;
      animation: pdp-hint-pulse 1.6s ease-in-out infinite;
      box-shadow: 0 4px 14px rgba(230, 57, 70, 0.15);
    }
    .pdp-variant-hint[hidden] { display: none; }
    .pdp-variant-hint .material-symbols-outlined {
      font-size: 20px !important;
      color: var(--brand-accent);
      font-variation-settings: 'FILL' 1;
      flex-shrink: 0;
    }
    .pdp-variant-hint .pdp-svg-icon { width: 20px; height: 20px; color: var(--brand-accent); flex-shrink: 0; }
    @keyframes pdp-hint-pulse {
      0%, 100% { box-shadow: 0 4px 14px rgba(230, 57, 70, 0.15), 0 0 0 0 rgba(230, 57, 70, 0); }
      50%      { box-shadow: 0 4px 14px rgba(230, 57, 70, 0.15), 0 0 0 6px rgba(230, 57, 70, 0.10); }
    }

    /* Needs-selection — dimmed sage, "help" cursor, smooth text swap */
    .pdp-atc--needs-selection {
      background: var(--brand-primary);
      color: #FFFFFF;
      opacity: 0.78;
      cursor: help;
      box-shadow: 0 4px 14px rgba(116, 151, 191, 0.20);
    }
    .pdp-atc--needs-selection:hover {
      opacity: 1;
      background: var(--brand-primary-hover);
      box-shadow: 0 6px 18px rgba(116, 151, 191, 0.30);
      filter: none;
    }
    .pdp-atc--needs-selection .pdp-atc-text {
      transition: opacity 180ms ease;
    }

    /* Shake animation gdy user kliknie ATC bez pełnego wyboru */
    .pdp-atc--shake {
      animation: pdp-shake 480ms cubic-bezier(0.36, 0.07, 0.19, 0.97);
    }
    @keyframes pdp-shake {
      10%, 90% { transform: translate3d(-1px, 0, 0); }
      20%, 80% { transform: translate3d(2px, 0, 0); }
      30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
      40%, 60% { transform: translate3d(4px, 0, 0); }
    }

    .pdp-shipping-urgency {
      color: var(--brand-primary-hover);
      font-size: 13px;
      font-weight: 600;
      margin: 0;
    }

    /* Hero trust 4-col */
    .pdp-hero-trust {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      padding-top: 20px;
      margin-top: 12px;
      border-top: 1px solid var(--brand-border);
    }
    .pdp-hero-trust-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      text-align: center;
      font-size: 11px;
      color: var(--brand-text);
      line-height: 1.3;
    }
    @media (min-width: 768px) {
      .pdp-hero-trust-item { font-size: 13px; }
    }
    .pdp-hero-trust-item .material-symbols-outlined {
      color: var(--brand-primary);
      font-size: 24px !important;
    }

    /* ==========================================
       2. TRUST STRIP
       ========================================== */
    .pdp-trust-strip {
      background: var(--brand-surface);
      border-top: 1px solid var(--brand-border);
      border-bottom: 1px solid var(--brand-border);
      padding: 24px 0;
    }
    .pdp-trust-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (min-width: 768px) {
      .pdp-trust-grid { grid-template-columns: repeat(4, 1fr); }
    }
    .pdp-trust-item {
      display: flex;
      align-items: center;
      gap: 12px;
      justify-content: center;
    }
    .pdp-trust-item .material-symbols-outlined {
      color: var(--brand-primary);
      font-size: 28px !important;
    }
    .pdp-trust-item span:last-child {
      font-size: 14px;
      font-weight: 700;
      color: var(--brand-heading);
    }

    /* ==========================================
       Sections — shared
       ========================================== */
    .pdp-section {
      padding: 64px 0;
    }
    @media (min-width: 768px) {
      .pdp-section { padding: 88px 0; }
    }
    .pdp-section-head {
      text-align: center;
      margin-bottom: 48px;
    }

    /* ==========================================
       3. PROBLEM AGITATION
       ========================================== */
    .pdp-section--problem {
      background: var(--brand-surface);
      border-bottom: 1px solid var(--brand-border);
    }
    .pdp-section--problem .pdp-narrow {
      text-align: center;
    }

    /* ==========================================
       4. SOLUTION 3-step
       ========================================== */
    .pdp-section--solution {
      background: var(--brand-primary-soft);
      border-bottom: 1px solid var(--brand-border);
    }
    .pdp-3-step {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
    }
    @media (min-width: 768px) {
      .pdp-3-step { grid-template-columns: repeat(3, 1fr); }
    }
    .pdp-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
    }
    .pdp-step-icon {
      width: 72px;
      height: 72px;
      background: var(--brand-surface);
      border: 2px solid var(--brand-primary);
      border-radius: 9999px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .pdp-step-icon .material-symbols-outlined {
      color: var(--brand-primary);
      font-size: 32px !important;
    }
    .pdp-step-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0;
    }
    .pdp-step-desc {
      font-size: 14px;
      color: var(--brand-text);
      max-width: 240px;
      margin: 0;
    }

    /* ==========================================
       5. FEATURES (product description)
       ========================================== */
    .pdp-section--features {
      background: var(--brand-surface);
      border-bottom: 1px solid var(--brand-border);
    }
    .pdp-description-card {
      background: var(--brand-bg);
      border: 1px solid var(--brand-border);
      border-radius: 24px;
      padding: 20px 16px;
      max-width: 800px;
      margin: 0 auto;
    }
    @media (min-width: 768px) {
      .pdp-description-card { padding: 32px; }
    }
    /* Mobile word-wrap fix — długie polskie słowa (np. "obgryzanie",
       "magnetyczne") mogły wystawać poza container i być ucinane przez
       overflow-x: clip na body. word-wrap + hyphens łamie wyrazy zamiast
       cięcia po prawej krawędzi. */
    .pdp-prose {
      color: var(--brand-text);
      font-size: 16px;
      line-height: 1.7;
      word-wrap: break-word;
      overflow-wrap: break-word;
      hyphens: auto;
      -webkit-hyphens: auto;
    }
    .pdp-prose h2, .pdp-prose h3, .pdp-prose h4 {
      color: var(--brand-heading);
      margin-top: 24px;
      margin-bottom: 12px;
    }
    .pdp-prose p { margin: 0 0 16px; }
    .pdp-prose ul { padding-left: 20px; }
    .pdp-prose li { margin-bottom: 8px; }
    .pdp-prose strong { color: var(--brand-heading); }

    /* ==========================================
       6. STATS
       ========================================== */
    .pdp-section--stats {
      background: var(--brand-bg);
      padding: 48px 0;
    }
    .pdp-stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .pdp-stat {
      text-align: center;
      padding: 0 16px;
      border-right: 1px solid var(--brand-border);
    }
    .pdp-stat:last-child { border-right: none; }
    .pdp-stat-value {
      font-family: 'Outfit', sans-serif;
      font-size: 32px;
      font-weight: 800;
      color: var(--brand-primary);
      line-height: 1.1;
    }
    @media (min-width: 768px) {
      .pdp-stat-value { font-size: 48px; }
    }
    .pdp-stat-label {
      font-size: 13px;
      color: var(--brand-text);
      margin-top: 4px;
    }

    /* ==========================================
       7. UGC GRID
       ========================================== */
    .pdp-section--ugc {
      background: var(--brand-surface);
      border-top: 1px solid var(--brand-border);
      border-bottom: 1px solid var(--brand-border);
    }
    .pdp-ugc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    @media (min-width: 768px) {
      .pdp-ugc-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
      }
    }
    .pdp-ugc-tile {
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 16px;
      background: var(--brand-surface-2);
    }
    .pdp-ugc-tile--tall {
      grid-row: span 2;
      aspect-ratio: 3 / 4;
    }
    @media (max-width: 767px) {
      .pdp-ugc-tile--tall { grid-row: auto; aspect-ratio: 1 / 1; }
    }
    .pdp-ugc-tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 400ms ease;
    }
    .pdp-ugc-tile:hover img { transform: scale(1.05); }

    /* ==========================================
       8. REVIEWS
       ========================================== */
    .pdp-section--reviews {
      background: var(--brand-primary-soft);
      border-bottom: 1px solid var(--brand-border);
    }
    .pdp-reviews-layout {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    @media (min-width: 768px) {
      .pdp-reviews-layout {
        flex-direction: row;
        gap: 48px;
        align-items: flex-start;
      }
    }
    .pdp-review-summary {
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 24px;
      padding: 24px;
      width: 100%;
    }
    @media (min-width: 768px) {
      .pdp-review-summary { width: 320px; flex-shrink: 0; }
    }
    .pdp-review-score {
      display: flex;
      align-items: flex-end;
      gap: 12px;
      margin: 12px 0 24px;
    }
    .pdp-score-big {
      font-family: 'Outfit', sans-serif;
      font-size: 48px;
      font-weight: 800;
      color: var(--brand-heading);
      line-height: 1;
    }
    .pdp-review-bars {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .pdp-review-bar {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 12px;
      color: var(--brand-text);
    }
    .pdp-review-bar > span:first-child { width: 24px; }
    .pdp-review-bar > span:last-child { width: 32px; text-align: right; color: var(--brand-muted); }
    .pdp-bar-track {
      flex: 1;
      height: 8px;
      background: var(--brand-surface-2);
      border-radius: 9999px;
      overflow: hidden;
    }
    .pdp-bar-fill {
      height: 100%;
      background: var(--brand-primary);
    }

    .pdp-review-list {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .pdp-review-card {
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 20px;
      padding: 20px;
    }
    .pdp-review-card-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 12px;
    }
    .pdp-review-verified {
      display: flex;
      align-items: center;
      gap: 4px;
      margin-bottom: 4px;
      font-size: 11px;
      font-weight: 700;
      color: var(--brand-primary);
    }
    .pdp-review-verified .material-symbols-outlined { font-size: 14px !important; }
    .pdp-review-date {
      font-size: 12px;
      color: var(--brand-muted);
    }
    .pdp-review-author {
      font-size: 14px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 0 0 4px;
    }
    .pdp-review-tag {
      font-weight: 500;
      color: var(--brand-muted);
      font-size: 12.5px;
    }
    .pdp-review-title {
      font-size: 14.5px;
      font-weight: 700;
      color: var(--brand-heading);
      margin: 6px 0 6px;
      letter-spacing: -0.005em;
      line-height: 1.3;
    }
    .pdp-review-text {
      font-size: 14px;
      line-height: 1.6;
      color: var(--brand-text);
      margin: 0;
    }

    /* ==========================================
       9. FAQ
       ========================================== */
    .pdp-section--faq {
      background: var(--brand-bg);
    }
    .pdp-section--faq .pdp-narrow { text-align: left; max-width: 760px; }
    .pdp-section--faq .pdp-section-head { text-align: center; }
    .pdp-faq-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .pdp-faq-item {
      background: var(--brand-surface);
      border: 1px solid var(--brand-border);
      border-radius: 16px;
      overflow: hidden;
      transition: border-color 200ms;
    }
    .pdp-faq-item[open] {
      border-color: var(--brand-primary);
    }
    .pdp-faq-item summary {
      padding: 18px 22px;
      font-family: 'Outfit', sans-serif;
      font-size: 15px;
      font-weight: 600;
      color: var(--brand-heading);
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .pdp-faq-item summary::-webkit-details-marker { display: none; }
    .pdp-faq-item summary .material-symbols-outlined {
      color: var(--brand-primary);
      transition: transform 200ms;
    }
    .pdp-faq-item[open] summary .material-symbols-outlined {
      transform: rotate(180deg);
    }
    .pdp-faq-item p {
      padding: 0 22px 18px;
      font-size: 14px;
      color: var(--brand-text);
      line-height: 1.6;
      margin: 0;
    }

    /* ==========================================
       10. FINAL CTA
       ========================================== */
    .pdp-section--final-cta {
      background: var(--brand-surface);
      border-top: 1px solid var(--brand-border);
    }
    .pdp-cta-card {
      background: linear-gradient(135deg, var(--brand-heading) 0%, #3F4339 100%);
      border-radius: 32px;
      padding: 48px 32px;
      text-align: center;
      color: var(--brand-inverse);
      box-shadow: var(--shadow-lg);
    }
    @media (min-width: 768px) {
      .pdp-cta-card { padding: 64px 48px; }
    }
    .pdp-cta-h2 {
      font-family: 'Outfit', sans-serif;
      font-size: 32px;
      font-weight: 800;
      color: var(--brand-inverse);
      margin: 0 0 16px;
    }
    @media (min-width: 768px) {
      .pdp-cta-h2 { font-size: 42px; }
    }
    .pdp-cta-lead {
      font-size: 16px;
      line-height: 1.6;
      color: rgba(255, 252, 247, 0.85);
      max-width: 480px;
      margin: 0 auto 32px;
    }
    .pdp-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--brand-accent);
      color: #FFFFFF;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 0.05em;
