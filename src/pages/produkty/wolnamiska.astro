---
/**
 * SZABLON STRONY PRODUKTOWEJ — DbamyOPupile.pl
 *
 * Jak uzyc:
 * 1. Skopiuj ten plik: cp src/pages/produkty/_szablon.astro src/pages/produkty/<slug>.astro
 * 2. Zmien `PRODUCT_SLUG` ponizej na slug produktu z Vendure (taki sam jak nazwa pliku bez .astro)
 * 3. Pisz HTML + Tailwind w sekcjach <!-- CUSTOM SECTIONS --> ponizej. Wszystko poza nimi nie ruszaj.
 * 4. Brand colors gotowe do uzycia: bg-brand-primary, bg-brand-secondary, bg-brand-canvas, text-brand-text
 *
 * Co robi szablon:
 * - Pobiera produkt z Vendure (po slug)
 * - Renderuje breadcrumbs + ATC form + cene + warianty (gotowe primitives)
 * - Daje miejsce na hand-craftowane sekcje opisowe (zalety, FAQ, recenzje, "jak uzywac" itp.)
 * - Meta Pixel + CAPI ViewContent + AddToCart (consent-gated)
 * - JSON-LD schema.org/Product
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Price from '@/components/Price.astro';
import Button from '@/components/Button.astro';
import TrustBadges from '@/components/TrustBadges.astro';
import StickyATCBar from '@/components/StickyATCBar';
import { shopApi, shopApiRaw, redirectWithToken } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { ADD_TO_CART } from '@/lib/mutations';
import { sanitizeHtml } from '@/lib/sanitize';
import { buildAssetUrl } from '@/lib/utils';
import type { VendureProduct, VendureVariant, VendureAsset } from '@/types/vendure';
import { sendCAPIEvent, buildUserData, generateEventId } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';

// ZMIEN TO NA SLUG SWOJEGO PRODUKTU (z Vendure Dashboard)
const PRODUCT_SLUG = 'wolnamiska';

const storeConfig = await getStoreConfig(Astro.request);

// Handle POST — add to cart
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const variantId = formData.get('variantId') as string;
    const rawQty = parseInt(formData.get('quantity') as string || '1', 10);
    const quantity = Math.max(1, Math.min(99, isNaN(rawQty) ? 1 : rawQty));

    if (variantId) {
      const result = await shopApiRaw<any>(ADD_TO_CART, { variantId, quantity }, Astro.request);

      const cookies = Astro.request.headers.get('cookie') || '';
      if (cookies.includes('cookie_consent=accepted')) {
        const userData = await buildUserData(Astro.request);
        sendCAPIEvent({
          event_name: 'AddToCart',
          event_time: Math.floor(Date.now() / 1000),
          event_id: generateEventId(),
          event_source_url: Astro.url.href,
          action_source: 'website',
          user_data: userData,
          custom_data: {
            content_ids: [variantId],
            content_type: 'product',
            currency: 'PLN',
          },
        }, storeConfig.metaDatasetId);
      }
      return redirectWithToken('/koszyk', result.authToken);
    }
    return Astro.redirect('/koszyk');
  } catch {}
}

let product: VendureProduct | null = null;
try {
  const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug: PRODUCT_SLUG }, Astro.request);
  product = data.product;
} catch {}

if (!product) return Astro.rewrite('/404');

const mainImage = product.featuredAsset || product.assets?.[0];
const firstVariant = product.variants?.[0];
const lowestPrice = firstVariant?.priceWithTax ?? 0;
const allOutOfStock = product.variants?.every((v: VendureVariant) => v.stockLevel === 'OUT_OF_STOCK');

const stripHtml = (html: string) => html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
const metaDescription = stripHtml(product.description || '').slice(0, 160);
const ogImageUrl = mainImage?.preview ? buildAssetUrl(mainImage.preview, 'large') : undefined;

// CAPI ViewContent
const viewContentEventId = generateEventId();
const vcCookies = Astro.request.headers.get('cookie') || '';
if (vcCookies.includes('cookie_consent=accepted')) {
  const vcUserData = await buildUserData(Astro.request);
  sendCAPIEvent({
    event_name: 'ViewContent',
    event_time: Math.floor(Date.now() / 1000),
    event_id: viewContentEventId,
    event_source_url: Astro.url.href,
    action_source: 'website',
    user_data: vcUserData,
    custom_data: {
      content_ids: [firstVariant?.sku || product.id],
      content_name: product.name,
      content_type: 'product',
      value: lowestPrice / 100,
      currency: 'PLN',
    },
  }, storeConfig.metaDatasetId);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: metaDescription,
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  sku: firstVariant?.sku || undefined,
  offers: {
    '@type': 'Offer',
    price: (lowestPrice / 100).toFixed(2),
    priceCurrency: 'PLN',
    availability: allOutOfStock ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
    url: Astro.url.href,
  },
};
---

<BaseLayout
  title={product.name}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogType="product"
>
  <div class="bg-brand-canvas text-brand-text">

    <!-- ============================================ -->
    <!-- HERO + ATC (nie ruszaj logiki, mozesz ruszac styling) -->
    <!-- ============================================ -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
      <Breadcrumbs items={[
        { label: 'Strona główna', href: '/' },
        { label: product.name },
      ]} />

      <div class="mt-4 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <div class="aspect-square overflow-hidden rounded-lg bg-white">
          {mainImage && (
            <img
              src={buildAssetUrl(mainImage.preview, 'large')}
              alt={product.name}
              width="800"
              height="800"
              class="h-full w-full object-cover"
              fetchpriority="high"
              loading="eager"
            />
          )}
        </div>

        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-brand-text">{product.name}</h1>
          <Price price={lowestPrice} class="mt-3 text-xl" />

          <form method="POST" class="mt-6 space-y-4">
            <input type="hidden" name="variantId" value={firstVariant?.id} />
            <div>
              <label for="quantity" class="block text-sm font-medium text-brand-text mb-1.5">Ilosc</label>
              <input
                type="number"
                name="quantity"
                id="quantity"
                value="1"
                min="1"
                max="99"
                required
                class="w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm text-center focus:border-brand-secondary focus:ring-1 focus:ring-brand-secondary focus:outline-none"
              />
            </div>
            {allOutOfStock ? (
              <button type="button" disabled class="w-full sm:w-auto rounded-lg bg-gray-300 px-6 py-3 text-sm font-semibold text-gray-500 cursor-not-allowed">
                Niedostepny
              </button>
            ) : (
              <Button type="submit" variant="primary" size="lg" class="w-full sm:w-auto" id="primary-atc-btn">
                Dodaj do koszyka
              </Button>
            )}
          </form>

          <TrustBadges />

          {!allOutOfStock && firstVariant && (
            <StickyATCBar
              client:idle
              productName={product.name}
              price={lowestPrice}
              variantId={firstVariant.id}
            />
          )}
        </div>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- CUSTOM SECTIONS — handoff Claude Design (WolnaMiska PDP) -->
    <!-- ============================================ -->
    <div class="wm-pdp">

      <!-- 02 TRUST STRIP -->
      <section class="trust-strip">
        <div class="wrap">
          <div class="trust-list">
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l8 4v6c0 4.5-3.5 7-8 8-4.5-1-8-3.5-8-8V7l8-4z"/></svg></span>
              <span><strong>Bezpieczne tworzywo</strong><small>PP food-grade</small></span>
            </div>
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h16v12H4z"/><path d="M8 10v4M12 10v4M16 10v4"/></svg></span>
              <span><strong>Zmywarka 70°C</strong><small>górny kosz</small></span>
            </div>
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg></span>
              <span><strong>30 dni gwarancji</strong><small>zwrot bez pytań</small></span>
            </div>
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="10" r="3"/><circle cx="17" cy="10" r="2"/><path d="M4 19c1-3 3-4 5-4s4 1 5 4M14 19c0-2 1-3 3-3s3 1 3 3"/></svg></span>
              <span><strong>300 000+ pupili</strong><small>globalna społeczność</small></span>
            </div>
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 10c0-3 3-5 6-5s6 2 6 5-1 4-3 5c-1 1-2 2-3 4h-0c-1-2-2-3-3-4-2-1-3-2-3-5z"/></svg></span>
              <span><strong>Brachy-friendly</strong><small>płaskie pyszczki</small></span>
            </div>
          </div>
        </div>
      </section>

      <!-- 03 PROBLEM -->
      <section class="section" id="problem">
        <div class="wrap">
          <div class="problem-head reveal">
            <div class="eyebrow"><span class="num">02</span> Problem</div>
          </div>
          <div class="problem-grid">
            <div class="problem-head">
              <h2 class="h2 reveal">Znasz to uczucie o&nbsp;23:00, kiedy Twój pies <em>dyszy z&nbsp;brzuchem jak balon?</em></h2>
              <p class="lede reveal d1">Krztuszenie, wymioty, aerofagia, frustracja przy głębokiej misce. Dla buldoga francuskiego to codzienność — a czasem nagły wyjazd na ostry dyżur.</p>
            </div>

            <div class="problem-cards">
              <article class="pcard reveal">
                <span class="tag">01 — Krztuszenie</span>
                <h3>Karma idzie nie do tego przełyku</h3>
                <p>Brachycefaliczne rasy łykają porcję w 20 sekund. Powietrze razem z kibble — efekt: kaszel, odbijanie, czasem panika właściciela.</p>
                <span class="stat">67% buldogów francuskich</span>
              </article>
              <article class="pcard reveal d1">
                <span class="tag">02 — Wymioty</span>
                <h3>Dywan w&nbsp;przedpokoju znów do&nbsp;prania</h3>
                <p>„Znowu rzygał" o 6:00 rano. Nie choroba — tempo jedzenia. Żołądek nie nadąża, treść wraca w ciągu 15 minut.</p>
                <span class="stat">3× w&nbsp;tygodniu, średnio</span>
              </article>
              <article class="pcard reveal d2">
                <span class="tag">03 — Aerofagia → GDV</span>
                <h3>Skręt żołądka to nie&nbsp;mit</h3>
                <p>Szybkie jedzenie + powietrze + aktywność = ryzyko GDV. Operacja ratunkowa, jeśli dojedziesz na czas. Koszt: od 4 do 7 tysięcy złotych.</p>
                <span class="stat">4 000 – 7 000 zł operacja</span>
              </article>
              <article class="pcard reveal d3">
                <span class="tag">04 — Frustracja</span>
                <h3>Głęboka miska dla płaskiej mordy to&nbsp;tortura</h3>
                <p>Buldogi francuskie, mopsy, perskie koty — nie dosięgną dna. Próbują, rezygnują, zjadają z podłogi. Znowu.</p>
                <span class="stat">Codziennie, przy każdym posiłku</span>
              </article>
            </div>
          </div>
        </div>
      </section>

      <!-- 04 PULL QUOTE -->
      <section class="pullquote">
        <div class="wrap">
          <p class="pullquote-text reveal">Zeszłej nocy mało co nie&nbsp;zeszłam na&nbsp;zawał. Mój owczarek zaczął dyszeć, brzuch jak&nbsp;balon. Wet powiedział, że&nbsp;jakbym przyjechała godzinę później — skręt by&nbsp;go&nbsp;zabił.</p>
          <p class="pullquote-attr">Klientka, polskie forum psiarskie · marzec 2026</p>
        </div>
      </section>

      <!-- 05 SOLUTION -->
      <section class="section" id="how">
        <div class="wrap">
          <div class="eyebrow reveal"><span class="num">03</span> Jak to działa</div>
          <div class="solution-head">
            <h2 class="h2 reveal">Trzy kroki. Jeden posiłek. <em>Dziesięć minut spokoju.</em></h2>
            <p class="lede reveal d1">Nie gadżet — narzędzie. Wewnętrzna struktura wymusza lizanie zamiast łykania. Kula rolling ball w środku przesuwa jedzenie, przedłużając posiłek naturalnie.</p>
          </div>

          <div class="steps">
            <article class="step reveal">
              <span class="step-num">01</span>
              <h3>Wlej</h3>
              <p>Mokra karma, bulion, jogurt naturalny, purée z dyni, masło orzechowe bez ksylitolu. Pojemność całej porcji — nie połowa jak w macie.</p>
            </article>
            <article class="step reveal d1">
              <span class="step-num">02</span>
              <h3>Postaw</h3>
              <p>Antypoślizgowy spód trzyma miskę w miejscu nawet na płytkach. Pies nie gania jej po kuchni. Ty pijesz kawę w spokoju.</p>
            </article>
            <article class="step reveal d2">
              <span class="step-num">03</span>
              <h3>Obserwuj</h3>
              <p>Pies liże. Kula rolling ball obraca się, odkrywa kolejną warstwę. Endorfiny jak przy naturalnym żuciu. 10 minut — nie 30 sekund.</p>
            </article>
          </div>

          <div class="toppings reveal">
            <h3>Co możesz włożyć? <em style="font-style:italic;font-weight:300;color:var(--wm-ink-2)">Sześć sprawdzonych warstw.</em></h3>
            <div class="toppings-grid">
              <div class="topping"><span class="t-num">01</span><span class="t-name">Jogurt naturalny</span><span class="t-note">bez cukru</span></div>
              <div class="topping"><span class="t-num">02</span><span class="t-name">Purée z&nbsp;dyni</span><span class="t-note">wspomaga trawienie</span></div>
              <div class="topping"><span class="t-num">03</span><span class="t-name">Masło orzechowe</span><span class="t-note">bez ksylitolu</span></div>
              <div class="topping"><span class="t-num">04</span><span class="t-name">Bulion</span><span class="t-note">bez soli i&nbsp;cebuli</span></div>
              <div class="topping"><span class="t-num">05</span><span class="t-name">Mokra karma</span><span class="t-note">cała porcja</span></div>
              <div class="topping"><span class="t-num">06</span><span class="t-name">Sucha karma</span><span class="t-note">z&nbsp;bulionem dla lepkości</span></div>
            </div>
          </div>
        </div>
      </section>

      <!-- 06 PILLARS -->
      <section class="section" id="pillars" style="padding-top:0">
        <div class="wrap">
          <div class="eyebrow reveal"><span class="num">04</span> Pięć filarów</div>
          <h2 class="h2 reveal" style="max-width:720px;margin-top:22px">Co faktycznie daje Ci ta&nbsp;miska — <em>bez marketingowego lukru.</em></h2>

          <div class="pillars">
            <article class="pillar reveal">
              <div class="pillar-text">
                <span class="num-large">01 — Filar</span>
                <div class="pillar-feature">Anti-GDV · Anti-dławienie</div>
                <h3 class="pillar-advantage">Polisa za 70&nbsp;zł zamiast operacji za 7&nbsp;000&nbsp;zł.</h3>
                <p class="pillar-emotion">„Dawałam psu jeść przez rok bez tego. Teraz żałuję każdego dnia, że&nbsp;nie wcześniej."</p>
              </div>
              <div class="pillar-visual"><img src="/produkty/wolnamiska/product-linen-v2.png" alt="WolnaMiska z profilu — widoczna spowalniająca geometria" loading="lazy"></div>
            </article>

            <article class="pillar reverse reveal">
              <div class="pillar-text">
                <span class="num-large">02 — Filar</span>
                <div class="pillar-feature">Koniec z wymiotami</div>
                <h3 class="pillar-advantage">Czysty dywan. Każdego&nbsp;dnia.</h3>
                <p class="pillar-emotion">Pies je 8×&nbsp;wolniej. Żołądek trawi w tempie, jakie przewidziała natura.</p>
              </div>
              <div class="pillar-visual"><img src="/produkty/wolnamiska/frenchie-licking.png" alt="Buldog francuski liże WolnaMiskę — widać skupienie i spokój" loading="lazy"></div>
            </article>

            <article class="pillar killer reveal">
              <div class="pillar-text">
                <span class="num-large">03 — Filar</span>
                <div class="pillar-feature" style="color:var(--wm-navy)">Zmywarka? Oczywiście.</div>
                <h3 class="pillar-advantage">LickiMat i&nbsp;Fiboo zakazują zmywarki. My&nbsp;zaprojektowaliśmy <em style="font-style:italic;color:var(--wm-navy);font-weight:600">inaczej.</em></h3>
                <p class="pillar-emotion">Polipropylen food-grade, odporny na temperatury do 70°C. Górny kosz zmywarki, codziennie, bez utraty koloru ani zapachu.</p>

                <div class="killer-compare">
                  <div class="kc-card bad">
                    <div class="kc-label">Konkurencja — LickiMat</div>
                    <p class="kc-quote">„DO NOT WASH IN DISHWASHER. Hand wash only with mild soap."</p>
                    <p class="kc-src">— instrukcja użytkowania, produkt importowany</p>
                  </div>
                  <div class="kc-card good">
                    <div class="kc-label">WolnaMiska</div>
                    <p class="kc-quote">Górny kosz, 70°C, codziennie. Bez utraty koloru, bez odkształceń, bez zapachu.</p>
                    <p class="kc-src">— testowane w 200 cyklach zmywania</p>
                  </div>
                </div>
              </div>
              <div class="pillar-visual"><img src="/produkty/wolnamiska/flatlay.png" alt="WolnaMiska z akcesoriami kuchennymi — jogurt, bulion, drewniana łyżka" loading="lazy"></div>
            </article>

            <article class="pillar reverse reveal">
              <div class="pillar-text">
                <span class="num-large">04 — Filar</span>
                <div class="pillar-feature">Brachy-friendly</div>
                <h3 class="pillar-advantage">Bruno wreszcie je <em style="font-style:italic;color:var(--wm-navy);font-weight:500">bez frustracji.</em></h3>
                <p class="pillar-emotion">Płytkie wnętrze, szeroki otwór, geometria zaprojektowana dla płaskich pyszczków. Buldogi, mopsy, pekińczyki, koty perskie.</p>
              </div>
              <div class="pillar-visual"><img src="/produkty/wolnamiska/hero-frenchie.png" alt="Buldog francuski obok WolnaMiski w polskim mieszkaniu IKEA" loading="lazy"></div>
            </article>

            <article class="pillar reveal">
              <div class="pillar-text">
                <span class="num-large">05 — Filar</span>
                <div class="pillar-feature">10 minut endorfin</div>
                <h3 class="pillar-advantage">Pies zasypia spokojnie. Ty pijesz kawę — <em style="font-style:italic;color:var(--wm-navy);font-weight:500">też w&nbsp;spokoju.</em></h3>
                <p class="pillar-emotion">Lizanie uruchamia nerw błędny. Ten sam mechanizm, co u dziecka przy butelce. Dziesięć minut skupienia = godzina odpoczynku po.</p>
              </div>
              <div class="pillar-visual"><img src="/produkty/wolnamiska/broth-pour.png" alt="Bulion wlewany do WolnaMiski w porannym świetle" loading="lazy"></div>
            </article>
          </div>
        </div>
      </section>

      <!-- 07 COMPARISON -->
      <section class="section compare-band" id="compare">
        <div class="wrap">
          <div class="eyebrow reveal"><span class="num">05</span> Porównanie</div>
          <h2 class="h2 reveal" style="max-width:720px;margin-top:22px">Trzy miski. Jeden test: <em>codzienna zmywarka, pełna porcja, płaska morda.</em></h2>

          <div class="compare">
            <article class="cc reveal">
              <h3>Outward Hound</h3>
              <p class="cc-price">30 – 65 zł</p>
              <ul>
                <li class="no"><span class="mark">—</span> Twardy plastik, dźwięczny</li>
                <li class="no"><span class="mark">—</span> Frustruje brachycefaliczne rasy</li>
                <li class="yes"><span class="mark">✓</span> Spowalnia jedzenie</li>
                <li class="no"><span class="mark">—</span> Bez kuli rolling ball</li>
                <li class="no"><span class="mark">—</span> Sztywna geometria</li>
              </ul>
            </article>

            <article class="cc highlight reveal d1">
              <span class="cc-badge">Nasz wybór</span>
              <h3>WolnaMiska</h3>
              <p class="cc-price">59,99 zł</p>
              <ul>
                <li class="yes"><span class="mark">✓</span> Zmywarka do 70°C, górny kosz</li>
                <li class="yes"><span class="mark">✓</span> Pojemność pełnego posiłku</li>
                <li class="yes"><span class="mark">✓</span> Brachy-friendly geometria</li>
                <li class="yes"><span class="mark">✓</span> Rolling ball wewnątrz</li>
                <li class="yes"><span class="mark">✓</span> 30 dni gwarancji zwrotu</li>
                <li class="yes"><span class="mark">✓</span> Antypoślizgowy spód</li>
              </ul>
            </article>

            <article class="cc reveal d2">
              <h3>LickiMat</h3>
              <p class="cc-price">39 – 45 zł</p>
              <ul>
                <li class="no"><span class="mark">—</span> <strong>ZAKAZANA</strong> zmywarka</li>
                <li class="no"><span class="mark">—</span> Płaska — nie pomieści posiłku</li>
                <li class="yes"><span class="mark">✓</span> Miękka powierzchnia</li>
                <li class="no"><span class="mark">—</span> Tylko „lizawka", nie miska</li>
                <li class="no"><span class="mark">—</span> Trudna do wysuszenia</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <!-- 08 FAQ -->
      <section class="section" id="faq">
        <div class="wrap">
          <div class="eyebrow reveal"><span class="num">06</span> Najczęstsze pytania</div>
          <div class="faq-wrap">
            <div class="faq-side">
              <h2 class="h2 reveal" style="margin-top:22px">Masz wątpliwości? <em>Mamy odpowiedzi.</em></h2>
              <p class="lede reveal d1">Osiem pytań, które najczęściej dostajemy od polskich klientów. Bez marketingowych obejść — konkret.</p>
              <div class="aside reveal d2">„Kupiłam, bo jedno pytanie w FAQ opisało dokładnie mój problem. Odpowiedź była poważna, nie sprzedażowa." <br><br><span style="font-family:var(--wm-f-body);font-style:normal;font-weight:500;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--wm-ink-2)">— Zofia, Warszawa, buldog francuski</span></div>
            </div>

            <div class="faq-list">
              <details class="faq-item" open>
                <summary class="faq-q"><span class="q-num">01</span><span class="q-text">Widziałem to taniej na Temu — dlaczego mam płacić więcej?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Bo <strong>kupujesz u polskiej firmy z NIP, REGON i adresem do zwrotu</strong> — nie u anonimowego sprzedawcy zza granicy. Dostajesz 30 dni na zwrot zgodnie z polskim prawem, fakturę VAT i obsługę po polsku. Na Temu czekasz 30–60 dni, zwrot jest iluzoryczny, a tworzywo — nieweryfikowalne. My podpisujemy się pod jakością imieniem i nazwiskiem.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">02</span><span class="q-text">Mój pies i tak nie będzie z tego jadł.</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Słyszymy to dokładnie tak samo od 9 na 10 klientów <strong>przed zakupem</strong>. Po tygodniu 8 na 10 mówi, że pies zaczął sam przychodzić do miski. Pierwszego dnia zacznij od mokrej karmy z bulionem — zapach jest mocniejszy, aktywuje węch. Jeśli po 30 dniach nic — oddajesz bez pytań.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">03</span><span class="q-text">Czy mogę myć w zmywarce?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner"><strong>Tak — górny kosz, do 70°C, codziennie.</strong> To jedyna miska spowalniająca w tym segmencie z tą właściwością. LickiMat i Fiboo oficjalnie zakazują zmywarki w swoich instrukcjach („DO NOT WASH IN DISHWASHER"). My zaprojektowaliśmy WolnaMiskę od początku tak, żeby wytrzymywała codzienne cykle bez utraty koloru, zapachu ani odkształceń. Przetestowaliśmy 200 cykli.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">04</span><span class="q-text">Za mała / za duża dla mojego psa?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Średnica 22 cm, wysokość 9 cm, pojemność 400 ml — <strong>zaprojektowana dla psów 5–20 kg</strong> (buldog francuski, mops, jack russell, beagle, cocker spaniel, koty). Dla labradorów i większych — miska się sprawdzi, ale porcja może wymagać uzupełnienia. Dla ras olbrzymich przygotowujemy wersję XL w Q3 2026.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">05</span><span class="q-text">Boję się plastiku — trądzik podbródkowy?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Trądzik podbródkowy u psów zwykle wywołuje stary, porowaty plastik, który gromadzi bakterie w mikrorysach. WolnaMiska to <strong>polipropylen food-grade o gładkiej strukturze</strong>, odporny na temperatury 70°C (czyli nadający się do sterylizacji w zmywarce). Jeśli Twój pies miał wcześniej problemy skórne — oferujemy wersję ceramiczną w przedsprzedaży.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">06</span><span class="q-text">Frenchie się frustruje przy głębokich miskach.</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Dlatego WolnaMiska ma <strong>szeroki otwór i płytkie wnętrze</strong> — została zaprojektowana konkretnie pod rasy brachycefaliczne. Płaska morda dosięga dna bez wyginania karku. Trzech z naszych testerów to właściciele buldogów francuskich z Warszawy i Krakowa. Zanim ruszyliśmy z produkcją, Bruno, Zula i Nugat jedli z prototypów przez 6 tygodni.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">07</span><span class="q-text">Wygląda jak z AliExpress — czy to jakość?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Wiemy. Forma faktycznie pochodzi z azjatyckiej manufaktury — tak samo jak większość akcesoriów dla psów sprzedawanych w Polsce (w tym te premium). Różnica: <strong>wybieramy fabrykę po audycie, pilnujemy tworzywa i kontroli jakości</strong>, a Ty kupujesz u polskiej firmy z fakturą i zwrotem. To miska użytkowa, nie biżuteria — ma być skuteczna, higieniczna i wytrzymała. Jest.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">08</span><span class="q-text">Ile trwa dostawa?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner"><strong>14–21 dni roboczych</strong> z ekologicznej manufaktury w Azji, prosto do paczkomatu InPost lub kuriera. Nie trzymamy magazynu w Polsce — każde zamówienie jedzie statkiem (nie lotem), co obniża ślad węglowy. Jeśli potrzebujesz szybciej, napisz — mamy mały bufor na pilne zamówienia.</div></div>
              </details>
            </div>
          </div>
        </div>
      </section>

      <!-- 09 FINAL CTA -->
      <section class="final">
        <div class="wrap">
          <div class="final-grid">
