      .wm-hero button.wm-atc.disabled:hover{background:var(--h-rule)}
      .wm-atc-text{font-weight:700;color:#ffffff}
      .wm-atc-price{font-family:var(--h-f-display);font-weight:700;font-size:20px;letter-spacing:-0.01em;color:#ffffff}
      .wm-atc-price::before{content:"";display:inline-block;width:1px;height:18px;background:oklch(1 0 0 / 0.28);margin-right:14px;vertical-align:middle}
      .wm-atc-arrow{width:20px;height:20px;color:#ffffff}

      /* Delivery promise */
      .wm-delivery-promise{display:flex;align-items:center;gap:10px;padding:12px 16px;background:oklch(0.85 0.055 235 / 0.18);border-radius:10px;font-family:var(--h-f-body);font-size:13px;line-height:1.45;color:var(--h-navy-2)}
      .wm-delivery-promise svg{width:20px;height:20px;flex-shrink:0;color:var(--h-navy)}
      .wm-delivery-promise strong{font-weight:700}

      /* Trust row — refined horizontal with dividers */
      .wm-trust-row{display:grid;grid-template-columns:repeat(2,1fr);gap:0;padding:18px 0;margin-top:4px;border-top:1px solid var(--h-rule-soft);border-bottom:1px solid var(--h-rule-soft)}
      @media(min-width:680px){.wm-trust-row{grid-template-columns:repeat(4,1fr)}}
      .wm-trust{display:flex;align-items:center;gap:11px;padding:8px 12px;border-right:1px solid var(--h-rule-soft);transition:opacity 200ms var(--h-ease)}
      .wm-trust:nth-child(2n){border-right:none}
      @media(min-width:680px){
        .wm-trust:nth-child(2n){border-right:1px solid var(--h-rule-soft)}
        .wm-trust:last-child{border-right:none}
      }
      .wm-trust:hover{opacity:0.85}
      .wm-trust-icon{flex-shrink:0;width:34px;height:34px;display:flex;align-items:center;justify-content:center;background:oklch(0.85 0.055 235 / 0.20);color:var(--h-navy);border-radius:9px}
      .wm-trust-icon svg{width:18px;height:18px}
      .wm-trust-text{display:flex;flex-direction:column;gap:1px;line-height:1.2;min-width:0}
      .wm-trust strong{font-family:var(--h-f-body);font-weight:600;font-size:12.5px;color:var(--h-ink);letter-spacing:-0.005em}
      .wm-trust small{font-family:var(--h-f-body);font-weight:400;font-size:11px;color:var(--h-ink-3);letter-spacing:0.005em}
      @media(max-width:520px){
        .wm-trust{padding:6px 8px;gap:9px}
        .wm-trust-icon{width:30px;height:30px}
        .wm-trust-icon svg{width:16px;height:16px}
        .wm-trust strong{font-size:11.5px}
        .wm-trust small{font-size:10.5px}
      }

      /* Accordions section (full-width, below hero) */
      .wm-acc-section{padding:clamp(28px, 4vw, 56px) 0;background:var(--h-canvas);border-top:1px solid var(--h-rule-soft)}
      .wm-acc-wrap{max-width:1240px;margin:0 auto;padding:0 clamp(16px, 4vw, 56px)}

      /* Accordions */
      .wm-accordions{display:flex;flex-direction:column;gap:8px;margin-top:0}
      .wm-acc{background:var(--h-white);border:1px solid var(--h-rule-soft);border-radius:12px;overflow:hidden;transition:border-color 200ms var(--h-ease), box-shadow 200ms var(--h-ease)}
      .wm-acc:hover{border-color:var(--h-blue)}
      .wm-acc[open]{border-color:var(--h-navy);box-shadow:var(--h-shadow-card)}
      .wm-acc summary{display:flex;align-items:center;gap:14px;padding:16px 18px;cursor:pointer;list-style:none;user-select:none;transition:background 200ms var(--h-ease)}
      .wm-acc summary::-webkit-details-marker{display:none}
      .wm-acc summary:hover{background:oklch(0.97 0.012 85)}
      .wm-acc-icon{flex-shrink:0;width:32px;height:32px;display:flex;align-items:center;justify-content:center;background:oklch(0.85 0.055 235 / 0.18);color:var(--h-navy);border-radius:8px}
      .wm-acc-icon svg{width:18px;height:18px}
      .wm-acc-title{flex:1;font-family:var(--h-f-body);font-weight:600;font-size:14.5px;color:var(--h-ink);letter-spacing:-0.005em}
      .wm-acc-chevron{flex-shrink:0;width:20px;height:20px;color:var(--h-ink-3);transition:transform 250ms var(--h-ease)}
      .wm-acc-chevron svg{width:100%;height:100%}
      .wm-acc[open] .wm-acc-chevron{transform:rotate(180deg);color:var(--h-navy)}
      .wm-acc-body{padding:0 18px 20px 64px;font-family:var(--h-f-body);font-size:14px;line-height:1.6;color:var(--h-ink-2);display:flex;flex-direction:column;gap:12px}
      .wm-acc-body p{margin:0}
      .wm-acc-body strong{color:var(--h-ink);font-weight:600}
      .wm-acc-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:7px}
      .wm-acc-list li{display:flex;gap:8px;padding-left:14px;position:relative;font-size:13.5px}
      .wm-acc-list li::before{content:"";position:absolute;left:0;top:9px;width:5px;height:5px;background:var(--h-navy);border-radius:50%}
      .wm-acc-note{font-size:12.5px;color:var(--h-ink-3);font-style:italic;padding-top:4px;border-top:1px dashed var(--h-rule-soft);margin-top:4px !important}
      @media(max-width:520px){
        .wm-acc summary{padding:14px 14px;gap:10px}
        .wm-acc-title{font-size:13.5px}
        .wm-acc-body{padding:0 14px 18px 52px;font-size:13.5px}
      }

      /* Mobile tweaks */
      @media(max-width:520px){
        .wm-title{font-size:24px}
        .wm-price{font-size:30px}
        .wm-atc{font-size:15px;padding:16px 22px}
        .wm-atc-price{font-size:17px}
      }

      .wm-pdp{
        --wm-canvas: oklch(0.972 0.012 85);
        --wm-ivory-2: oklch(0.955 0.015 82);
        --wm-navy: oklch(0.30 0.06 255);
        --wm-blue: oklch(0.85 0.055 235);
        --wm-ink: oklch(0.18 0.004 265);
        --wm-ink-2: oklch(0.40 0.01 265);
        --wm-rule: oklch(0.88 0.01 85);
        --wm-white: #ffffff;
        --wm-shadow-soft: 0 4px 16px oklch(0.30 0.06 255 / 0.08);
        --wm-shadow-lift: 0 12px 40px oklch(0.30 0.06 255 / 0.12);
        --wm-f-display: "Fraunces", "Iowan Old Style", Georgia, serif;
        --wm-f-body: "Inter", -apple-system, system-ui, sans-serif;
        --wm-wrap: 1240px;
        --wm-gutter: clamp(20px, 4vw, 56px);
        --wm-ease: cubic-bezier(0.16, 1, 0.3, 1);
        font-family: var(--wm-f-body);
        color: var(--wm-ink);
        background: var(--wm-canvas);
        line-height: 1.6;
        font-size: 16px;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      .wm-pdp *,.wm-pdp *::before,.wm-pdp *::after{box-sizing:border-box}
      .wm-pdp img{display:block;max-width:100%;height:auto}
      .wm-pdp button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
      .wm-pdp a{color:inherit;text-decoration:none}
      .wm-pdp p{margin:0}
      .wm-pdp h1,.wm-pdp h2,.wm-pdp h3,.wm-pdp h4,.wm-pdp h5{margin:0;font-family:var(--wm-f-display);font-weight:700;line-height:1.02;letter-spacing:-0.02em;color:var(--wm-ink)}

      .wm-pdp .wrap{max-width:var(--wm-wrap);margin:0 auto;padding-left:max(var(--wm-gutter), env(safe-area-inset-left));padding-right:max(var(--wm-gutter), env(safe-area-inset-right));box-sizing:border-box;width:100%}
      .wm-pdp .section{padding:clamp(48px, 6vw, 88px) 0}

      .wm-pdp .h2{font-family:var(--wm-f-display);font-weight:700;font-size:clamp(28px, 3.5vw, 44px);line-height:1.1;letter-spacing:-0.02em;max-width:720px}
      .wm-pdp .h2 + .lede{margin-top:18px}
      .wm-pdp .h2 + .bundle-lede{margin-top:18px}
      .wm-pdp .h2 + p{margin-top:18px}
      .wm-pdp .lede{font-family:var(--wm-f-body);font-weight:400;font-size:clamp(16px, 1.4vw, 19px);line-height:1.55;color:var(--wm-ink-2)}

      /* Trust strip */
      .wm-pdp .trust-strip{background:var(--wm-ivory-2);border-top:1px solid var(--wm-rule);border-bottom:1px solid var(--wm-rule);padding:clamp(28px,4vw,40px) 0}
      .wm-pdp .trust-list{display:grid;grid-template-columns:repeat(2,1fr);gap:32px 28px;align-items:center;font-size:14px;font-weight:600;color:var(--wm-ink)}
      @media(min-width:720px){.wm-pdp .trust-list{grid-template-columns:repeat(4,1fr);gap:40px 32px}}
      .wm-pdp .trust-item{display:flex;flex-direction:column;align-items:center;text-align:center;gap:14px}
      .wm-pdp .trust-icon{width:56px;height:56px;flex-shrink:0;border:1.5px solid var(--wm-navy);border-radius:50%;display:grid;place-items:center;color:var(--wm-navy);background:var(--wm-canvas)}
      .wm-pdp .trust-icon svg{width:28px;height:28px}
      .wm-pdp .trust-item strong{display:block;line-height:1.2}
      .wm-pdp .trust-item small{display:block;font-size:12px;color:var(--wm-ink-2);font-weight:600;letter-spacing:0.02em;margin-top:4px}

      /* Problem */
      .wm-pdp .problem-grid{display:grid;grid-template-columns:1fr;gap:clamp(32px, 4vw, 64px);align-items:start;margin-top:40px}
      @media(min-width:960px){.wm-pdp .problem-grid{grid-template-columns: 0.9fr 1.1fr}}
      .wm-pdp .problem-head .lede{margin-top:22px;max-width:520px}
      .wm-pdp .problem-cards{display:grid;grid-template-columns:1fr;gap:1px;background:var(--wm-rule);border:1px solid var(--wm-rule)}
      @media(min-width:640px){.wm-pdp .problem-cards{grid-template-columns:1fr 1fr}}
      .wm-pdp .pcard{background:var(--wm-canvas);padding:28px 26px 30px;display:flex;flex-direction:column;gap:12px;min-height:180px}
      .wm-pdp .pcard h3{font-family:var(--wm-f-body);font-weight:700;font-size:18px;letter-spacing:-0.005em;line-height:1.3}
      .wm-pdp .pcard p{font-size:14px;line-height:1.55;color:var(--wm-ink-2)}

      .wm-pdp .how-grid{display:grid;grid-template-columns:1fr;gap:28px;margin-top:48px}
      @media(min-width:680px){.wm-pdp .how-grid{grid-template-columns:repeat(2,1fr)}}
      @media(min-width:1100px){.wm-pdp .how-grid{grid-template-columns:repeat(4,1fr);gap:24px}}
      .wm-pdp .how-card{background:var(--wm-white);border:1px solid var(--wm-rule);display:flex;flex-direction:column;transition:transform 400ms var(--wm-ease), box-shadow 400ms var(--wm-ease)}
      .wm-pdp .how-card:hover{transform:translateY(-3px);box-shadow:var(--wm-shadow-lift)}
      .wm-pdp .how-media{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--wm-ivory-2)}
      .wm-pdp .how-media img{width:100%;height:100%;object-fit:cover;display:block}
      .wm-pdp .how-placeholder{position:absolute;top:12px;right:12px;background:rgba(30,58,95,0.85);color:var(--wm-canvas);font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:4px 8px;border-radius:3px}
      .wm-pdp .how-num{font-family:var(--wm-f-display);font-style:italic;font-weight:300;font-size:64px;line-height:1;color:var(--wm-navy);padding:24px 26px 0}
      .wm-pdp .how-card h3{font-family:var(--wm-f-body);font-weight:700;font-size:18px;letter-spacing:-0.005em;padding:8px 26px 0}
      .wm-pdp .how-card p{font-size:14.5px;color:var(--wm-ink-2);line-height:1.55;padding:12px 26px 28px}

      /* SOCIAL NUMBER */
      .wm-pdp .social-number{padding:clamp(36px,4.5vw,64px) 0;background:var(--wm-canvas)}
      .wm-pdp .sn-grid{display:grid;grid-template-columns:1fr;gap:24px;align-items:center;text-align:center}
      @media(min-width:780px){.wm-pdp .sn-grid{grid-template-columns:auto 1fr;gap:48px;text-align:left}}
      .wm-pdp .sn-big{font-family:var(--wm-f-display);font-weight:700;font-size:clamp(64px,9vw,120px);line-height:1;letter-spacing:-0.04em;color:var(--wm-navy)}
      .wm-pdp .sn-title{font-family:var(--wm-f-display);font-weight:700;font-size:clamp(20px,2.4vw,28px);line-height:1.2;color:var(--wm-ink);margin-bottom:8px}
      .wm-pdp .sn-sub{font-size:14.5px;color:var(--wm-ink-2);line-height:1.55;max-width:520px}
      @media(min-width:780px){.wm-pdp .sn-sub{margin:0}}

      /* REVIEWS */
      .wm-pdp .reviews-section{background:var(--wm-ivory-2);border-top:1px solid var(--wm-rule);border-bottom:1px solid var(--wm-rule)}
      .wm-pdp .reviews-head{display:flex;flex-direction:column;gap:14px;margin-bottom:48px}
      @media(min-width:780px){.wm-pdp .reviews-head{flex-direction:row;justify-content:space-between;align-items:flex-end}}
      .wm-pdp .reviews-rating{display:flex;flex-direction:column;gap:4px}
      .wm-pdp .rs-stars{color:#d97706;font-size:22px;letter-spacing:2px}
      .wm-pdp .rs-num{font-size:14px;color:var(--wm-ink-2)}
      .wm-pdp .reviews-grid{display:grid;grid-template-columns:1fr;gap:20px}
      @media(min-width:680px){.wm-pdp .reviews-grid{grid-template-columns:repeat(2,1fr)}}
      @media(min-width:1100px){.wm-pdp .reviews-grid{grid-template-columns:repeat(4,1fr);gap:18px}}
      .wm-pdp .review-card{background:var(--wm-white);padding:24px 22px;border:1px solid var(--wm-rule);display:flex;flex-direction:column;gap:14px}
      .wm-pdp .rc-stars{color:#d97706;font-size:16px;letter-spacing:2px}
      .wm-pdp .rc-text{font-size:15px;line-height:1.55;color:var(--wm-ink);font-style:italic}
      .wm-pdp .rc-author{font-size:13px;color:var(--wm-ink-2);margin-top:auto}
      .wm-pdp .rc-author strong{color:var(--wm-ink);font-weight:600}
      .wm-pdp .reviews-note{margin-top:32px;font-size:12px;color:var(--wm-ink-2);text-align:center;font-style:italic}

      /* BUNDLE */
      .wm-pdp .bundle-section{background:var(--wm-canvas)}
      .wm-pdp .bundle-lede{font-size:16px;color:var(--wm-ink-2);max-width:600px;line-height:1.55;margin:16px 0 40px}
      .wm-pdp .bundle-grid{display:grid;grid-template-columns:1fr;gap:24px}
      @media(min-width:780px){.wm-pdp .bundle-grid{grid-template-columns:repeat(3,1fr);align-items:stretch}}
      .wm-pdp .bundle-card{background:var(--wm-white);padding:32px 28px;border:1px solid var(--wm-rule);display:flex;flex-direction:column;gap:14px;position:relative;transition:transform 300ms var(--wm-ease), box-shadow 300ms var(--wm-ease)}
      .wm-pdp .bundle-card:hover{transform:translateY(-3px);box-shadow:var(--wm-shadow-lift)}
      .wm-pdp .bundle-card.popular{border:2px solid var(--wm-navy);transform:scale(1.02)}
      .wm-pdp .bc-badge{position:absolute;top:-12px;left:24px;background:var(--wm-navy);color:var(--wm-canvas);font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:5px 12px}
      .wm-pdp .bc-badge-free{background:#d97706}
      .wm-pdp .bc-qty{font-family:var(--wm-f-display);font-weight:700;font-size:32px;letter-spacing:-0.02em;color:var(--wm-ink)}
      .wm-pdp .bc-price{font-family:var(--wm-f-display);font-weight:700;font-size:36px;letter-spacing:-0.02em;color:var(--wm-navy)}
      .wm-pdp .bc-each{font-size:13px;color:var(--wm-ink-2)}
      .wm-pdp .bc-feat{list-style:none;padding:0;margin:8px 0 0;display:flex;flex-direction:column;gap:8px;font-size:14px;color:var(--wm-ink-2)}
      .wm-pdp .bc-feat li{position:relative;padding-left:20px}
      .wm-pdp .bc-feat li::before{content:"✓";position:absolute;left:0;color:var(--wm-navy);font-weight:700}
      .wm-pdp .bc-form{margin-top:auto;padding-top:14px}
      .wm-pdp .bc-btn{width:100%;padding:14px 20px;font-family:var(--wm-f-body);font-size:14px;font-weight:600;letter-spacing:0.02em;color:var(--wm-ink);background:var(--wm-canvas);border:1px solid var(--wm-ink);cursor:pointer;transition:all 200ms var(--wm-ease)}
      .wm-pdp .bc-btn:hover{background:var(--wm-ivory-2)}
      .wm-pdp .bc-btn-primary{background:var(--wm-navy);color:var(--wm-canvas);border-color:var(--wm-navy)}
      .wm-pdp .bc-btn-primary:hover{background:var(--wm-ink);border-color:var(--wm-ink)}

      .wm-pdp .features-grid{display:grid;grid-template-columns:1fr;gap:40px;margin-top:48px}
      @media(min-width:680px){.wm-pdp .features-grid{grid-template-columns:repeat(2,1fr)}}
      @media(min-width:1100px){.wm-pdp .features-grid{grid-template-columns:repeat(4,1fr);gap:32px}}
      .wm-pdp .feat{display:flex;flex-direction:column;gap:16px}
      .wm-pdp .feat-img{aspect-ratio:1/1;background:var(--wm-ivory-2);overflow:hidden}
      .wm-pdp .feat-img img{width:100%;height:100%;object-fit:cover}
      .wm-pdp .feat h3{font-family:var(--wm-f-body);font-weight:700;font-size:18px;letter-spacing:-0.005em;line-height:1.3}
      .wm-pdp .feat p{font-size:14.5px;color:var(--wm-ink-2);line-height:1.55}

      /* Comparison */
      .wm-pdp .compare-band{background:var(--wm-ivory-2);border-top:1px solid var(--wm-rule);border-bottom:1px solid var(--wm-rule)}
      .wm-pdp .compare{display:grid;grid-template-columns:1fr;gap:20px;margin-top:48px;align-items:stretch}
      @media(min-width:900px){.wm-pdp .compare{grid-template-columns:1fr 1.12fr 1fr;gap:20px;align-items:center}}
      .wm-pdp .cc{background:var(--wm-white);border:1px solid var(--wm-rule);padding:32px 28px 36px;display:flex;flex-direction:column}
      .wm-pdp .cc h3{font-family:var(--wm-f-body);font-weight:700;font-size:18px;margin-bottom:4px;letter-spacing:-0.005em}
      .wm-pdp .cc .cc-price{font-family:var(--wm-f-body);font-weight:600;color:var(--wm-ink-2);font-size:14px;margin-bottom:22px}
      .wm-pdp .cc ul{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px}
      .wm-pdp .cc li{font-size:14.5px;display:flex;gap:10px;align-items:flex-start;line-height:1.45}
      .wm-pdp .cc li .mark{flex-shrink:0;font-family:var(--wm-f-body);font-weight:700;font-size:14px;width:16px;line-height:1.45}
      .wm-pdp .cc li.yes .mark{color:var(--wm-navy)}
      .wm-pdp .cc li.no .mark{color:oklch(0.48 0.15 25)}
      .wm-pdp .cc li.no{color:var(--wm-ink-2)}
      .wm-pdp .cc.highlight{background:var(--wm-navy);color:var(--wm-canvas);border-color:var(--wm-navy);box-shadow:var(--wm-shadow-lift);padding:44px 30px 48px}
      @media(min-width:900px){.wm-pdp .cc.highlight{transform:scale(1.05)}}
      .wm-pdp .cc.highlight h3{color:var(--wm-canvas)}
      .wm-pdp .cc.highlight .cc-price{color:var(--wm-blue)}
      .wm-pdp .cc.highlight li.yes .mark{color:var(--wm-blue)}
      .wm-pdp .cc.highlight .cc-badge{align-self:flex-start;font-size:10px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--wm-blue);background:transparent;border:1px solid var(--wm-blue);padding:5px 11px;margin-bottom:18px}

      /* FAQ */
      .wm-pdp .faq-wrap{display:grid;grid-template-columns:1fr;gap:clamp(32px, 4vw, 64px);margin-top:40px;align-items:start}
      @media(min-width:960px){.wm-pdp .faq-wrap{grid-template-columns: 0.8fr 1.2fr}}
      .wm-pdp .faq-side .h2{max-width:420px}
      .wm-pdp .faq-side .lede{margin-top:22px;max-width:380px}
      .wm-pdp .faq-side .aside{margin-top:36px;padding:22px 24px;background:var(--wm-ivory-2);border-left:2px solid var(--wm-navy);font-family:var(--wm-f-body);font-weight:500;font-style:italic;font-size:15px;line-height:1.55;color:var(--wm-navy)}
      .wm-pdp .faq-list{border-top:1px solid var(--wm-ink)}
      .wm-pdp .faq-item{border-bottom:1px solid var(--wm-rule)}
      .wm-pdp .faq-item summary{list-style:none;cursor:pointer}
      .wm-pdp .faq-item summary::-webkit-details-marker{display:none}
      .wm-pdp .faq-q{display:flex;align-items:baseline;gap:20px;width:100%;padding:24px 0;text-align:left;transition:color 200ms var(--wm-ease)}
      .wm-pdp .faq-q .q-num{font-family:var(--wm-f-display);font-style:italic;font-weight:300;font-size:14px;color:var(--wm-navy);flex-shrink:0;width:36px}
      .wm-pdp .faq-q .q-text{flex:1;font-family:var(--wm-f-body);font-weight:600;font-size:clamp(15px, 1.3vw, 17px);line-height:1.4;letter-spacing:-0.005em}
      .wm-pdp .faq-q .q-icon{flex-shrink:0;width:20px;height:20px;position:relative;transition:transform 300ms var(--wm-ease);color:var(--wm-navy)}
      .wm-pdp .faq-q .q-icon::before,.wm-pdp .faq-q .q-icon::after{content:"";position:absolute;background:currentColor}
