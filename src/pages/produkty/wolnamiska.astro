    <!-- ============================================ -->
    <!-- CUSTOM SECTIONS — handoff Claude Design (WolnaMiska PDP) -->
    <!-- ============================================ -->
    <div class="wm-pdp">

      <!-- 02 TRUST STRIP -->
      <section class="trust-strip">
        <div class="wrap">
          <div class="trust-list">
            <div class="trust-item">
