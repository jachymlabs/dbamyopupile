      .wm-pdp .pillar-visual{aspect-ratio: 4 / 3;background:var(--wm-ivory-2);overflow:hidden;position:relative}
      .wm-pdp .pillar-visual img{width:100%;height:100%;object-fit:cover}
      .wm-pdp .pillar-feature{font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--wm-navy);display:flex;align-items:center;gap:12px}
      .wm-pdp .pillar-feature::before{content:"";width:24px;height:1px;background:var(--wm-navy)}
      .wm-pdp .pillar-advantage{font-family:var(--wm-f-display);font-weight:600;font-size:clamp(28px, 3.6vw, 48px);line-height:1.05;letter-spacing:-0.02em;margin:16px 0 18px;max-width:560px}
      .wm-pdp .pillar-emotion{font-family:var(--wm-f-display);font-weight:700;font-style:italic;font-size:clamp(18px, 1.9vw, 22px);line-height:1.35;color:var(--wm-navy);max-width:520px}
      .wm-pdp .pillar .num-large{font-family:var(--wm-f-display);font-style:italic;font-weight:300;font-size:15px;color:var(--wm-ink-2);letter-spacing:0;display:block;margin-bottom:4px}
      .wm-pdp .pillar.killer{background: var(--wm-canvas);border:1.5px solid var(--wm-navy);margin:24px 0;padding:clamp(40px,5vw,64px) clamp(28px,4vw,56px);position:relative;box-shadow:var(--wm-shadow-lift)}
      .wm-pdp .pillar.killer::before{content:"killer feature";position:absolute;top:-12px;left:clamp(24px,4vw,48px);background:var(--wm-navy);color:var(--wm-blue);font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;padding:6px 14px}
      .wm-pdp .killer-compare{display:grid;grid-template-columns:1fr;gap:12px;margin-top:24px}
      @media(min-width:640px){.wm-pdp .killer-compare{grid-template-columns:1fr 1fr}}
      .wm-pdp .kc-card{padding:20px 22px;border:1px solid var(--wm-rule);background:var(--wm-white);position:relative}
      .wm-pdp .kc-card.bad{background:oklch(0.97 0.015 30)}
      .wm-pdp .kc-card .kc-label{font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--wm-ink-2);margin-bottom:8px}
      .wm-pdp .kc-card .kc-quote{font-family:var(--wm-f-display);font-weight:600;font-size:18px;line-height:1.25;letter-spacing:-0.01em}
      .wm-pdp .kc-card.bad .kc-quote{color:oklch(0.42 0.12 30)}
      .wm-pdp .kc-card.good .kc-quote{color:var(--wm-navy)}
      .wm-pdp .kc-card .kc-src{font-size:11px;color:var(--wm-ink-2);margin-top:12px;font-style:italic}

      /* Comparison */
