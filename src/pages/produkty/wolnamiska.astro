      .wm-pdp .cc.highlight .cc-price{color:var(--wm-blue)}
      .wm-pdp .cc.highlight li.yes .mark{color:var(--wm-blue)}
      .wm-pdp .cc.highlight .cc-badge{align-self:flex-start;font-size:10px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:var(--wm-blue);background:transparent;border:1px solid var(--wm-blue);padding:5px 11px;margin-bottom:18px}

      /* FAQ */
      .wm-pdp .faq-wrap{display:grid;grid-template-columns:1fr;gap:clamp(32px, 4vw, 64px);margin-top:40px;align-items:start}
      @media(min-width:960px){.wm-pdp .faq-wrap{grid-template-columns: 0.8fr 1.2fr}}
      .wm-pdp .faq-side .h2{max-width:420px}
      .wm-pdp .faq-side .lede{margin-top:22px;max-width:380px}
      .wm-pdp .faq-side .aside{margin-top:36px;padding:22px 24px;background:var(--wm-ivory-2);border-left:2px solid var(--wm-navy);font-family:var(--wm-f-display);font-weight:500;font-style:italic;font-size:18px;line-height:1.35;color:var(--wm-navy)}
      .wm-pdp .faq-list{border-top:1px solid var(--wm-ink)}
      .wm-pdp .faq-item{border-bottom:1px solid var(--wm-rule)}
      .wm-pdp .faq-item summary{list-style:none;cursor:pointer}
      .wm-pdp .faq-item summary::-webkit-details-marker{display:none}
      .wm-pdp .faq-q{display:flex;align-items:baseline;gap:20px;width:100%;padding:24px 0;text-align:left;transition:color 200ms var(--wm-ease)}
      .wm-pdp .faq-q .q-num{font-family:var(--wm-f-display);font-style:italic;font-weight:300;font-size:14px;color:var(--wm-navy);flex-shrink:0;width:36px}
      .wm-pdp .faq-q .q-text{flex:1;font-family:var(--wm-f-display);font-weight:500;font-size:clamp(18px, 1.6vw, 22px);line-height:1.25;letter-spacing:-0.01em}
      .wm-pdp .faq-q .q-icon{flex-shrink:0;width:20px;height:20px;position:relative;transition:transform 300ms var(--wm-ease);color:var(--wm-navy)}
      .wm-pdp .faq-q .q-icon::before,.wm-pdp .faq-q .q-icon::after{content:"";position:absolute;background:currentColor}
      .wm-pdp .faq-q .q-icon::before{left:0;right:0;top:50%;height:1px;transform:translateY(-50%)}
      .wm-pdp .faq-q .q-icon::after{top:0;bottom:0;left:50%;width:1px;transform:translateX(-50%);transition:transform 300ms var(--wm-ease)}
      .wm-pdp .faq-item[open] .faq-q .q-icon::after{transform:translateX(-50%) scaleY(0)}
      .wm-pdp .faq-q:hover .q-text{color:var(--wm-navy)}
      .wm-pdp .faq-a-inner{padding:0 0 28px 56px;font-size:15px;line-height:1.65;color:var(--wm-ink-2);max-width:640px}
      .wm-pdp .faq-a-inner strong{color:var(--wm-ink);font-weight:600}

      /* Final CTA */
      .wm-pdp .final{background:var(--wm-navy);color:var(--wm-canvas);padding:clamp(72px, 9vw, 120px) 0;position:relative;overflow:hidden}
      .wm-pdp .final::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 50% 50% at 80% 100%, oklch(0.85 0.055 235 / 0.22), transparent 60%);pointer-events:none}
      .wm-pdp .final-grid{position:relative;display:grid;grid-template-columns:1fr;gap:clamp(32px, 4vw, 64px);align-items:center}
      @media(min-width:900px){.wm-pdp .final-grid{grid-template-columns:1.1fr 0.9fr}}
      .wm-pdp .final .eyebrow{color:var(--wm-blue)}
      .wm-pdp .final .eyebrow::before{background:var(--wm-blue)}
      .wm-pdp .final .eyebrow .num{color:var(--wm-blue)}
      .wm-pdp .final h2{color:var(--wm-canvas);font-family:var(--wm-f-display);font-weight:400;font-style:italic;font-size:clamp(36px, 5.2vw, 72px);line-height:1.02;letter-spacing:-0.02em;margin:18px 0 22px}
      .wm-pdp .final h2 strong{font-weight:800;font-style:normal;display:block}
      .wm-pdp .final-lede{color:var(--wm-blue);font-family:var(--wm-f-display);font-weight:300;font-size:clamp(18px, 1.8vw, 22px);max-width:520px;line-height:1.4}
      .wm-pdp .final-buy{background:var(--wm-canvas);color:var(--wm-ink);padding:36px 32px;display:flex;flex-direction:column;gap:18px}
      .wm-pdp .final-buy .fb-row{display:flex;gap:18px;align-items:center}
      .wm-pdp .final-buy .fb-img{width:96px;height:96px;flex-shrink:0;background:var(--wm-ivory-2);overflow:hidden}
      .wm-pdp .final-buy .fb-img img{width:100%;height:100%;object-fit:cover}
      .wm-pdp .final-buy .fb-title{font-family:var(--wm-f-display);font-weight:700;font-size:18px;letter-spacing:-0.01em}
      .wm-pdp .final-buy .fb-desc{font-size:12.5px;color:var(--wm-ink-2);margin-top:3px}
      .wm-pdp .final-buy .fb-price-wrap{font-family:var(--wm-f-display);font-weight:900;font-size:28px;letter-spacing:-0.02em;margin-top:8px;color:var(--wm-ink);display:block}
      .wm-pdp .cta-primary{position:relative;display:flex;align-items:center;justify-content:center;width:100%;padding:20px 28px;background:var(--wm-navy);color:var(--wm-canvas);font-family:var(--wm-f-body);font-weight:600;font-size:15px;letter-spacing:0.06em;text-transform:uppercase;overflow:hidden;transition:background 300ms var(--wm-ease), transform 300ms var(--wm-ease)}
      .wm-pdp .cta-primary::after{content:"";position:absolute;left:28px;right:28px;bottom:14px;height:1px;background:var(--wm-blue);transform:scaleX(0);transform-origin:left;transition:transform 400ms var(--wm-ease)}
      .wm-pdp .cta-primary:hover::after{transform:scaleX(1)}
      .wm-pdp .cta-primary span.arrow{margin-left:12px;font-family:var(--wm-f-display);font-weight:300;font-size:22px;transition:transform 300ms var(--wm-ease)}
      .wm-pdp .cta-primary:hover span.arrow{transform:translateX(6px)}
      .wm-pdp .final-buy .fb-trust{display:flex;gap:14px;flex-wrap:wrap;font-size:11px;font-weight:500;color:var(--wm-ink-2);letter-spacing:0.02em;padding-top:14px;border-top:1px solid var(--wm-rule)}
      .wm-pdp .final-buy .fb-trust span{display:inline-flex;align-items:center;gap:6px}
      .wm-pdp .final-buy .fb-trust span::before{content:"";width:4px;height:4px;border-radius:50%;background:var(--wm-navy)}

      /* Scroll reveal */
      .wm-pdp .reveal{opacity:0;transform:translateY(20px);transition:opacity 700ms var(--wm-ease), transform 700ms var(--wm-ease)}
      .wm-pdp .reveal.in{opacity:1;transform:none}
      .wm-pdp .reveal.d1{transition-delay:100ms}
      .wm-pdp .reveal.d2{transition-delay:200ms}
      .wm-pdp .reveal.d3{transition-delay:300ms}
      .wm-pdp .reveal.d4{transition-delay:400ms}

      @media (prefers-reduced-motion: reduce){
        .wm-pdp *,.wm-pdp *::before,.wm-pdp *::after{animation:none !important;transition:none !important}
        .wm-pdp .reveal{opacity:1;transform:none}
      }
    </style>

    <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" slot="head" />

  </div>

  {/* JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  {/* ViewContent pixel (browser) */}
  {firstVariant && (
    <script
      is:inline
      define:vars={{
        vcEventId: viewContentEventId,
        vcContentName: product.name,
        vcContentIds: [firstVariant.sku || firstVariant.id],
        vcValue: lowestPrice / 100,
      }}
    >
      if (typeof fbq !== 'undefined') {
        fbq('track', 'ViewContent', {
          content_name: vcContentName,
          content_ids: vcContentIds,
          content_type: 'product',
          value: vcValue,
          currency: 'PLN',
        }, { eventID: vcEventId });
      }
    </script>
  )}

  {/* Async ATC form */}
  <script>
    (function() {
      const form = document.querySelector('form[method="POST"]');
      if (!form) return;
      const btn = form.querySelector('button[type="submit"]');
      if (!btn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const variantId = formData.get('variantId');
        const quantity = parseInt(formData.get('quantity') || '1', 10);
        if (!variantId) return;

        btn.disabled = true;
        const original = btn.textContent;
        btn.textContent = 'Dodawanie...';

        try {
          const res = await fetch('/api/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ variantId, quantity }),
          });
          if (res.ok) {
            const data = await res.json();
            window.dispatchEvent(new CustomEvent('cart-updated', { detail: data.order }));
          } else {
            form.submit();
            return;
          }
        } catch {
          form.submit();
          return;
        }

        btn.disabled = false;
        btn.textContent = original;
      });
    })();
  </script>
</BaseLayout>
