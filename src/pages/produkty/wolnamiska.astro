  {/* JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  {/* ViewContent pixel (browser) */}
  {firstVariant && (
    <script
      is:inline
      define:vars={{
        vcEventId: viewContentEventId,
        vcContentName: product.name,
        vcContentIds: [firstVariant.sku || firstVariant.id],
        vcValue: lowestPrice / 100,
      }}
    >
      if (typeof fbq !== 'undefined') {
        fbq('track', 'ViewContent', {
          content_name: vcContentName,
          content_ids: vcContentIds,
          content_type: 'product',
          value: vcValue,
          currency: 'PLN',
        }, { eventID: vcEventId });
      }
    </script>
  )}

  {/* Async ATC form */}
  <script>
    (function() {
      const form = document.querySelector('form[method="POST"]');
      if (!form) return;
      const btn = form.querySelector('button[type="submit"]');
      if (!btn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const variantId = formData.get('variantId');
        const quantity = parseInt(formData.get('quantity') || '1', 10);
        if (!variantId) return;

        btn.disabled = true;
        const original = btn.textContent;
        btn.textContent = 'Dodawanie...';

        try {
          const res = await fetch('/api/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ variantId, quantity }),
          });
          if (res.ok) {
            const data = await res.json();
            window.dispatchEvent(new CustomEvent('cart-updated', { detail: data.order }));
          } else {
            form.submit();
            return;
          }
        } catch {
          form.submit();
          return;
        }

        btn.disabled = false;
        btn.textContent = original;
      });
    })();
  </script>

  {/* Scroll reveal for handoff sections */}
  <script>
    (function() {
      const items = document.querySelectorAll('.wm-pdp .reveal');
      if (!items.length) return;
      if (!('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('in'));
        return;
      }
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
      items.forEach((el) => io.observe(el));
    })();
  </script>

  {/* Hero interactivity: bundle selection + gallery thumbs/dots */}
  <script>
    (function() {
      // ---- Bundle cards ----
      const cards = document.querySelectorAll('.wm-bundle-card');
      const qtyInput = document.getElementById('wm-qty');
      const atcPrice = document.getElementById('wm-atc-price');

      cards.forEach((card) => {
        card.addEventListener('click', (e) => {
          e.preventDefault();
          cards.forEach((c) => c.classList.remove('active'));
          card.classList.add('active');

          const radio = card.querySelector('input[type="radio"]');
          if (radio) radio.checked = true;

          const qty = card.getAttribute('data-qty');
          const price = card.getAttribute('data-price');
          if (qtyInput && qty) qtyInput.value = qty;
          if (atcPrice && price) atcPrice.textContent = price;
        });
      });

      // ---- Gallery (thumbs + arrows + swipe + counter) ----
      const thumbs = document.querySelectorAll('.wm-thumb');
      const images = document.querySelectorAll('.wm-gallery-img');
      const counter = document.getElementById('wm-counter-current');
      const arrowPrev = document.getElementById('wm-arrow-prev');
      const arrowNext = document.getElementById('wm-arrow-next');
      const total = images.length;
      let currentIdx = 0;

      const thumbsContainer = document.querySelector('.wm-gallery-thumbs');

      function activate(idx) {
        currentIdx = (idx + total) % total;
        thumbs.forEach((t) => t.classList.toggle('active', t.getAttribute('data-target') === String(currentIdx)));
        images.forEach((img) => img.classList.toggle('active', img.getAttribute('data-idx') === String(currentIdx)));
        if (counter) counter.textContent = String(currentIdx + 1);

        // Scroll only the thumbs container horizontally (NOT the page)
        if (thumbsContainer && thumbsContainer.scrollWidth > thumbsContainer.clientWidth) {
          const activeThumb = thumbsContainer.querySelector('.wm-thumb.active');
          if (activeThumb) {
            const target = activeThumb.offsetLeft - (thumbsContainer.clientWidth / 2) + (activeThumb.clientWidth / 2);
            thumbsContainer.scrollTo({ left: target, behavior: 'smooth' });
          }
        }
      }

      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          activate(parseInt(thumb.getAttribute('data-target') || '0', 10));
        });
      });

      if (arrowPrev) arrowPrev.addEventListener('click', () => activate(currentIdx - 1));
      if (arrowNext) arrowNext.addEventListener('click', () => activate(currentIdx + 1));

      // ---- Touch swipe (mobile) ----
      const main = document.getElementById('wm-gallery-main');
      if (main) {
        let touchStartX = 0;
        let touchEndX = 0;

        main.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        main.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          const diff = touchStartX - touchEndX;
          if (Math.abs(diff) < 40) return;
          if (diff > 0) activate(currentIdx + 1);
          else activate(currentIdx - 1);
        }, { passive: true });
      }

      // ---- Keyboard arrows (desktop a11y) ----
      document.addEventListener('keydown', (e) => {
        if (!main) return;
        const rect = main.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > window.innerHeight) return;
        if (e.key === 'ArrowLeft') activate(currentIdx - 1);
        else if (e.key === 'ArrowRight') activate(currentIdx + 1);
      });
    })();
  </script>
</BaseLayout>
