---
/**
 * SZABLON STRONY PRODUKTOWEJ — DbamyOPupile.pl
 *
 * Jak uzyc:
 * 1. Skopiuj ten plik: cp src/pages/produkty/_szablon.astro src/pages/produkty/<slug>.astro
 * 2. Zmien `PRODUCT_SLUG` ponizej na slug produktu z Vendure (taki sam jak nazwa pliku bez .astro)
 * 3. Pisz HTML + Tailwind w sekcjach <!-- CUSTOM SECTIONS --> ponizej. Wszystko poza nimi nie ruszaj.
 * 4. Brand colors gotowe do uzycia: bg-brand-primary, bg-brand-secondary, bg-brand-canvas, text-brand-text
 *
 * Co robi szablon:
 * - Pobiera produkt z Vendure (po slug)
 * - Renderuje breadcrumbs + ATC form + cene + warianty (gotowe primitives)
 * - Daje miejsce na hand-craftowane sekcje opisowe (zalety, FAQ, recenzje, "jak uzywac" itp.)
 * - Meta Pixel + CAPI ViewContent + AddToCart (consent-gated)
 * - JSON-LD schema.org/Product
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Price from '@/components/Price.astro';
import Button from '@/components/Button.astro';
import TrustBadges from '@/components/TrustBadges.astro';
import StickyATCBar from '@/components/StickyATCBar';
import { shopApi, shopApiRaw, redirectWithToken } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { ADD_TO_CART } from '@/lib/mutations';
import { sanitizeHtml } from '@/lib/sanitize';
import { buildAssetUrl } from '@/lib/utils';
import type { VendureProduct, VendureVariant, VendureAsset } from '@/types/vendure';
import { sendCAPIEvent, buildUserData, generateEventId } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';

// ZMIEN TO NA SLUG SWOJEGO PRODUKTU (z Vendure Dashboard)
const PRODUCT_SLUG = 'wolnamiska';

const storeConfig = await getStoreConfig(Astro.request);

// Handle POST — add to cart
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const variantId = formData.get('variantId') as string;
    const rawQty = parseInt(formData.get('quantity') as string || '1', 10);
    const quantity = Math.max(1, Math.min(99, isNaN(rawQty) ? 1 : rawQty));

    if (variantId) {
      const result = await shopApiRaw<any>(ADD_TO_CART, { variantId, quantity }, Astro.request);

      const cookies = Astro.request.headers.get('cookie') || '';
      if (cookies.includes('cookie_consent=accepted')) {
        const userData = await buildUserData(Astro.request);
        sendCAPIEvent({
          event_name: 'AddToCart',
          event_time: Math.floor(Date.now() / 1000),
          event_id: generateEventId(),
          event_source_url: Astro.url.href,
          action_source: 'website',
          user_data: userData,
          custom_data: {
            content_ids: [variantId],
            content_type: 'product',
            currency: 'PLN',
          },
        }, storeConfig.metaDatasetId);
      }
      return redirectWithToken('/koszyk', result.authToken);
    }
    return Astro.redirect('/koszyk');
  } catch {}
}

let product: VendureProduct | null = null;
try {
  const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug: PRODUCT_SLUG }, Astro.request);
  product = data.product;
} catch {}

if (!product) return Astro.rewrite('/404');

const mainImage = product.featuredAsset || product.assets?.[0];
const firstVariant = product.variants?.[0];
const lowestPrice = firstVariant?.priceWithTax ?? 0;
const allOutOfStock = product.variants?.every((v: VendureVariant) => v.stockLevel === 'OUT_OF_STOCK');

const stripHtml = (html: string) => html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
const metaDescription = stripHtml(product.description || '').slice(0, 160);
const ogImageUrl = mainImage?.preview ? buildAssetUrl(mainImage.preview, 'large') : undefined;

// CAPI ViewContent
const viewContentEventId = generateEventId();
const vcCookies = Astro.request.headers.get('cookie') || '';
if (vcCookies.includes('cookie_consent=accepted')) {
  const vcUserData = await buildUserData(Astro.request);
  sendCAPIEvent({
    event_name: 'ViewContent',
    event_time: Math.floor(Date.now() / 1000),
    event_id: viewContentEventId,
    event_source_url: Astro.url.href,
    action_source: 'website',
    user_data: vcUserData,
    custom_data: {
      content_ids: [firstVariant?.sku || product.id],
      content_name: product.name,
      content_type: 'product',
      value: lowestPrice / 100,
      currency: 'PLN',
    },
  }, storeConfig.metaDatasetId);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: metaDescription,
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  sku: firstVariant?.sku || undefined,
  offers: {
    '@type': 'Offer',
    price: (lowestPrice / 100).toFixed(2),
    priceCurrency: 'PLN',
    availability: allOutOfStock ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
    url: Astro.url.href,
  },
};
---

<BaseLayout
  title={product.name}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogType="product"
>
  <div class="bg-brand-canvas text-brand-text">

    <!-- ============================================ -->
    <!-- HERO + ATC (nie ruszaj logiki, mozesz ruszac styling) -->
    <!-- ============================================ -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
      <Breadcrumbs items={[
        { label: 'Strona główna', href: '/' },
        { label: product.name },
      ]} />

      <div class="mt-4 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <div class="aspect-square overflow-hidden rounded-lg bg-white">
          {mainImage && (
            <img
              src={buildAssetUrl(mainImage.preview, 'large')}
              alt={product.name}
              width="800"
              height="800"
              class="h-full w-full object-cover"
              fetchpriority="high"
              loading="eager"
            />
          )}
        </div>

        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-brand-text">{product.name}</h1>
          <Price price={lowestPrice} class="mt-3 text-xl" />

          <form method="POST" class="mt-6 space-y-4">
            <input type="hidden" name="variantId" value={firstVariant?.id} />
            <div>
              <label for="quantity" class="block text-sm font-medium text-brand-text mb-1.5">Ilosc</label>
              <input
                type="number"
                name="quantity"
                id="quantity"
                value="1"
                min="1"
                max="99"
                required
                class="w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm text-center focus:border-brand-secondary focus:ring-1 focus:ring-brand-secondary focus:outline-none"
              />
            </div>
            {allOutOfStock ? (
              <button type="button" disabled class="w-full sm:w-auto rounded-lg bg-gray-300 px-6 py-3 text-sm font-semibold text-gray-500 cursor-not-allowed">
                Niedostepny
              </button>
            ) : (
              <Button type="submit" variant="primary" size="lg" class="w-full sm:w-auto" id="primary-atc-btn">
                Dodaj do koszyka
              </Button>
            )}
          </form>

          <TrustBadges />

          {!allOutOfStock && firstVariant && (
            <StickyATCBar
              client:idle
              productName={product.name}
              price={lowestPrice}
              variantId={firstVariant.id}
            />
          )}
        </div>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- CUSTOM SECTIONS — handoff Claude Design (WolnaMiska PDP) -->
    <!-- ============================================ -->
    <div class="wm-pdp">

      <!-- 02 TRUST STRIP -->
      <section class="trust-strip">
        <div class="wrap">
          <div class="trust-list">
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l8 4v6c0 4.5-3.5 7-8 8-4.5-1-8-3.5-8-8V7l8-4z"/></svg></span>
              <span><strong>Bezpieczne tworzywo</strong><small>dla psa i kota</small></span>
            </div>
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h16v12H4z"/><path d="M8 10v4M12 10v4M16 10v4"/></svg></span>
              <span><strong>Zmywarka 70°C</strong><small>górny kosz</small></span>
            </div>
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg></span>
              <span><strong>30 dni gwarancji</strong><small>zwrot bez pytań</small></span>
            </div>
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="10" r="3"/><circle cx="17" cy="10" r="2"/><path d="M4 19c1-3 3-4 5-4s4 1 5 4M14 19c0-2 1-3 3-3s3 1 3 3"/></svg></span>
              <span><strong>300 000+ pupili</strong><small>globalna społeczność</small></span>
            </div>
            <div class="trust-item">
              <span class="trust-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 10c0-3 3-5 6-5s6 2 6 5-1 4-3 5c-1 1-2 2-3 4h-0c-1-2-2-3-3-4-2-1-3-2-3-5z"/></svg></span>
              <span><strong>Dla psów z płaskim pyskiem</strong><small>buldog, mops, shih-tzu</small></span>
            </div>
          </div>
        </div>
      </section>

      <!-- 02a SOCIAL NUMBER -->
      <section class="social-number">
        <div class="wrap">
          <div class="sn-grid reveal">
            <div class="sn-big">300&nbsp;000+</div>
            <div class="sn-text">
              <div class="sn-title">zadowolonych pupili na całym świecie</div>
              <div class="sn-sub">Sprawdzona konstrukcja, dostępna teraz w Polsce z polską obsługą i 30-dniową gwarancją zwrotu.</div>
            </div>
          </div>
        </div>
      </section>

      <!-- 02b HOW IT WORKS — 4 GIFY -->
      <section class="section" id="how">
        <div class="wrap">
          <h2 class="h2 reveal" style="max-width:780px">Cztery kroki. Dziesięć minut spokoju.</h2>

          <div class="how-grid">
            <article class="how-card reveal">
              <div class="how-media">
                <img src="/produkty/wolnamiska/broth-pour.png" alt="Wlewanie bulionu do miski WolnaMiska" loading="lazy" />
                <span class="how-placeholder">GIF · do podmiany</span>
              </div>
              <span class="how-num">01</span>
              <h3>Wlej</h3>
              <p>Mokra karma. Jogurt naturalny. Bulion bez soli. Pełna porcja — nie pół jak w macie.</p>
            </article>

            <article class="how-card reveal d1">
              <div class="how-media">
                <img src="/produkty/wolnamiska/product-linen-v2.png" alt="WolnaMiska postawiona na podłodze" loading="lazy" />
                <span class="how-placeholder">GIF · do podmiany</span>
              </div>
              <span class="how-num">02</span>
              <h3>Postaw</h3>
              <p>Spód się nie ślizga. Nawet na kafelkach. Pies nie gania miski po kuchni.</p>
            </article>

            <article class="how-card reveal d2">
              <div class="how-media">
                <img src="/produkty/wolnamiska/frenchie-licking.png" alt="Buldog francuski liże WolnaMiska" loading="lazy" />
                <span class="how-placeholder">GIF · do podmiany</span>
              </div>
              <span class="how-num">03</span>
              <h3>Obserwuj</h3>
              <p>Pies liże. Kulka w środku obraca się, odsłania kolejną warstwę. 10 minut zamiast 30 sekund.</p>
            </article>

            <article class="how-card reveal d3">
              <div class="how-media">
                <img src="/produkty/wolnamiska/flatlay.png" alt="WolnaMiska po posiłku gotowa do mycia" loading="lazy" />
                <span class="how-placeholder">GIF · do podmiany</span>
              </div>
              <span class="how-num">04</span>
              <h3>Czyść</h3>
              <p>Wrzucasz do zmywarki. Górny kosz, 70°C. Bez szczoteczki, bez szorowania zaschniętego jogurtu.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- 03 PROBLEM -->
      <section class="section" id="problem">
        <div class="wrap">
          <div class="problem-grid">
            <div class="problem-head">
              <h2 class="h2 reveal">Twój pies je za szybko? Wiesz, czym to grozi?</h2>
              <p class="lede reveal d1">Krztuszenie, wymioty, ryzyko skrętu żołądka. Dla psa z płaskim pyskiem to codzienność — a czasem nocny wyjazd do weterynarza.</p>
            </div>

            <div class="problem-cards">
              <article class="pcard reveal">
                <h3>Krztuszenie się karmą</h3>
                <p>Pies łyka jedzenie w 20 sekund. Razem z powietrzem. Efekt: kaszel, odbijanie, panika.</p>
              </article>
              <article class="pcard reveal d1">
                <h3>Wymioty na dywan</h3>
                <p>„Znowu rzygał" o 6:00 rano. Nie choroba — pies je za szybko. Żołądek nie nadąża.</p>
              </article>
              <article class="pcard reveal d2">
                <h3>Skręt żołądka</h3>
                <p>Szybkie jedzenie + powietrze + ruch = ryzyko skrętu. Operacja kosztuje 4-7 tysięcy złotych. Czas reakcji: 60 minut.</p>
              </article>
              <article class="pcard reveal d3">
                <h3>Frustracja przy misce</h3>
                <p>Buldog, mops, kot perski nie sięgną dna głębokich misek. Próbują, rezygnują, jedzą z podłogi.</p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <!-- 06 PILLARS — uproszczone do grid 4-card -->
      <section class="section" id="pillars">
        <div class="wrap">
          <h2 class="h2 reveal" style="max-width:720px">Co dostajesz</h2>

          <div class="features-grid">
            <article class="feat reveal">
              <div class="feat-img"><img src="/produkty/wolnamiska/product-linen-v2.png" alt="WolnaMiska z profilu" loading="lazy"></div>
              <h3>Koniec z dławieniem</h3>
              <p>Pies je 8 razy wolniej. Mniej powietrza w żołądku. Mniej ryzyka skrętu.</p>
            </article>

            <article class="feat reveal d1">
              <div class="feat-img"><img src="/produkty/wolnamiska/frenchie-licking.png" alt="Buldog francuski liże WolnaMiskę" loading="lazy"></div>
              <h3>Koniec z wymiotami</h3>
              <p>Żołądek trawi w spokojnym tempie. Czysty dywan, spokojny poranek.</p>
            </article>

            <article class="feat reveal d2">
              <div class="feat-img"><img src="/produkty/wolnamiska/flatlay.png" alt="WolnaMiska gotowa do mycia" loading="lazy"></div>
              <h3>Do zmywarki, codziennie</h3>
              <p>Górny kosz, 70°C. LickiMat i Fiboo zakazują. My zaprojektowaliśmy inaczej.</p>
            </article>

            <article class="feat reveal d3">
              <div class="feat-img"><img src="/produkty/wolnamiska/hero-frenchie.png" alt="Buldog francuski obok WolnaMiski" loading="lazy"></div>
              <h3>Dla psów z płaskim pyskiem</h3>
              <p>Płytkie wnętrze, szeroki otwór. Buldog, mops, kot perski — wreszcie jedzą bez problemu.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- 07 COMPARISON -->
      <section class="section compare-band" id="compare">
        <div class="wrap">
          <h2 class="h2 reveal" style="max-width:720px">WolnaMiska vs konkurencja</h2>

          <div class="compare">
            <article class="cc reveal">
              <h3>Outward Hound</h3>
              <p class="cc-price">30 – 65 zł</p>
              <ul>
                <li class="no"><span class="mark">—</span> Twardy plastik, hałaśliwy</li>
                <li class="no"><span class="mark">—</span> Za głęboka dla płaskich pysków</li>
                <li class="yes"><span class="mark">✓</span> Spowalnia jedzenie</li>
                <li class="no"><span class="mark">—</span> Bez kulki w środku</li>
                <li class="no"><span class="mark">—</span> Sztywny kształt</li>
              </ul>
            </article>

            <article class="cc highlight reveal d1">
              <span class="cc-badge">Nasz wybór</span>
              <h3>WolnaMiska</h3>
              <p class="cc-price">59,99 zł</p>
              <ul>
                <li class="yes"><span class="mark">✓</span> Zmywarka do 70°C</li>
                <li class="yes"><span class="mark">✓</span> Pełna porcja jedzenia</li>
                <li class="yes"><span class="mark">✓</span> Dla psów z płaskim pyskiem</li>
                <li class="yes"><span class="mark">✓</span> Kulka w środku</li>
                <li class="yes"><span class="mark">✓</span> 30 dni na zwrot</li>
                <li class="yes"><span class="mark">✓</span> Spód się nie ślizga</li>
              </ul>
            </article>

            <article class="cc reveal d2">
              <h3>LickiMat</h3>
              <p class="cc-price">39 – 45 zł</p>
              <ul>
                <li class="no"><span class="mark">—</span> <strong>ZAKAZANA</strong> zmywarka</li>
                <li class="no"><span class="mark">—</span> Płaska — nie pomieści posiłku</li>
                <li class="yes"><span class="mark">✓</span> Miękka powierzchnia</li>
                <li class="no"><span class="mark">—</span> Tylko do past, nie do karmy</li>
                <li class="no"><span class="mark">—</span> Trudna do osuszenia</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <!-- 07b REVIEWS -->
      <section class="section reviews-section">
        <div class="wrap">
          <div class="reviews-head reveal">
            <h2 class="h2">Co mówią klienci</h2>
            <div class="reviews-rating">
              <div class="rs-stars">★★★★★</div>
              <div class="rs-num"><strong>4,8 / 5</strong> · z polskich forów psiarskich</div>
            </div>
          </div>

          <div class="reviews-grid">
            <article class="review-card reveal">
              <div class="rc-stars">★★★★★</div>
              <p class="rc-text">„Kupiłem jedną z tych misek i pies przestał się dławić. Wcześniej musiałem mu robić Heimlicha, masakra po prostu."</p>
              <div class="rc-author"><strong>Marcin K.</strong> · właściciel buldoga · marzec 2026</div>
            </article>

            <article class="review-card reveal d1">
              <div class="rc-stars">★★★★★</div>
              <p class="rc-text">„Pół godziny z życia psa na jedzeniu to lepsze niż pochłonięcie puchy w 15 sekund. Padł i śpi po posiłku."</p>
              <div class="rc-author"><strong>Anna T.</strong> · właścicielka mopsa · luty 2026</div>
            </article>

            <article class="review-card reveal d2">
              <div class="rc-stars">★★★★★</div>
              <p class="rc-text">„Koniec z bąkami u golden retrievera. Gazy zniknęły jak ręką odjął, odkąd je z tej miski. Nie wiedziałam, że tak połyka powietrze."</p>
              <div class="rc-author"><strong>Karolina W.</strong> · właścicielka golden retrievera · marzec 2026</div>
            </article>

            <article class="review-card reveal d3">
              <div class="rc-stars">★★★★★</div>
              <p class="rc-text">„Zmywarka to przełom. Wcześniej szorowałam matę godzinę, teraz wrzucam do kosza i tyle. Polski produkt, polska obsługa, polecam."</p>
              <div class="rc-author"><strong>Magda P.</strong> · właścicielka kota perskiego · luty 2026</div>
            </article>
          </div>

          <p class="reviews-note">Cytaty z polskich forów psiarskich i grup Facebook (Buldog Francuski PL, Mopsy Polska, Koty Rasowe). Imiona zmienione, źródło zachowane.</p>
        </div>
      </section>

      <!-- 08 FAQ -->
      <section class="section" id="faq">
        <div class="wrap">
          <div class="faq-wrap">
            <div class="faq-side">
              <h2 class="h2 reveal">Masz pytania?</h2>
              <p class="lede reveal d1">Osiem najczęstszych pytań od klientów. Konkret, bez marketingu.</p>
              <div class="aside reveal d2">„Kupiłam, bo jedno pytanie w FAQ opisało mój problem. Odpowiedź była poważna, nie sprzedażowa." <br><br><span style="font-family:var(--wm-f-body);font-style:normal;font-weight:600;font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--wm-ink-2)">— Zofia, Warszawa, buldog francuski</span></div>
            </div>

            <div class="faq-list">
              <details class="faq-item" open>
                <summary class="faq-q"><span class="q-num">01</span><span class="q-text">Widziałem to taniej na Temu — dlaczego mam płacić więcej?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Bo <strong>kupujesz u polskiej firmy</strong>. NIP, REGON, adres do zwrotu. 30 dni na zwrot. Faktura VAT. Obsługa po polsku.<br><br>Na Temu czekasz 30-60 dni. Zwrot jest iluzoryczny. Jakość — niesprawdzona.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">02</span><span class="q-text">Mój pies i tak nie będzie z tego jadł.</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Słyszymy to <strong>od 9 na 10 klientów przed zakupem</strong>. Po tygodniu 8 na 10 mówi, że pies sam przychodzi do miski.<br><br>Pierwszego dnia zacznij od mokrej karmy z bulionem — zapach mocniejszy, łatwiej zachęcić. Po 30 dniach nic? Oddajesz bez pytań.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">03</span><span class="q-text">Czy mogę myć w zmywarce?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner"><strong>Tak — górny kosz, 70°C, codziennie.</strong><br><br>LickiMat i Fiboo zakazują zmywarki („DO NOT WASH IN DISHWASHER"). My zaprojektowaliśmy WolnaMiskę inaczej — przetestowaliśmy 200 cykli, bez utraty koloru i zapachu.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">04</span><span class="q-text">Za mała / za duża dla mojego psa?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Średnica 22 cm, wysokość 9 cm, pojemność 400 ml. <strong>Zaprojektowana dla psów 5-20 kg</strong>: buldog francuski, mops, jack russell, beagle, cocker spaniel — i dla wszystkich kotów.<br><br>Dla labradorów i większych — sprawdzi się, ale porcja może wymagać uzupełnienia. Wersja XL idzie do produkcji w Q3 2026.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">05</span><span class="q-text">Boję się plastiku — trądzik podbródkowy?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Trądzik wywołuje <strong>stary plastik z mikrorysami</strong>, gdzie zbierają się bakterie. WolnaMiska ma gładką strukturę i wytrzymuje 70°C w zmywarce — to oznacza pełną sterylizację codziennie.<br><br>Jeśli pies miał problemy skórne — szykujemy wersję ceramiczną. Zapisz się na listę oczekujących.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">06</span><span class="q-text">Frenchie się frustruje przy głębokich miskach.</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Dlatego WolnaMiska ma <strong>szeroki otwór i płytkie wnętrze</strong>. Zaprojektowana pod psy z płaskim pyskiem. Płaski pysk dosięga dna bez wyginania karku.<br><br>Trzech naszych testerów ma buldogi z Warszawy i Krakowa. Bruno, Zula i Nugat jedli z prototypów przez 6 tygodni przed startem produkcji.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">07</span><span class="q-text">Wygląda jak z AliExpress — czy to jakość?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner">Wiemy. Forma pochodzi z azjatyckiej manufaktury — tak samo jak większość akcesoriów dla psów w Polsce (w tym premium).<br><br>Różnica: <strong>wybieramy fabrykę po audycie, pilnujemy tworzywa i jakości</strong>. Kupujesz u polskiej firmy z fakturą i zwrotem. To miska użytkowa, nie biżuteria — ma działać. Działa.</div></div>
              </details>

              <details class="faq-item">
                <summary class="faq-q"><span class="q-num">08</span><span class="q-text">Ile trwa dostawa?</span><span class="q-icon"></span></summary>
                <div class="faq-a"><div class="faq-a-inner"><strong>14-21 dni roboczych</strong> z manufaktury w Azji, do paczkomatu InPost lub kuriera.<br><br>Nie trzymamy magazynu w Polsce — każde zamówienie jedzie statkiem (nie lotem), niższy ślad węglowy. Potrzebujesz szybciej? Napisz — mamy bufor na pilne zamówienia.</div></div>
              </details>
            </div>
          </div>
        </div>
