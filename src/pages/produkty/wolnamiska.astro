---
/**
 * SZABLON STRONY PRODUKTOWEJ — DbamyOPupile.pl
 *
 * Jak uzyc:
 * 1. Skopiuj ten plik: cp src/pages/produkty/_szablon.astro src/pages/produkty/<slug>.astro
 * 2. Zmien `PRODUCT_SLUG` ponizej na slug produktu z Vendure (taki sam jak nazwa pliku bez .astro)
 * 3. Pisz HTML + Tailwind w sekcjach <!-- CUSTOM SECTIONS --> ponizej. Wszystko poza nimi nie ruszaj.
 * 4. Brand colors gotowe do uzycia: bg-brand-primary, bg-brand-secondary, bg-brand-canvas, text-brand-text
 *
 * Co robi szablon:
 * - Pobiera produkt z Vendure (po slug)
 * - Renderuje breadcrumbs + ATC form + cene + warianty (gotowe primitives)
 * - Daje miejsce na hand-craftowane sekcje opisowe (zalety, FAQ, recenzje, "jak uzywac" itp.)
 * - Meta Pixel + CAPI ViewContent + AddToCart (consent-gated)
 * - JSON-LD schema.org/Product
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Price from '@/components/Price.astro';
import Button from '@/components/Button.astro';
import TrustBadges from '@/components/TrustBadges.astro';
import StickyATCBar from '@/components/StickyATCBar';
import { shopApi, shopApiRaw, redirectWithToken } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { ADD_TO_CART } from '@/lib/mutations';
import { sanitizeHtml } from '@/lib/sanitize';
import '@/styles/wolnamiska-pdp.css';
import { buildAssetUrl } from '@/lib/utils';
import type { VendureProduct, VendureVariant, VendureAsset } from '@/types/vendure';
import { sendCAPIEvent, buildUserData, generateEventId } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';

// ZMIEN TO NA SLUG SWOJEGO PRODUKTU (z Vendure Dashboard)
const PRODUCT_SLUG = 'wolnamiska';

const storeConfig = await getStoreConfig(Astro.request);

// Handle POST — add to cart
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const variantId = formData.get('variantId') as string;
    const rawQty = parseInt(formData.get('quantity') as string || '1', 10);
    const quantity = Math.max(1, Math.min(99, isNaN(rawQty) ? 1 : rawQty));

    if (variantId) {
      const result = await shopApiRaw<any>(ADD_TO_CART, { variantId, quantity }, Astro.request);

      const cookies = Astro.request.headers.get('cookie') || '';
      if (cookies.includes('cookie_consent=accepted')) {
        const userData = await buildUserData(Astro.request);
        sendCAPIEvent({
          event_name: 'AddToCart',
          event_time: Math.floor(Date.now() / 1000),
          event_id: generateEventId(),
          event_source_url: Astro.url.href,
          action_source: 'website',
          user_data: userData,
          custom_data: {
            content_ids: [variantId],
            content_type: 'product',
            currency: 'PLN',
          },
        }, storeConfig.metaDatasetId);
      }
      return redirectWithToken('/koszyk', result.authToken);
    }
    return Astro.redirect('/koszyk');
  } catch {}
}

let product: VendureProduct | null = null;
try {
  const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug: PRODUCT_SLUG }, Astro.request);
  product = data.product;
} catch {}

if (!product) return Astro.rewrite('/404');

const mainImage = product.featuredAsset || product.assets?.[0];
const firstVariant = product.variants?.[0];

// ============================================
// GALLERY — dynamic array (dodaj/usuń tu, reszta JS się dostosuje)
// ============================================
type GalleryImage = { src: string; thumb?: string; alt: string };
const galleryImages: GalleryImage[] = [
  { src: '/produkty/wolnamiska/hero-shiba.webp', alt: 'WolnaMiska — Shiba Inu liże miskę z 4 zaletami' },
  { src: '/produkty/wolnamiska/jak-dziala.webp', alt: 'Jak działa WolnaMiska — wlej, postaw, obserwuj' },
  { src: '/produkty/wolnamiska/shiba-jedzenie.webp', alt: 'WolnaMiska w użyciu — Shiba Inu pracuje językiem nad kulką' },
  { src: '/produkty/wolnamiska/piec-zalet.webp', alt: 'Pięć zalet WolnaMiska' },
  { src: '/produkty/wolnamiska/przed-po.webp', alt: 'Przed i po — 30 sekund vs 15 minut, stres vs spokój' },
  { src: '/produkty/wolnamiska/frenchie-jasny.webp', alt: 'WolnaMiska — buldog francuski liże w salonie' },
  { src: '/produkty/wolnamiska/dla-kogo.webp', alt: 'Dla kogo WolnaMiska — płaski pysk, łapczywy, senior, znudzony' },
  { src: '/produkty/wolnamiska/bez-z-porownanie.webp', alt: 'Bez WolnaMiski vs z WolnaMiską — porównanie' },
  { src: '/produkty/wolnamiska/kuchnia-shiba.webp', alt: 'WolnaMiska na podłodze kuchennej' },
  { src: '/produkty/wolnamiska/polisa-na-zycie.webp', alt: 'WolnaMiska polisa na życie — 70 zł vs 7000 zł' },
  { src: '/produkty/wolnamiska/rece-misa.webp', alt: 'WolnaMiska — skala produktu w rękach' },
  { src: '/produkty/wolnamiska/misa-kubek.webp', alt: 'WolnaMiska — porównanie skali z kubkiem' },
  { src: '/produkty/wolnamiska/wymiar-16cm.webp', alt: 'WolnaMiska — wymiar 16cm średnicy' },
];
const lowestPrice = firstVariant?.priceWithTax ?? 0;
const allOutOfStock = product.variants?.every((v: VendureVariant) => v.stockLevel === 'OUT_OF_STOCK');

const stripHtml = (html: string) => html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
const metaDescription = stripHtml(product.description || '').slice(0, 160);
const ogImageUrl = mainImage?.preview ? buildAssetUrl(mainImage.preview, 'large') : undefined;

// CAPI ViewContent
const viewContentEventId = generateEventId();
const vcCookies = Astro.request.headers.get('cookie') || '';
if (vcCookies.includes('cookie_consent=accepted')) {
  const vcUserData = await buildUserData(Astro.request);
  sendCAPIEvent({
    event_name: 'ViewContent',
    event_time: Math.floor(Date.now() / 1000),
    event_id: viewContentEventId,
    event_source_url: Astro.url.href,
    action_source: 'website',
    user_data: vcUserData,
    custom_data: {
      content_ids: [firstVariant?.sku || product.id],
      content_name: product.name,
      content_type: 'product',
      value: lowestPrice / 100,
      currency: 'PLN',
    },
  }, storeConfig.metaDatasetId);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: metaDescription,
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  sku: firstVariant?.sku || undefined,
  offers: {
    '@type': 'Offer',
    price: (lowestPrice / 100).toFixed(2),
    priceCurrency: 'PLN',
    availability: allOutOfStock ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
    url: Astro.url.href,
  },
};
---

<BaseLayout
  title={product.name}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogType="product"
>
  <div class="bg-brand-canvas text-brand-text">

    <!-- ============================================ -->
    <!-- HERO + ATC — Conversion-Optimized (research-pdp-hero.md) -->
    <!-- ============================================ -->
    <section class="wm-hero">
      <div class="wm-hero-wrap">
        <div class="wm-hero-grid">
          <!-- LEFT: Sticky Gallery -->
          <div class="wm-gallery-col">
            <div class="wm-gallery">
              <div class="wm-gallery-main" id="wm-gallery-main">
                {galleryImages.map((img, i) => (
                  <img
                    src={img.src}
                    alt={img.alt}
                    width="900"
                    height="900"
                    class:list={['wm-gallery-img', i === 0 && 'active']}
                    data-idx={String(i)}
                    fetchpriority={i === 0 ? 'high' : undefined}
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                ))}

                <button type="button" class="wm-gallery-arrow prev" id="wm-arrow-prev" aria-label="Poprzednie zdjęcie">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <button type="button" class="wm-gallery-arrow next" id="wm-arrow-next" aria-label="Następne zdjęcie">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>

                <span class="wm-gallery-counter">
                  <span id="wm-counter-current">1</span> / <span id="wm-counter-total">{galleryImages.length}</span>
                </span>
              </div>

              <div class="wm-gallery-thumbs" role="tablist" aria-label="Galeria produktu">
                {galleryImages.map((img, i) => (
                  <button
                    class:list={['wm-thumb', i === 0 && 'active']}
                    data-target={String(i)}
                    aria-label={`Zdjęcie ${i + 1}`}
                    type="button"
                  >
                    <img src={img.thumb || img.src} alt="" loading="lazy" />
                  </button>
                ))}
              </div>
            </div>
          </div>

          <!-- RIGHT: Conversion Engine -->
          <div class="wm-conv-col">
            <div class="wm-prelaunch">
              <span class="wm-prelaunch-dot"></span>
              <span><strong>Ebook z 30 przepisami</strong> w prezencie do każdego zamówienia</span>
            </div>

            <h1 class="wm-title">WolnaMiska — Koniec z łapczywym jedzeniem i wzdęciami</h1>
            <p class="wm-subtitle">Hybrydowa miska z ruchomą kulką w środku. Zmienia każdy posiłek z 30 sekund pochłaniania w 15 minut spokojnego jedzenia.</p>

            <div class="wm-price-block">
              <div class="wm-price-row">
                <span class="wm-price" id="wm-price">59,99 zł</span>
                <span class="wm-price-old">89,99 zł</span>
                <span class="wm-price-save">Oszczędzasz 30 zł</span>
              </div>
              <div class="wm-omnibus">Najniższa cena z 30 dni przed obniżką: 59,99 zł</div>
            </div>

            <ul class="wm-usps">
              <li>
                <svg class="wm-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>Zdrowe trawienie</strong> — koniec ze wzdęciami i wymiotami</span>
              </li>
              <li>
                <svg class="wm-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>Uspokaja pupila</strong> — lizanie uwalnia endorfiny</span>
              </li>
              <li>
                <svg class="wm-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>Zmywarka 70°C</strong> — bezpieczne tworzywo, łatwe czyszczenie</span>
              </li>
            </ul>

            <form method="POST" class="wm-form" id="wm-atc-form">
