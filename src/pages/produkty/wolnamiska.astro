                    <div class="wm-bundle-price">59,99 zł</div>
                    <div class="wm-bundle-perunit">59,99 zł / szt</div>
                  </div>
                </label>

                <label class="wm-bundle-card popular" data-qty="2" data-price="104,99 zł">
                  <span class="wm-bundle-badge">Oszczędzasz 15 zł</span>
                  <input type="radio" name="bundle" value="2" />
                  <div class="wm-bundle-check">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <div class="wm-bundle-main">
                    <div class="wm-bundle-name">Zestaw 2 szt</div>
                    <div class="wm-bundle-meta">Idealnie jeśli masz 2 psy w domu</div>
                  </div>
                  <div class="wm-bundle-pricing">
                    <div class="wm-bundle-price">104,99 zł</div>
                    <div class="wm-bundle-perunit"><s>59,99</s> 52,49 zł / szt</div>
                  </div>
                </label>

                <label class="wm-bundle-card" data-qty="3" data-price="149,99 zł">
                  <span class="wm-bundle-badge navy">−30 zł + darmowa dostawa</span>
                  <input type="radio" name="bundle" value="3" />
                  <div class="wm-bundle-check">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <div class="wm-bundle-main">
                    <div class="wm-bundle-name">Zestaw 3 szt</div>
                    <div class="wm-bundle-meta">Maksymalna oszczędność</div>
                  </div>
                  <div class="wm-bundle-pricing">
                    <div class="wm-bundle-price">149,99 zł</div>
                    <div class="wm-bundle-perunit"><s>59,99</s> 49,99 zł / szt</div>
                  </div>
                </label>
              </div>

              {allOutOfStock ? (
                <button type="button" disabled class="wm-atc disabled">Chwilowo niedostępna</button>
              ) : (
                <button type="submit" class="wm-atc" id="primary-atc-btn">
                  <span class="wm-atc-text">Kup Teraz</span>
                  <span class="wm-atc-price" id="wm-atc-price">59,99 zł</span>
                  <svg class="wm-atc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </button>
              )}

              <div class="wm-delivery-promise">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>Zamów do <strong>14:00</strong>, paczka wyruszy <strong>jeszcze dzisiaj</strong></span>
              </div>
            </form>

            <div class="wm-trust-row">
              <div class="wm-trust">
                <div class="wm-trust-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                </div>
                <div class="wm-trust-text">
                  <strong>BLIK · PayU</strong>
                  <small>Płatność</small>
                </div>
              </div>
              <div class="wm-trust">
                <div class="wm-trust-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="1"/><line x1="9" y1="4" x2="9" y2="20"/><line x1="15" y1="4" x2="15" y2="20"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/></svg>
                </div>
                <div class="wm-trust-text">
                  <strong>InPost</strong>
                  <small>Wysyłka 24h</small>
                </div>
              </div>
              <div class="wm-trust">
                <div class="wm-trust-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
                </div>
                <div class="wm-trust-text">
                  <strong>30 dni</strong>
                  <small>Zwrotu</small>
                </div>
              </div>
              <div class="wm-trust">
                <div class="wm-trust-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 4v6c0 4.5-3.5 7-8 8-4.5-1-8-3.5-8-8V7l8-4z"/></svg>
                </div>
