      .wm-pdp .bc-qty{font-family:var(--wm-f-display);font-weight:700;font-size:32px;letter-spacing:-0.02em;color:var(--wm-ink)}
      .wm-pdp .bc-price{font-family:var(--wm-f-display);font-weight:700;font-size:36px;letter-spacing:-0.02em;color:var(--wm-navy)}
      .wm-pdp .bc-each{font-size:13px;color:var(--wm-ink-2)}
      .wm-pdp .bc-feat{list-style:none;padding:0;margin:8px 0 0;display:flex;flex-direction:column;gap:8px;font-size:14px;color:var(--wm-ink-2)}
      .wm-pdp .bc-feat li{position:relative;padding-left:20px}
      .wm-pdp .bc-feat li::before{content:"✓";position:absolute;left:0;color:var(--wm-navy);font-weight:700}
      .wm-pdp .bc-form{margin-top:auto;padding-top:14px}
      .wm-pdp .bc-btn{width:100%;padding:14px 20px;font-family:var(--wm-f-body);font-size:14px;font-weight:600;letter-spacing:0.02em;color:var(--wm-ink);background:var(--wm-canvas);border:1px solid var(--wm-ink);cursor:pointer;transition:all 200ms var(--wm-ease)}
      .wm-pdp .bc-btn:hover{background:var(--wm-ivory-2)}
      .wm-pdp .bc-btn-primary{background:var(--wm-navy);color:var(--wm-canvas);border-color:var(--wm-navy)}
      .wm-pdp .bc-btn-primary:hover{background:var(--wm-ink);border-color:var(--wm-ink)}

      .wm-pdp .features-grid{display:grid;grid-template-columns:1fr;gap:40px;margin-top:48px}
      @media(min-width:680px){.wm-pdp .features-grid{grid-template-columns:repeat(2,1fr)}}
      @media(min-width:1100px){.wm-pdp .features-grid{grid-template-columns:repeat(4,1fr);gap:32px}}
      .wm-pdp .feat{display:flex;flex-direction:column;gap:16px}
      .wm-pdp .feat-img{aspect-ratio:1/1;background:var(--wm-ivory-2);overflow:hidden}
      .wm-pdp .feat-img img{width:100%;height:100%;object-fit:cover}
      .wm-pdp .feat h3{font-family:var(--wm-f-display);font-weight:700;font-size:22px;letter-spacing:-0.01em;line-height:1.2}
      .wm-pdp .feat p{font-size:14.5px;color:var(--wm-ink-2);line-height:1.55}
      .wm-pdp .pillars{display:flex;flex-direction:column;gap:0;margin-top:40px}
      .wm-pdp .pillar{display:grid;grid-template-columns:1fr;border-top:1px solid var(--wm-rule);padding:clamp(40px,5vw,64px) 0;gap:clamp(28px,3vw,56px);align-items:center}
