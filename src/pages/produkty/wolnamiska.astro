      <!-- 02b HOW IT WORKS — 4 GIFY (zawsze pierwsza sekcja w opisie) -->
      <section class="section" id="how">
        <div class="wrap">
          <h2 class="h2 reveal">Cztery kroki. Piętnaście minut spokoju.</h2>

