---
/**
 * SZABLON STRONY PRODUKTOWEJ — BezSmugi.pl
 *
 * Jak uzyc:
 * 1. Skopiuj ten plik: cp src/pages/produkty/_szablon.astro src/pages/produkty/<slug>.astro
 * 2. Zmien `PRODUCT_SLUG` ponizej na slug produktu z Vendure (taki sam jak nazwa pliku bez .astro)
 * 3. Pisz HTML + Tailwind w sekcjach <!-- CUSTOM SECTIONS --> ponizej. Wszystko poza nimi nie ruszaj.
 * 4. Brand colors gotowe do uzycia: bg-brand-primary, bg-brand-secondary, bg-brand-canvas, text-brand-text
 *
 * Co robi szablon:
 * - Pobiera produkt z Vendure (po slug)
 * - Renderuje breadcrumbs + ATC form + cene + warianty (gotowe primitives)
 * - Daje miejsce na hand-craftowane sekcje opisowe (zalety, FAQ, recenzje, "jak uzywac" itp.)
 * - Meta Pixel + CAPI ViewContent + AddToCart (consent-gated)
 * - JSON-LD schema.org/Product
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Price from '@/components/Price.astro';
import Button from '@/components/Button.astro';
import TrustBadges from '@/components/TrustBadges.astro';
import StickyATCBar from '@/components/StickyATCBar';
import { shopApi, shopApiRaw, redirectWithToken } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { ADD_TO_CART } from '@/lib/mutations';
import { sanitizeHtml } from '@/lib/sanitize';
import { buildAssetUrl } from '@/lib/utils';
import type { VendureProduct, VendureVariant, VendureAsset } from '@/types/vendure';
import { sendCAPIEvent, buildUserData, generateEventId } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';

// ZMIEN TO NA SLUG SWOJEGO PRODUKTU (z Vendure Dashboard)
const PRODUCT_SLUG = 'kulka-do-powolnego-karmienia';

const storeConfig = await getStoreConfig(Astro.request);

// Handle POST — add to cart
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const variantId = formData.get('variantId') as string;
    const rawQty = parseInt(formData.get('quantity') as string || '1', 10);
    const quantity = Math.max(1, Math.min(99, isNaN(rawQty) ? 1 : rawQty));

    if (variantId) {
      const result = await shopApiRaw<any>(ADD_TO_CART, { variantId, quantity }, Astro.request);

      const userData = await buildUserData(Astro.request);
      await sendCAPIEvent({
        event_name: 'AddToCart',
        event_time: Math.floor(Date.now() / 1000),
        event_id: generateEventId(),
        event_source_url: Astro.url.href,
        action_source: 'website',
        user_data: userData,
        custom_data: {
          content_ids: [variantId],
          content_type: 'product',
          currency: 'PLN',
        },
      }, storeConfig.metaDatasetId);
      return redirectWithToken('/koszyk', result.authToken);
    }
    return Astro.redirect('/koszyk');
  } catch {}
}

let product: VendureProduct | null = null;
try {
  const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug: PRODUCT_SLUG }, Astro.request);
  product = data.product;
} catch {}

if (!product) return Astro.rewrite('/404');

const mainImage = product.featuredAsset || product.assets?.[0];
const firstVariant = product.variants?.[0];
const lowestPrice = firstVariant?.priceWithTax ?? 0;
const allOutOfStock = product.variants?.every((v: VendureVariant) => v.stockLevel === 'OUT_OF_STOCK');

const stripHtml = (html: string) => html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
const metaDescription = stripHtml(product.description || '').slice(0, 160);
const ogImageUrl = mainImage?.preview ? buildAssetUrl(mainImage.preview, 'large') : undefined;

// CAPI ViewContent
const viewContentEventId = generateEventId();
const vcUserData = await buildUserData(Astro.request);
sendCAPIEvent({
  event_name: 'ViewContent',
  event_time: Math.floor(Date.now() / 1000),
  event_id: viewContentEventId,
  event_source_url: Astro.url.href,
  action_source: 'website',
  user_data: vcUserData,
  custom_data: {
    content_ids: [firstVariant?.sku || product.id],
    content_name: product.name,
    content_type: 'product',
    value: lowestPrice / 100,
    currency: 'PLN',
  },
}, storeConfig.metaDatasetId);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: metaDescription,
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  sku: firstVariant?.sku || undefined,
  offers: {
    '@type': 'Offer',
    price: (lowestPrice / 100).toFixed(2),
    priceCurrency: 'PLN',
    availability: allOutOfStock ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
    url: Astro.url.href,
  },
};
---

<BaseLayout
  title={product.name}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogType="product"
>
  <div class="bg-brand-canvas text-brand-text">

    <!-- ============================================ -->
    <!-- HERO + ATC (nie ruszaj logiki, mozesz ruszac styling) -->
    <!-- ============================================ -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
      <Breadcrumbs items={[
        { label: 'Strona główna', href: '/' },
        { label: product.name },
      ]} />

      <div class="mt-4 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <div class="aspect-square overflow-hidden rounded-lg bg-white">
          {mainImage && (
            <img
              src={buildAssetUrl(mainImage.preview, 'large')}
              alt={product.name}
              width="800"
              height="800"
              class="h-full w-full object-cover"
              fetchpriority="high"
              loading="eager"
            />
          )}
        </div>

        <div>
          <h1 class="text-2xl sm:text-3xl font-bold text-brand-text">{product.name}</h1>
          <Price price={lowestPrice} class="mt-3 text-xl" />

          <form method="POST" class="mt-6 space-y-4">
            <input type="hidden" name="variantId" value={firstVariant?.id} />
            <div>
              <label for="quantity" class="block text-sm font-medium text-brand-text mb-1.5">Ilosc</label>
              <input
                type="number"
                name="quantity"
                id="quantity"
                value="1"
                min="1"
                max="99"
                required
                class="w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm text-center focus:border-brand-secondary focus:ring-1 focus:ring-brand-secondary focus:outline-none"
              />
            </div>
            {allOutOfStock ? (
              <button type="button" disabled class="w-full sm:w-auto rounded-lg bg-gray-300 px-6 py-3 text-sm font-semibold text-gray-500 cursor-not-allowed">
                Niedostepny
              </button>
            ) : (
              <Button type="submit" variant="primary" size="lg" class="w-full sm:w-auto" id="primary-atc-btn">
                Dodaj do koszyka
              </Button>
            )}
          </form>

          <TrustBadges />

          {!allOutOfStock && firstVariant && (
            <StickyATCBar
              client:idle
              productName={product.name}
              price={lowestPrice}
              variantId={firstVariant.id}
            />
          )}
        </div>
      </div>
    </div>

    <!-- ============================================ -->
    <!-- CUSTOM SECTIONS — TUTAJ PISZ HTML + TAILWIND  -->
    <!-- ============================================ -->

    <!-- Sekcja 1: Zalety produktu -->
    <section class="py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl sm:text-4xl font-bold text-brand-text mb-12 text-center">
          Dlaczego ten produkt?
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          <div class="bg-brand-primary rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3">{'\u{1F436}'}</div>
            <h3 class="font-semibold text-brand-text mb-2">Bezpieczne</h3>
            <p class="text-sm text-brand-text/80">Materialy bezpieczne dla pupila</p>
          </div>
          <div class="bg-brand-primary rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3">{'\u{1F49A}'}</div>
            <h3 class="font-semibold text-brand-text mb-2">Sprawdzone</h3>
            <p class="text-sm text-brand-text/80">Polecane przez weterynarzy</p>
          </div>
          <div class="bg-brand-primary rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3">{'\u{1F69A}'}</div>
            <h3 class="font-semibold text-brand-text mb-2">Szybka wysylka</h3>
            <p class="text-sm text-brand-text/80">Z Polski w 24h</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Sekcja 2: CTA -->
    <section class="py-16 sm:py-24 bg-brand-secondary text-brand-canvas">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Sprobuj juz dzis</h2>
        <p class="text-lg mb-8 opacity-90">Twoj pupil zasluguje na to, co najlepsze.</p>
        <a href="#primary-atc-btn" class="inline-block bg-brand-canvas text-brand-secondary px-8 py-4 rounded-lg font-semibold hover:bg-white transition">
          Zamow teraz
        </a>
      </div>
    </section>

    <!-- TODO: Dodaj wiecej sekcji wedlug potrzeb (FAQ, opinie, video, jak uzywac, etc.) -->

  </div>

  {/* JSON-LD */}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  {/* ViewContent pixel (browser) */}
  {firstVariant && (
    <script
      is:inline
      define:vars={{
        vcEventId: viewContentEventId,
        vcContentName: product.name,
        vcContentIds: [firstVariant.sku || firstVariant.id],
        vcValue: lowestPrice / 100,
      }}
    >
      if (typeof fbq !== 'undefined') {
        fbq('track', 'ViewContent', {
          content_name: vcContentName,
          content_ids: vcContentIds,
          content_type: 'product',
          value: vcValue,
          currency: 'PLN',
        }, { eventID: vcEventId });
      }
    </script>
  )}

  {/* Async ATC form */}
  <script>
    (function() {
      const form = document.querySelector<HTMLFormElement>('form[method="POST"]');
      if (!form) return;
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!btn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const variantId = formData.get('variantId');
        const quantity = parseInt(String(formData.get('quantity') || '1'), 10);
        if (!variantId) return;

        btn.disabled = true;
        const original = btn.textContent;
        btn.textContent = 'Dodawanie...';

        try {
          const res = await fetch('/api/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ variantId, quantity }),
          });
          if (res.ok) {
            const data = await res.json();
            window.dispatchEvent(new CustomEvent('cart-updated', { detail: data.order }));
          } else {
            form.submit();
            return;
          }
        } catch {
          form.submit();
          return;
        }

        btn.disabled = false;
        btn.textContent = original;
      });
    })();
  </script>
</BaseLayout>
