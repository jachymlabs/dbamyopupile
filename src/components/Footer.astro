---
interface Props {
  storeName?: string;
  storeTagline?: string;
  contactEmail?: string;
}
const { storeName = 'DbamyOPupile.pl', storeTagline = 'Sklep dla świadomych opiekunów', contactEmail = 'sklep@dbamyopupile.pl' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-gray-50 mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <p class="text-lg font-bold text-gray-900">{storeName}</p>
        <p class="mt-2 text-sm text-gray-500">{storeTagline}</p>
      </div>

      <!-- Sklep -->
      <div>
        <p class="text-sm font-medium text-gray-900 mb-3">Sklep</p>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-gray-500 hover:text-gray-900 transition-colors no-underline">Strona główna</a></li>
          <li><a href="/produkty/wolnamiska" class="text-sm text-gray-500 hover:text-gray-900 transition-colors no-underline">WolnaMiska</a></li>
          <li><a href="/koszyk" class="text-sm text-gray-500 hover:text-gray-900 transition-colors no-underline">Koszyk</a></li>
          <li><a href="/kontakt" class="text-sm text-gray-500 hover:text-gray-900 transition-colors no-underline">Kontakt</a></li>
        </ul>
      </div>

      <!-- Informacje prawne -->
      <div>
        <p class="text-sm font-medium text-gray-900 mb-3">Informacje</p>
        <ul class="space-y-2">
          <li><a href="/regulamin" class="text-sm text-gray-500 hover:text-gray-900 transition-colors no-underline">Regulamin</a></li>
          <li><a href="/polityka-prywatnosci" class="text-sm text-gray-500 hover:text-gray-900 transition-colors no-underline">Polityka prywatności</a></li>
          <li><a href="/dostawa-i-zwroty" class="text-sm text-gray-500 hover:text-gray-900 transition-colors no-underline">Dostawa i zwroty</a></li>
        </ul>
      </div>

      <!-- Dane firmy -->
      <div>
        <p class="text-sm font-medium text-gray-900 mb-3">Dane firmy</p>
        <address class="not-italic text-sm text-gray-500 space-y-1">
          <p>PATRYK JACHYM LABS</p>
          <p>ul. Tarnowskich 71p/1<br/>33-100 Tarnów</p>
          <p>NIP: 9930710781</p>
          <p>REGON: 542607372</p>
          <p class="pt-2"><a href={`mailto:${contactEmail}`} class="text-gray-500 hover:text-gray-900 transition-colors no-underline">{contactEmail}</a></p>
          <p><a href="tel:+48577723506" class="text-gray-500 hover:text-gray-900 transition-colors no-underline">+48 577 723 506</a></p>
        </address>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-200">
      <p class="text-xs text-gray-400 text-center">
        &copy; {year} PATRYK JACHYM LABS · NIP 9930710781 · Wszystkie prawa zastrzeżone.
      </p>
    </div>
  </div>
</footer>
