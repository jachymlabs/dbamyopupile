---
/**
 * FlickoDescription — pełny opis produktu Flicko.
 * Brelok-pierścień z kulką flickable. Kinetic ring fidget, antystresowy keychain
 * z kulką do pstrykania. Dyskretny, mały, zawsze przy kluczach.
 *
 * Assety w /public/flicko/photos/ (20 webp).
 * Brand voice: sentence case, brak em-dashes, founder Hubert i Patryk.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/flicko/photos';

// Reviews z reviews.json (klucz "flicko")
const reviews = getProductReviews('flicko');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products, exclude flicko, take 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'flicko')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('FlickoDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/flicko-01-lifestyle-park-mezczyzna.webp`} alt="" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/flicko-11-lifestyle-kobieta-pociag.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/flicko-08-lifestyle-kobieta-klasa.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/flicko-03-lifestyle-dlon-wnetrze.webp`} alt="" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od kieszeni do kluczy</span>
        <h2>Małe pstryknięcie, które <span class="md-em">zawsze masz przy sobie</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Klikasz długopisem, aż ktoś spojrzy z irytacją</li>
            <li><span class="material-symbols-outlined">close</span>Obgryzasz paznokcie podczas pięciominutowej przerwy</li>
            <li><span class="material-symbols-outlined">close</span>Telefon wyjeżdża z kieszeni, bo nic innego nie ma</li>
            <li><span class="material-symbols-outlined">close</span>Napięcie zostaje w ciele, choć minuta już minęła</li>
          </ul>
          <p class="md-ps-foot">Ręce chcą czegoś konkretnego. I zawsze znajdą sobie coś, niekoniecznie to, czego chcesz.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">Flicko</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Jedna kulka, jedno pstryknięcie, zero hałasu</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Zawsze przy kluczach, zero szukania</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Cichy klik zamiast głośnego długopisu</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Napięcie idzie w ruch, nie w paznokcie</li>
          </ul>
          <p class="md-ps-foot">Pstrykasz kciukiem, kulka się obraca, palce mają konkretne zajęcie. I już chcesz jeszcze raz.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/flicko-13-reklama-porownanie.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Nie ma w tym winy, ręce po prostu muszą coś robić</h2>
        <p class="md-body">Wykład, korek, czekanie na odpowiedź, palce same gdzieś wędrują. Do długopisu, do telefonu, do ust. Nie dlatego, że jesteś rozkojarzony, tylko dlatego, że ręce szukają zajęcia, którego mózg w tej chwili nie dostaje. Flicko daje im to zajęcie po cichu, bez otwierania kolejnej aplikacji i bez wyciągania telefonu z kieszeni. Mały brelok zawsze pod ręką, gotowy w tej samej sekundzie, w której tego potrzebujesz.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/flicko-14-packshot-bialy-hero.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Co dostajesz w zestawie</span>
        <h2>Mała kulka do pstrykania, pierścień do trzymania, karabinek do kluczy</h2>
        <p class="md-body">Pierścień leży w dłoni jak gruba opaska. Silikon miękki, ale z charakterem. W środku osadzona jest mała kulka, którą pstrykasz kciukiem. Obraca się, daje wyraźny opór i wraca na miejsce z cichym, satysfakcjonującym klikiem. Możesz pstrykać raz po raz, podrzucać, łapać, kręcić, im dłużej masz Flicko w dłoni, tym więcej kombinacji odkrywasz. Metalowy karabinek wpinasz do kluczy albo zaczepiasz na plecaku. Brelok jest przy tobie, kiedy go potrzebujesz.</p>
      </div>
    </div>
  </section>

  {/* ========== 05 CUSTOMER STORY (featured = pierwsza opinia z items) ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/flicko-15-lifestyle-kobieta-okno.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== 06 COMPARISON TABLE (Flicko vs alternatives) ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Porównanie</span>
        <h2>Flicko kontra rzeczy, które i tak już robisz</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>Flicko</span></th>
              <th>Zwykły fidget ring</th>
              <th>Spinner</th>
              <th>Brelok ozdobny</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Cichy na zajęciach i w biurze</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Zawsze przy kluczach</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Zajmuje ręce i głowę</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Mieści się w najmniejszej kieszeni</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Wciąga na dłużej niż tydzień</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Nie wygląda jak dziecięca zabawka</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== 07 TABBED USE CASES ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Kiedy Flicko robi robotę</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">Zawsze pod ręką</button>
        <button class="md-tab-btn" data-md-tab="1">W pracy ukradkiem</button>
        <button class="md-tab-btn" data-md-tab="2">Podczas spotkań</button>
        <button class="md-tab-btn" data-md-tab="3">W komunikacji</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/flicko-06-lifestyle-klucze-szafka.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Wpięty do kluczy, gotowy w sekundę</h3>
            <p class="md-body">Karabinek trzyma Flicko przy kluczach albo przy szelce plecaka. Wyciągasz klucze i już masz brelok w dłoni, bez szukania, bez pamiętania, że trzeba go zabrać. Idzie z tobą do domu, do auta, do akademika, do siłowni. Najlepszy fidget to ten, który masz wtedy, kiedy go potrzebujesz.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/flicko-03-lifestyle-dlon-wnetrze.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Reset między mailami, którego nikt nie zauważa</h3>
            <p class="md-body">Programista czekający na build, nauczyciel między lekcjami, menedżer po trudnym telefonie. Ręce mają co robić, głowa chwilę odpoczywa. Flicko nie wygląda jak zabawka, wygląda jak przemyślany dodatek przy kluczach. Możesz pstrykać przy biurku i nikt obok nawet nie podniesie wzroku.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/flicko-08-lifestyle-kobieta-klasa.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Skupienie, które nie przeszkadza w skupieniu innych</h3>
            <p class="md-body">Na długim spotkaniu, prezentacji, wykładzie albo egzaminie, ręce chcą czegoś. Flicko siedzi w dłoni pod stołem albo na kolanach i nie hałasuje. Kulka pstryka miękko, klik słyszysz ty, a nie cała sala. Wystarczy, żeby myśli wróciły do tematu.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/flicko-11-lifestyle-kobieta-pociag.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Autobus, pociąg, poczekalnia, bez szukania zasięgu</h3>
            <p class="md-body">Flicko nie potrzebuje Wi-Fi, baterii, ładowania ani aplikacji. Wiszący na kluczach jest przy tobie zanim wyjmiesz telefon z kieszeni. Pstrykasz kciukiem, rzucasz w górę, łapiesz, kręcisz między palcami. Nikt obok nawet nie podniesie wzroku, a tobie dłuży się o połowę krócej.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 08 POLECANE PRODUKTY ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-related-head">
          <div>
            <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
            <h2>Polecane produkty</h2>
          </div>
          <a href="/sklep" class="md-related-all">
            zobacz wszystko
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const salePct = hasSale ? Math.round(((regularPrice - currentPrice) / regularPrice) * 100) : 0;
            const isRange = p.priceWithTax?.__typename === 'PriceRange' && p.priceWithTax.min !== p.priceWithTax.max;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {hasSale && <span class="md-related-sale-badge">−{salePct}%</span>}
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {isRange ? `od ${formatPrice(p.priceWithTax.min)}` : formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== 09 TRUST STRIP ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>10k+ klientów</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== 10 VARIANT SHOWCASE (4 kolory, mobile: scroll-snap carousel) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Wybór koloru</span>
        <h2>Cztery warianty, każdy z innym charakterem</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć kolory
        </p>
      </div>
      <div class="md-variants-grid md-variants-grid--four">
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/flicko-19-packshot-czarny-studio.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
