  /* ---------- PROBLEM → SOLUTION — refined polish ---------- */
  .md-ps-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .md-ps-emoji {
    display: inline-flex;
