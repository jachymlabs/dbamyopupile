---
/**
 * FasolkaDescription — pełny opis produktu Fasolka (brelok-strąk z groszkami).
 * Silikonowy brelok pop-it w kształcie strąka groszku, antystresowy fidget dla rąk.
 *
 * Assety w /public/brelok-fasola/photos/ (9 webp).
 * Struktura: 18 sekcji 1:1 z MoodlesDescription. Brand voice: sentence case,
 * brak em-dashy, Founder "Hubert i Patryk", brand names z dużej.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/brelok-fasola/photos';

// Reviews — z osobnego JSON per produkt (brelok-fasola tutaj)
const reviews = getProductReviews('brelok-fasola');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude brelok-fasola, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'brelok-fasola')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('FasolkaDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/fasolka-01.webp`} alt="" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/fasolka-07.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/fasolka-04.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/fasolka-03.webp`} alt="" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od nerwowego nawyku do spokojnego rytuału</span>
        <h2>Daj rękom coś <span class="md-em">cichego</span> do roboty</h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Skubiesz etykietki na butelce</li>
            <li><span class="material-symbols-outlined">close</span>Klikasz długopisem aż ktoś patrzy krzywo</li>
            <li><span class="material-symbols-outlined">close</span>Zaciskasz dłonie pod stołem, kiedy czekasz</li>
            <li><span class="material-symbols-outlined">close</span>Bierzesz telefon, bo ręce nie wiedzą gdzie być</li>
          </ul>
          <p class="md-ps-foot">Ręce zawsze coś znajdą. Pytanie tylko co, i czy skończy się na pogniecionej kartce i spojrzeniach przy stole.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">Fasolka</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Jeden groszek, jeden miękki pop</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Nieskończona pętla bez ładowania</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Zupełnie cicho, tylko dla siebie</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Wisi przy kluczach, zawsze pod ręką</li>
          </ul>
          <p class="md-ps-foot">Wyciskasz groszek ze strąka, przeskakuje na drugą stronę z cichym pop. Wracasz. Powtarzasz. Ręce wiedzą co robić.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/fasolka-05.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2><span class="md-em">Koniec</span> sięgania po telefon, kiedy ręce się nudzą</h2>
        <p class="md-body">Kolejka, długa lekcja, nudna prezentacja. Ręce szukają, mózg szuka, razem lądują na telefonie, bo nic innego nie ma pod ręką. Fasolka nie walczy z telefonem ani z tym, że lubisz coś mieć w dłoni. Po prostu daje rękom lepszą robotę. Miękki silikonowy strąk, kilka groszków w środku, jeden pop i wracasz do tego, czym się zajmowałeś przed chwilą. Bez ekranu, bez powiadomień, bez nieskończonego scrolla.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/fasolka-01.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Zielony strąk, kilka groszków z buźkami</h2>
        <p class="md-body">Fasolka to silikonowy strąk w stylu edamame, miękki i zielony, około sześciu centymetrów długości. Otwiera się wzdłuż na dwie połówki, w środku siedzą małe groszki z kawaii twarzyczkami. Kciukiem wypychasz <strong>groszek ze strąka</strong>, przeskakuje na drugą stronę z miękkim, cichym pop. Wracasz z powrotem, powtarzasz. Można to robić godzinami i żaden groszek tego nie pamięta, zawsze jest gotowy na następne wciśnięcie. Na górze <strong>metalowy łańcuszek kulkowy</strong> i zielona pętelka, do kluczy, do plecaka, do suwaka kurtki.</p>
      </div>
    </div>
  </section>

  {/* ========== CUSTOMER STORY (pozycja 5) — featured = pierwsza opinia 5-star ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/fasolka-09.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== COMPARISON TABLE (pozycja 6) — Fasolka vs fidget spinner / pop-it / squishy klasyczny ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Porównanie</span>
        <h2>Fasolka kontra inne fidgety</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>Fasolka</span></th>
              <th>Fidget spinner</th>
              <th>Pop-it</th>
              <th>Klasyczny squishy</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Cichy, można używać w klasie</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Wisi przy kluczach, zawsze przy sobie</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Mieści się w kieszeni</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Nie znudzi się po tygodniu</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Działa od pierwszego wciśnięcia</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Wygląda dobrze przy biurku</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      {/* Mobile swipe hint — pokazuje się tylko gdy tabela się scrolluje */}
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo, aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== TABBED USE CASES (pozycja 7) — Dla kogo jest Fasolka ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Dla kogo jest Fasolka?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">Dorośli przy biurku</button>
        <button class="md-tab-btn" data-md-tab="1">Dzieci squish it</button>
        <button class="md-tab-btn" data-md-tab="2">BFRB self regulation</button>
        <button class="md-tab-btn" data-md-tab="3">Prezent pod ręką</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/fasolka-09.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Reset przy biurku w dziesięć sekund</h3>
            <p class="md-body">Telekonferencja się dłuży, mail się kompiluje, projekt utknął na chwilę. Wyciągasz Fasolkę z kieszeni albo zsuwasz z karabińczyka przy kluczach, wyciskasz parę groszków i wracasz do roboty. Ręce mają co robić, mózg dostaje mikro pauzę, telefon zostaje na biurku. Brelok nie wygląda jak zabawka dla dzieci, więc nikt na zoomie nie zwróci uwagi.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/fasolka-04.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Pierwsze fidgetowanie, które nie stuka</h3>
            <p class="md-body">Od mniej więcej trzech lat. Miękki silikon, żadnych ostrych krawędzi, żadnych małych elementów do zgubienia. Groszki siedzą w strąku, mają buźki, są zielone i trochę śmieszne. Dzieci lubią to wyciskać z prostego powodu, że lubią. Cichy pop nie przeszkadza na lekcji, brelok można przyczepić do plecaka albo piórnika. Przy najmłodszych warto być obok dla spokoju rodziców, nie groszków.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/fasolka-03.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Ręce, które same szukają zajęcia</h3>
            <p class="md-body">Obgryzanie paznokci, skubanie skórek, wyrywanie włosów, klikanie długopisem. Ręce same szukają bodźca, bo mózg potrzebuje rozproszenia. Fasolka przekierowuje tę energię na konkretny, satysfakcjonujący ruch. Jeden groszek, jeden pop, potem drugi. Po dwóch tygodniach palce wyglądają inaczej, a stary nawyk traci napęd. To nie zastępuje terapii, ale dobrze uzupełnia codzienne strategie radzenia sobie.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/fasolka-02.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Mały prezent, który nie ląduje w szufladzie</h3>
            <p class="md-body">Do urodzinowego zestawu, jako wisząca rzecz przy plecaku, do szkolnej paczki ze słodyczami i naklejkami. Fasolka ma buźki, jest zielona, wygląda jak edamame, to się pamięta. I działa od pierwszego wciśnięcia, bez tłumaczenia zasad. Cena na tyle niska, że można kupić kilka sztuk i rozdać całej klasie albo całemu zespołowi.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== POLECANE PRODUKTY (pozycja 8) ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== TRUST STRIP — pozycja 9 ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>10k+ klientów</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== VARIANT SHOWCASE — 3 karty użycia (pozycja 10, mobile: scroll-snap carousel) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Trzy sposoby na Fasolkę</span>
        <h2>Mały brelok, kilka różnych powodów, żeby go mieć</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </p>
      </div>
      <div class="md-variants-grid">
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/fasolka-04.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #4A7A52;"></span>
            <h3>Dla dzieci</h3>
