---
/**
 * SnapStonesDescription — pełny opis produktu SnapStones.
 * Rodzinna gra balansowa: gładkie kamienie do układania i balansowania,
 * lniany woreczek, rytuał wieczoru bez ekranu.
 *
 * Assety w /public/snapstones/photos/ (18 webp).
 * Tone post-humanizer: sentence case, konwersacyjny, anti-screen, slow play.
 * Struktura 18 sekcji wg MoodlesDescription.astro (universal template).
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/snapstones/photos';

// Reviews — z osobnego JSON per produkt (snapstones tutaj)
const reviews = getProductReviews('snapstones');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude snapstones, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'snapstones')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('SnapStonesDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/snapstones-01.webp`} alt="" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/snapstones-02.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/snapstones-09.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/snapstones-04.webp`} alt="" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od scrollowania do wspólnego wieczoru</span>
        <h2>Daj wieczorom rytm, który <span class="md-em">naprawdę zostaje</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Każdy w domu na swoim telefonie</li>
            <li><span class="material-symbols-outlined">close</span>Wieczór mija i nikt nie pamięta, o czym rozmawialiście</li>
            <li><span class="material-symbols-outlined">close</span>Gry planszowe wymagają instrukcji na sześć stron</li>
            <li><span class="material-symbols-outlined">close</span>Dzieci pytają „a możemy obejrzeć jeszcze jeden odcinek"</li>
          </ul>
          <p class="md-ps-foot">Każdy chce wieczoru razem. Ale kiedy nikt nie wstaje pierwszy od ekranu, to ten wieczór nie przychodzi sam.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">SnapStones</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Rytuał, który wciąga w trzy minuty</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Chwila skupienia dla każdego przy stole</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Wieczory bez ekranu, które przychodzą same</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Gra dla 6-latka i dla babci w jednej partii</li>
          </ul>
          <p class="md-ps-foot">Wyciągasz kamienie z woreczka, układasz je na stole i już jesteście w środku. Bez instrukcji, bez baterii, bez ekranu.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/snapstones-17.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2><span class="md-em">Koniec</span> z wieczorami, w których jesteście tylko obok siebie</h2>
        <p class="md-body">Wszyscy w domu, każdy na swojej kanapie, każdy w swoim telefonie. Niby razem, a jakby osobno. SnapStones zmieniają to bez wielkich deklaracji. Wystarczy wysypać kamienie, ustawić pierwszy na stole i już ktoś dosiada się do partii. Gładkie otoczaki w dłoni, ostrożny ruch, czyjś śmiech, kiedy wieża się rozsypie. Wieczory razem, które nie wymagają od nikogo dobrej woli, tylko zwykłych chwil ze sobą.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/snapstones-15.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Cztery kształty, jeden rytm wieczoru</h2>
        <p class="md-body">Każdy kamień jest inny. <strong>Płaskie</strong> stanowią fundament i schodzą się gładko. <strong>Owalne</strong> się chwieją, ale jak złapią równowagę, trzymają cały balans. <strong>Wąskie</strong> układają się jak kolumny i podnoszą wieżę w górę. <strong>Zaokrąglone</strong> są na koniec, dla odważnych, kiedy konstrukcja drga. Cztery kształty, które razem grają jak orkiestra. Każda partia wychodzi inaczej.</p>
      </div>
    </div>
  </section>

  {/* ========== 05 — CUSTOMER STORY (featured = pierwsza opinia 5-star z items) ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/snapstones-11.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== 06 — COMPARISON TABLE (SnapStones vs Jenga / klocki / gry planszowe) ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Porównanie</span>
        <h2>Spokojnie inne niż wieczory z planszówką</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>SnapStones</span></th>
              <th>Jenga</th>
              <th>Klocki</th>
              <th>Planszówka</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Zasada w jednym zdaniu</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Partia w 10 minut</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Działa bez instrukcji</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Naturalne materiały, zero plastiku</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Dla 6-latka i dla dziadka przy jednym stole</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Można po prostu pobawić, bez zasad</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Mieści się w plecaku</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo, żeby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== 07 — TABBED USE CASES ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Dla kogo są SnapStones?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">Rodzina przy stole</button>
        <button class="md-tab-btn" data-md-tab="1">Dzieci kreatywne</button>
        <button class="md-tab-btn" data-md-tab="2">Mindfulness dorośli</button>
        <button class="md-tab-btn" data-md-tab="3">Prezent</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/snapstones-13.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Wieczór, który dzieje się sam</h3>
            <p class="md-body">Wysypujesz kamienie na stół i każdy się dosiada. Pierwsza partia to nauka, druga to już rywalizacja. Bez instrukcji, bez tłumaczenia, bez „kto wymyślił te zasady". Wieczór razem, który nie wymaga od nikogo wysiłku.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/snapstones-12.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Wieża, most, drzewko, smok</h3>
            <p class="md-body">Dzieci nie potrzebują zasad. Wystarczą kształty, które się układają. Budują wieże, mosty, ludziki, smoki. Każda konstrukcja inna. SnapStones rozwijają wyobraźnię i koordynację bez ekranu i bez podpowiedzi z YouTube.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/snapstones-10.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Kamień w dłoni zamiast telefonu</h3>
            <p class="md-body">Wieczorne układanie kamieni działa jak mała medytacja. Wybierasz kształt, sprawdzasz balans, kładziesz ostrożnie. Oddech sam zwalnia. Idealnie pasuje do osób z ADHD, które potrzebują rytuału przed snem albo chwili skupienia po pracy.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/snapstones-05.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Prezent, który nie ląduje w szufladzie</h3>
            <p class="md-body">Lniany woreczek, gładkie kamienie, pomysł na wieczór bez ekranu. Sprawdza się na urodziny dziecka, prezent ślubny, niespodziankę dla rodziców. Praktyczny, ładny i taki, do którego naprawdę się wraca.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 08 — POLECANE PRODUKTY ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== 09 — TRUST STRIP ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>3k+ klientów</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== 10 — VARIANT SHOWCASE (3 karty — sposoby grania, mobile: scroll-snap carousel) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Trzy sposoby grania</span>
        <h2>Wybierz, jak chcesz spędzić wieczór</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </p>
      </div>
      <div class="md-variants-grid">
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/snapstones-12.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #4A7A52;"></span>
            <h3>Wieża balansu</h3>
            <p>Klasyczny tryb gry. Każdy gracz dokłada kolejny kamień. Kto przewróci wieżę, ten przegrywa. Partia trwa 10 do 15 minut, ale napięcie zostaje na długo po ostatnim ruchu.</p>
          </div>
        </div>
        <div class="md-variant-card md-variant-card--lavender">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/snapstones-01.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #A78BCC;"></span>
            <h3>Swobodne układanie</h3>
            <p>Bez zasad, bez rywalizacji. Każdy buduje swoje. Wieże, mosty, smoki, ludziki. Dzieci robią postacie, dorośli ćwiczą mindfulness, wieczór mija sam. Najczęściej wybierany tryb przed snem.</p>
          </div>
        </div>
        <div class="md-variant-card md-variant-card--strawberry">
