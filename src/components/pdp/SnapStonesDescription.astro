  /* ---------- EXTRA 03 — COMPARISON TABLE ---------- */
  .md-compare-wrap {
    max-width: 1100px;
    margin: 0 auto;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    /* Fade na prawej krawedzi sygnalizujacy ze jest wiecej content'u do scrolla */
    mask-image: linear-gradient(to right, black 0, black calc(100% - 24px), transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 0, black calc(100% - 24px), transparent 100%);
  }
  /* Mobile-only swipe hint pod tabela */
  .md-compare-hint {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin: 14px auto 0;
    padding: 8px 14px;
    font-size: 12.5px;
    color: var(--brand-muted);
