---
/**
 * MoodlesKidsDescription — opis produktu Moodles Kids (dziecięca wersja Moodles).
 * Bazuje na szablonie MoodlesDescription.
 *
 * Assety w /public/moodles-kids/photos/ (14 webp + placeholder; gify zastąpione img).
 * Część zdjęć to placeholdery — user dogeneruje resztę.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/moodles-kids/photos';

// Reviews — z osobnego JSON per produkt (moodles-kids; null = sekcja się chowa)
const reviews = getProductReviews('moodles-kids');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude moodles-kids, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'moodles-kids')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('MoodlesKidsDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 GIFY (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/26-hero-etui-z-lancuchem-lesne.webp`} alt="Moodles Kids" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/35-wariant-truskawkowe-4-ujecie-1.webp`} alt="Moodles Kids" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/29-hero-etui-czarne-solo.webp`} alt="Moodles Kids" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/39-wariant-lesne-4-ujecie-1.webp`} alt="Moodles Kids" loading="eager" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od chaosu do spokoju</span>
        <h2>Daj dziecku coś <span class="md-em">do trzymania</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Wybuchy złości nie wiadomo skąd</li>
            <li><span class="material-symbols-outlined">close</span>Nuda, która zamienia się w awanturę</li>
            <li><span class="material-symbols-outlined">close</span>Wiercenie się przy odrabianiu lekcji</li>
            <li><span class="material-symbols-outlined">close</span>Trudne zasypianie po intensywnym dniu</li>
          </ul>
          <p class="md-ps-foot">Dziecko, które ma za dużo energii albo za dużo bodźców, szuka ujścia w ciele. Gryzienie, drapanie, wiercenie się. Cokolwiek przyniesie choć chwilę ulgi.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">moodles</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Ręce mają konkretne zajęcie</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Napięcie odpływa przez palce</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Dziecko się wycisza, nie wyłącza</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Działa też przy ADHD i nadwrażliwości</li>
          </ul>
          <p class="md-ps-foot">Daj dziecku coś, co pochłonie jego ręce. Magnesy, faktury, kulki składane na nowo. Ciało się uspokaja, głowa zwalnia.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/23-porownanie-bez-vs-z-moodles.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Ręce, które <span class="md-em">nie mogą wysiedzieć</span></h2>
        <p class="md-body">Twoje dziecko gryzie kołnierzyk, skubie paznokcie, nie może przestać się wiercić. To nie jest zła wola. Tak wygląda układ nerwowy, który szuka ujścia. Moodles dają mu dokładnie to, czego potrzebuje. Cztery faktury, magnesy w środku, kulki same skaczą do siebie przy każdym ruchu. Ręce mają konkretne zajęcie, głowa zwalnia, nawyk traci siłę. Szczególnie dla dzieci z ADHD, których dłonie ciągle szukają czegoś nowego.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/12-etui-otwieranie-lawendowe-2x2.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Cztery faktury, każda inna w dotyku</h2>
        <p class="md-body">Każda kulka czuje się inaczej w dłoni. <strong>Kostka</strong> pomaga się skupić, kiedy myśli skaczą. <strong>Kolczasta</strong> daje mocny, wyraźny bodziec dla rąk, które potrzebują czegoś intensywnego. <strong>Lawa</strong> rozluźnia napięcie. <strong>Fala</strong> działa wyciszająco przed snem albo po trudnym dniu. Razem tworzą zestaw, który dziecko samo zaczyna dobierać do nastroju.</p>
      </div>
    </div>
  </section>

  {/* ========== CUSTOMER STORY (pozycja 5) — featured = pierwsza opinia 5-star ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/27-klient-kobieta-z-otwartym-etui.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== COMPARISON TABLE (pozycja 6) — moodles vs terapia/leki/aplikacja ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Spokój bez kompromisów</span>
        <h2>Moodles a inne sposoby na wyciszenie</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>Moodles</span></th>
              <th>Terapia</th>
              <th>Leki</th>
              <th>Aplikacja</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Pomagają na napięcie</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Bez skutków ubocznych</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Bez drogich wizyt</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Bez długiego czekania na efekty</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Pomagają na dłuższy czas</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Odpowiednie dla każdego</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      {/* Mobile swipe hint — pokazuje się tylko gdy tabela się scrolluje (overflow visible) */}
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== TABBED USE CASES (pozycja 7) — Dla kogo są Moodles ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Dla kogo są Moodles Kids?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">ADHD</button>
        <button class="md-tab-btn" data-md-tab="1">Złość</button>
        <button class="md-tab-btn" data-md-tab="2">Przebodźcowanie</button>
        <button class="md-tab-btn" data-md-tab="3">Lęk</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/31-styl-zycia-spokojne-biurko.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Dziecko z ADHD potrzebuje czegoś w rękach</h3>
            <p class="md-body">Dziecko z ADHD nie siądzie spokojnie dlatego, że go o to poprosisz. Jego układ nerwowy cały czas szuka nowego bodźca. Moodles dają mu ten bodziec w dłoni: cztery różne faktury, magnesy, kulki składane na setki sposobów. Ręce są zajęte, reszta może się skupić na tym, co ważne.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/14-styl-zycia-czytanie-w-pociagu.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Złość, która musi gdzieś wyjść</h3>
            <p class="md-body">Twoje dziecko trzaska drzwiami, rzuca rzeczami, wybucha nie wiadomo skąd. Ta energia jest prawdziwa i musi mieć ujście. Moodles dają jej konkretne miejsce: ściskanie, rozciąganie, rozsypywanie i zbieranie kuleczek od nowa. Złość odpływa przez dłonie, zanim zdąży się przelać na cokolwiek wokół.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/16-styl-zycia-spotkanie-pod-biurkiem.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Za dużo bodźców naraz</h3>
            <p class="md-body">Szkoła, hałas, tłum, zbyt wiele rzeczy na raz. Dziecko wraca do domu naładowane do granic i nie wie, co z sobą zrobić. Moodles dają prosty reset: kulki w dłoni, magnesy, cisza. Bez ekranu, bez kolejnego bodźca z zewnątrz. Tylko ręce i skupienie na tym, co czujesz w palcach.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/29-hero-etui-czarne-solo.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Lęk, który nie pyta o pozwolenie</h3>
            <p class="md-body">Nowa szkoła, wyjście do lekarza, ciemny pokój wieczorem. Dziecko się boi i nie zawsze umie powiedzieć dlaczego. Serce bije szybciej, ręce szukają czegoś do trzymania. Moodles dają im to coś: ciepły silikon w dłoni, magnesy, które spokojnie klikają. Małe skupienie na dotyku pomaga wrócić do tu i teraz.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== POLECANE PRODUKTY (pozycja 8) ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== TRUST STRIP — pozycja 9 ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>10k+ klientów</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== 11 — REVIEWS (dynamiczne z reviews.json) ========== */}
  {reviews && ratingPct && (
  <section id="reviews-section" class="md-section">
    <div class="md-reviews">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>{(reviews.totalCount * 35).toLocaleString('pl-PL')}+ rodzin już wypróbowało Moodles Kids</h2>
      </div>
      <div class="md-reviews-header">
        <div class="md-reviews-big-rating">
          <div class="md-reviews-big-num">{formatRating(reviews.averageRating)}</div>
          <div class="md-reviews-big-stars">
            {[1, 2, 3, 4, 5].map((i) => {
              const k = starKind(i, reviews.averageRating);
              return k === 'full'
                ? <svg viewBox="0 0 24 24" width="24" height="24" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
                : k === 'half'
                ? <svg viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-big-half-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-big-half-${i})`}/></svg>
