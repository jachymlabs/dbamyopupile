    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .md-ps-tag--problem {
    background: var(--brand-accent-soft);
    color: var(--brand-accent);
  }
  .md-ps-tag--solution {
    background: var(--brand-primary);
    color: #FFFCF7;
  }
  .md-ps-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .md-ps-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15.5px;
    font-weight: 500;
    color: var(--brand-text);
    line-height: 1.35;
  }
  .md-ps-list li .material-symbols-outlined {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    background: var(--brand-accent-soft);
    color: var(--brand-accent);
    border-radius: 50%;
  }
  .md-ps-list--ok li {
    color: var(--brand-heading);
    font-weight: 600;
  }
  .md-ps-list--ok li .material-symbols-outlined {
    background: transparent;
