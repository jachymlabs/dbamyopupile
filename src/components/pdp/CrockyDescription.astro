---
/**
 * CrockyDescription — pełny opis produktu Crocky.
 * Gra zręcznościowa „krokodyl z chorym zębem" — napięcie przy stole bez ekranu.
 *
 * Universal 18-section template (parity z MoodlesDescription).
 * Tone: sentence case, konwersacyjny, rodzinny, ZERO em-dashes, founder = "Hubert i Patryk".
 *
 * Assety w /public/crocky/photos/ (15 webp).
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/crocky/photos';

// Reviews — z osobnego JSON per produkt (crocky tutaj)
const reviews = getProductReviews('crocky');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude crocky, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'crocky')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('CrockyDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/crocky-01-dziecko-naciska-zab.webp`} alt="Dziecko naciska ząb krokodyla Crocky" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/crocky-02-rodzina-przy-stole.webp`} alt="Rodzina gra w Crocky przy stole" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/crocky-03-makro-zeby-paszcza.webp`} alt="Makro zębów krokodyla Crocky" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/crocky-04-lifestyle-salon.webp`} alt="Crocky w salonie podczas wieczoru rodzinnego" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od nudy do napięcia</span>
        <h2>Daj wieczorom w domu coś, co naprawdę <span class="md-em">wciąga</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Wszyscy w domu, każdy w innym ekranie</li>
            <li><span class="material-symbols-outlined">close</span>Plansze leżą w szafie i nikt ich nie wyciąga</li>
            <li><span class="material-symbols-outlined">close</span>Dziecko nudzi się po pięciu minutach każdej gry</li>
            <li><span class="material-symbols-outlined">close</span>Goście siedzą i nie wiadomo, czym ich zająć</li>
          </ul>
          <p class="md-ps-foot">Dobra gra rodzinna nie powinna wymagać przygotowań ani tłumaczenia zasad. Powinna po prostu działać. Od razu, dla każdego, od pięciolatka po dziadka.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">Crocky</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Jedna zasada, którą każdy rozumie od razu</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Napięcie i śmiech od pierwszego ząbka</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Partia w pół minuty, rozgrywka raz za razem</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Działa od 4 lat do 75, bez przewagi wieku</li>
          </ul>
          <p class="md-ps-foot">Kładziesz krokodyla na stole, wciskasz ząb, czekasz. Każdy przy stole wie, co robić. Każdy chce spróbować jeszcze raz.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/crocky-04-lifestyle-salon.webp`} alt="Nudny wieczór w salonie zanim pojawi się Crocky" loading="lazy" />
      </div>
      <div>
        <h2><span class="md-em">Koniec</span> z nudnymi wieczorami w domu</h2>
        <p class="md-body">Wszyscy są w domu, ale każdy patrzy w swój ekran. Dziecko marudzi, że nie ma co robić. Rodzice scrollują, dziadkowie oglądają telewizję. Ktoś rzuca: zagrajmy w coś. I zaczyna się problem. Plansza wymaga pół godziny rozkładania, karty trzeba tłumaczyć, a najmłodsi wychodzą w połowie. Crocky nie wymaga niczego. Leży na stole, otwiera paszczę i pyta: spróbujesz? Wszyscy łapią zasadę w trzy sekundy. Dziadek gra tak samo jak pięciolatek. Wieczór zmienia się sam.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/crocky-01-dziecko-naciska-zab.webp`} alt="Dziecko naciska ząb krokodyla podczas gry" loading="lazy" />
      </div>
      <div>
        <h2>Wciskasz ząb. Czekasz. Krokodyl decyduje za ciebie</h2>
        <p class="md-body">Gracze na zmianę wciskają zęby krokodyla. Po jednym, po kolei. <strong>Każdy ząb może być tym jednym albo nie.</strong> Im dłużej nikt nie trafi na feralny, tym mocniej rośnie napięcie. Każdy patrzy na każdego, twarze się napinają, oddechy zwalniają. Kiedy paszcza w końcu zatrzaskuje się z hukiem, jest pół sekundy ciszy, a potem śmiech i natychmiastowe: jeszcze raz. Crocky resetuje się w sekundę. Wieczór trwa tak długo, jak długo wszystkim chce się grać.</p>
      </div>
    </div>
  </section>

  {/* ========== CUSTOMER STORY (pozycja 5) — featured = pierwsza opinia z reviews.json ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/crocky-02-rodzina-przy-stole.webp`} alt="Rodzina śmieje się przy stole grając w Crocky" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== COMPARISON TABLE (pozycja 6) — Crocky vs plansza/Jenga/karty/mobile ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Spektrum wieczornych gier</span>
        <h2>Porównanie z innymi sposobami na wieczór</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>Crocky</span></th>
              <th>Plansza</th>
              <th>Jenga</th>
              <th>Karty</th>
              <th>Mobile</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Gotowe od razu, bez rozkładania</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Zero zasad do tłumaczenia</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Wszyscy patrzą na siebie, nie w ekran</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Dziecko 4-latek gra z dziadkiem na równi</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Partia kończy się w minutę</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Mieści się w torbie, działa wszędzie</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== TABBED USE CASES (pozycja 7) — Dla kogo jest Crocky ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Kiedy Crocky robi robotę?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">Rodzina przy stole</button>
        <button class="md-tab-btn" data-md-tab="1">Dzieci 4+</button>
        <button class="md-tab-btn" data-md-tab="2">Spotkania ze znajomymi</button>
        <button class="md-tab-btn" data-md-tab="3">Prezent</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/crocky-02-rodzina-przy-stole.webp`} alt="Rodzina gra w Crocky po kolacji" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Wieczór, który wciąga wszystkich naraz</h3>
            <p class="md-body">Po kolacji, przed filmem, zamiast telefonów. Crocky ląduje na stole i zajmuje całą rodzinę. Dziecko czeka na swoją kolej, dziadek śmieje się głośniej niż wnuczek, mama trzyma oddech. To są te wieczory, o których potem mówi się: pamiętasz, jak ta paszcza zatrzasnęła się tacie na palcu?</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/crocky-01-dziecko-naciska-zab.webp`} alt="Dziecko 4+ samodzielnie bawi się Crocky" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Gra, którą czterolatek rozumie szybciej niż ty</h3>
            <p class="md-body">Crocky działa od około 4-5 roku życia. Dzieci łapią zasadę bez tłumaczenia. Zero liter, zero punktów do liczenia, zero kart do zapamiętania. Jest krokodyl, są zęby, jest jedno wielkie pytanie: który to będzie? To wystarczy na długie popołudnie, bez ekranu i bez nudy.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/crocky-04-lifestyle-salon.webp`} alt="Znajomi grają w Crocky podczas spotkania" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Najszybszy lodołamacz na każde spotkanie</h3>
            <p class="md-body">Kiedy do stołu siada siedem osób z różnych światów, propozycja gry planszowej to ryzyko. Crocky nie wymaga niczego. Ktoś kładzie krokodyla na stole, ktoś mówi: wciskaj. Pięć minut później wszyscy się śmieją, fotografują paszczę i krzyczą jak na meczu. Najlepiej działa po pierwszym piwie, ale w wersji rodzinnej też.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/crocky-08-produkt-na-stoliku.webp`} alt="Crocky jako prezent na stoliku" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Prezent, który trafia bez pytania o gust</h3>
            <p class="md-body">Urodziny dziecka, święta u dziadków, wieczór panieński, mikołajki, imieniny. Crocky pasuje wszędzie, gdzie ktoś lubi się śmiać. Wychodzi z pudełka gotowy do gry, nie potrzebuje baterii ani tłumaczenia. Nawet osoba, która nie lubi gier, sięga po zęby już po trzech sekundach. Sprawdzony prezent od 4 lat aż po dziadka.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== POLECANE PRODUKTY (pozycja 8) ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== TRUST STRIP — pozycja 9 ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>2600+ rodzin gra</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== ZASADY GRY — pozycja 10 (zamiast variantów kolorystycznych, 3 cards z infografik) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
