  .md-bento-cell--strawberry .md-bento-foot { color: var(--brand-accent-hover); opacity: 0.85; }
  .md-bento-star {
    color: #E8A317;
    font-size: 15px !important;
  }

  /* ---------- SECTION 2 — PROBLEM → SOLUTION SPLIT ---------- */
  .md-problem-solve {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: stretch;
  }
  @media (min-width: 768px) {
    .md-problem-solve {
      grid-template-columns: 1fr auto 1fr;
      gap: 24px;
      align-items: center;
    }
  }
  .md-ps-side {
    background: var(--brand-bg);
    border: 1px solid var(--brand-border);
    border-radius: 22px;
    padding: 26px 24px;
  }
  .md-ps-side--solution {
    background: var(--brand-primary-soft);
    border-color: var(--brand-primary);
  }
  .md-ps-tag {
    display: inline-block;
    padding: 5px 12px;
    border-radius: 999px;
