---
/**
 * BryzaDescription — pełny opis produktu Bryza (szal chłodzący dla psa).
 * Bazuje na uniwersalnym templatcie Moodles (te same klasy md-*).
 *
 * Assety w /public/bryza-pdp/ (webp z folderu szal-chlodzacy/generated).
 * Sekcja 01 (gify) na razie pusta.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/bryza-pdp';

// Reviews — z osobnego JSON per produkt (bryza; jeśli brak danych → sekcje opinii się ukryją)
const reviews = getProductReviews('bryza');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude bryza, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'bryza')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('BryzaDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 GIFY — PUSTE (gify dodamy później) ========== */}

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <h2>Koniec z <span class="md-em">przegrzewaniem psa</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Pies dyszy po kilku minutach spaceru</li>
            <li><span class="material-symbols-outlined">close</span>Ciągle szuka cienia i chwili przerwy</li>
            <li><span class="material-symbols-outlined">close</span>Pupil ciągle szuka wody do orzeźwienia</li>
            <li><span class="material-symbols-outlined">close</span>Spacery są znacznie krótsze</li>
          </ul>
          <p class="md-ps-foot">W upał chłodzi się głównie dyszeniem, które w lecie po prostu nie wystarcza.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">bryza</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Chłód, który trzyma godzinami</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Pełny spacer bez przegrzania</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Ulga w aucie, na działce, w podróży</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Wystarczy namoczyć w zimnej wodzie</li>
          </ul>
          <p class="md-ps-foot">Bryzę wystarczy namoczyć w zimnej wodzie, wykręcić z nadmiaru wody i założyć na szyję pupila.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/bryza-porownanie-bez-z-bryza.webp`} alt="Pies w upał bez szala i z szalem chłodzącym Bryza" loading="lazy" />
      </div>
      <div>
        <h2>Zobacz <span class="md-em">radość</span> w oczach pupila</h2>
        <p class="md-body">Znasz to uczucie, kiedy pies dyszy już po kilku minutach? To nie lenistwo — to sygnał, że nie nadąża z chłodzeniem. Pies nie poci się jak my, w upał ratuje się głównie dyszeniem. Wystarczy namoczyć Bryzę w zimnej wodzie, wycisnąć z nadmiaru wody i zawiązać wokół szyi pupila. Spacery zaczną wracać do normalnej długości, a pies przestanie się przegrzewać w upały. Różnicę szczególnie poczują psy z krótkim pyskiem oraz seniorzy.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/bryza-soak-wear-wykrecanie.webp`} alt="Aktywacja szala Bryza: namoczenie i wykręcenie" loading="lazy" />
      </div>
      <div>
        <h2>Ochłodzenie w <span class="md-em">30 sekund</span></h2>
        <p class="md-body">Przygotowanie Bryzy zajmuje 30 sekund — wystarczy zamoczyć ją w zimnej wodzie, odcisnąć z nadmiaru wody i założyć na szyję psa. Bryza zapewnia ochłodzenie przez około 4-5 godzin, w zależności od temperatury. Po wyschnięciu wystarczy namoczyć ją ponownie, a koraliki chłodzące znów nasiąkną chłodną wodą.</p>
      </div>
    </div>
  </section>

  {/* ========== CUSTOMER STORY (pozycja 5) — featured = pierwsza opinia 5-star ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/bryza-lifestyle-kobieta-buldog-park.webp`} alt="Właścicielka z buldogiem na spacerze w upalny dzień" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">Mój buldog francuski nie wytrzymywał upałów — po kilku minutach spaceru już dyszał i kładł się w cień. Koleżanka poleciła mi Bryzę. Namoczyłam ją w zimnej wodzie przed spacerem i zawiązałam na szyi — i pierwszy raz przeszliśmy całą rundę bez ani jednej przerwy. Teraz zakładam ją za każdym razem, gdy robi się gorąco.</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: 5 }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>Anna</strong>
            <span>, buldog francuski</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== COMPARISON TABLE (pozycja 6) — moodles vs terapia/leki/aplikacja ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Bryza vs reszta</span>
        <h2>Porównanie z domowymi metodami</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>Bryza</span></th>
              <th>Mokry ręcznik</th>
              <th>Kostki lodu</th>
              <th>Wiatrak</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Chłodzi przez godziny</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Działa też na spacerze</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Nie moczy psa i podłogi</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Łagodny chłód, bez szoku termicznego</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Bez prądu i bez zamrażarki</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Wielokrotnego użytku, na lata</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      {/* Mobile swipe hint — pokazuje się tylko gdy tabela się scrolluje (overflow visible) */}
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== TABBED USE CASES (pozycja 7) — Dla kogo są Moodles ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Dla jakiego psa jest Bryza?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">Upały na spacerze</button>
        <button class="md-tab-btn" data-md-tab="1">Pies senior</button>
        <button class="md-tab-btn" data-md-tab="2">Auto i podróże</button>
        <button class="md-tab-btn" data-md-tab="3">Krótkie pyski</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/bryza-spacer-przerwa-na-wode.webp`} alt="Pies na spacerze w upalny dzień" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Spacer, który nie kończy się po pięciu minutach</h3>
            <p class="md-body">W lipcu wystarczy kwadrans w słońcu i pies zaczyna dyszeć, szukać cienia, ciągnąć do domu. Bryza założona przed wyjściem trzyma chłód przez całą rundę. Pies idzie dalej, mniej się ścina, wraca bez tego ciężkiego sapania. Sprawdza się też na treningu i dłuższych wędrówkach.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/bryza-seniorka-jamnik-dzialka.webp`} alt="Starszy pies odpoczywa na działce w cieniu" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Starszy pies znosi upał najgorzej</h3>
            <p class="md-body">Z wiekiem serce i krążenie gorzej radzą sobie z gorącem, a ruch w skwarze szybciej męczy. Łagodny chłód na szyi odciąża psa tam, gdzie najbardziej tego potrzebuje, bez zimnego szoku. Senior może spokojnie poleżeć na tarasie czy działce, zamiast dyszeć przez całe popołudnie.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/bryza-labrador-auto-czarna.webp`} alt="Pies w samochodzie z szalem chłodzącym" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Nagrzane auto i długa trasa</h3>
            <p class="md-body">Nawet z klimą wnętrze nagrzewa się błyskawicznie, a pies w transporterze nie ma jak się schłodzić. Bryza założona przed jazdą daje mu chłód na czas drogi, postoju na stacji i pierwszych minut po wyjściu. Przyda się na wakacyjnym wyjeździe i przy wizycie u weterynarza.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/bryza-balkon-kawa-golden-czarna.webp`} alt="Pies odpoczywa w cieniu w upalny dzień" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Buldogi, mopsy i inne krótkie pyski</h3>
            <p class="md-body">Brachycefale chłodzą się dyszeniem znacznie gorzej niż psy z dłuższym pyskiem — i upał jest dla nich naprawdę groźny. Każde wsparcie w odprowadzaniu ciepła ma tu znaczenie. Bryza na szyi daje stały, łagodny chłód, a buldog czy mops łatwiej przetrwa gorące popołudnie.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== POLECANE PRODUKTY (pozycja 8) ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== TRUST STRIP — pozycja 9 ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>10k+ klientów</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== VARIANT SHOWCASE — usunięte (sekcja z kolorami) ========== */}

  {/* ========== 11 — REVIEWS (dynamiczne z reviews.json) ========== */}
  {reviews && ratingPct && (
  <section id="reviews-section" class="md-section">
    <div class="md-reviews">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>{(reviews.totalCount * 35).toLocaleString('pl-PL')}+ psiarzy już wypróbowało Bryzę</h2>
      </div>
      <div class="md-reviews-header">
        <div class="md-reviews-big-rating">
          <div class="md-reviews-big-num">{formatRating(reviews.averageRating)}</div>
          <div class="md-reviews-big-stars">
            {[1, 2, 3, 4, 5].map((i) => {
              const k = starKind(i, reviews.averageRating);
              return k === 'full'
                ? <svg viewBox="0 0 24 24" width="24" height="24" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
                : k === 'half'
                ? <svg viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-big-half-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-big-half-${i})`}/></svg>
                : <svg viewBox="0 0 24 24" width="24" height="24" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
            })}
          </div>
          <div class="md-reviews-big-meta">z {reviews.totalCount} {opiniiPlural(reviews.totalCount)}, zakup zweryfikowany</div>
        </div>
        <div class="md-reviews-bars">
          {([5, 4, 3, 2, 1] as const).map((star) => (
            <div class="md-reviews-bar">
              <div class="md-stars-mini">
                {[1, 2, 3, 4, 5].map((i) => (
                  i <= star
                    ? <svg viewBox="0 0 24 24" width="14" height="14" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
