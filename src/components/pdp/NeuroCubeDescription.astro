<script is:inline>
  // Carousel arrows (mobile)
  document.querySelectorAll('[data-md-carousel-prev], [data-md-carousel-next]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-md-carousel-prev') || btn.getAttribute('data-md-carousel-next');
      const dir = btn.getAttribute('data-md-carousel-prev') ? -1 : 1;
      const el = document.getElementById(id);
      if (!el) return;
      const item = el.firstElementChild;
      if (!item) return;
      const gap = parseFloat(getComputedStyle(el).gap) || 16;
      el.scrollBy({ left: (item.offsetWidth + gap) * dir, behavior: 'smooth' });
    });
  });

  // Tabs
  document.querySelectorAll('.md-tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = Number(btn.getAttribute('data-md-tab'));
      document.querySelectorAll('.md-tab-btn').forEach((b) => b.classList.remove('md-tab-btn--active'));
      document.querySelectorAll('.md-tab-content').forEach((c) => c.classList.remove('md-tab-content--active'));
      btn.classList.add('md-tab-btn--active');
      const all = document.querySelectorAll('.md-tab-content');
      if (all[idx]) all[idx].classList.add('md-tab-content--active');
    });
  });
</script>
