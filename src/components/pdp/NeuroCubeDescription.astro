---
/**
 * NeuroCubeDescription — pełny opis produktu NeuroCube.
 * Drewniana łamigłówka 3D dla 6+ lat. Alternatywa do ekranu.
 *
 * Assety w /public/neurocube/photos/ (14 webp).
 * Struktura 18 sekcji wg Moodles template.
 * Tone: sentence case, konwersacyjny, anti-ekran, ADHD uppercase.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/neurocube/photos';

// Reviews — z osobnego JSON per produkt (neurocube tutaj)
const reviews = getProductReviews('neurocube');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude neurocube, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'neurocube')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('NeuroCubeDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/neurocube-01-hero-sage-polka.webp`} alt="" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/neurocube-02-full-set-biurko.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/neurocube-04-result-dziecko-uklada.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/neurocube-05-unusual-charcoal-dramatic.webp`} alt="" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od ekranu do skupienia</span>
        <h2>Ekran zawsze wygrywa. Aż nie <span class="md-em">spróbujesz innego</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Dzieci znikają w tablecie</li>
            <li><span class="material-symbols-outlined">close</span>Dorośli scrollują po wieczorach</li>
            <li><span class="material-symbols-outlined">close</span>Głowa pracuje, ale nic z tego nie zostaje</li>
            <li><span class="material-symbols-outlined">close</span>Ręce zawsze przy szkle</li>
          </ul>
          <p class="md-ps-foot">Mózg potrzebuje skupienia, którego ekran mu nie daje. Każda notyfikacja zaczyna nowy wątek, każdy scroll resetuje uwagę. Dlatego po godzinie z telefonem jesteś bardziej zmęczony niż przed.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">NeuroCube</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Jedno zadanie, które wciąga</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Logiczne myślenie w ruchu</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Ciepłe drewno zamiast szkła</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Cisza i satysfakcja na koniec</li>
          </ul>
          <p class="md-ps-foot">Drewniana kostka, której kształty same prowadzą palce. Ułożysz raz, rozłożysz, zaczniesz od nowa. Bez ładowarki, bez aplikacji, bez powiadomień.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/neurocube-12-kawiarnia-student.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2><span class="md-em">Ekran</span> zawsze będzie czekał</h2>
        <p class="md-body">Dzieci sięgają po tablet, dorośli po telefon, dziadkowie po pilota. Wszyscy szukamy tego samego: zajęcia dla głowy, kiedy nie wiadomo co ze sobą zrobić. Ekran daje to natychmiast, ale niczego nie zostawia. Po godzinie z telefonem jesteś bardziej zmęczony niż przed. NeuroCube działa odwrotnie. Wciąga przez kształt i fakturę drewna, nie przez algorytm. Ręce mają konkretne zadanie, głowa zwalnia, a po ułożeniu zostaje coś realnego.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/neurocube-07-kontrast-czarne-naturalne.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Jedna drewniana kostka, setki możliwych dróg</h2>
        <p class="md-body">Każdy element ma inny kształt. <strong>Naturalne drewno</strong> w naturalnym kolorze i <strong>matowy charcoal</strong> dla kontrastu. Elementy układają się w pełną bryłę co do milimetra. <strong>Wystarczy raz dotknąć</strong>, żeby zrozumieć: to nie jest plastikowy gadżet. To rzecz, która z czasem ładnieje. Dla 6+ lat, ale tak naprawdę dla każdego, kto chce mieć coś do rąk zamiast kolejnego ekranu.</p>
      </div>
    </div>
  </section>

  {/* ========== CUSTOMER STORY (pozycja 5) — featured = pierwsza opinia 5-star ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/neurocube-09-reka-wklada-element.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== COMPARISON TABLE (pozycja 6) — neurocube vs tablet/rubik/drewniane klocki ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Anti-ekran</span>
        <h2>Porównanie z klasycznymi alternatywami</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>NeuroCube</span></th>
              <th>Tablet edukacyjny</th>
              <th>Kostka Rubika</th>
              <th>Drewniane klocki</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Bez ekranu</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Rozwija logiczne myślenie</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Naturalny materiał</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Bez baterii i aplikacji</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Wyzwanie też dla dorosłego</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Wygląda dobrze na półce</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== TABBED USE CASES (pozycja 7) — Dla kogo NeuroCube ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Dla kogo jest NeuroCube?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">Dzieci 6+</button>
        <button class="md-tab-btn" data-md-tab="1">Dorośli</button>
        <button class="md-tab-btn" data-md-tab="2">Terapeuci</button>
        <button class="md-tab-btn" data-md-tab="3">Seniorzy</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/neurocube-04-result-dziecko-uklada.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Detox od ekranu, który dziecko polubi</h3>
            <p class="md-body">Tablet daje natychmiastową stymulację, ale po godzinie zostaje tylko zmęczenie. NeuroCube wciąga inaczej, przez kształt i fakturę drewna. Dziecko ma konkretne zadanie, palce uczą się przestrzeni, a głowa odpoczywa od bodźców. Bez nagrody w aplikacji, bez kolejnych etapów. Tylko ułożona kostka, której nikt nie musi sprawdzać.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/neurocube-12-kawiarnia-student.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Fokus w przerwie między zadaniami</h3>
            <p class="md-body">Pięć minut z NeuroCube robi z głową to, czego pół godziny scrollowania nigdy nie zrobi. Palce mają robotę, mózg się resetuje. Po wstaniu od biurka łatwiej wrócić do tego, co było przed chwilą za trudne. Szczególnie dla osób z ADHD, które potrzebują fizycznego zaczepienia, kiedy myśli pędzą za szybko.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/neurocube-13-dlonie-close-up.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Narzędzie w gabinecie, nie zabawka</h3>
            <p class="md-body">Terapeuci sensoryczni, logopedzi, psychologowie dziecięcy. NeuroCube daje konkretne, mierzalne zadanie do dłoni. Pomaga przy regulacji emocji, koncentracji, motoryce małej. Drewno wygląda profesjonalnie i nie kojarzy się z dziecięcą plastikową zabawką, więc działa też z dorosłym pacjentem.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/neurocube-11-tata-syn-stol.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Trening głowy, który nie wygląda jak terapia</h3>
            <p class="md-body">Badania pokazują, że codzienne układanie pomaga utrzymać sprawność palców i pamięci przestrzennej. NeuroCube nie wygląda jednak jak rehabilitacja. To po prostu ładny przedmiot na stoliku, który zaprasza, żeby coś ułożyć przy kawie. Wnuki dostają to samo zadanie i jest o czym pogadać.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== POLECANE PRODUKTY (pozycja 8) ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== TRUST STRIP (pozycja 9) ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">forest</span>
        <span>Naturalne drewno</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== VARIANT SHOWCASE / FEATURE HIGHLIGHTS (pozycja 10, mobile: scroll-snap carousel) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Trzy powody</span>
        <h2>Co dostajesz z każdą kostką</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </p>
      </div>
      <div class="md-variants-grid">
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/neurocube-06-makro-uslojenie-drewna.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #7B9075;"></span>
            <h3>Naturalne drewno</h3>
            <p>Olcha lub dąb, ręcznie szlifowane. Każdy element ma własny rysunek słojów. Dłonie czują różnicę natychmiast, plastik tego nie zrobi.</p>
          </div>
        </div>
        <div class="md-variant-card md-variant-card--lavender">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/neurocube-05-unusual-charcoal-dramatic.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #2A2D27;"></span>
            <h3>Logiczne wyzwanie</h3>
