  .md-anti-card:hover {
    border-color: var(--brand-accent);
    transform: translateY(-2px);
  }
  .md-anti-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--brand-accent-soft);
