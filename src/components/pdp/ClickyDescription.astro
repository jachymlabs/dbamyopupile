    line-height: 1.55;
    color: var(--brand-text);
  }

  /* =====================================================
     EXTRA 8 SECTIONS — final closing rhythm
     ===================================================== */

  /* ---------- EXTRA 01 — MAGAZINE SPREAD ---------- */
  .md-mag-spread {
    position: relative;
    width: 100%;
    min-height: 380px;
    overflow: hidden;
  }
  @media (min-width: 768px) { .md-mag-spread { min-height: 520px; } }
  .md-mag-img {
    position: absolute;
    inset: 0;
  }
  .md-mag-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .md-mag-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(42,45,39,0.78) 0%, rgba(42,45,39,0.55) 40%, rgba(42,45,39,0.20) 100%);
  }
  .md-mag-overlay {
    position: relative;
