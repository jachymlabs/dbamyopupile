    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 22px;
    padding: 26px 24px 28px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: transform 240ms ease, box-shadow 240ms ease, border-color 240ms ease;
