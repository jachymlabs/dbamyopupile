  /* ---------- STATS — BENTO GRID (asymetryczny, light bg) ---------- */
  .md-bento {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
