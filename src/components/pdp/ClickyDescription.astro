---
/**
 * ClickyDescription — pełny opis produktu Clicky.
 * Smukły walec z mikro-kolcami i cichym pop-buttonem — aktywność dla rąk bez ekranu.
 *
 * Assety w /public/clicky/photos/ (22 webp).
 * Tone post-humanizer: lowercase, konwersacyjny, screen-free, bez medical claims.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/clicky/photos';

// Reviews — z osobnego JSON per produkt (clicky tutaj)
const reviews = getProductReviews('clicky');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude clicky, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'clicky')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('ClickyDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/clicky-01-makro-pawprint-button.webp`} alt="" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/clicky-16-hero-studio-okno-promien.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/clicky-17-hero-lifestyle-salon.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/clicky-02-makro-spikes-tekstura.webp`} alt="" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od telefonu do kieszeni</span>
        <h2>Twoje ręce i tak będą szukać czegoś do roboty. Niech to nie będzie długopis albo <span class="md-em">paznokieć</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>klikasz długopis — i wszyscy w sali to słyszą</li>
            <li><span class="material-symbols-outlined">close</span>obgryzasz paznokcie zanim zdążysz zauważyć, że zacząłeś</li>
            <li><span class="material-symbols-outlined">close</span>sięgasz po telefon nie dlatego, że chcesz, ale żeby ręce miały co robić</li>
            <li><span class="material-symbols-outlined">close</span>napięcie zostaje w ciele, a głowa kręci się w kółko</li>
          </ul>
          <p class="md-ps-foot">to nie jest kwestia silnej woli. ręce po prostu potrzebują zadania. i zazwyczaj biorą pierwsze, co jest pod ręką.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">Clicky</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>cichy klik, którego słyszysz tylko ty</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>kolce do przesuwania palcami — rytmicznie, bez myślenia</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>napięcie odpuszcza w kilkadziesiąt sekund</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>mieści się w kieszeni, wychodzi tylko kiedy chcesz</li>
          </ul>
          <p class="md-ps-foot">jeden ruch kciukiem — cichy, miękki klik. tyle wystarczy, żeby głowa wzięła oddech.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/clicky-15-bez-z-clicky-kanapa.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Telefon zawsze jest pod ręką. To nie pomaga</h2>
        <p class="md-body">Sięgasz po niego nie dlatego, że masz co sprawdzić. Sięgasz, bo ręce potrzebują czegoś. I znowu jesteś w środku scrollowania, które nie daje nic poza kolejnym bodźcem. Clicky nie walczy z telefonem i nie udaje, że cię od niego odciągnie. Po prostu daje rękom inne zadanie, spokojne, ciche, w pełni pod kontrolą. Bez ekranu i bez angażowania głowy.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — PRODUKT W AKCJI (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/clicky-04-side-profile-15cm.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Co dostajesz w dłoni</span>
        <h2>Walec, który mieści się w kieszeni. Z kolcami po bokach i cichym klikiem na górze</h2>
        <p class="md-body">clicky to smukły walec — około piętnastu centymetrów wysokości, cztery centymetry średnicy. boki pokryte są równymi rzędami mikro-kolców: ostrosłupowe wierzchołki, miękko zaokrąglone, rozstawione tak, żeby palec trafiał na nie naturalnie przy przesuwaniu w górę i w dół. na górnej pokrywie biały silikonowy odcisk łapki — pod nim pop-button, który przy naciśnięciu kciukiem wydaje cichy, wyraźny klik. dolna pokrywa ma dwa małe otwory — po użyciu spłukujesz clicky pod bieżącą wodą i zostawiasz do wyschnięcia. materiał to premium PLA z druku 3D: widoczne subtelne linie warstw, które przypominają słoje drewna. nie wygląda jak gadżet z marketu.</p>
      </div>
    </div>
  </section>

  {/* ========== POLECANE PRODUKTY — przeniesione: pozycja 5 ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-related-head">
          <div>
            <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
            <h2>Polecane produkty</h2>
          </div>
          <a href="/sklep" class="md-related-all">
            zobacz wszystko
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const salePct = hasSale ? Math.round(((regularPrice - currentPrice) / regularPrice) * 100) : 0;
            const isRange = p.priceWithTax?.__typename === 'PriceRange' && p.priceWithTax.min !== p.priceWithTax.max;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {hasSale && <span class="md-related-sale-badge">−{salePct}%</span>}
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {isRange ? `od ${formatPrice(p.priceWithTax.min)}` : formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== 06 — STICKY SCROLL DETAILS (refined) ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Dlaczego to działa</span>
        <h2>Trzy powody, dla których Clicky leży na biurku, a nie w szufladzie</h2>
      </div>
      <div class="md-sticky-text">
        <div class="md-sticky-block">
          <div class="md-sticky-block-head">
            <span class="md-sticky-num">01</span>
            <span class="md-sticky-meta">Cisza</span>
          </div>
          <h3>Klikasz bez irytowania kogokolwiek w zasięgu głosu</h3>
          <p class="md-body">Długopis stuka głośno. Klik Clicky'ego jest cichy i miękki, słyszysz go tylko ty. Możesz go nacisnąć podczas spotkania, przy nauce w kawiarni, w poczekalni. Nikt się nie obejrzy.</p>
        </div>
        <div class="md-sticky-block">
          <div class="md-sticky-block-head">
            <span class="md-sticky-num">02</span>
            <span class="md-sticky-meta">Tekstura</span>
          </div>
          <h3>Kolce robią robotę, zanim zdążysz pomyśleć, że jej potrzebujesz</h3>
          <p class="md-body">równe rzędy mikro-kolców wzdłuż całego walca. przesuwasz palcem w górę i w dół — rytmicznie, bez wysiłku, bez skupienia. to działa na poziomie ciała, nie decyzji. ręce mają zadanie, głowa przestaje się kręcić.</p>
        </div>
        <div class="md-sticky-block">
          <div class="md-sticky-block-head">
            <span class="md-sticky-num">03</span>
            <span class="md-sticky-meta">Format</span>
          </div>
          <h3>Mieści się w kieszeni. Wychodzi kiedy trzeba. Chowa się kiedy nie</h3>
          <p class="md-body">nie potrzebuje miejsca na biurku, nie wymaga specjalnego etui. smukły walec wchodzi do kieszeni spodni, torebki, plecaka. wyciągasz w windzie, przy telefonie, przed snem. chowasz bez ceremonii.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== VARIANT SHOWCASE — 2 kolory (mobile: scroll-snap carousel) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Wybór koloru</span>
        <h2>Dwa kolory. Ten sam Clicky</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć kolory
        </p>
      </div>
      <div class="md-variants-grid md-variants-grid--two">
        <div class="md-variant-card md-variant-card--lavender">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/clicky-22-fomo-promocja-38.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #8B3FD4;"></span>
            <h3>Fioletowy</h3>
            <p>bardziej wyrazisty. gradient od fioletu przez magentę do niebieskiego. dla tych, którzy lubią, gdy rzecz w dłoni ma trochę charakteru.</p>
          </div>
        </div>
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/clicky-21-opinia-mariola-przed-snem.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #2BA88A;"></span>
            <h3>Zielony</h3>
            <p>spokojniejszy. teal, limonka i morski przechodzą jeden w drugi. dla tych, którzy wolą stonowane, chłodne barwy.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== DLA KOGO — 3 karty (mobile: scroll-snap carousel) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Dla kogo to jest</span>
        <h2>Trzy osoby. Jeden walec</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </p>
      </div>
      <div class="md-variants-grid">
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/clicky-05-kobieta-biurko-praca.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-meta">Praca i napięcie</span>
            <h3>Coś dla rąk, kiedy głowa jest zajęta czymś innym</h3>
            <p>Spotkanie na słuchawkach, długi raport, rozmowa, która idzie nie tak, Clicky siedzi w dłoni i robi swoje. Kolce, cichy klik, rytm. Nie przeszkadza w myśleniu, ale pozwala nie uciekać do telefonu.</p>
          </div>
        </div>
        <div class="md-variant-card md-variant-card--lavender">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/clicky-08-studentka-kawiarnia.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-meta">Nauka i skupienie</span>
            <h3>Anchor dla rąk, żeby głowa mogła zostać przy zadaniu</h3>
            <p>Kawiarnia, biblioteka, wieczór przed egzaminem, Clicky jest na tyle dyskretny, żeby nie przeszkadzać innym i na tyle konkretny, żeby ręce nie szukały czegoś innego. Po prostu leży obok i czeka, aż go potrzebujesz.</p>
          </div>
        </div>
        <div class="md-variant-card md-variant-card--strawberry">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/clicky-11-emocja-spokoj-przed-snem.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-meta">Wieczór i wyciszenie</span>
            <h3>Zamiast kolejnego odcinka albo scrollowania bez celu</h3>
            <p>Kanapa, herbata, Clicky w dłoni, ręce mają co robić, głowa zwalnia. Przesuwasz palcem po kolcach, naciskasz klik co jakiś czas. Żadnych powiadomień, żadnego następnego odcinka, który sam się włącza. Cisza.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== TRUST STRIP — przeniesione spod hero do opisu ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">sentiment_satisfied</span>
        <span>10k+ zadowolonych</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">shield</span>
        <span>bezpieczne płatności</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>polska marka</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">support_agent</span>
        <span>wsparcie 24/7</span>
      </div>
    </div>
  </section>

  {/* ========== TABBED USE CASES — przeniesione wyżej ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Kiedy Clicky robi robotę</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">przy biurku</button>
        <button class="md-tab-btn" data-md-tab="1">w kawiarni</button>
        <button class="md-tab-btn" data-md-tab="2">przed snem</button>
        <button class="md-tab-btn" data-md-tab="3">w ruchu</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/clicky-08-studentka-kawiarnia.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Ręce w ruchu, głowa przy tym co ważne</h3>
            <p class="md-body">Praca zdalna, open space, spotkania na słuchawkach, Clicky leży obok klawiatury. Sięgasz po niego kiedy czekasz, myślisz, słuchasz. Cichy klik nie przeszkadza nikomu. Kolce pod palcami dają rękom zajęcie bez angażowania wzroku ani uwagi.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/clicky-18-flat-lay-zestaw.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Nauka bez klikania długopisem co pięć minut</h3>
            <p class="md-body">Siedzisz z laptopem, starasz się skupić i wiesz, że ręce zaraz zaczną szukać czegoś. Clicky jest na tyle dyskretny, że możesz go trzymać w dłoni bez zwracania na siebie uwagi. Cichy, lekki, bez żadnych efektów dźwiękowych dla otoczenia.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/clicky-11-emocja-spokoj-przed-snem.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Wyciszenie, które nie wymaga ekranu</h3>
            <p class="md-body">Telefon odłożony, ale głowa nie chce wyhamować. Clicky w dłoni, rytmiczne przesuwanie po kolcach, od czasu do czasu klik. Nie stymuluje, wycisza. Ręce mają co robić, a ty nie wpatrujesz się w żaden wyświetlacz.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/clicky-13-problem-bezsenne-scrollowanie.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Kieszeń, metro, poczekalnia, zawsze gotowy</h3>
            <p class="md-body">Clicky nie potrzebuje ładowania, sieci ani miejsca w plecaku. Leży w kieszeni i nie waży. Wyciągasz w poczekalni u lekarza, w metrze, stojąc w kolejce. Chowasz bez szukania etui. Zero przygotowania.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 10 — CUSTOMER STORY (featured = pierwsza opinia 5-star z items) ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/clicky-10-emocja-skupienie-flow.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
