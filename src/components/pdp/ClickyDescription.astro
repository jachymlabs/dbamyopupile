  /* ---------- ANTI-CLAIMS — czym NIE są ---------- */
  .md-eyebrow--strawberry { color: var(--brand-accent); }
  .md-em-strawberry { color: var(--brand-accent); }
  .md-anti-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (min-width: 768px) { .md-anti-grid { grid-template-columns: repeat(3, 1fr); gap: 24px; } }
  .md-anti-card {
    background: var(--brand-surface);
    border: 1.5px solid var(--brand-border);
    border-radius: 18px;
    padding: 28px 26px;
    position: relative;
    transition: border-color 240ms ease, transform 240ms ease;
  }
  .md-anti-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 22px;
    bottom: 22px;
