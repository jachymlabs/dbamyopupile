  /* Swipe hint — widoczny tylko na mobile */
  .md-variants-swipe-hint {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 14px 0 0;
    font-size: 12.5px;
    color: var(--brand-muted);
    font-weight: 600;
  }
  .md-variants-swipe-hint .material-symbols-outlined {
    font-size: 16px;
    color: var(--brand-primary);
  }
  @media (min-width: 768px) { .md-variants-swipe-hint { display: none; } }

  /* ---------- VARIANT SHOWCASE — 3 cards (mobile: scroll-snap carousel) ---------- */
  .md-variants-grid {
    display: flex;
    gap: 14px;
    max-width: 1100px;
    margin: 0 auto;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 4px 9% 16px;
    scrollbar-width: none;
  }
  .md-variants-grid::-webkit-scrollbar { display: none; }
  .md-variants-grid > .md-variant-card {
    scroll-snap-align: center;
    flex: 0 0 82%;
    min-width: 0;
  }
  @media (min-width: 768px) {
    .md-variants-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      overflow: visible;
      padding: 0;
      margin-left: auto;
      margin-right: auto;
    }
    .md-variants-grid > .md-variant-card { flex: initial; min-width: 0; }
    /* Wariant z 2 kartami — wyśrodkowane, węższy grid */
    .md-variants-grid--two {
      grid-template-columns: repeat(2, 1fr);
      max-width: 720px;
    }
  }
  .md-variant-card {
    background: var(--brand-bg);
    border-radius: 24px;
    overflow: hidden;
    transition: transform 280ms ease, box-shadow 280ms ease;
    position: relative;
    isolation: isolate;
  }
  .md-variant-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(42, 45, 39, 0.04) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .md-variant-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 20px 48px rgba(42, 45, 39, 0.12);
  }
  .md-variant-img {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .md-variant-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .md-variant-card:hover .md-variant-img img { transform: scale(1.04); }
  .md-variant-body {
    padding: 22px 24px 26px;
    position: relative;
    z-index: 2;
  }
  .md-variant-dot {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
