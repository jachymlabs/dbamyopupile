---
/**
 * WibbloDescription — pełny opis produktu Wibblo.
 * Silikonowy fidget z teksturą + drainage holes (myjny w pralce), antystresowy z kolcami.
 * Dla BFRB (obgryzanie paznokci), praca biurowa, wieczorny relaks, ADHD.
 *
 * Assety w /public/wibblo/photos/ (12 webp).
 * Tone post-humanizer: sentence case, konwersacyjny, ADHD-aware, brak medical claims.
 * Struktura 18 sekcji - kopia Moodles template.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/wibblo/photos';

// Reviews — z osobnego JSON per produkt (wibblo tutaj)
const reviews = getProductReviews('wibblo');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude wibblo, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'wibblo')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('WibbloDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/wibblo-01-makro-pawprint-button.webp`} alt="" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/wibblo-03-drainage-holes-myjny.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/wibblo-05-kobieta-biurko-praca.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/wibblo-07-emocja-ulga-dlonie.webp`} alt="" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od skubania do spokoju</span>
        <h2>Daj palcom coś, co zatrzyma je <span class="md-em">na dłużej</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Obgryzasz paznokcie i skórki</li>
            <li><span class="material-symbols-outlined">close</span>Skubiesz, gniecesz, kruszysz</li>
            <li><span class="material-symbols-outlined">close</span>Tani fidget brudzi się po tygodniu</li>
            <li><span class="material-symbols-outlined">close</span>Po stresie ręce same szukają roboty</li>
          </ul>
          <p class="md-ps-foot">Mózg, który nie dostaje sensorycznego bodźca, sam zaczyna go szukać. Najczęściej w paznokciach, skórkach albo na ekranie telefonu.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">Wibblo</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Faktura, która angażuje palce na długo</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Drainage holes, więc wrzucasz do pralki</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Mięciutki silikon, który wraca do kształtu</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Dyskretne narzędzie dla rąk, gdziekolwiek</li>
          </ul>
          <p class="md-ps-foot">Daj rękom konkretną fakturę do gniecenia. Kolce, krawędzie, otwory pod palcami. Paznokcie zostają nietknięte, a głowa zwalnia.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/wibblo-09-problem-paznokcie-dlugopis.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2><span class="md-em">Koniec</span> ze skubaniem paznokci</h2>
        <p class="md-body">Obgryzasz paznokcie, skubiesz skórki, klikasz długopisem. To nie kwestia silnej woli. Tak zachowuje się mózg, który nie dostaje wystarczająco sensorycznych bodźców. Wibblo daje mu to, czego szuka. Faktura z kolcami, drainage holes, mięciutki silikon, który wraca do kształtu pod palcami. Ręce dostają konkretne zajęcie, przez co głowa zwalnia, zapominając o paznokciach. Szczególnie dla osób z BFRB i ADHD, których dłonie ciągle czegoś szukają.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/wibblo-01-makro-pawprint-button.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Faktura, która naprawdę zajmuje palce</h2>
        <p class="md-body">Każdy detal został przemyślany. <strong>Kolce</strong> dają mocny sensoryczny feedback przy każdym ściśnięciu. <strong>Drainage holes</strong> pozwalają go umyć nawet w pralce. <strong>Mięciutki silikon medyczny</strong> wraca do kształtu po każdym zgnieceniu. <strong>Ergonomiczny kształt 15 cm</strong> idealnie pasuje do zamkniętej dłoni. Cztery rzeczy w jednym narzędziu dla rąk, które naprawdę nie odpuszczają.</p>
      </div>
    </div>
  </section>

  {/* ========== 05 — CUSTOMER STORY (featured = pierwsza opinia 5-star) ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/wibblo-07-emocja-ulga-dlonie.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== 06 — COMPARISON TABLE — Wibblo vs Clicky / stress ball / spinner ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Spektrum fidgetów</span>
        <h2>Wibblo kontra to, co znasz</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>Wibblo</span></th>
              <th>Clicky</th>
              <th>Zwykły stress ball</th>
              <th>Spinner</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Bogata faktura sensoryczna</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Można umyć w pralce</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Bezgłośny, do biura</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Nie pęknie po miesiącu</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Dobry dla obgryzaczy paznokci</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Higieniczny po latach użytku</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      {/* Mobile swipe hint — pokazuje się tylko gdy tabela się scrolluje (overflow visible) */}
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== 07 — TABBED USE CASES — kiedy Wibblo robi robotę ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Dla kogo jest Wibblo?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">BFRB / paznokcie</button>
        <button class="md-tab-btn" data-md-tab="1">Praca biurowa</button>
        <button class="md-tab-btn" data-md-tab="2">Wieczorny relaks</button>
        <button class="md-tab-btn" data-md-tab="3">ADHD fidget</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/wibblo-09-problem-paznokcie-dlugopis.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Palce, które same idą do ust</h3>
            <p class="md-body">Obgryzanie paznokci, skubanie skórek, wyrywanie włosów. Body-focused repetitive behaviour to nie nawyk do wyplenienia silną wolą. To mózg, który potrzebuje sensorycznego bodźca w palcach. Wibblo daje ten bodziec konkretnie. Kolce, krawędzie i drainage holes pod palcami zajmują dłonie tak, że ręce same przestają iść do ust.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/wibblo-05-kobieta-biurko-praca.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Spokojnie obok klawiatury</h3>
            <p class="md-body">Przy biurku, podczas calli, przy czytaniu maili. Wibblo leży obok myszki i czeka. Bezgłośny, nikt nie zauważy go na Zoomie. Po stresującym mailu sięgasz, ściskasz, wrzucasz z powrotem. Napięcie z głowy idzie w palce, zostaje w silikonie i nie wraca do paznokci.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/wibblo-06-mezczyzna-koldra-wieczor.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Kanapa, koc, ręce zajęte</h3>
            <p class="md-body">Wieczór bez telefonu w dłoni jest naprawdę możliwy. Wibblo robi swoje, palce mają fakturę pod opuszkami, głowa odpuszcza. Bez powiadomień, bez podświetlonego ekranu pod brodą. Tylko silikon, kolce i powolny ruch palców. Po 10 minutach senność przychodzi sama.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/wibblo-08-problem-stres-piesc.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Mózg z ADHD chce więcej</h3>
            <p class="md-body">Mózg osoby z ADHD często myśli i zachowuje się inaczej. Potrzebuje dostarczać sobie nowych bodźców, inaczej nie da rady skupić się na jednej rzeczy. Faktura Wibblo, kolce, drainage holes i ergonomia 15 cm dostarczają tych bodźców cały czas, dzięki czemu uwaga zostaje przy zadaniu, nie przy telefonie.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 08 — POLECANE PRODUKTY ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== 09 — TRUST STRIP ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>10k+ klientów</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== 10 — VARIANT SHOWCASE — 3 sytuacje (mobile: scroll-snap carousel) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Trzy sytuacje, jedna faktura</span>
        <h2>Gdzie Wibblo robi największą robotę</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </p>
      </div>
      <div class="md-variants-grid">
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/wibblo-05-kobieta-biurko-praca.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #5C7BA0;"></span>
            <h3>Przy biurku</h3>
            <p>Najczęściej wybierane przez naszych klientów. Leży obok klawiatury, bezgłośnie zajmuje palce między mailami. Idealne dla osób, które łapią się na obgryzaniu paznokci przy Excelu albo na callu.</p>
          </div>
        </div>
        <div class="md-variant-card md-variant-card--lavender">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/wibblo-06-mezczyzna-koldra-wieczor.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #A78BCC;"></span>
