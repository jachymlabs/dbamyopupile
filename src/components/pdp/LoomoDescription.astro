    scroll-snap-align: center;
    aspect-ratio: 4 / 5;
    border-radius: 20px;
    overflow: hidden;
    background: var(--brand-surface-2);
    border: 1px solid var(--brand-border);
  }
  @media (min-width: 768px) {
    .md-gif-carousel { gap: 12px; overflow-x: visible; }
    .md-gif-item { flex: 1 1 0; }
  }
  .md-gif-item img,
  .md-gif-item video { width: 100%; height: 100%; object-fit: cover; }
  .md-mobile-arrows { display: flex; justify-content: center; gap: 12px; margin-top: 24px; }
  @media (min-width: 768px) { .md-mobile-arrows { display: none; } }
  .md-arrow {
    width: 44px; height: 44px; border-radius: 9999px;
    background: var(--brand-surface); border: 1px solid var(--brand-border);
    color: var(--brand-primary); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 200ms, color 200ms;
  }
  .md-arrow:hover { background: var(--brand-primary); color: white; }
  .md-arrow .material-symbols-outlined { color: inherit; font-size: 22px; }

  /* ---------- 02 MANIFESTO ---------- */
  .md-manifesto { text-align: center; max-width: 720px; margin: 0 auto; }
  .md-manifesto-eyebrow {
    display: block;
    font-size: 12px; font-weight: 700; letter-spacing: 0.22em;
    color: var(--brand-primary); text-transform: uppercase;
    margin-bottom: 20px;
  }
  .md-manifesto h2 { font-size: 32px; line-height: 1.12; font-weight: 800; letter-spacing: -0.025em; }
  @media (min-width: 768px) { .md-manifesto h2 { font-size: 48px; } }
  .md-em { color: var(--brand-primary); }
  .md-manifesto-divider {
    width: 32px; height: 2px; background: var(--brand-primary);
    margin: 24px auto; border-radius: 2px;
  }
  .md-manifesto p.md-body { font-size: 15px; max-width: 540px; margin: 0 auto; line-height: 1.6; }
  @media (min-width: 768px) { .md-manifesto p.md-body { font-size: 16px; } }

  /* ---------- 05 TIMELINE ---------- */
  .md-timeline {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1100px; margin: 0 auto;
    position: relative;
  }
  @media (min-width: 768px) {
    .md-timeline { grid-template-columns: repeat(4, 1fr); gap: 16px; align-items: start; }
    .md-timeline::before {
      content: ''; position: absolute; top: 36px; left: 12.5%; right: 12.5%;
      height: 2px;
      background: repeating-linear-gradient(to right, var(--brand-primary) 0 8px, transparent 8px 14px);
      z-index: 0;
    }
  }
  .md-timeline-step { text-align: center; position: relative; z-index: 1; }
  .md-timeline-circle {
    width: 72px; height: 72px;
    background: var(--brand-surface);
    border: 2px solid var(--brand-primary);
    border-radius: 9999px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
    position: relative; z-index: 1;
  }
  .md-timeline-circle .material-symbols-outlined {
    font-size: 32px !important;
    color: var(--brand-primary);
  }
  .md-timeline-num {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: 0.18em;
    color: var(--brand-primary); text-transform: uppercase;
    margin-bottom: 6px;
  }
  .md-timeline-step h3 { font-size: 16px; margin-bottom: 4px; }
  .md-timeline-step p { font-size: 13px; }

  /* ---------- 06 STICKY SCROLL — polished ---------- */
  .md-sticky-min {
    display: grid; grid-template-columns: 1fr; gap: 40px;
    max-width: 1100px; margin: 0 auto;
    align-items: start;
  }
  @media (min-width: 1024px) { .md-sticky-min { grid-template-columns: 1fr 1.05fr; gap: 72px; } }
  @media (min-width: 1024px) {
    .md-sticky-img { position: sticky; top: 100px; align-self: start; }
  }
  .md-sticky-img .md-img-square {
    border-radius: 20px;
    box-shadow: 0 18px 48px rgba(42, 45, 39, 0.10);
  }
  .md-sticky-text {
    display: grid; grid-template-columns: 1fr; gap: 18px;
    max-width: 1100px; margin: 0 auto;
  }
  @media (min-width: 768px) { .md-sticky-text { grid-template-columns: repeat(3, 1fr); gap: 20px; } }

  /* ---------- BENEFIT 2 — infografika no-tech ---------- */
  .md-notech {
    display: grid; grid-template-columns: 1fr; gap: 18px;
    max-width: 1000px; margin: 0 auto;
  }
  @media (min-width: 768px) { .md-notech { grid-template-columns: repeat(3, 1fr); gap: 24px; } }
  .md-notech-item {
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 20px;
    padding: 32px 28px;
    text-align: center;
  }
  .md-notech-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: 16px;
    background: var(--brand-primary-soft);
    margin-bottom: 16px;
  }
  .md-notech-icon .material-symbols-outlined { font-size: 30px; color: var(--brand-primary-hover); }
  .md-notech-item h3 {
    font-size: 19px; font-weight: 700; margin: 0 0 8px; color: var(--brand-heading);
  }
  .md-notech-item p {
    font-size: 14.5px; line-height: 1.6; color: var(--brand-text); margin: 0;
  }
  .md-sticky-block {
    position: relative;
    padding: 28px 28px 28px 88px;
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 18px;
    transition: border-color 240ms ease, box-shadow 240ms ease, transform 240ms ease;
  }
  .md-sticky-block:hover {
    border-color: var(--brand-primary);
    box-shadow: 0 10px 28px rgba(146, 194, 234, 0.14);
    transform: translateY(-2px);
  }
  .md-sticky-num {
    position: absolute;
    top: 26px;
    left: 26px;
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 0.01em;
    color: var(--brand-primary-hover);
    background: var(--brand-primary-soft);
    border: 1.5px solid var(--brand-primary);
    border-radius: 50%;
  }
  .md-sticky-block h3 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0 0 8px;
    color: var(--brand-heading);
    line-height: 1.25;
  }
  .md-sticky-block .md-body {
    font-size: 15px;
    line-height: 1.6;
    color: var(--brand-text);
    margin: 0;
  }
  @media (max-width: 640px) {
    .md-sticky-block {
      padding: 22px 22px 22px 74px;
      border-radius: 16px;
    }
    .md-sticky-num {
      top: 22px;
      left: 22px;
      width: 38px;
      height: 38px;
      font-size: 14px;
    }
    .md-sticky-block h3 { font-size: 18px; }
  }

  /* ---------- TRUST STRIP (between sticky scroll and stats) ---------- */
  .md-trust-strip {
    background: var(--brand-bg);
    border-top: 1px solid var(--brand-border);
    border-bottom: 1px solid var(--brand-border);
    padding: 28px 20px;
  }
  @media (min-width: 768px) { .md-trust-strip { padding: 32px 32px; } }
  .md-trust-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .md-trust-grid { grid-template-columns: repeat(4, 1fr); gap: 24px; }
  }
  .md-trust-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .md-trust-cell .material-symbols-outlined {
    color: var(--brand-primary);
    font-size: 26px !important;
  }
  .md-trust-cell span:last-child {
    font-size: 13px;
    font-weight: 700;
    color: var(--brand-heading);
  }
  @media (min-width: 768px) {
    .md-trust-cell span:last-child { font-size: 14px; }
  }

  /* ---------- 07 STATS image + numbers vertical ---------- */
  .md-stats-img-num {
    display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center;
    max-width: 1100px; margin: 0 auto;
  }
  @media (min-width: 768px) { .md-stats-img-num { grid-template-columns: 1fr 1fr; gap: 64px; } }
  .md-stats-vlist {
    display: flex; flex-direction: column; gap: 24px;
  }
  .md-stat-vrow {
    display: flex; align-items: baseline; gap: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--brand-border);
  }
  .md-stat-vrow:last-child { border-bottom: none; padding-bottom: 0; }
  .md-stat-vrow-num {
    font-family: 'Outfit', sans-serif; font-weight: 800;
    font-size: 44px; line-height: 1; color: var(--brand-primary);
    letter-spacing: -0.025em;
    min-width: 110px; flex-shrink: 0;
  }
  @media (min-width: 768px) { .md-stat-vrow-num { font-size: 56px; min-width: 140px; } }
  .md-stat-vrow-num small {
    font-size: 0.45em; color: var(--brand-muted);
    font-weight: 600; margin-left: 3px;
  }
  .md-stat-vrow-text { flex: 1; }
  .md-stat-vrow-text h3 { font-size: 15px; margin-bottom: 4px; }
  .md-stat-vrow-text p { font-size: 13px; }

  /* ---------- 08 SPECS ---------- */
  .md-spec-card {
    display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center;
    max-width: 1100px; margin: 0 auto;
  }
  @media (min-width: 768px) { .md-spec-card { grid-template-columns: 1fr 1fr; gap: 64px; } }
  .md-spec-card--mirror > div:first-child { order: 0; }
  @media (min-width: 768px) { .md-spec-card--mirror > div:first-child { order: 1; } }
  .md-spec-list { list-style: none; padding: 0; margin: 16px 0 0; }
  .md-spec-list li {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--brand-border);
    font-size: 15px; color: var(--brand-text);
  }
  .md-spec-list li:last-child { border-bottom: none; }
  .md-spec-list li strong {
    color: var(--brand-heading);
    font-weight: 700; font-size: 13px;
    display: inline-block; min-width: 100px;
  }
  .md-spec-list li .material-symbols-outlined {
    font-size: 18px !important;
    flex-shrink: 0; margin-top: 2px;
  }

  /* ---------- 09 TABS ---------- */
  .md-tabs-wrap { max-width: 1000px; margin: 0 auto; }
  .md-tabs-nav {
    display: flex; gap: 6px; flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 32px;
  }
  .md-tab-btn {
    padding: 12px 22px;
    border: none; background: transparent; cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 14px; font-weight: 700;
    letter-spacing: 0.02em; color: var(--brand-muted);
    transition: color 200ms, background 200ms;
    border-radius: 9999px;
  }
  .md-tab-btn.md-tab-btn--active {
    background: var(--brand-primary);
    color: white;
  }
  .md-tab-btn:hover:not(.md-tab-btn--active) {
    color: var(--brand-heading);
    background: var(--brand-surface-2);
  }
  .md-tab-content { display: none; }
  .md-tab-content.md-tab-content--active {
    display: block;
    animation: md-tab-fade 280ms ease;
  }
  @keyframes md-tab-fade {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .md-tab-grid {
    display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center;
    max-width: 1000px; margin: 0 auto;
  }
  @media (min-width: 768px) { .md-tab-grid { grid-template-columns: 1fr 1fr; gap: 56px; } }

  /* ---------- 10 CUSTOMER STORY ---------- */
  .md-customer-quote {
    font-family: 'Outfit', sans-serif;
    font-style: italic;
    font-size: 24px; line-height: 1.35;
    color: var(--brand-heading);
    margin: 0 0 24px;
    padding-left: 24px;
    border-left: 3px solid var(--brand-primary);
  }
  @media (min-width: 768px) { .md-customer-quote { font-size: 30px; } }
  .md-customer-author {
    display: flex; align-items: center; gap: 12px;
    font-size: 14px;
  }
  .md-stars { color: var(--brand-primary); display: inline-flex; gap: 1px; }
  .md-stars .material-symbols-outlined { font-size: 16px !important; }
  .md-customer-author strong { font-weight: 700; color: var(--brand-heading); }
  .md-customer-author span { color: var(--brand-muted); }

  /* ---------- 11 REVIEWS ---------- */
  .md-reviews { max-width: 1100px; margin: 0 auto; }
  .md-reviews-header {
    display: grid; grid-template-columns: 1fr; gap: 24px; align-items: center;
    margin-bottom: 40px; padding-bottom: 32px;
    border-bottom: 1px solid var(--brand-border);
  }
  @media (min-width: 768px) { .md-reviews-header { grid-template-columns: 1fr 1fr; gap: 48px; } }
  .md-reviews-big-rating { text-align: center; }
  .md-reviews-big-num {
    font-family: 'Outfit', sans-serif; font-weight: 800;
    font-size: 72px; line-height: 1;
    color: var(--brand-heading);
    letter-spacing: -0.03em;
  }
  @media (min-width: 768px) { .md-reviews-big-num { font-size: 96px; } }
  .md-reviews-big-stars { color: var(--brand-primary); margin: 12px 0 8px; }
  .md-reviews-big-stars .material-symbols-outlined { font-size: 24px !important; }
  .md-reviews-big-meta { font-size: 14px; color: var(--brand-muted); }
  .md-reviews-bars { display: flex; flex-direction: column; gap: 10px; }
  .md-reviews-bar {
    display: flex; align-items: center; gap: 12px;
    font-size: 13px; color: var(--brand-text);
  }
  .md-stars-mini { color: var(--brand-primary); display: inline-flex; gap: 1px; }
  .md-stars-mini .material-symbols-outlined { font-size: 14px !important; }
  .md-track {
    flex: 1; height: 8px;
    background: var(--brand-surface-2);
    border-radius: 9999px; overflow: hidden;
  }
  .md-fill {
    height: 100%; background: var(--brand-primary);
    border-radius: 9999px;
  }
  .md-count {
    color: var(--brand-muted); font-size: 12px;
    min-width: 32px; text-align: right;
  }
  .md-reviews-grid {
    display: grid; grid-template-columns: 1fr; gap: 16px;
  }
  @media (min-width: 768px) { .md-reviews-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; } }
  .md-review-card {
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 20px;
    padding: 22px;
    display: flex; flex-direction: column; gap: 12px;
  }
  .md-stars-row { color: var(--brand-primary); display: inline-flex; gap: 1px; }
  .md-stars-row .material-symbols-outlined { font-size: 18px !important; }
  .md-verified {
    font-size: 11px; font-weight: 700;
    color: var(--brand-primary);
    display: inline-flex; align-items: center; gap: 4px;
  }
  .md-verified .material-symbols-outlined { font-size: 14px !important; }
  .md-quote {
    font-size: 14px; color: var(--brand-text);
    line-height: 1.55; margin: 0;
  }
  .md-review-footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--brand-border);
    font-size: 13px;
  }
  .md-review-footer strong { color: var(--brand-heading); font-weight: 700; }
  .md-review-footer span { color: var(--brand-muted); font-size: 12px; }

  /* ---------- 12 GUARANTEE ---------- */
  .md-guarantee {
    display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center;
    max-width: 1100px; margin: 0 auto;
  }
  @media (min-width: 768px) { .md-guarantee { grid-template-columns: 1fr 1.4fr; gap: 64px; } }
  .md-guarantee-badge {
    width: 200px; height: 200px;
    border-radius: 9999px;
    background: var(--brand-primary-soft);
    border: 4px solid var(--brand-primary);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    margin: 0 auto;
    position: relative;
  }
  .md-guarantee-badge::before {
    content: ''; position: absolute; inset: -16px;
    border: 1px dashed var(--brand-primary);
    border-radius: 9999px;
  }
  .md-guarantee-num {
    font-family: 'Outfit', sans-serif;
    font-size: 56px; font-weight: 800;
    color: var(--brand-primary);
    line-height: 1; letter-spacing: -0.03em;
  }
  .md-guarantee-label {
    font-size: 12px; font-weight: 700; letter-spacing: 0.18em;
    color: var(--brand-primary); text-transform: uppercase;
    margin-top: 4px;
  }
  .md-trust-row {
    display: flex; flex-wrap: wrap; gap: 16px;
    margin-top: 24px;
  }
  .md-trust-item {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--brand-text);
  }
  .md-trust-item .material-symbols-outlined {
    font-size: 18px !important;
    color: var(--brand-primary);
  }

  /* ---------- 13 FINAL CTA ---------- */
  .md-cta {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }
  .md-cta-eyebrow {
    display: block;
    font-size: 13px; font-weight: 700; letter-spacing: 0.24em;
    color: var(--brand-accent); text-transform: uppercase;
    margin-bottom: 24px;
  }
  .md-cta h2 { font-size: 40px; line-height: 1.1; margin: 0 0 16px; }
  @media (min-width: 768px) { .md-cta h2 { font-size: 64px; } }
  .md-cta p.md-body {
    font-size: 17px;
    margin: 0 0 40px;
  }
  .md-btn-strawberry {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--brand-accent); color: white;
    padding: 22px 48px; border-radius: 9999px;
    font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;
    font-size: 16px; text-decoration: none;
    box-shadow: 0 12px 32px rgba(230, 57, 70, 0.4);
    transition: transform 150ms, box-shadow 200ms;
  }
  .md-btn-strawberry:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(230, 57, 70, 0.5);
  }
  .md-btn-strawberry .material-symbols-outlined {
    color: white;
    font-size: 20px !important;
  }
  .md-cta-trust {
    display: inline-flex; gap: 20px;
    margin-top: 28px;
    font-size: 13px; color: var(--brand-muted);
    flex-wrap: wrap; justify-content: center;
  }
  .md-cta-trust span {
    display: inline-flex; align-items: center; gap: 6px;
  }
  .md-cta-trust .material-symbols-outlined {
    font-size: 16px !important;
    color: var(--brand-primary);
  }

  /* ---------- 14 FAQ ---------- */
  .md-faq-list { max-width: 760px; margin: 0 auto; }
  .md-faq-item {
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 16px;
    margin-bottom: 8px;
    overflow: hidden;
    transition: border-color 200ms;
  }
  .md-faq-item[open] { border-color: var(--brand-primary); }
  .md-faq-item summary {
    padding: 18px 22px;
    font-weight: 700; font-size: 15px;
    cursor: pointer; list-style: none;
    display: flex; justify-content: space-between; align-items: center;
    gap: 12px;
  }
  .md-faq-item summary::-webkit-details-marker { display: none; }
  .md-faq-item summary .material-symbols-outlined {
    color: var(--brand-primary);
    transition: transform 200ms;
  }
  .md-faq-item[open] summary .material-symbols-outlined {
    transform: rotate(180deg);
  }
  .md-faq-item p {
    padding: 0 22px 18px;
    margin: 0;
    font-size: 14px; color: var(--brand-text);
    line-height: 1.6;
  }

  /* =====================================================
     NEW VARIETY SECTIONS — add visual rhythm
     ===================================================== */

  /* ---------- UNBOXING — quad grid ---------- */
  .md-unbox-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .md-unbox-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
  }
  .md-unbox-cell {
    position: relative;
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 18px;
    overflow: hidden;
    transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
  }
  .md-unbox-cell:hover {
    border-color: var(--brand-primary);
    box-shadow: 0 14px 32px rgba(146, 194, 234, 0.12);
    transform: translateY(-2px);
  }
  .md-unbox-img { aspect-ratio: 1; overflow: hidden; }
  .md-unbox-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .md-unbox-tag {
    position: absolute;
    top: 12px;
    left: 12px;
    width: 30px;
    height: 30px;
    background: var(--brand-heading);
    color: #FFFCF7;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.02em;
  }
  .md-unbox-cell h3 {
    font-size: 15px;
    font-weight: 700;
    color: var(--brand-heading);
    margin: 14px 16px 4px;
    line-height: 1.25;
  }
  .md-unbox-cell p {
    margin: 0 16px 16px;
    font-size: 13px;
    color: var(--brand-text);
    line-height: 1.5;
  }
  @media (min-width: 768px) {
    .md-unbox-cell h3 { font-size: 16px; margin: 16px 20px 6px; }
    .md-unbox-cell p { font-size: 13.5px; margin: 0 20px 20px; }
  }

  /* Swipe hint — widoczny tylko na mobile */
  .md-variants-swipe-hint {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 14px 0 0;
    font-size: 12.5px;
    color: var(--brand-muted);
    font-weight: 600;
  }
  .md-variants-swipe-hint .material-symbols-outlined {
    font-size: 16px;
    color: var(--brand-primary);
  }
  @media (min-width: 768px) { .md-variants-swipe-hint { display: none; } }

  /* ---------- VARIANT SHOWCASE — 3 cards (mobile: scroll-snap carousel) ---------- */
  .md-variants-grid {
    display: flex;
    gap: 14px;
    max-width: 1100px;
    margin: 0 auto;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 4px 9% 16px;
    scrollbar-width: none;
  }
  .md-variants-grid::-webkit-scrollbar { display: none; }
  .md-variants-grid > .md-variant-card {
    scroll-snap-align: center;
    flex: 0 0 82%;
    min-width: 0;
  }
  @media (min-width: 768px) {
    .md-variants-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      overflow: visible;
      padding: 0;
      margin-left: auto;
      margin-right: auto;
    }
    .md-variants-grid > .md-variant-card { flex: initial; min-width: 0; }
  }
  .md-variant-card {
    background: var(--brand-bg);
    border-radius: 24px;
    overflow: hidden;
    transition: transform 280ms ease, box-shadow 280ms ease;
    position: relative;
    isolation: isolate;
  }
  .md-variant-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(42, 45, 39, 0.04) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .md-variant-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 20px 48px rgba(42, 45, 39, 0.12);
  }
  .md-variant-img {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }
  .md-variant-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .md-variant-card:hover .md-variant-img img { transform: scale(1.04); }
  .md-variant-body {
    padding: 22px 24px 26px;
    position: relative;
    z-index: 2;
  }
  .md-variant-dot {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-bottom: 12px;
    box-shadow: 0 2px 6px rgba(42, 45, 39, 0.15);
  }
  .md-variant-card h3 {
    font-size: 22px;
    font-weight: 800;
    color: var(--brand-heading);
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }
  .md-variant-card p {
    margin: 0;
    font-size: 14.5px;
    color: var(--brand-text);
    line-height: 1.55;
  }

  /* ---------- PULL QUOTE — typographic breather ---------- */
  .md-section--pullquote {
    background:
      radial-gradient(50% 70% at 20% 20%, rgba(146, 194, 234, 0.08) 0%, transparent 60%),
      radial-gradient(45% 60% at 85% 80%, rgba(230, 57, 70, 0.05) 0%, transparent 60%),
      var(--brand-bg);
    padding: 96px 20px;
  }
  @media (min-width: 768px) { .md-section--pullquote { padding: 128px 32px; } }
  .md-pullquote {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }
  .md-pullquote-mark {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 120px;
    font-weight: 900;
    color: var(--brand-primary);
    line-height: 0.7;
    margin-bottom: 24px;
    opacity: 0.7;
  }
  @media (min-width: 768px) { .md-pullquote-mark { font-size: 180px; } }
  .md-pullquote-text {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: var(--brand-heading);
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 0 0 28px;
  }
  @media (min-width: 768px) { .md-pullquote-text { font-size: 42px; } }
  .md-pullquote-sign {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-primary);
  }

  /* ---------- ANTI-CLAIMS — czym NIE są ---------- */
  .md-eyebrow--strawberry { color: var(--brand-accent); }
  .md-em-strawberry { color: var(--brand-accent); }
  .md-anti-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (min-width: 768px) { .md-anti-grid { grid-template-columns: repeat(3, 1fr); gap: 24px; } }
  .md-anti-card {
    background: var(--brand-surface);
    border: 1.5px solid var(--brand-border);
    border-radius: 18px;
    padding: 28px 26px;
    position: relative;
    transition: border-color 240ms ease, transform 240ms ease;
  }
  .md-anti-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 22px;
    bottom: 22px;
    width: 4px;
    background: var(--brand-accent);
    border-radius: 0 4px 4px 0;
  }
  .md-anti-card:hover {
    border-color: var(--brand-accent);
    transform: translateY(-2px);
  }
  .md-anti-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--brand-accent-soft);
    color: var(--brand-accent);
    border-radius: 50%;
    margin-bottom: 14px;
  }
  .md-anti-icon .material-symbols-outlined { font-size: 22px; }
  .md-anti-card h3 {
    font-size: 19px;
    font-weight: 700;
    color: var(--brand-heading);
    margin: 0 0 10px;
    letter-spacing: -0.015em;
  }
  .md-anti-card h3 s {
    color: var(--brand-accent);
    text-decoration-thickness: 2px;
    text-decoration-color: var(--brand-accent);
  }
  .md-anti-card p {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--brand-text);
  }

  /* ---------- USE CASE SCENARIOS — 6 cards ---------- */
  .md-uses-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (min-width: 640px) {
    .md-uses-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
  @media (min-width: 1024px) {
    .md-uses-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; }
  }
  .md-use-card {
    background: var(--brand-bg);
    border: 1px solid var(--brand-border);
    border-radius: 16px;
    padding: 22px 22px 24px;
    transition: border-color 220ms ease, transform 220ms ease, box-shadow 220ms ease;
  }
  .md-use-card:hover {
    border-color: var(--brand-primary);
    transform: translateY(-2px);
    box-shadow: 0 10px 26px rgba(146, 194, 234, 0.12);
  }
  .md-use-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: var(--brand-primary-soft);
    color: var(--brand-primary-hover);
    border-radius: 12px;
    margin-bottom: 14px;
  }
  .md-use-icon .material-symbols-outlined { font-size: 22px; }
  .md-use-card h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--brand-heading);
    margin: 0 0 6px;
    letter-spacing: -0.015em;
  }
  .md-use-card p {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--brand-text);
  }

  /* =====================================================
     EXTRA 8 SECTIONS — final closing rhythm
     ===================================================== */

  /* ---------- EXTRA 01 — MAGAZINE SPREAD ---------- */
  .md-mag-spread {
    position: relative;
    width: 100%;
    min-height: 380px;
    overflow: hidden;
  }
  @media (min-width: 768px) { .md-mag-spread { min-height: 520px; } }
  .md-mag-img {
    position: absolute;
    inset: 0;
  }
  .md-mag-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .md-mag-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(42,45,39,0.78) 0%, rgba(42,45,39,0.55) 40%, rgba(42,45,39,0.20) 100%);
  }
  .md-mag-overlay {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    padding: 64px 24px;
    color: #FFFCF7;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 380px;
    max-width: 720px;
  }
  @media (min-width: 768px) {
    .md-mag-overlay { padding: 96px 64px; min-height: 520px; }
  }
  .md-mag-eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brand-primary-soft);
    margin-bottom: 18px;
  }
  .md-mag-overlay h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0 0 18px;
    color: #FFFCF7;
  }
  @media (min-width: 768px) { .md-mag-overlay h2 { font-size: 56px; } }
  .md-mag-overlay p {
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255,252,247,0.85);
    max-width: 540px;
  }
  @media (min-width: 768px) { .md-mag-overlay p { font-size: 17px; } }

  /* ---------- EXTRA 02 — FOUNDER STORY ---------- */
  .md-founder {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1100px;
    margin: 0 auto;
    align-items: center;
  }
  @media (min-width: 768px) { .md-founder { grid-template-columns: 1.05fr 1fr; gap: 64px; } }
  .md-founder-img {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 24px 56px rgba(42,45,39,0.14);
  }
  .md-founder-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .md-founder-stamp {
    position: absolute;
    bottom: 20px;
    right: 20px;
    width: 80px;
    height: 80px;
    background: var(--brand-primary);
    color: #FFFCF7;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
    letter-spacing: 0.02em;
    transform: rotate(-8deg);
    box-shadow: 0 8px 20px rgba(146,194,234,0.40);
  }
  .md-founder-stamp span { font-size: 9px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.8; }
  .md-founder-stamp strong { font-size: 22px; font-weight: 800; }
  .md-founder-body h2 {
    font-size: 30px;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--brand-heading);
    margin: 14px 0 18px;
    line-height: 1.1;
  }
  @media (min-width: 768px) { .md-founder-body h2 { font-size: 40px; } }
  .md-founder-body .md-body { font-size: 15px; line-height: 1.65; margin: 0 0 14px; }
  @media (min-width: 768px) { .md-founder-body .md-body { font-size: 16px; } }
  .md-founder-sign {
    margin-top: 22px;
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--brand-muted);
    font-size: 13.5px;
    font-style: italic;
  }
  .md-founder-sign-line {
    width: 32px; height: 2px;
    background: var(--brand-primary);
    border-radius: 2px;
  }

  /* ---------- EXTRA 03 — COMPARISON TABLE ---------- */
  .md-compare-wrap {
    max-width: 1100px;
    margin: 0 auto;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    /* Fade na prawej krawędzi sygnalizujący że jest więcej content'u do scrolla */
    mask-image: linear-gradient(to right, black 0, black calc(100% - 24px), transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 0, black calc(100% - 24px), transparent 100%);
  }
  /* Mobile-only swipe hint pod tabelą */
  .md-compare-hint {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin: 14px auto 0;
    padding: 8px 14px;
    font-size: 12.5px;
    color: var(--brand-muted);
    font-style: italic;
    text-align: center;
    max-width: max-content;
    background: var(--brand-surface-2);
    border-radius: 9999px;
  }
  .md-compare-hint .material-symbols-outlined {
    font-size: 16px !important;
    color: var(--brand-primary);
    animation: md-swipe-pulse 2s ease-in-out infinite;
  }
  @keyframes md-swipe-pulse {
    0%, 100% { transform: translateX(0); opacity: 0.7; }
    50% { transform: translateX(6px); opacity: 1; }
  }
  /* Tylko mobile gdzie tabela się scrolluje (min-width: 580px wymusza overflow) */
  @media (max-width: 640px) {
    .md-compare-hint { display: inline-flex; }
  }
  .md-compare-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    min-width: 580px;
  }
  .md-compare-table th,
  .md-compare-table td {
    padding: 14px 16px;
    text-align: center;
    font-size: 14px;
    color: var(--brand-text);
    border-bottom: 1px solid var(--brand-border);
  }
  .md-compare-table thead th {
    font-weight: 600;
    color: var(--brand-muted);
    font-size: 13px;
    border-bottom: 2px solid var(--brand-border);
    padding-bottom: 18px;
  }
  .md-compare-table tbody td:first-child {
    text-align: left;
    font-weight: 600;
    color: var(--brand-heading);
    background: var(--brand-bg);
    border-radius: 10px 0 0 10px;
  }
  .md-compare-col-us {
    background: var(--brand-primary-soft);
    border-radius: 10px 10px 0 0;
    color: var(--brand-primary-hover) !important;
    font-weight: 800 !important;
    font-size: 15px !important;
  }
  .md-compare-col-us span {
    display: inline-block;
    padding: 4px 14px;
    background: var(--brand-primary);
    color: #FFFCF7;
    border-radius: 999px;
    font-size: 14px;
  }
  .md-compare-cell-us {
    background: var(--brand-primary-soft);
  }
  .md-compare-table tbody tr:last-child .md-compare-cell-us {
    border-radius: 0 0 10px 10px;
  }
  .md-yes { color: var(--brand-primary); font-size: 24px !important; }
  .md-no { color: rgba(42,45,39,0.20); font-size: 24px !important; }

  /* ---------- STATS — BENTO GRID (asymetryczny, light bg) ---------- */
  .md-bento {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  @media (min-width: 768px) {
    .md-bento {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto auto;
      gap: 18px;
    }
  }
  .md-bento-cell {
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 22px;
    padding: 26px 24px 28px;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: transform 240ms ease, box-shadow 240ms ease, border-color 240ms ease;
  }
  .md-bento-cell:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 36px rgba(42,45,39,0.10);
  }
  /* Featured XL cell — zajmuje 2 wiersze i 1 kolumnę na desktop */
  .md-bento-cell--xl {
    background: linear-gradient(160deg, var(--brand-primary) 0%, var(--brand-primary-hover) 100%);
    color: #FFFCF7;
    border: none;
    padding: 32px 30px 36px;
  }
  @media (min-width: 768px) {
    .md-bento-cell--xl { grid-column: 1; grid-row: 1 / span 2; padding: 40px 36px; }
  }
  .md-bento-cell--xl .md-bento-num { color: #FFFCF7; font-size: 56px; }
  @media (min-width: 768px) { .md-bento-cell--xl .md-bento-num { font-size: 72px; } }
  .md-bento-cell--xl .md-bento-label { color: rgba(255,252,247,0.92); font-size: 15px; font-weight: 700; }
  .md-bento-cell--xl .md-bento-sub { color: rgba(255,252,247,0.72); font-size: 13.5px; margin: 12px 0 0; line-height: 1.55; }
  .md-bento-cell--sage {
    background: var(--brand-primary-soft);
    border-color: var(--brand-primary);
  }
  .md-bento-cell--strawberry {
    background: var(--brand-accent-soft);
    border-color: var(--brand-accent);
  }
  .md-bento-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(255,252,247,0.18);
    color: #FFFCF7;
    border-radius: 12px;
    margin-bottom: 4px;
  }
  .md-bento-icon .material-symbols-outlined { font-size: 24px; }
  .md-bento-num {
    font-family: 'Outfit', sans-serif;
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.035em;
    color: var(--brand-heading);
    line-height: 1;
  }
  @media (min-width: 768px) { .md-bento-num { font-size: 46px; } }
  .md-bento-num small {
    font-size: 0.45em;
    font-weight: 600;
    color: var(--brand-muted);
    margin-left: 2px;
    letter-spacing: -0.02em;
  }
  .md-bento-cell--xl .md-bento-num small { color: rgba(255,252,247,0.55); }
  .md-bento-label {
    font-size: 14.5px;
    font-weight: 700;
    color: var(--brand-heading);
    line-height: 1.3;
  }
  .md-bento-cell--sage .md-bento-label,
  .md-bento-cell--sage .md-bento-num { color: var(--brand-primary-hover); }
  .md-bento-cell--strawberry .md-bento-label,
  .md-bento-cell--strawberry .md-bento-num { color: var(--brand-accent-hover); }
  .md-bento-foot {
    font-size: 12.5px;
    color: var(--brand-muted);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
  }
  .md-bento-cell--sage .md-bento-foot { color: var(--brand-primary-hover); opacity: 0.85; }
  .md-bento-cell--strawberry .md-bento-foot { color: var(--brand-accent-hover); opacity: 0.85; }
  .md-bento-star {
    color: #E8A317;
    font-size: 15px !important;
  }

  /* ---------- SECTION 2 — PROBLEM → SOLUTION SPLIT ---------- */
  .md-problem-solve {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: stretch;
  }
  @media (min-width: 768px) {
    .md-problem-solve {
      grid-template-columns: 1fr auto 1fr;
      gap: 24px;
      align-items: center;
    }
  }
  .md-ps-side {
    background: var(--brand-bg);
    border: 1px solid var(--brand-border);
    border-radius: 22px;
    padding: 26px 24px;
  }
  .md-ps-side--solution {
    background: var(--brand-primary-soft);
    border-color: var(--brand-primary);
  }
  .md-ps-tag {
    display: inline-block;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .md-ps-tag--problem {
    background: var(--brand-accent-soft);
    color: var(--brand-accent);
  }
  .md-ps-tag--solution {
    background: var(--brand-primary);
    color: #FFFCF7;
  }
  .md-ps-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .md-ps-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15.5px;
    font-weight: 500;
    color: var(--brand-text);
    line-height: 1.35;
  }
  .md-ps-list li .material-symbols-outlined {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    background: var(--brand-accent-soft);
    color: var(--brand-accent);
    border-radius: 50%;
  }
  .md-ps-list--ok li {
    color: var(--brand-heading);
    font-weight: 600;
  }
  .md-ps-list--ok li .material-symbols-outlined {
    background: transparent;
    color: var(--brand-primary);
    font-size: 22px;
    width: auto;
    height: auto;
  }
  .md-ps-bridge {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--brand-primary);
  }
  @media (min-width: 768px) {
    .md-ps-bridge { flex-direction: column; gap: 6px; }
  }
  .md-ps-bridge-arrow {
    font-size: 32px;
    line-height: 1;
    color: var(--brand-primary);
    font-weight: 300;
    transform: rotate(0);
  }
  @media (min-width: 768px) {
    .md-ps-bridge-arrow { transform: rotate(0); font-size: 40px; }
  }
  .md-ps-bridge-label {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand-primary-hover);
  }

  /* ---------- EXTRA 05 — CARE FLOW (4 steps with arrows) ---------- */
  .md-care-flow {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: stretch;
  }
  @media (min-width: 768px) {
    .md-care-flow {
      grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
      gap: 14px;
      align-items: center;
    }
  }
  .md-care-step {
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 18px;
    padding: 24px 22px 26px;
    text-align: left;
    position: relative;
    transition: border-color 240ms ease, transform 240ms ease, box-shadow 240ms ease;
  }
  .md-care-step:hover {
    border-color: var(--brand-primary);
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(146,194,234,0.12);
  }
  .md-care-icon {
    width: 44px;
    height: 44px;
    background: var(--brand-primary-soft);
    color: var(--brand-primary-hover);
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }
  .md-care-icon .material-symbols-outlined { font-size: 24px; }
  .md-care-num {
    position: absolute;
    top: 22px;
    right: 22px;
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--brand-primary);
    letter-spacing: -0.02em;
    opacity: 0.45;
  }
  .md-care-step h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--brand-heading);
    margin: 0 0 6px;
    letter-spacing: -0.015em;
  }
  .md-care-step p {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--brand-text);
  }
  .md-care-arrow {
    display: none;
    font-size: 28px;
    color: var(--brand-primary);
    font-weight: 300;
  }
  @media (min-width: 768px) { .md-care-arrow { display: inline-flex; align-items: center; justify-content: center; } }

  /* ---------- EXTRA 06 — QUOTE WALL ---------- */
  .md-quotes-wall {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) { .md-quotes-wall { grid-template-columns: repeat(2, 1fr); gap: 20px; } }
  @media (min-width: 1024px) { .md-quotes-wall { grid-template-columns: repeat(4, 1fr); gap: 18px; } }
  .md-quote-card {
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 18px;
    padding: 22px 22px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 240ms ease, box-shadow 240ms ease;
  }
  .md-quote-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px rgba(42,45,39,0.10);
  }
  .md-quote-stars {
    display: inline-flex;
    gap: 2px;
    color: #E8A317;
  }
  .md-quote-stars .material-symbols-outlined { font-size: 16px; }
  .md-quote-card p {
    margin: 0;
    flex: 1;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--brand-heading);
    font-style: italic;
  }
  .md-quote-author {
    font-size: 13px;
    color: var(--brand-muted);
  }
  .md-quote-author strong {
    color: var(--brand-heading);
    font-weight: 700;
    font-style: normal;
  }

  /* ---------- EXTRA 07 — MATERIALS / SUSTAINABILITY ---------- */
  .md-materials-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 768px) { .md-materials-grid { grid-template-columns: repeat(3, 1fr); gap: 24px; } }
  .md-material-card {
    position: relative;
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-top: 4px solid var(--mat-color);
    border-radius: 18px;
    padding: 28px 26px 26px;
    transition: transform 240ms ease, box-shadow 240ms ease;
  }
  .md-material-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 32px rgba(42,45,39,0.10);
  }
  .md-material-tag {
    display: inline-block;
    padding: 5px 12px;
    background: var(--mat-soft);
    color: var(--mat-color);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: 999px;
    margin-bottom: 16px;
  }
  .md-material-card h3 {
    font-size: 20px;
    font-weight: 800;
    color: var(--brand-heading);
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .md-material-card p {
    margin: 0 0 18px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--brand-text);
  }
  .md-material-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 16px;
    border-top: 1px solid var(--brand-border);
    font-size: 12.5px;
    color: var(--brand-muted);
  }
  .md-material-meta strong {
    color: var(--brand-heading);
    font-weight: 700;
    margin-right: 4px;
  }

  /* ---------- FINAL CTA — contained card (nie full-bg, daje breathing room z dark footerem) ---------- */
  .md-cta-card {
    max-width: 1100px;
    margin: 0 auto;
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 24px;
    box-shadow: 0 24px 56px rgba(42,45,39,0.10);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .md-cta-card { grid-template-columns: 5fr 7fr; }
  }
  .md-cta-card-img {
    background: var(--brand-primary-soft);
    aspect-ratio: 16 / 11;
    overflow: hidden;
  }
  @media (min-width: 900px) {
    .md-cta-card-img { aspect-ratio: auto; min-height: 100%; }
  }
  .md-cta-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .md-cta-card-body {
    padding: 28px 26px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (min-width: 768px) { .md-cta-card-body { padding: 44px 44px; } }
  .md-cta-card-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brand-primary);
    margin-bottom: 14px;
  }
  .md-cta-card-body h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--brand-heading);
    margin: 0 0 14px;
  }
  @media (min-width: 768px) { .md-cta-card-body h2 { font-size: 34px; } }
  .md-cta-card-body p {
    margin: 0 0 26px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--brand-text);
  }
  .md-cta-card-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start;
    margin-bottom: 22px;
  }
  @media (min-width: 640px) {
    .md-cta-card-actions { flex-direction: row; align-items: center; gap: 16px; }
  }
  .md-cta-card-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 15px 28px;
    background: var(--brand-primary);
    color: #FFFCF7;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
    text-decoration: none;
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 10px 24px rgba(146,194,234,0.30);
  }
  .md-cta-card-btn:hover {
    background: var(--brand-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(146,194,234,0.40);
  }
  .md-cta-card-btn .material-symbols-outlined { font-size: 18px; }
  .md-cta-card-link {
    color: var(--brand-text);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: color 200ms ease;
  }
  .md-cta-card-link:hover { color: var(--brand-primary-hover); }
  .md-cta-card-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    padding-top: 22px;
    border-top: 1px solid var(--brand-border);
    color: var(--brand-muted);
    font-size: 12.5px;
  }
  .md-cta-card-trust span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .md-cta-card-trust .material-symbols-outlined {
    font-size: 16px;
    color: var(--brand-primary);
  }

  /* ---------- PROBLEM → SOLUTION — refined polish ---------- */
  .md-ps-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .md-ps-emoji {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-family: 'Outfit', sans-serif;
    font-size: 18px;
    font-weight: 800;
    line-height: 1;
  }
  .md-ps-side--problem .md-ps-emoji {
    background: var(--brand-accent-soft);
    color: var(--brand-accent);
  }
  .md-ps-side--solution .md-ps-emoji {
    background: var(--brand-primary);
    color: #FFFCF7;
  }
  .md-ps-side {
    padding: 28px 26px;
    border-radius: 22px;
    box-shadow: 0 4px 16px rgba(42,45,39,0.04);
    transition: transform 240ms ease, box-shadow 240ms ease;
  }
  .md-ps-side:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(42,45,39,0.08);
  }
  .md-ps-foot {
    margin: 20px 0 0;
    padding-top: 16px;
    border-top: 1px solid var(--brand-border);
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--brand-muted);
    font-style: italic;
  }
  .md-ps-side--solution .md-ps-foot { border-top-color: var(--brand-primary); opacity: 0.85; }
  .md-ps-bridge-circle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--brand-surface);
    border: 2px solid var(--brand-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(146,194,234,0.25);
  }
  .md-ps-bridge-circle .md-ps-bridge-arrow {
    color: var(--brand-primary);
    font-size: 28px;
    font-weight: 600;
    line-height: 1;
  }
  @media (max-width: 768px) {
    .md-ps-bridge-circle .md-ps-bridge-arrow { transform: rotate(90deg); display: inline-block; }
  }

  /* ---------- STICKY MIN — refined polish ---------- */
  .md-sticky-img .md-img-square {
    position: relative;
  }
  .md-sticky-img-tag {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background: rgba(42,45,39,0.85);
    color: #FFFCF7;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    backdrop-filter: blur(8px);
  }
  .md-sticky-img-tag .material-symbols-outlined {
    font-size: 14px;
    color: var(--brand-primary-soft);
  }
  .md-sticky-block-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .md-sticky-meta {
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-muted);
  }
  .md-sticky-tags {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .md-sticky-tags li {
    padding: 4px 10px;
    background: var(--brand-primary-soft);
    color: var(--brand-primary-hover);
    border-radius: 999px;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  /* ---------- POLECANE PRODUKTY — related products ---------- */
  .md-related-head {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 28px;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .md-related-head {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
      gap: 24px;
    }
  }
  .md-related-head h2 {
    margin: 6px 0 0;
  }
  .md-related-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    color: var(--brand-heading);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    transition: all 200ms ease;
  }
  .md-related-all:hover {
    background: var(--brand-primary);
    color: #FFFCF7;
    border-color: var(--brand-primary);
    transform: translateY(-1px);
  }
  .md-related-all .material-symbols-outlined { font-size: 16px; }
  .md-related-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (max-width: 900px) {
    .md-related-grid {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 4px 16px 16px;
      margin-left: -16px;
      margin-right: -16px;
      scrollbar-width: none;
    }
    .md-related-grid::-webkit-scrollbar { display: none; }
    .md-related-card {
      flex: 0 0 65%;
      scroll-snap-align: start;
    }
  }
  @media (max-width: 640px) {
    .md-related-card { flex-basis: 72%; }
  }
  .md-related-card {
    display: flex;
    flex-direction: column;
    background: var(--brand-surface);
    border: 1px solid var(--brand-border);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }
  .md-related-card:hover {
    transform: translateY(-3px);
    border-color: var(--brand-primary);
    box-shadow: 0 14px 28px rgba(42,45,39,0.10);
  }
  .md-related-img {
    aspect-ratio: 1;
    background: var(--brand-primary-soft);
    overflow: hidden;
  }
  .md-related-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 480ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .md-related-card:hover .md-related-img img { transform: scale(1.05); }
  .md-related-img-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--brand-muted);
  }
  .md-related-img-empty .material-symbols-outlined { font-size: 40px; }
  .md-related-body {
    padding: 14px 16px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .md-related-body h3 {
    font-size: 14.5px;
    font-weight: 700;
    color: var(--brand-heading);
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.005em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .md-related-price {
    font-size: 15px;
    font-weight: 800;
    color: var(--brand-primary-hover);
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .md-related-price-row {
    margin: auto 0 0;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .md-related-price-regular {
    font-size: 13px;
    font-weight: 500;
    color: var(--brand-muted);
    text-decoration: line-through;
    text-decoration-color: currentColor;
    text-decoration-thickness: 1.5px;
    line-height: 1;
  }
  .md-related-price--sale {
    color: var(--brand-accent);
    font-size: 16px;
  }

  /* Rating row pod nazwą produktu w polecanych */
  .md-related-rating {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: var(--brand-muted);
    margin: 2px 0;
  }
  .md-related-stars {
    display: inline-flex;
    align-items: center;
    gap: 1px;
  }
  .md-related-star {
    font-size: 13px !important;
    line-height: 1;
    font-variation-settings: 'FILL' 1;
  }
  .md-related-star--full,
  .md-related-star--half {
    color: #F5B544;
  }
  .md-related-star--empty {
    color: var(--brand-border-strong);
    font-variation-settings: 'FILL' 0;
  }
  .md-related-rating-num {
    font-weight: 700;
    color: var(--brand-heading);
    font-size: 12px;
  }
  .md-related-rating-count {
    color: var(--brand-muted);
    font-size: 11.5px;
  }
  .md-related-sale-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    padding: 4px 10px;
    background: var(--brand-accent);
    color: #FFFFFF;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.03em;
    border-radius: 9999px;
    box-shadow: 0 3px 10px rgba(230, 57, 70, 0.35);
  }
  .md-related-mobile-hint {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 16px;
    font-size: 12.5px;
    color: var(--brand-muted);
    font-weight: 600;
  }
  .md-related-mobile-hint .material-symbols-outlined {
    font-size: 16px;
    color: var(--brand-primary);
  }
  @media (min-width: 901px) { .md-related-mobile-hint { display: none; } }

  /* =====================================================
     MOBILE TUNING — wszystkie sekcje
     ===================================================== */
  @media (max-width: 640px) {
    /* Section padding mniejszy na mobile */
    .md-section { padding: 40px 16px; }
    .md-section--compact { padding: 28px 16px; }
    .md-section--last { padding-bottom: 40px; }

    /* H2 mniejsze */
    .md-center h2, .md-split h2, .md-section h2 {
      font-size: 26px !important;
      letter-spacing: -0.02em;
    }
    .md-body, .md-section p { font-size: 14.5px; line-height: 1.55; }

    /* Problem/solve split — w pionie, bridge horyzontalny */
    .md-problem-solve { gap: 12px; }
    .md-ps-side { padding: 20px 18px; }
    .md-ps-list li { font-size: 14.5px; }
    .md-ps-bridge { padding: 6px 0; }
    .md-ps-bridge-arrow { transform: rotate(90deg); font-size: 28px; }
    .md-ps-bridge-label { font-size: 11px; }

    /* Split sections — image first, then text */
    .md-split, .md-split--mirror { gap: 22px; }
    .md-split .md-img-square, .md-split--mirror .md-img-square { border-radius: 16px; }

    /* Sticky scroll cards — mniejsze paddingi już są w base */

    /* Variant showcase — pojedyncza kolumna na mobile */
    .md-variants-grid { gap: 14px; }
    .md-variant-card { border-radius: 18px; }
    .md-variant-body { padding: 18px 20px 22px; }
    .md-variant-card h3 { font-size: 19px; }

    /* Trust strip — 2x2 grid */
    .md-trust-strip { padding: 20px 16px; }

    /* Tabs */
    .md-tabs-nav { gap: 6px; flex-wrap: wrap; justify-content: center; }
    .md-tab-btn { font-size: 12.5px; padding: 8px 14px; }

    /* Customer story (sage-soft) */
    .md-customer-quote { font-size: 18px; line-height: 1.4; }

    /* Reviews — keep responsive */
    .md-reviews-big-num { font-size: 56px; }

    /* Specyfikacja */
    .md-spec-card { gap: 22px; }
    .md-spec-list li { font-size: 13.5px; }

    /* Founder */
    .md-founder { gap: 28px; }
    .md-founder-img { border-radius: 18px; }
    .md-founder-stamp {
      width: 64px; height: 64px; bottom: 14px; right: 14px;
    }
    .md-founder-stamp strong { font-size: 18px; }
    .md-founder-body h2 { font-size: 26px !important; }
    .md-founder-body .md-body { font-size: 14.5px; }

    /* Comparison table — scrollowalna */
    .md-compare-table { font-size: 12.5px; min-width: 460px; }
    .md-compare-table th, .md-compare-table td { padding: 10px 8px; }

    /* Bento stats — 1 col, większe paddings */
    .md-bento { gap: 12px; }
    .md-bento-cell { padding: 22px 22px 24px; border-radius: 18px; }
    .md-bento-cell--xl { padding: 28px 26px 30px; }
    .md-bento-cell--xl .md-bento-num { font-size: 48px; }
    .md-bento-num { font-size: 36px; }

    /* FAQ — szczelniej */
    .md-faq-item summary { padding: 14px 18px; font-size: 14.5px; }

    /* Final CTA card */
    .md-cta-card { border-radius: 20px; }
    .md-cta-card-img { aspect-ratio: 16 / 10; }
    .md-cta-card-body { padding: 24px 22px 28px; }
    .md-cta-card-body h2 { font-size: 22px !important; line-height: 1.2; }
    .md-cta-card-body p { font-size: 14.5px; margin-bottom: 22px; }
    .md-cta-card-btn { width: 100%; min-width: 0; padding: 14px 22px; }
    .md-cta-card-trust { gap: 12px; font-size: 12px; }
  }
</style>

<script is:inline>
  // Carousel arrows (mobile)
  document.querySelectorAll('[data-md-carousel-prev], [data-md-carousel-next]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-md-carousel-prev') || btn.getAttribute('data-md-carousel-next');
      const dir = btn.getAttribute('data-md-carousel-prev') ? -1 : 1;
      const el = document.getElementById(id);
      if (!el) return;
      const item = el.firstElementChild;
      if (!item) return;
      const gap = parseFloat(getComputedStyle(el).gap) || 16;
      el.scrollBy({ left: (item.offsetWidth + gap) * dir, behavior: 'smooth' });
    });
  });

  // Tabs
  document.querySelectorAll('.md-tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = Number(btn.getAttribute('data-md-tab'));
      document.querySelectorAll('.md-tab-btn').forEach((b) => b.classList.remove('md-tab-btn--active'));
      document.querySelectorAll('.md-tab-content').forEach((c) => c.classList.remove('md-tab-content--active'));
      btn.classList.add('md-tab-btn--active');
      const all = document.querySelectorAll('.md-tab-content');
      if (all[idx]) all[idx].classList.add('md-tab-content--active');
    });
  });
</script>
