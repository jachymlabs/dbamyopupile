---
/**
 * LoomoDescription — pełny opis produktu Loomo.
 * Drewniany kinetic fidget — zazębione koła obracające się płynnie wokół osi.
 * Cichy, naturalny, dla biurka. Dla dorosłych pracujących umysłowo + dzieci z ADHD.
 *
 * Struktura: 18-sekcyjny template (zgodny z MoodlesDescription).
 * Assety w /public/loomo/photos/ (7 webp).
 * Tone: lowercase konwersacyjny, ADHD-aware, brak medical claims, sentence case, zero em-dashy.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/loomo/photos';

// Reviews — z osobnego JSON per produkt (loomo tutaj)
const reviews = getProductReviews('loomo');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude loomo, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'loomo')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('LoomoDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  // SinglePrice { value } | PriceRange { min, max }
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/loomo-01-hero-sage-polka.webp`} alt="" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/loomo-06-makro-zazebione-kola.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/loomo-02-full-set-biurko-kreatywne.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/loomo-07-centralny-pivot-diamentowy.webp`} alt="" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od rozproszenia do skupienia</span>
        <h2>Daj rękom coś, co naprawdę <span class="md-em">wycisza</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Klikasz długopisem przez całe spotkanie</li>
            <li><span class="material-symbols-outlined">close</span>Co chwilę odpalasz telefon bez powodu</li>
            <li><span class="material-symbols-outlined">close</span>Myśl się urywa, zanim ją skończysz</li>
            <li><span class="material-symbols-outlined">close</span>Wieczorem dalej scrollujesz, choć nic nie szukasz</li>
          </ul>
          <p class="md-ps-foot">Mózg, który nie dostaje wystarczającej ilości bodźców, sam zaczyna ich szukać. Długopis, paznokieć, telefon. Cokolwiek jest pod ręką.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">Loomo</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Ruch, który się nie kończy</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Cichy mechanizm zamiast klikania</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Skupienie, które wraca przez dłonie</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Dla głów z ADHD, dla biurka, dla ciszy</li>
          </ul>
          <p class="md-ps-foot">Drewniany kinetic, który mieści się w dłoni. Obracasz, koła chodzą płynnie, głowa zwalnia. Bez ekranu, bez baterii, bez powiadomień.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/loomo-05-unusual-charcoal-dramatic.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2><span class="md-em">Koniec</span> z klikaniem długopisem</h2>
        <p class="md-body">Klikasz długopisem na spotkaniu, stukasz palcem o klawiaturę, podrzucasz telefon w dłoni. To nie kwestia silnej woli. Tak zachowuje się mózg, który pracuje na zbyt niskich obrotach i sam szuka bodźców. Loomo daje mu dokładnie to, czego szuka, ale w sposób cichy i naturalny. Zazębione koła chodzą płynnie wokół drewnianej osi. Ręce dostają konkretne zajęcie, przez co głowa zwalnia. Szczególnie dla głów z ADHD, których dłonie cały czas czegoś szukają.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/loomo-06-makro-zazebione-kola.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Drewno, zazębione koła i jedna naoliwiona oś</h2>
        <p class="md-body">Loomo to nie jest plastikowy fidget. To kawałek litego drewna z mechanizmem w środku. <strong>Zazębione koła</strong> obracają się płynnie wokół naoliwionej osi, każdy obrót przechodzi w kolejny bez oporu. <strong>Centralny pivot</strong> trzyma wszystko w ryzach, nawet po miesiącach codziennego używania. <strong>Drewno</strong> ociepla się od dłoni, faktura zmienia się z czasem. <strong>Cisza</strong> jest gwarantowana, mechanizm nie stuka, nie skrzypi, nie brzęczy. Cztery elementy, które razem dają coś, czego plastikowy spinner nigdy nie da.</p>
      </div>
    </div>
  </section>

  {/* ========== 05 — CUSTOMER STORY (sage-soft, featured = pierwsza opinia 5-star) ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/loomo-04-result-mezczyzna-pisze-fokus.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== 06 — COMPARISON TABLE (Loomo vs fidget spinner / spinner plastik / aplikacja mindfulness) ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Spektrum fidgetów</span>
        <h2>Porównanie z klasycznymi rozwiązaniami</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>Loomo</span></th>
              <th>Fidget spinner</th>
              <th>Spinner z plastiku</th>
              <th>Aplikacja mindfulness</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Cichy, bez stukania i brzęczenia</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Bez baterii i ładowania</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Bez ekranu i powiadomień</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Naturalny materiał (drewno)</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Nie nudzi się po tygodniu</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Nie wygląda jak zabawka</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== 07 — TABBED USE CASES (praca biurowa / ADHD / studenci / prezent) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Dla kogo jest Loomo?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">Praca biurowa</button>
        <button class="md-tab-btn" data-md-tab="1">ADHD i skupienie</button>
        <button class="md-tab-btn" data-md-tab="2">Studenci na wykładach</button>
        <button class="md-tab-btn" data-md-tab="3">Prezent na biurko</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/loomo-02-full-set-biurko-kreatywne.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Ośmiogodzinny dzień przed monitorem</h3>
            <p class="md-body">Loomo leży obok klawiatury i czeka. Ręce go łapią odruchowo, gdy myśl utknie albo w połowie długiego maila. Płynny ruch zazębionych kół daje dłoniom zajęcie bez odciągania uwagi od ekranu. Skupienie wraca samo, bez otwierania nowej zakładki czy sięgania po telefon.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/loomo-04-result-mezczyzna-pisze-fokus.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Mózg, który potrzebuje więcej bodźców</h3>
            <p class="md-body">Mózg z ADHD często myśli i działa inaczej. Potrzebuje stałego dopływu bodźców, inaczej nie utrzyma uwagi przy jednym zadaniu. Loomo daje rękom konkretną pracę, dzięki czemu głowa może zostać przy tekście, rozmowie czy lekturze. Cicho, dyskretnie, bez przyciągania uwagi. Sprawdza się też u dzieci z ADHD od 8 roku życia, na lekcjach i przy odrabianiu zadań.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/loomo-03-mid-use-polotwarte-na-ksiazce.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Półtorej godziny wykładu i jedna ręka</h3>
            <p class="md-body">Słuchanie z notowaniem zostawia drugą rękę bez zajęcia. Po dwudziestu minutach przychodzi senność albo wyciąga się telefon pod ławką. Loomo wypełnia tę pustkę. Cicho, bez przyciągania spojrzeń wykładowcy. Mózg ma dodatkowy bodziec, materiał lepiej wchodzi do głowy, a ręka nie zaczyna szukać czegoś gorszego.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/loomo-07-centralny-pivot-diamentowy.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Coś, czego nie wstydzi się postawić na biurku</h3>
            <p class="md-body">Drewniany kinetic wygląda jak obiekt dekoracyjny, nie jak gadżet z marketu. Pasuje do biurka w kawiarni, w open space, w domowym home office. Dla szefa, dla taty, dla osoby, która siedzi po dziesięć godzin przed komputerem. Coś, co wraca do rąk następnego dnia bez powodu.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 08 — POLECANE PRODUKTY (sage-soft) ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== 09 — TRUST STRIP ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>10k+ klientów</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== 10 — VARIANT SHOWCASE (3 sytuacje użycia, mobile: scroll-snap carousel) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Trzy miejsca</span>
        <h2>Gdzie Loomo robi największą robotę</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </p>
      </div>
      <div class="md-variants-grid">
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/loomo-02-full-set-biurko-kreatywne.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #4A7A52;"></span>
            <h3>Biurko</h3>
