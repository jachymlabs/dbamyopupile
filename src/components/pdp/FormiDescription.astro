---
/**
 * FormiDescription — pełny opis produktu Formi.
 * Peg toy z patyczkami i dziurkami: sensoryka + motoryka dla dzieci 3-10 lat,
 * reset dla dorosłych przy biurku, narzędzie terapeutów SI i rehabilitacji.
 *
 * Assety w /public/formi/photos/ (21 webp).
 * Struktura: identyczna z MoodlesDescription (18 sekcji + identyczne klasy md-*).
 * Tone: konwersacyjny, sentence case, ADHD-aware, bez medical claims, screen-free.
 */
import { shopApi } from '@/lib/vendure';
import { SEARCH_PRODUCTS } from '@/lib/queries';
import { getProductReviews, formatRating, ratingPercentages, opiniiPlural, starKind } from '@/lib/reviews';
import { getRegularPrice } from '@/lib/prices';

const ASSET_BASE = '/formi/photos';

// Reviews — z osobnego JSON per produkt (formi tutaj)
const reviews = getProductReviews('formi');
const ratingPct = reviews ? ratingPercentages(reviews) : null;

// Fetch related products — exclude formi, take first 5
let relatedProducts: any[] = [];
try {
  const data = await shopApi<any>(SEARCH_PRODUCTS, {
    input: { groupByProduct: true, take: 12 },
  }, Astro.request);
  relatedProducts = (data.search?.items ?? [])
    .filter((p: any) => p.slug !== 'formi')
    .slice(0, 5);
} catch (e: any) {
  if (import.meta.env.DEV) console.error('FormiDescription related products fetch failed:', e?.message);
}

function formatPrice(grosze: number): string {
  return (grosze / 100).toLocaleString('pl-PL', { style: 'currency', currency: 'PLN', minimumFractionDigits: 2 });
}

function extractPrice(p: any): number {
  const pw = p?.priceWithTax;
  if (!pw) return 0;
  if (typeof pw === 'number') return pw;
  if (typeof pw.value === 'number') return pw.value;
  if (typeof pw.min === 'number') return pw.min;
  return 0;
}
---

<div class="md-pdp">

  {/* ========== 01 — HERO 4 ZDJĘCIA (PC: 4-up grid, no arrows; mobile: carousel) ========== */}
  {/* TODO: brak hero .webm gif'ów dla Formi — używamy 4 najlepszych webp */}
  <section class="md-hero-gifs">
    <div class="md-gif-carousel" id="md-gif-carousel">
      <div class="md-gif-item"><img src={`${ASSET_BASE}/formi-01-makro-strona-A-z-patyczkiem.webp`} alt="" loading="eager" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/formi-05-dziewczynka-uklada-strona-A.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/formi-06-mama-z-dzieckiem-kanapa.webp`} alt="" loading="lazy" /></div>
      <div class="md-gif-item"><img src={`${ASSET_BASE}/formi-03-patyczki-w-dloni-elastycznosc.webp`} alt="" loading="lazy" /></div>
    </div>
    <div class="md-mobile-arrows">
      <button type="button" class="md-arrow" data-md-carousel-prev="md-gif-carousel" aria-label="Poprzedni">
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button type="button" class="md-arrow" data-md-carousel-next="md-gif-carousel" aria-label="Następny">
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>
  </section>

  {/* ========== 02 — PROBLEM → SOLUTION (refined split) ========== */}
  <section class="md-section md-section--surface md-section--compact">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Od ekranu do stołu</span>
        <h2>Daj rękom dziecka <span class="md-em">coś prawdziwego</span></h2>
      </div>
      <div class="md-problem-solve">
        <div class="md-ps-side md-ps-side--problem">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">⨯</span>
            <span class="md-ps-tag md-ps-tag--problem">Co teraz</span>
          </div>
          <ul class="md-ps-list">
            <li><span class="material-symbols-outlined">close</span>Ekran przyciąga jak magnes</li>
            <li><span class="material-symbols-outlined">close</span>Kolejna aplikacja, kolejna gra</li>
            <li><span class="material-symbols-outlined">close</span>Wiercenie się, zero cierpliwości</li>
            <li><span class="material-symbols-outlined">close</span>Wszystko naraz, nic do końca</li>
          </ul>
          <p class="md-ps-foot">Małe dłonie potrzebują czegoś, co da im konkretne zajęcie. Jeśli nie dostaną, znajdą sobie same. Najczęściej to telefon mamy.</p>
        </div>
        <div class="md-ps-bridge" aria-hidden="true">
          <div class="md-ps-bridge-circle">
            <span class="md-ps-bridge-arrow">→</span>
          </div>
          <span class="md-ps-bridge-label">formi</span>
        </div>
        <div class="md-ps-side md-ps-side--solution">
          <div class="md-ps-head">
            <span class="md-ps-emoji" aria-hidden="true">✓</span>
            <span class="md-ps-tag md-ps-tag--solution">Co dostajesz</span>
          </div>
          <ul class="md-ps-list md-ps-list--ok">
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Ręce zajęte czymś prawdziwym</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Skupienie, które wraca samo</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Trening motoryki małej przy okazji</li>
            <li><span class="material-symbols-outlined md-icon-fill">check_circle</span>Bez ładowania, bez aplikacji</li>
          </ul>
          <p class="md-ps-foot">Jeden patyczek wciśnięty w rowek i dziecko siedzi przy tym pół godziny. Bez przekonywania.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 03 — PROBLEM (text + image LEWO) ========== */}
  <section class="md-section">
    <div class="md-split">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/formi-12-problem-tablet-znuzone.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2><span class="md-em">Tablet</span> to nie wróg. Ale powinno być coś jeszcze</h2>
        <p class="md-body">Kiedy dziecko dostaje ekran, żeby chwilę poczekało, wszyscy wiemy, jak to wychodzi. Pół godziny staje się godziną, cisza zastępuje rozmowę. Formi nie zastępuje tabletu i z nim nie walczy. Daje rękom inną robotę, konkretną, wciągającą, bez ani jednego przycisku. Wciskanie patyczków w silikonowe rowki to dla mózgu dziecka coś zupełnie innego niż przewijanie filmików, bo wymaga decyzji i precyzji palca. Po pół godzinie wstaje od stołu wyciszone, a nie pobudzone.</p>
      </div>
    </div>
  </section>

  {/* ========== 04 — SOLUTION MIRROR (text LEWO, image PRAWO) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/formi-02-makro-strona-B-peg-palec.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <h2>Dwie strony, zestaw patyczków, naprawdę dużo kombinacji</h2>
        <p class="md-body">Strona A ma swój wzór rowków, strona B inny. <strong>Patyczki</strong> w czterech kolorach (fioletowe, pomarańczowe, białe, czarne) wciskasz w wybrane miejsca. Możesz śledzić gotowy wzór albo tworzyć własny. <strong>Silikon</strong> jest miękki, ale patyczki w rowku siedzą z wyczuwalnym oporem, czuć każde wciśnięcie. <strong>Mata</strong> zwija się i wchodzi do plecaka szkolnego bez kombinowania. <strong>Zestaw</strong> wystarczy, żeby dwoje dzieci grało obok siebie.</p>
      </div>
    </div>
  </section>

  {/* ========== 05 CUSTOMER STORY — featured = pierwsza opinia z items ========== */}
  {reviews && reviews.items[0] && (
  <section class="md-section md-section--sage-soft">
    <div class="md-split md-split--mirror">
      <div class="md-img-square">
        <img src={`${ASSET_BASE}/formi-19-opinia-anna-dabrowa-gornicza.webp`} alt="" loading="lazy" />
      </div>
      <div>
        <span class="md-eyebrow md-eyebrow--sage">Prawdziwa historia</span>
        <blockquote class="md-customer-quote">{reviews.items[0].body}</blockquote>
        <div class="md-customer-author">
          <div class="md-stars">
            {Array.from({ length: reviews.items[0].stars }).map(() => (
              <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>
            ))}
          </div>
          <div>
            <strong>{reviews.items[0].name}</strong>
            <span>
              {reviews.items[0].age ? ` · ${reviews.items[0].age} lat` : ''}
              {reviews.items[0].tag ? ` · ${reviews.items[0].tag}` : ''}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  {/* ========== 06 COMPARISON TABLE — formi vs tablet / klocki / tradycyjne zabawki ========== */}
  <section class="md-section">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 36px;">
        <span class="md-eyebrow md-eyebrow--sage">Spektrum opcji</span>
        <h2>Porównanie z tym, co dziecko ma już w domu</h2>
      </div>
      <div class="md-compare-wrap">
        <table class="md-compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="md-compare-col-us"><span>Formi</span></th>
              <th>Tablet</th>
              <th>Tradycyjna układanka</th>
              <th>Klocki</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Bez ekranu</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Bez ładowania i internetu</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Trening motoryki małej</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
            </tr>
            <tr>
              <td>Dwie strony, dużo kombinacji</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Zwija się, wchodzi do plecaka</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
            <tr>
              <td>Bez bałaganu do sprzątania</td>
              <td class="md-compare-cell-us"><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-yes">check_circle</span></td>
              <td><span class="material-symbols-outlined md-no">cancel</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="md-compare-hint">
        <span class="material-symbols-outlined">swipe</span>
        Przesuń w lewo i prawo aby zobaczyć całą tabelę
      </p>
    </div>
  </section>

  {/* ========== 07 TABBED USE CASES — dla kogo jest Formi ========== */}
  <section class="md-section md-section--surface">
    <div class="md-tabs-wrap">
      <div class="md-center" style="margin-bottom: 32px;">
        <h2>Dla kogo jest Formi?</h2>
      </div>
      <div class="md-tabs-nav" role="tablist">
        <button class="md-tab-btn md-tab-btn--active" data-md-tab="0">Dzieci</button>
        <button class="md-tab-btn" data-md-tab="1">Terapeuci SI</button>
        <button class="md-tab-btn" data-md-tab="2">Mama z dzieckiem</button>
        <button class="md-tab-btn" data-md-tab="3">Seniorzy</button>
      </div>
      <div class="md-tab-content md-tab-content--active">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/formi-09-emocja-skupienie-dziecko.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Pierwsze skupienie bez ekranu</h3>
            <p class="md-body">Wzory są na tyle proste, żeby zacząć od razu, i na tyle złożone, żeby nie znudzić się po minucie. Wciskanie patyczków uczy nacisku, precyzji i decyzji, czyli wszystkiego tego, co buduje motorykę małą i koncentrację. Sprawdza się przy lekcjach, przed snem, w podróży. Dzieci z ADHD często siedzą przy Formi dłużej, niż się rodzic spodziewa.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/formi-11-emocja-ciekawosc-peg-side.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Narzędzie do gabinetu integracji sensorycznej</h3>
            <p class="md-body">Dwustronna mata, cztery kolory patyczków, opór wciskania, możliwość pracy nad chwytem pęsetkowym i koordynacją wzrokowo-ruchową. Terapeuci SI używają Formi zamiast wielu mniejszych pomocy, bo jedna mata zajmuje miejsce kilku ćwiczeń jednocześnie. Łatwa do dezynfekcji, zwija się między pacjentami.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/formi-06-mama-z-dzieckiem-kanapa.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Pierwsza zabawa, która nie wymaga udawania zaangażowania</h3>
            <p class="md-body">Mata ma dwie strony, każde z was ma swoją. Układacie razem albo każde swoje. Żadnych zasad do tłumaczenia, żadnego wygrywania ani przegrywania. Po prostu siedzisz obok. Wieczorne 20 minut przy stole, które nie kończy się scrollowaniem na każdym końcu kanapy.</p>
          </div>
        </div>
      </div>
      <div class="md-tab-content">
        <div class="md-tab-grid">
          <div class="md-img-square">
            <img src={`${ASSET_BASE}/formi-08-babcia-z-wnukiem-kuchnia.webp`} alt="" loading="lazy" />
          </div>
          <div>
            <h3 style="font-size: 22px;">Rehabilitacja palców, której nikt nie nazywa rehabilitacją</h3>
            <p class="md-body">Po udarze, przy artretyzmie, w trakcie powrotu sprawności ręki, wciskanie patyczków to ćwiczenie chwytu, siły palców i precyzji. Bez kontekstu medycznego, bez zachęcania. Babcia z wnuczkiem przy stole, mata leży między nimi, ręce mają robotę. Mózg nie widzi tego jako rehabilitacji.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========== 08 POLECANE PRODUKTY ========== */}
  {relatedProducts.length > 0 && (
    <section class="md-section md-section--sage-soft">
      <div class="md-container">
        <div class="md-center" style="margin-bottom: 36px;">
          <span class="md-eyebrow md-eyebrow--sage">Jeszcze coś z naszego sklepu</span>
          <h2>Polecane produkty</h2>
        </div>
        <div class="md-related-grid">
          {relatedProducts.map((p: any) => {
            const currentPrice = extractPrice(p);
            const regularPrice = getRegularPrice(p.slug);
            const hasSale = regularPrice && regularPrice > currentPrice;
            const productReviews = getProductReviews(p.slug);
            const productRating = productReviews ? formatRating(productReviews.averageRating) : '';
            const productCount = productReviews?.totalCount ?? 0;
            return (
              <a href={`/produkty/${p.slug}`} class="md-related-card">
                <div class="md-related-img">
                  {p.productAsset?.preview ? (
                    <img src={p.productAsset.preview} alt={p.productName} loading="lazy" />
                  ) : (
                    <div class="md-related-img-empty"><span class="material-symbols-outlined">image</span></div>
                  )}
                </div>
                <div class="md-related-body">
                  <h3>{p.productName}</h3>
                  {productReviews && productCount > 0 && (
                    <div class="md-related-rating">
                      <div class="md-related-stars" aria-label={`Ocena ${productRating} na 5`}>
                        {[1, 2, 3, 4, 5].map((i) => {
                          const k = starKind(i, productReviews.averageRating);
                          if (k === 'full') return <svg class="md-related-star md-related-star--full" viewBox="0 0 24 24" width="13" height="13" fill="#F5B544" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                          if (k === 'half') return <svg class="md-related-star md-related-star--half" viewBox="0 0 24 24" width="13" height="13" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id={`md-rel-half-${p.slug}-${i}`}><stop offset="50%" stop-color="#F5B544"/><stop offset="50%" stop-color="#D6CEBE"/></linearGradient></defs><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z" fill={`url(#md-rel-half-${p.slug}-${i})`}/></svg>;
                          return <svg class="md-related-star md-related-star--empty" viewBox="0 0 24 24" width="13" height="13" fill="#D6CEBE" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l2.9 6.9L22 9.27l-5.5 4.77L18.18 22 12 18.27 5.82 22l1.68-7.96L2 9.27l7.1-.37L12 2z"/></svg>;
                        })}
                      </div>
                      <span class="md-related-rating-num">{productRating}</span>
                      <span class="md-related-rating-count">({productCount})</span>
                    </div>
                  )}
                  <p class="md-related-price-row">
                    {hasSale && <span class="md-related-price-regular">{formatPrice(regularPrice)}</span>}
                    <span class={`md-related-price${hasSale ? ' md-related-price--sale' : ''}`}>
                      {formatPrice(currentPrice)}
                    </span>
                  </p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="md-related-mobile-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </div>
      </div>
    </section>
  )}

  {/* ========== 09 TRUST STRIP ========== */}
  <section class="md-trust-strip">
    <div class="md-trust-grid">
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">groups</span>
        <span>10k+ klientów</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">local_shipping</span>
        <span>Dostawa 24h</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">published_with_changes</span>
        <span>14 dni na zwrot</span>
      </div>
      <div class="md-trust-cell">
        <span class="material-symbols-outlined">award_star</span>
        <span>Polska marka</span>
      </div>
    </div>
  </section>

  {/* ========== 10 VARIANT SHOWCASE — 3 sceny użycia (Formi nie ma kolorów wariantowych) ========== */}
  <section class="md-section md-section--surface">
    <div class="md-container">
      <div class="md-center" style="margin-bottom: 32px;">
        <span class="md-eyebrow md-eyebrow--sage">Trzy sceny</span>
        <h2>Jedna mata, trzy zupełnie inne momenty</h2>
        <p class="md-variants-swipe-hint">
          <span class="material-symbols-outlined">swipe</span>
          przesuń, żeby zobaczyć więcej
        </p>
      </div>
      <div class="md-variants-grid">
        <div class="md-variant-card md-variant-card--forest">
          <div class="md-variant-img"><img src={`${ASSET_BASE}/formi-05-dziewczynka-uklada-strona-A.webp`} alt="" loading="lazy" /></div>
          <div class="md-variant-body">
            <span class="md-variant-dot" style="background: #5C7BA0;"></span>
            <h3>Po szkole</h3>
            <p>Dziecko wraca z lekcji, mata leży na stole. Pierwsze 30 minut bez prośby o tablet. Wzory ze strony A są na tyle proste, żeby od razu zacząć, na tyle ciekawe, żeby nie odpuścić po minucie.</p>
          </div>
        </div>
        <div class="md-variant-card md-variant-card--lavender">
