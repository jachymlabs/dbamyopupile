---
/**
 * PromoBar — sticky announcement bar z auto-rotującymi wiadomościami.
 * Sage primary tło, biały tekst, BEZ dismiss button (zawsze widoczny).
 *
 * Wiadomości rotują co ~4s z fade crossfade.
 *
 * Użycie w BaseLayout:
 *   <PromoBar /> — domyślne 4 wiadomości
 *   <PromoBar messages={["custom 1", "custom 2"]} interval={5000} theme="accent" />
 */

interface Props {
  /** Lista wiadomości do rotacji. Domyślnie: 4 brand messages. */
  messages?: string[];
  /** Single message — backward compat (jeśli podane, użyte zamiast messages). */
  text?: string;
  /** Interwał rotacji w ms (domyślnie 4000 = 4s). */
  interval?: number;
  theme?: 'primary' | 'accent' | 'dark';
  id?: string;
}

const DEFAULT_MESSAGES = [
  'Darmowa dostawa od 99 zł',
  'Wysyłka w 24h',
  '14 dni na zwrot',
  'Promocja -30%',
];

const {
  messages,
  text,
  interval = 4000,
  theme = 'primary',
  id = 'promo-bar',
} = Astro.props;

// Priorytet: messages prop > text prop > defaults
const items: string[] = messages && messages.length > 0
  ? messages
  : text
    ? [text]
    : DEFAULT_MESSAGES;
---

<div
  id={id}
  class:list={['dd-promo-bar', `dd-promo-bar--${theme}`]}
  data-promo-id={id}
  data-interval={interval}
>
  <div class="dd-promo-bar-track" data-promo-track>
    {items.map((msg, i) => (
      <span
        class:list={['dd-promo-bar-msg', i === 0 && 'dd-promo-bar-msg--active']}
        data-index={i}
      >
        {msg}
      </span>
    ))}
  </div>
</div>

<style is:global>
  /* PromoBar fixed top:0 (zamiast sticky) — eliminuje rendering glitche
     na Chrome mobile podczas address bar collapse. Fixed = zawsze relative
     do visual viewport, brak layout viewport conflicts.
     env(safe-area-inset-top) dodaje przestrzeń pod iPhone notch / status
     bar — bar rozszerza się góra, content (message) zostaje wycentrowany
     w usable area (poniżej notch). Na non-iOS env() = 0, bez zmian. */
  .dd-promo-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: calc(36px + env(safe-area-inset-top, 0px));
    padding-top: env(safe-area-inset-top, 0px);
    text-align: center;
    font-family: 'Outfit', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.01em;
    z-index: 60;
    color: #FFFFFF;
    overflow: hidden;
    transition: height 240ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  @media (min-width: 768px) {
    .dd-promo-bar {
      height: calc(38px + env(safe-area-inset-top, 0px));
      font-size: 14px;
    }
    body.is-scrolled .dd-promo-bar {
      height: calc(30px + env(safe-area-inset-top, 0px));
    }
  }

  .dd-promo-bar--primary { background: var(--brand-primary); }
  .dd-promo-bar--accent { background: var(--brand-accent); }
  .dd-promo-bar--dark { background: var(--brand-heading); }

  /* Track — wszystkie wiadomości w jednym miejscu, fade between */
  .dd-promo-bar-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .dd-promo-bar-msg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) translateY(8px);
    width: 100%;
    padding: 0 16px;
    opacity: 0;
    transition: opacity 400ms ease, transform 400ms ease;
    pointer-events: none;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
  .dd-promo-bar-msg--active {
    opacity: 1;
    transform: translate(-50%, -50%) translateY(0);
  }
  .dd-promo-bar-msg--leaving {
    opacity: 0;
    transform: translate(-50%, -50%) translateY(-8px);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-promo-id]').forEach((bar) => {
    const interval = parseInt(bar.dataset.interval || '4000', 10);
    const track = bar.querySelector<HTMLElement>('[data-promo-track]');
    if (!track) return;

    const messages = Array.from(track.querySelectorAll<HTMLElement>('.dd-promo-bar-msg'));
    if (messages.length <= 1) return; // tylko jedna wiadomość — nie rotuj

    let currentIndex = 0;

    function rotate() {
      const current = messages[currentIndex];
      const nextIndex = (currentIndex + 1) % messages.length;
      const next = messages[nextIndex];

      // Current → leaving (slide up + fade out)
      current.classList.remove('dd-promo-bar-msg--active');
      current.classList.add('dd-promo-bar-msg--leaving');

      // Next → active (slide in from below + fade in)
      next.classList.remove('dd-promo-bar-msg--leaving');
      next.classList.add('dd-promo-bar-msg--active');

      // Po animacji wyczyść leaving class
      setTimeout(() => {
        current.classList.remove('dd-promo-bar-msg--leaving');
      }, 400);

      currentIndex = nextIndex;
    }

    // Pause rotation gdy karta nie jest aktywna (oszczędza CPU)
    let timer: ReturnType<typeof setInterval> | null = null;
    function start() {
      if (timer) return;
      timer = setInterval(rotate, interval);
    }
    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else start();
    });

    start();
  });
</script>
